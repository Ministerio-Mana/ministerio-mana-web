# Copia este archivo a .env y rellena con tus llaves (NO subas .env)

# Cloudflare Turnstile (anti-bots)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Wompi (Colombia)
WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
WOMPI_INTEGRITY_KEY=
WOMPI_WEBHOOK_SECRET=
WOMPI_API_BASE=https://sandbox.wompi.co/v1
WOMPI_CHECKOUT_URL=https://checkout-sandbox.wompi.co/p/
WOMPI_ENV=sandbox

# Stripe (internacional)
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=

# Cumbre Mundial 2026
CUMBRE_REFERENCE_PREFIX=MM-EVT-CM26
CUMBRE_EMAIL_FROM=info@ministeriomana.org
CUMBRE_CRON_SECRET=
CUMBRE_EXPORT_SECRET=
CUMBRE_INSTALLMENT_DEADLINE=2026-05-15
CUMBRE_PENDING_PAYMENT_LOCK_MINUTES=120
CUMBRE_REGISTRATION_CLOSED_AT=2026-06-09T00:00:00-05:00
CUMBRE_ADMIN_EXPORT_SECRET=
CUMBRE_MANUAL_SECRET=
# CUMBRE_TEST_MODE=true
# CUMBRE_TEST_AMOUNT_COP=5000
# CUMBRE_TEST_AMOUNT_USD=1

# Recordatorios (WhatsApp webhook opcional)
WHATSAPP_WEBHOOK_URL=
WHATSAPP_WEBHOOK_TOKEN=

# Donaciones / Contabilidad
DONATION_REFERENCE_PREFIX=DON
# DONATION_REFERENCE_PREFIX_CAMPUS=CAMP
# DONATION_REFERENCE_PREFIX_CUMBRE=CUM
# DONATION_REFERENCE_PREFIX_PRIMICIAS=PRI
# DONATION_REFERENCE_PREFIX_OTHER=DON
DONATIONS_EXPORT_SECRET=
DONATION_REMINDER_CRON_SECRET=
DONATION_SUBSCRIPTION_CRON_SECRET=
CAMPUS_CRON_SECRET=
CRON_SECRET=
SECURITY_ALERT_CRON_SECRET=

# Webhook interno (forwarding Wompi desde otro servicio)
INTERNAL_WEBHOOK_SECRET=

# SendGrid (opcional para correos)
SENDGRID_API_KEY=
SENDGRID_FROM=
SENDGRID_REPLY_TO=

# Ven y Ayudanos (formularios con datos de contacto; listas separadas por coma)
VEN_AYUDANOS_NOTIFY_EMAILS=
VEN_AYUDANOS_CAMPUS_NOTIFY_EMAILS=
VEN_AYUDANOS_NINOS_NOTIFY_EMAILS=
VEN_AYUDANOS_VARONES_NOTIFY_EMAILS=
VEN_AYUDANOS_MUJERES_NOTIFY_EMAILS=
VEN_AYUDANOS_MANA_NOTIFY_EMAILS=
VEN_AYUDANOS_GENERAL_NOTIFY_EMAILS=

# Clerk (Auth)
PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
PUBLIC_CLERK_SIGN_IN_URL=/sign-in
PUBLIC_CLERK_SIGN_UP_URL=/sign-up
PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/portal
PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/portal
# PUBLIC_CLERK_DOMAIN=
# PUBLIC_CLERK_PROXY_URL=
# PUBLIC_CLERK_JS_URL=

# Base de datos / Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=

# Biblioteca publica del CMS (por defecto conserva Supabase)
CMS_MEDIA_PROVIDER=supabase
CMS_MEDIA_BUCKET=cms-media
CMS_PREVIEW_TOKEN=
# Configura estas tres solo en Vercel; IMAGEKIT_PRIVATE_KEY nunca va al cliente.
IMAGEKIT_URL_ENDPOINT=
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=

# Microsoft 365 / SharePoint (apagado hasta completar Sites.Selected)
MICROSOFT_GRAPH_ENABLED=false
MICROSOFT_GRAPH_TENANT_ID=
MICROSOFT_GRAPH_CLIENT_ID=
MICROSOFT_GRAPH_CLIENT_SECRET=
MICROSOFT_SHAREPOINT_SITE_ID=
# Opcional: fija una biblioteca concreta despues de verificar el sitio.
MICROSOFT_SHAREPOINT_DRIVE_ID=
# Piloto de documentos internos por evento. Las galerias publicas usan ImageKit.
# Mantener apagado hasta conceder escritura exclusivamente sobre la biblioteca Eventos.
MICROSOFT_SHAREPOINT_EVENTS_DRIVE_ID=
MICROSOFT_SHAREPOINT_EVENTS_WRITE_ENABLED=false
# Opcional: Lista privada para sincronización operativa de inscripciones.
MICROSOFT_SHAREPOINT_EVENT_REGISTRATIONS_LIST_ID=

# Bucket privado para QR y recursos de cobro de Eventos.
EVENT_PAYMENT_ASSETS_BUCKET=event-payment-assets

# Portal Iglesias / Roles
PORTAL_SUPERADMIN_EMAILS=info@ministeriomana.org,santiquilva@gmail.com
PORTAL_ADMIN_IP_ALLOWLIST=
ADMIN_IP_ALLOWLIST=
PORTAL_PASSWORD_LOGIN_ENABLED=false
PORTAL_SUPERADMIN_PASSWORD=
PORTAL_ADMIN_SESSION_SECRET=

# Geocodificación (Nominatim / OSM)
NOMINATIM_USER_AGENT=ministeriomana.org

# Otros opcionales que uses en src/lib/*.ts
# RESEND_API_KEY=
# SECURITY_WEBHOOK_URL=
# LOGTAIL_TOKEN=
