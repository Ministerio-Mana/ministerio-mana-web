{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "paths": {
      "@components/*": [
        "./src/components/*"
      ],
      "@layouts/*": [
        "./src/layouts/*"
      ],
      "@data/*": [
        "./src/data/*"
      ],
      "@i18n/*": [
        "./src/i18n/*"
      ],
      "@lib/*": [
        "./src/lib/*"
      ],
      "@scripts/*": [
        "./src/scripts/*"
      ]
    }
  }
}
