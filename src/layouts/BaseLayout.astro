---
import SEO from '@components/SEO.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import '../styles/portal.css';
import appModalScript from '../scripts/app-modal.js?url';
import devotionalFooterPlayerScript from '../scripts/devotional-footer-player.js?url';

const {
  title,
  description,
  image,
  imageAlt,
  imageWidth,
  imageHeight,
  imageType,
  type = 'website',
  structuredData,
  noindex = false,
  hideHeader = false,
  hideFooter = false,
  disableSmoothScroll = true,
  includeTurnstile = false,
} = Astro.props;
const isPortalPath = Astro.url.pathname.startsWith('/portal');
const enableClientRouter = !isPortalPath;
const documentLocale = Astro.cookies.get('lang')?.value === 'en' ? 'en' : 'es';
const cspNonce = Astro.locals?.cspNonce;
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL ?? import.meta.env.SUPABASE_URL;
let supabaseOrigin = '';
if (supabaseUrl) {
  try {
    supabaseOrigin = new URL(supabaseUrl).origin;
  } catch {
    supabaseOrigin = '';
  }
}
---
<!doctype html>
<html lang={documentLocale} class="scroll-smooth">
  <head>
    <SEO {title} {description} {image} {imageAlt} {imageWidth} {imageHeight} {imageType} {type} {structuredData} {noindex} />
    {enableClientRouter && <ClientRouter fallback="swap" />}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    {isPortalPath && supabaseOrigin && <link rel="preconnect" href={supabaseOrigin} crossorigin="anonymous" />}
    {isPortalPath && supabaseOrigin && <link rel="dns-prefetch" href={supabaseOrigin} />}
    {includeTurnstile && (
      <script
        src="https://challenges.cloudflare.com/turnstile/v0/api.js"
        async
        defer
      ></script>
    )}
    {!isPortalPath && <script src="/js/scroll-reveal.js" defer></script>}
  </head>
  <body>
    <a href="#main-content" class="skip-link">Saltar al contenido principal</a>
    {!hideHeader && <Header />}
    <main id="main-content" tabindex="-1" class="min-h-[60vh]"><slot /></main>
    {!hideFooter && <Footer />}

    <!-- App Modal -->
    <div id="app-modal" role="dialog" aria-modal="true" aria-labelledby="app-modal-title" aria-hidden="true" class="fixed inset-0 z-[999] hidden items-center justify-center">
      <div id="app-modal-overlay" aria-hidden="true" class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>
      <div class="relative z-10 w-[92%] max-w-lg rounded-2xl border border-white/10 bg-brand-navy/95 p-6 shadow-2xl">
        <button id="app-modal-close" type="button" aria-label="Cerrar aviso" class="absolute right-4 top-4 flex h-11 w-11 items-center justify-center rounded-md text-xl leading-none text-white/70 hover:bg-white/10 hover:text-white">×</button>
        <h3 id="app-modal-title" class="text-xl font-bold text-white mb-2">Aviso</h3>
        <p id="app-modal-message" class="text-sm text-white/60 mb-4"></p>
        <ul id="app-modal-list" class="hidden space-y-2 pl-6 text-sm text-white/80 list-disc"></ul>
      </div>
    </div>
    
    <!-- Smooth Scroll & Parallax Animations -->
    {!disableSmoothScroll && (
    <script>
      import Lenis from '@studio-freight/lenis';
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';
      
      gsap.registerPlugin(ScrollTrigger);
      
      let lenis;
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      
      if (!prefersReducedMotion) {
        lenis = new Lenis({
          lerp: 0.08,
          orientation: 'vertical',
          gestureOrientation: 'vertical',
          smoothWheel: true,
          wheelMultiplier: 1,
          smoothTouch: false,
          touchMultiplier: 2,
          infinite: false,
        });

        lenis.on('scroll', ScrollTrigger.update);
        
        function raf(time) {
          lenis.raf(time);
          requestAnimationFrame(raf);
        }
        
        requestAnimationFrame(raf);
        window.lenis = lenis;
      }
      
      document.documentElement.setAttribute('data-lenis-enabled', String(!prefersReducedMotion));
      
      window.addEventListener('load', () => {
        if (prefersReducedMotion) return;
        
        const hero = document.querySelector('[data-hero]');
        if (hero) {
          gsap.to(hero, {
            scrollTrigger: {
              trigger: hero,
              start: 'top top',
              end: 'bottom top',
              scrub: true,
            },
            y: 100,
            opacity: 0.6,
          });
        }
        
        document.querySelectorAll('[data-parallax-bg]').forEach((el) => {
          const speed = parseFloat(el.dataset.bg) || 0.5;
          gsap.to(el, {
            scrollTrigger: {
              trigger: el,
              start: 'top bottom',
              end: 'bottom top',
              scrub: true,
            },
            y: -50 * speed,
          });
        });
      });
    </script>
    )}
    {!hideFooter && <script src={devotionalFooterPlayerScript} nonce={cspNonce} defer></script>}
    <script type="module" src={appModalScript} nonce={cspNonce}></script>
    <script>
      const skipLink = document.querySelector('.skip-link');
      const mainContent = document.getElementById('main-content');
      skipLink?.addEventListener('click', (event) => {
        if (!mainContent) return;
        event.preventDefault();
        mainContent.focus({ preventScroll: true });
        mainContent.scrollIntoView({ block: 'start' });
        window.history.replaceState(null, '', '#main-content');
      });
    </script>
    <script>
      import '@scripts/vercel-speed-insights.js';
    </script>
  </body>
</html>
