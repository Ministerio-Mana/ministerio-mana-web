---
import BaseLayout from '@layouts/BaseLayout.astro';

const devotionalYoutubeChannelUrl = 'https://www.youtube.com/channel/UCC85JrvTKq9dfCcgxQQU_Ag';
const devotionalUploadsPlaylistId = 'UUC85JrvTKq9dfCcgxQQU_Ag';
const devotionalSpotifyShowUrl = 'https://open.spotify.com/show/4SbbhNxkSXrh0qyEwJK7lO';
const devotionalWhatsappUrl = 'https://whatsapp.com/channel/0029VaABvlHGzzKb3f53TQ3M';
const devotionalEmbedParams = new URLSearchParams({
  list: devotionalUploadsPlaylistId,
  rel: '0',
  modestbranding: '1',
  playsinline: '1',
  origin: Astro.url.origin,
  widget_referrer: Astro.url.origin,
});
const devotionalEmbedUrl = `https://www.youtube.com/embed/videoseries?${devotionalEmbedParams.toString()}`;
---

<BaseLayout title="Devocional Maná — con el Ps. Carlos Ríos" description="Devocional en YouTube de lunes a viernes con el Pastor Carlos Ríos.">
  <section class="devotional-page">
    <div class="devotional-hero">
      <div class="devotional-copy">
        <p class="devotional-script">Devocional</p>
        <h1>
          <span>Maná</span>
          de hoy
        </h1>
        <p class="devotional-lead">
          Una palabra diaria para comenzar, pausar y volver a Dios durante el día.
        </p>

        <div class="devotional-actions" aria-label="Acciones del Devocional Maná">
          <a href={devotionalWhatsappUrl} target="_blank" rel="noreferrer">Recibir por WhatsApp</a>
          <a href={devotionalYoutubeChannelUrl} target="_blank" rel="noreferrer">Canal de YouTube</a>
        </div>
      </div>

      <div class="devotional-video-shell">
        <div class="devotional-video-top">
          <span>En vivo cada día</span>
          <strong>Ps. Carlos Ríos</strong>
        </div>
        <div class="devotional-video">
          <iframe
            src={devotionalEmbedUrl}
            title="Devocional Maná en YouTube"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
            referrerpolicy="strict-origin-when-cross-origin"
          ></iframe>
        </div>
      </div>
    </div>

    <div class="devotional-resource-grid">
      <a href="https://21retos.com" target="_blank" rel="noreferrer">
        <span>01</span>
        <strong>21 Retos</strong>
        <small>Hábitos espirituales para caminar con intención.</small>
      </a>
      <a href="https://agendadevocionalmana.com" target="_blank" rel="noreferrer">
        <span>02</span>
        <strong>Agenda Devocional</strong>
        <small>Guía diaria para escribir, meditar y orar.</small>
      </a>
      <a href={devotionalSpotifyShowUrl} target="_blank" rel="noreferrer">
        <span>03</span>
        <strong>Spotify</strong>
        <small>Escucha recursos de audio durante la semana.</small>
      </a>
      <a href="https://soundcloud.com" target="_blank" rel="noreferrer">
        <span>04</span>
        <strong>SoundCloud</strong>
        <small>Devocionales y mensajes para volver a la Palabra.</small>
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  @font-face {
    font-family: "Summer Loving";
    src: url("/fonts/SUMMER%20FONT/Summer%20Loving%20Regular.otf") format("opentype");
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  .devotional-page {
    --devotional-teal: #28a6bd;
    --devotional-navy: #10183a;
    --devotional-ink: #172151;
    max-width: 1180px;
    margin: 0 auto;
    padding: clamp(2rem, 5vw, 4.5rem) 1.25rem clamp(2.5rem, 5vw, 5rem);
  }

  .devotional-hero {
    display: grid;
    grid-template-columns: minmax(0, 0.82fr) minmax(360px, 1.18fr);
    align-items: stretch;
    gap: clamp(1.25rem, 3vw, 2.5rem);
    min-width: 0;
  }

  .devotional-copy {
    display: flex;
    min-height: 100%;
    min-width: 0;
    flex-direction: column;
    justify-content: center;
    border-left: 4px solid var(--devotional-teal);
    padding: clamp(0.5rem, 2vw, 1rem) 0 clamp(0.5rem, 2vw, 1rem) clamp(1rem, 3vw, 1.75rem);
  }

  .devotional-script {
    margin: 0 0 -0.15em;
    color: var(--devotional-teal);
    font-family: "Summer Loving", cursive;
    font-size: clamp(3rem, 7vw, 5.5rem);
    line-height: 0.78;
    transform: rotate(-3deg);
    transform-origin: left center;
  }

  .devotional-copy h1 {
    margin: 0;
    color: var(--devotional-navy);
    font-family: "Intro", ui-sans-serif, system-ui, sans-serif;
    font-size: clamp(3rem, 8vw, 6.75rem);
    font-weight: 900;
    letter-spacing: 0;
    line-height: 0.84;
    text-transform: uppercase;
  }

  .devotional-copy h1 span {
    display: block;
    color: transparent;
    -webkit-text-stroke: 1.25px rgba(16, 24, 58, 0.78);
  }

  .devotional-lead {
    max-width: 30rem;
    margin: 1.25rem 0 0;
    color: rgba(16, 24, 58, 0.72);
    font-size: clamp(1rem, 1.8vw, 1.15rem);
    line-height: 1.65;
  }

  .devotional-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: clamp(1.5rem, 3vw, 2.25rem);
  }

  .devotional-actions a {
    display: inline-flex;
    min-height: 2.85rem;
    align-items: center;
    justify-content: center;
    border-radius: 0.65rem;
    padding: 0.8rem 1.1rem;
    font-size: 0.82rem;
    font-weight: 900;
    line-height: 1;
  }

  .devotional-actions a:first-child {
    background: var(--devotional-teal);
    color: white;
    box-shadow: 0 1rem 2rem rgba(40, 166, 189, 0.24);
  }

  .devotional-actions a:last-child {
    border: 1px solid rgba(16, 24, 58, 0.16);
    background: rgba(255, 255, 255, 0.5);
    color: var(--devotional-ink);
  }

  .devotional-video-shell {
    min-width: 0;
    overflow: hidden;
    border: 1px solid rgba(16, 24, 58, 0.12);
    border-radius: 0.75rem;
    background: #0f1837;
    box-shadow: 0 1.75rem 4rem rgba(16, 24, 58, 0.16);
  }

  .devotional-video-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.85rem 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    background: linear-gradient(90deg, rgba(40, 166, 189, 0.18), rgba(255, 255, 255, 0.04));
    color: white;
  }

  .devotional-video-top span,
  .devotional-video-top strong {
    color: white;
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .devotional-video-top span {
    color: #9ee7f4;
  }

  .devotional-video {
    aspect-ratio: 16 / 9;
    background: #050816;
  }

  .devotional-video iframe {
    display: block;
    width: 100%;
    max-width: 100%;
    height: 100%;
    border: 0;
  }

  .devotional-resource-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.8rem;
    margin-top: clamp(1rem, 3vw, 1.75rem);
  }

  .devotional-resource-grid a {
    display: grid;
    min-width: 0;
    min-height: 8rem;
    align-content: start;
    gap: 0.45rem;
    border: 1px solid rgba(16, 24, 58, 0.12);
    border-radius: 0.75rem;
    background: rgba(255, 255, 255, 0.58);
    padding: 1rem;
    color: var(--devotional-ink);
    transition: transform 180ms ease, border-color 180ms ease, background 180ms ease;
  }

  .devotional-resource-grid a:hover {
    transform: translateY(-2px);
    border-color: rgba(40, 166, 189, 0.46);
    background: rgba(255, 255, 255, 0.82);
    color: var(--devotional-ink);
  }

  .devotional-resource-grid span {
    color: var(--devotional-teal);
    font-size: 0.78rem;
    font-weight: 900;
  }

  .devotional-resource-grid strong {
    color: var(--devotional-navy);
    font-size: 1rem;
    font-weight: 900;
    line-height: 1.15;
  }

  .devotional-resource-grid small {
    color: rgba(16, 24, 58, 0.66);
    font-size: 0.82rem;
    line-height: 1.45;
  }

  @media (max-width: 900px) {
    .devotional-hero {
      grid-template-columns: 1fr;
    }

    .devotional-copy,
    .devotional-video-shell {
      width: 100%;
      max-width: calc(100vw - 2.5rem);
      justify-self: stretch;
    }

    .devotional-copy {
      min-height: auto;
    }

    .devotional-resource-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    .devotional-page {
      width: 100%;
      max-width: 100%;
      padding-inline: 1rem;
      overflow-x: clip;
    }

    .devotional-copy {
      max-width: calc(100vw - 2rem);
      border-left-width: 3px;
      padding-left: 1rem;
    }

    .devotional-video-shell {
      max-width: calc(100vw - 2rem);
    }

    .devotional-lead {
      max-width: 100%;
    }

    .devotional-actions a {
      width: 100%;
    }

    .devotional-resource-grid {
      grid-template-columns: 1fr;
    }

    .devotional-video-top {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.25rem;
    }
  }
</style>
