    <script nonce={cspNonce} is:inline>
      (() => {
        const root = document.querySelector('[data-pilgrim-story-root]');
        if (!root) return;

        const scrollToStoryPanel = (targetPanel) => {
          const story = root.querySelector('[data-cumbre-story]');
          if (!story || !targetPanel) return false;

          const isAnimatedPanel = getComputedStyle(targetPanel).position === 'absolute';
          if (isAnimatedPanel) {
            const panels = Array.from(story.querySelectorAll('[data-cumbre-panel]'));
            const index = Math.max(0, panels.indexOf(targetPanel));
            const breakpoint = Number.parseInt(story.dataset.cumbreScrollFactorBreakpoint || '768', 10);
            const scrollFactor = window.innerWidth >= breakpoint ? 1.34 : 1;
            const viewportHeight = window.visualViewport?.height || window.innerHeight || 1;
            const storyTop = story.offsetTop || 0;
            const target = Math.max(storyTop, storyTop + viewportHeight * index * scrollFactor);

            if (window.lenis?.scrollTo) {
              window.lenis.scrollTo(target, { duration: 0.48, force: true });
              return true;
            }

            window.scrollTo({ top: target, behavior: 'smooth' });
            return true;
          }

          targetPanel.scrollIntoView({ behavior: 'smooth', block: 'start' });
          return true;
        };

        document.addEventListener('click', (event) => {
          if (!(event.target instanceof Element)) return;

          const link = event.target.closest('.pilgrim-page a[href^="#"]');
          if (!link) return;

          const href = link.getAttribute('href');
          if (!href || href === '#') return;

          const target = document.querySelector(href);
          if (!target) return;

          event.preventDefault();

          const handled = target.matches('[data-cumbre-panel]')
            ? scrollToStoryPanel(target)
            : false;

          if (!handled) {
            const top = Math.max(0, target.getBoundingClientRect().top + window.scrollY - 68);
            if (window.lenis?.scrollTo) {
              window.lenis.scrollTo(top, { duration: 0.48, force: true });
            } else {
              window.scrollTo({ top, behavior: 'smooth' });
            }
          }

          if (history.pushState) {
            history.pushState(null, '', href);
          }
        });
      })();
    </script>
    <script>
      import '@scripts/cumbre-welcome-story.js';
    </script>
