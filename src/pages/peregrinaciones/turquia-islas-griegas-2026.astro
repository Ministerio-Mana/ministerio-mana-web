---
import CumbreLayout from '@components/cumbre2026/CumbreLayout.astro';
import bookOpenCheckIcon from 'lucide-static/icons/book-open-check.svg?raw';
import calendarIcon from 'lucide-static/icons/calendar.svg?raw';
import clockIcon from 'lucide-static/icons/clock.svg?raw';
import contactIcon from 'lucide-static/icons/contact.svg?raw';
import mapIcon from 'lucide-static/icons/map.svg?raw';
import planeIcon from 'lucide-static/icons/plane.svg?raw';
import shipIcon from 'lucide-static/icons/ship.svg?raw';
import ticketIcon from 'lucide-static/icons/ticket.svg?raw';
import walletIcon from 'lucide-static/icons/wallet.svg?raw';

const lucideIcon = (svg: string) =>
  svg
    .replace(/<!--[\s\S]*?-->\s*/g, '')
    .replace(/<svg\b([^>]*)class="([^"]*)"([^>]*)>/, '<svg$1class="pilgrim-lucide-icon $2"$3 aria-hidden="true" focusable="false">')
    .replace(/<svg\b((?:(?!class=)[^>])*)>/, '<svg$1 class="pilgrim-lucide-icon" aria-hidden="true" focusable="false">');

const assetBase = '/images/peregrinaciones/turquia-islas-griegas-2026';
const heroImage = `${assetBase}/istanbul-cruise.jpg`;
const flagImage = `${assetBase}/turkey-flag.jpg`;
const posterImage = `${assetBase}/poster-reference.jpg`;
const routeMapImage = `${assetBase}/route-map-original.jpg`;

const whatsappText = encodeURIComponent(
  'Hola Ministerio Maná, quiero información de la peregrinación a Turquía e Islas Griegas 2026.',
);
const whatsappHref = `https://wa.me/573004298001?text=${whatsappText}`;
const whatsappSecondaryHref = `https://wa.me/573148297534?text=${whatsappText}`;

const quickFacts = [
  { label: 'Fecha', value: '17 oct - 1 nov 2026', icon: lucideIcon(calendarIcon) },
  { label: 'Duración', value: '16 días', icon: lucideIcon(clockIcon) },
  { label: 'Ruta', value: 'Turquía + Islas Griegas', icon: lucideIcon(mapIcon) },
  { label: 'Enfoque', value: 'Las siete iglesias', icon: lucideIcon(bookOpenCheckIcon) },
];

const routeStops = [
  'Estambul',
  'Esmirna',
  'Kuşadası',
  'Patmos',
  'Rodas',
  'Creta',
  'Santorini',
  'Atenas',
  'Mykonos',
  'Éfeso',
  'Pérgamo',
  'Tiatira',
  'Sardes',
  'Filadelfia',
  'Pamukkale',
  'Laodicea',
  'Konya',
  'Capadocia',
];

const routePillars = [
  {
    title: 'Palabra',
    text: 'Una ruta para caminar escenarios bíblicos y leer la historia con propósito.',
  },
  {
    title: 'Comunión',
    text: 'Un tiempo para viajar como iglesia, compartir mesa y crecer juntos.',
  },
  {
    title: 'Preparación',
    text: 'Acompañamiento para cupos, requisitos, tiquetes y claridad logística.',
  },
];

const itinerary = [
  {
    day: '01',
    date: '17 oct',
    title: 'Salida del país',
    meta: 'Inicio de la peregrinación',
    body: 'Salida desde tu lugar de origen con destino a Estambul. ¡Comienza nuestra peregrinación a Turquía e Islas Griegas!',
  },
  {
    day: '02',
    date: '18 oct',
    title: 'Llegada a Estambul',
    meta: 'Cena',
    body: 'Llegada a Estambul y traslado al hotel. Cena y alojamiento.',
  },
  {
    day: '03',
    date: '19 oct',
    title: 'Estambul - Izmir',
    meta: 'D - A - C',
    body: 'Bazar Egipcio, mercado de las especias. Recorrido en barco por el Bósforo, entre Europa y Asia, con sus palacios y yalıs. Almuerzo, traslado al aeropuerto y vuelo a Esmirna. Cena y alojamiento.',
  },
  {
    day: '04',
    date: '20 oct',
    title: 'Embarque al crucero',
    meta: 'Kuşadası / Patmos · D - A - C',
    body: 'Desayuno. Traslado al puerto de Kuşadası para embarcar en el crucero. Salida hacia la isla de Patmos: visita al monasterio y a la gruta donde el apóstol Juan escribió el Apocalipsis.',
  },
  {
    day: '05',
    date: '21 oct',
    title: 'Crucero: Rodas',
    meta: 'D - A - C',
    body: 'Llegada al puerto de Rodas, isla de los Caballeros de la Orden de San Juan. Excursión opcional a la Acrópolis de Lindos y a la ciudad medieval, Antigua Rodas.',
  },
  {
    day: '06',
    date: '22 oct',
    title: 'Crucero: Creta / Santorini',
    meta: 'D - A - C',
    body: 'Parada en Heraklio, Creta, con excursión opcional al Palacio de Knosos, centro de la civilización minoica. Navegación a Santorini, el continente perdido de la Atlántida. Excursión opcional a Oía, uno de los lugares más mágicos para ver la puesta de sol.',
  },
  {
    day: '07',
    date: '23 oct',
    title: 'Crucero: Atenas / Mykonos',
    meta: 'D - A - C',
    body: 'Por la mañana, excursión opcional a Atenas. Por la tarde, parada en Mykonos, famosa por sus playas, molinos de viento y encanto.',
  },
  {
    day: '08',
    date: '24 oct',
    title: 'Kuşadası - Éfeso - Izmir',
    meta: 'Desayuno y almuerzo',
    body: 'Desembarque y visita de Éfeso, una de las siete iglesias, desde donde el apóstol Pablo escribió a los Corintios y a los Gálatas: el Teatro, la Biblioteca de Celso y la Vía Mármol. Almuerzo, Basílica de San Juan, dedicada al apóstol Juan, autor del Apocalipsis. Centro de cuero. Alojamiento en Kuşadası.',
  },
  {
    day: '09',
    date: '25 oct',
    title: 'Izmir - Pérgamo - Tiatira',
    meta: 'Desayuno y cena',
    body: 'Pérgamo: Acrópolis con su Gran Teatro y los Templos de Atenea y Zeus. Basílica Roja, la primera de las siete iglesias. Tiatira, la segunda de las siete iglesias, con el templo dedicado a Apolo. Regreso a Izmir, cena y alojamiento.',
  },
  {
    day: '10',
    date: '26 oct',
    title: 'Esmirna - Sardes - Filadelfia',
    meta: 'Pamukkale · D - A - C',
    body: 'Iglesia de Policarpo en Esmirna, la tercera de las siete iglesias; obispo y mártir cristiano del siglo II. Sardes, la madre de las siete iglesias, donde el rey Creso acuñó la primera moneda de la historia: templo, iglesia bizantina, gimnasio y sinagoga. Almuerzo. Filadelfia, la sexta de las siete iglesias, con su basílica bizantina. Continuación a Pamukkale. Cena y alojamiento.',
  },
  {
    day: '11',
    date: '27 oct',
    title: 'Pamukkale',
    meta: 'D - A - C',
    body: 'Pamukkale, cuyas aguas calcáreas han creado formaciones espectaculares. Hierápolis: tumba del apóstol Felipe, teatro y tiempo en aguas termales. Laodicea, una de las siete iglesias evangelizada por Epafras. Almuerzo, cena y alojamiento.',
  },
  {
    day: '12',
    date: '28 oct',
    title: 'Pamukkale - Konya - Capadocia',
    meta: 'D - A - C',
    body: 'Konya, Iconium, donde los apóstoles Pablo y Bernabé predicaron el Evangelio. Almuerzo. Continuación a Capadocia; en ruta, un kervansaray del siglo XIII de la Ruta de la Seda. Cena y alojamiento.',
  },
  {
    day: '13',
    date: '29 oct',
    title: 'Capadocia',
    meta: 'D - A - C',
    body: 'Al amanecer, paseo en globo aerostático sobre las chimeneas de hadas, incluido. Valle de Göreme, Uçhisar, Avcilar y Valle de Derbent. Almuerzo, talleres de alfombras y ónyx. Cena y espectáculo de danza folclórica.',
  },
  {
    day: '14',
    date: '30 oct',
    title: 'Vuelo a Estambul',
    meta: 'Sultanahmet · D - A - C',
    body: 'Vuelo a Estambul. Barrios de Pera y Gálata: Torre de Gálata, exterior, Plaza Taksim y avenida İstiklal. Almuerzo. Barrio de Sultanahmet: Hipódromo Romano, Mezquita Azul, 6 minaretes, y Santa Sofía, siglo VI. Cena y alojamiento.',
  },
  {
    day: '15',
    date: '31 oct',
    title: 'Estambul',
    meta: 'Topkapi y Gran Bazar · D - A - C',
    body: 'Palacio Topkapi, residencia de los sultanes otomanos, con entrada incluida. Patriarcado de Constantinopla en Fener; si está cerrado, se visita San Esteban de los Búlgaros. Barrios de Fener y Balat, Mezquita de Süleymaniye y tiempo libre en el Gran Bazar.',
  },
  {
    day: '16',
    date: '1 nov',
    title: 'Salida de Estambul',
    meta: 'Desayuno',
    body: 'Desayuno y traslado al aeropuerto de Estambul. Fin de nuestros servicios.',
  },
];

const hotels = [
  { city: 'Crucero', hotel: 'Celestyal - cabina interior, categoría IB / IC' },
  { city: 'Esmirna', hotel: 'Kaya Izmir Termal o similar' },
  { city: 'Pamukkale', hotel: 'Colossae Thermal o Adempira Thermal o similar' },
  { city: 'Capadocia', hotel: 'Utopia Hotel Cueva o similar' },
  { city: 'Estambul', hotel: 'Wish More o Windsor o similar' },
];

const includedTurkey = [
  '3 noches en Estambul, 2 en Capadocia, 2 en Pamukkale y 3 en Esmirna.',
  'Todos los traslados en grupo, en bus privado con aire acondicionado.',
  'Todos los tours con guía de habla española.',
  '10 desayunos, 9 almuerzos y 10 cenas.',
  'Vuelo doméstico Capadocia - Estambul con 20 kg + 8 kg de cabina.',
  'Noche de bailes folclóricos y paseo en globo en Capadocia.',
  'Entradas a los museos y auriculares.',
  'Nueva tasa de alojamiento en los hoteles de Turquía.',
];

const includedCruise = [
  'Crucero en régimen de pensión completa en cabina interior categoría IB.',
  'Café, té, agua y jugo ilimitados en el horario del restaurante, 6:30-22:00.',
  'Refrescos ilimitados con las comidas en restaurantes Thalassa y Taverna.',
  'Impuestos y propinas del crucero.',
];

const notIncluded = [
  'Gastos personales.',
  'Bebidas durante los almuerzos y las cenas en Turquía.',
  'Traslados individuales por llegadas o salidas fuera de los vuelos del grupo.',
  'Propinas al guía y al conductor: sugerido 3-5 USD por persona/día al guía y 2-3 USD al chofer.',
  'Las excursiones del crucero en Patmos y Atenas, y otras excursiones.',
  'Bebidas durante el crucero.',
  'Gastos personales y todo lo no mencionado expresamente como incluido.',
];

const flightNotes = [
  'Es importante tener en cuenta que el Ministerio Maná no es una agencia de viajes; por ello, los tiquetes aéreos son adquiridos a través de una agencia, y nosotros actuamos como intermediarios entre la agencia y el peregrino.',
  'Cada persona es libre de comparar los tiquetes de forma particular. Nosotros ayudamos a gestionar sus vuelos, escalas y tiempos, pero la decisión final la toma cada peregrino.',
  'Los valores enviados son válidos solo por 24 horas; pasado este tiempo, se debe volver a cotizar. Si desea negociar directamente con la agencia, puede hacerlo.',
  'El Ministerio Maná no cobra ningún valor por la intermediación; por lo tanto, si el itinerario sufre algún cambio que implique un sobrecosto, este deberá ser asumido por cada viajero.',
  'En caso de devoluciones relacionadas con la porción aérea, cada viajero deberá asumir los gastos bancarios correspondientes, que oscilan entre el 3% y el 5%, según la comisión de cada banco.',
  'Los cambios que realice la aerolínea, modificación del día, cambio de horario o cancelación de escalas, entre otros, deberán ser asumidos por cada peregrino, ya que están fuera de nuestro alcance.',
  'Al reservar el cupo de la peregrinación, usted nos autoriza a realizar la compra de los tiquetes. Si por motivos personales decide cancelar su viaje, los tiquetes quedarán abiertos para usarse dentro del período que determine la aerolínea, generalmente hasta un año, por lo que el Ministerio Maná no podrá hacer devolución de dinero por este concepto.',
];

const travelCare = [
  {
    title: 'Pasaporte',
    body: 'Debe estar en buen estado, con vigencia mínima de 6 meses y al menos 5 hojas en blanco.',
  },
  {
    title: 'Aeropuerto',
    body: 'Llegar a la hora indicada, llevar pasaporte, documento de identidad y dinero siempre en bolsa de mano.',
  },
  {
    title: 'Durante el vuelo',
    body: 'Conservar siempre el pase de abordaje y registrarse por internet antes del viaje si desea redimir millas.',
  },
];

const itineraryPreview = itinerary.slice(0, 6);
const includedPreview = includedTurkey.slice(0, 4);
const notIncludedPreview = notIncluded.slice(0, 3);
const overviewSections = [
  { label: 'Turquía', icon: lucideIcon(mapIcon), items: includedPreview },
  { label: 'Crucero', icon: lucideIcon(shipIcon), items: includedCruise },
  { label: 'No incluye', icon: lucideIcon(walletIcon), items: notIncludedPreview },
];
const travelCareWithIcons = [
  { ...travelCare[0], icon: lucideIcon(contactIcon) },
  { ...travelCare[1], icon: lucideIcon(planeIcon) },
  { ...travelCare[2], icon: lucideIcon(ticketIcon) },
];

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'TouristTrip',
  name: 'Peregrinación Turquía e Islas Griegas 2026',
  description: 'Ruta de peregrinación del Ministerio Maná por Turquía, las siete iglesias e Islas Griegas.',
  image: `https://ministeriomana.org${posterImage}`,
  itinerary: routeStops.join(', '),
};

const cspNonce = Astro.locals?.cspNonce;
---

<CumbreLayout
  title="Peregrinación Turquía e Islas Griegas 2026 | Ministerio Maná"
  description="Ruta de peregrinación por Turquía, las siete iglesias e Islas Griegas del 17 de octubre al 1 de noviembre de 2026."
  image={posterImage}
  imageAlt="Arte de la peregrinación Turquía e Islas Griegas 2026"
  structuredData={structuredData}
  flush
  showEventBadge={false}
  showBackButton
  showAccountButton={false}
  backHref="/peregrinaciones/"
  backLabel="Peregrinaciones"
  useHistoryBack={false}
>
  <main class="pilgrim-page" data-pilgrim-story-root>
    <section
      class="pilgrim-story"
      data-cumbre-story
      data-cumbre-static-mobile="true"
      data-cumbre-static-breakpoint="520"
      data-cumbre-scroll-factor-breakpoint="520"
      data-cumbre-snap-directional="false"
      data-cumbre-snap-inertia="false"
      style="--panel-count: 6;"
    >
      <section class="cumbre-panel pilgrim-panel pilgrim-panel--hero pilgrim-hero" aria-labelledby="peregrinacion-title" data-cumbre-panel data-panel-theme="dark">
        <div class="pilgrim-panel-bg" data-panel-bg aria-hidden="true"></div>
        <div class="pilgrim-panel-inner pilgrim-shell pilgrim-hero__grid">
          <div class="pilgrim-hero__copy">
            <p class="pilgrim-kicker" data-reveal>Peregrinación 2026</p>
            <h1 id="peregrinacion-title" data-split-title>Turquía e Islas Griegas</h1>
            <p class="pilgrim-script" data-reveal>Las Siete Iglesias</p>
            <p class="pilgrim-hero__lead" data-reveal>
              Una ruta para caminar la Palabra, reconocer lugares bíblicos y vivir comunión
              como familia Maná.
            </p>
            <div class="pilgrim-actions" data-reveal>
              <a href={whatsappHref} target="_blank" rel="noopener noreferrer" class="pilgrim-button pilgrim-button--teal">
                Quiero información
              </a>
              <a href="#itinerario" class="pilgrim-button pilgrim-button--line" data-story-link>Ver itinerario</a>
            </div>
          </div>

          <div class="pilgrim-poster" aria-label="Arte de referencia de la peregrinación" data-reveal>
            <img src={posterImage} alt="" loading="eager" />
          </div>
        </div>
      </section>

      <section id="ruta" class="cumbre-panel pilgrim-panel pilgrim-panel--route pilgrim-route" data-cumbre-panel data-panel-theme="dark">
        <div class="pilgrim-panel-bg" data-panel-bg aria-hidden="true"></div>
        <div class="pilgrim-panel-inner pilgrim-shell pilgrim-route__grid">
          <div class="pilgrim-route__map" data-reveal>
            <img
              src={routeMapImage}
              alt="Mapa de la ruta de peregrinación por Turquía con Estambul, Esmirna, Capadocia y Colossae."
              width="945"
              height="570"
              loading="lazy"
              decoding="async"
            />
          </div>

          <div class="pilgrim-route__content">
            <p class="pilgrim-kicker" data-reveal>La ruta</p>
            <h2 class="pilgrim-display-title pilgrim-display-title--route" data-reveal>
              <span class="pilgrim-display-title__outline">Ruta</span>
              <span class="pilgrim-display-title__solid">Bíblica</span>
              <span class="pilgrim-display-title__script">Turquía e Islas Griegas</span>
            </h2>
            <p data-reveal>
              Una peregrinación para recorrer lugares bíblicos, caminar la historia de la iglesia
              primitiva y vivir la ruta con acompañamiento pastoral, logística clara y comunidad.
            </p>
            <div class="pilgrim-facts pilgrim-facts--panel" aria-label="Datos principales" data-reveal>
              {quickFacts.map((fact) => (
                <article>
                  <span class="pilgrim-fact-icon" set:html={fact.icon}></span>
                  <span class="pilgrim-fact-label">{fact.label}</span>
                  <strong>{fact.value}</strong>
                </article>
              ))}
            </div>
            <div class="pilgrim-route__stops" data-reveal>
              {routeStops.slice(0, 10).map((stop) => <span>{stop}</span>)}
            </div>
          </div>
        </div>
      </section>

      <section id="itinerario" class="cumbre-panel pilgrim-panel pilgrim-panel--itinerary pilgrim-section pilgrim-section--navy" data-cumbre-panel data-panel-theme="dark">
        <div class="pilgrim-panel-bg" data-panel-bg aria-hidden="true"></div>
        <div class="pilgrim-panel-inner pilgrim-shell pilgrim-itinerary__grid">
          <div class="pilgrim-section-head pilgrim-section-head--story">
            <p class="pilgrim-kicker" data-reveal>Itinerario</p>
            <h2 class="pilgrim-display-title pilgrim-display-title--itinerary" data-reveal>
              <span class="pilgrim-display-title__outline">Día</span>
              <span class="pilgrim-display-title__solid">Por Día</span>
              <span class="pilgrim-display-title__script">paso a paso</span>
            </h2>
            <p data-reveal>D = desayuno, A = almuerzo, C = cena. Algunas excursiones del crucero son opcionales.</p>
          </div>

          <div class="pilgrim-itinerary__side">
            <div class="pilgrim-days pilgrim-days--preview" data-reveal>
              {itineraryPreview.map((item) => (
                <article class="pilgrim-day pilgrim-day--preview">
                  <div class="pilgrim-day__badge">
                    <span>Día</span>
                    <strong>{item.day}</strong>
                  </div>
                  <div class="pilgrim-day__body">
                    <p>{item.meta}</p>
                    <h3>{item.title}</h3>
                  </div>
                  <div class="pilgrim-day__date">{item.date}</div>
                </article>
              ))}
            </div>

            <div class="pilgrim-actions" data-reveal>
              <a href="#itinerario-detalle" class="pilgrim-button pilgrim-button--teal">Ver itinerario completo</a>
            </div>
          </div>
        </div>
      </section>

      <section id="hoteles" class="cumbre-panel pilgrim-panel pilgrim-panel--hotels pilgrim-hotels" data-cumbre-panel data-panel-theme="dark">
        <div class="pilgrim-panel-bg" data-panel-bg aria-hidden="true"></div>
        <div class="pilgrim-panel-inner pilgrim-shell pilgrim-hotels__grid">
          <div>
            <p class="pilgrim-kicker" data-reveal>Hotelería</p>
            <h2 class="pilgrim-display-title pilgrim-display-title--hotels" data-reveal>
              <span class="pilgrim-display-title__outline">Descanso</span>
              <span class="pilgrim-display-title__solid">Previsto</span>
              <span class="pilgrim-display-title__script">en la ruta</span>
            </h2>
            <p data-reveal>Hoteles de primera categoría y turista superior. El check-in es a partir de las 4:00 p.m.</p>
          </div>
          <div class="pilgrim-hotels__list" data-reveal>
            {hotels.map((item) => (
              <article>
                <span>{item.city}</span>
                <strong>{item.hotel}</strong>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section id="incluye" class="cumbre-panel pilgrim-panel pilgrim-panel--includes pilgrim-section pilgrim-section--navy" data-cumbre-panel data-panel-theme="dark">
        <div class="pilgrim-panel-bg" data-panel-bg aria-hidden="true"></div>
        <div class="pilgrim-panel-inner pilgrim-shell pilgrim-includes-panel__grid">
          <div class="pilgrim-section-head pilgrim-section-head--story">
            <p class="pilgrim-kicker" data-reveal>Servicios incluidos</p>
            <h2 class="pilgrim-display-title pilgrim-display-title--includes" data-reveal>
              <span class="pilgrim-display-title__outline">Lo que</span>
              <span class="pilgrim-display-title__solid">Incluye</span>
              <span class="pilgrim-display-title__script">la peregrinación</span>
            </h2>
            <p data-reveal>Un resumen claro para comparar lo que está cubierto en Turquía, en el crucero y lo que debe presupuestarse aparte.</p>
          </div>

          <div class="pilgrim-includes-panel__side">
            <div class="pilgrim-overview-grid" data-reveal>
              {overviewSections.map((section) => (
                <article>
                  <span class="pilgrim-overview-icon" set:html={section.icon}></span>
                  <span class="pilgrim-overview-label">{section.label}</span>
                  <ul>
                    {section.items.map((item) => <li>{item}</li>)}
                  </ul>
                </article>
              ))}
            </div>

            <div class="pilgrim-actions" data-reveal>
              <a href="#incluye-detalle" class="pilgrim-button pilgrim-button--teal">Ver detalle incluido</a>
              <a href="#tiquetes-detalle" class="pilgrim-button pilgrim-button--line">Tiquetes</a>
            </div>
          </div>
        </div>
      </section>

      <section class="cumbre-panel pilgrim-panel pilgrim-panel--final pilgrim-final" data-cumbre-panel data-panel-theme="light">
        <div class="pilgrim-panel-bg" data-panel-bg aria-hidden="true"></div>
        <div class="pilgrim-panel-inner pilgrim-shell pilgrim-final__box">
          <div>
            <p class="pilgrim-kicker pilgrim-kicker--navy" data-reveal>Da el primer paso</p>
            <h2 class="pilgrim-display-title pilgrim-display-title--final" data-reveal>
              <span class="pilgrim-display-title__outline">Reserva</span>
              <span class="pilgrim-display-title__solid">Tu Lugar</span>
              <span class="pilgrim-display-title__script">con el equipo</span>
            </h2>
            <p data-reveal>Te ayudamos a revisar cupos, requisitos, pasaporte, reserva y cotización aérea vigente.</p>
          </div>
