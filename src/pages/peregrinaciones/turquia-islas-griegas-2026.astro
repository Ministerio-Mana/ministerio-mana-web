  .pilgrim-includes__not li::after {
    left: 6px;
    top: 0.42em;
    width: 10px;
    height: 10px;
    border: 0;
    background:
      linear-gradient(45deg, transparent 44%, var(--pilgrim-navy) 45%, var(--pilgrim-navy) 55%, transparent 56%),
      linear-gradient(-45deg, transparent 44%, var(--pilgrim-navy) 45%, var(--pilgrim-navy) 55%, transparent 56%);
