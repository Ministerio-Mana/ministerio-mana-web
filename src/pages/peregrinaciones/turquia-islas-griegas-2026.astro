  .pilgrim-includes li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.2em;
    width: 22px;
    height: 22px;
    border-radius: 999px;
    background: var(--pilgrim-teal);
  }

  .pilgrim-includes li::after {
    content: "";
    position: absolute;
    left: 7px;
    top: 0.52em;
    width: 8px;
    height: 4px;
    border-left: 2px solid var(--pilgrim-navy);
    border-bottom: 2px solid var(--pilgrim-navy);
    transform: rotate(-45deg);
