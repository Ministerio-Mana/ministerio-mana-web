---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const events = await getCollection('events', ({ data }) => data.category === 'peregrinacion');
const peregrinaciones = events.sort((a, b) => b.data.date.localeCompare(a.data.date));
const assetBase = '/images/peregrinaciones/turquia-islas-griegas-2026';
const posterImage = `${assetBase}/poster-reference.jpg`;
const featuredFacts = ['17 oct - 1 nov 2026', '16 días', 'Turquía e Islas Griegas', 'Las siete iglesias'];
---

<BaseLayout
  title="Peregrinaciones · Ministerio Maná"
  description="Peregrinaciones del Ministerio Maná para caminar la Palabra, crecer en comunidad y preparar cada ruta con claridad."
>
  <main class="pilgrimages-home">
    <section class="pilgrimages-shell pilgrimages-feature">
      <div class="pilgrimages-feature__copy">
        <p class="pilgrimages-kicker">Ministerio Maná</p>
        <h1>
          <span>Ruta</span>
          <span>Peregrinación</span>
          <strong>Turquía - Islas Griegas</strong>
        </h1>
        <p class="pilgrimages-script">Las Siete Iglesias</p>
        <p>
          Una peregrinación para caminar la Palabra, recorrer lugares bíblicos y vivir
          formación, historia y comunidad.
        </p>
        <div class="pilgrimages-feature__facts" aria-label="Datos principales de la peregrinación">
          {featuredFacts.map((fact) => <span>{fact}</span>)}
        </div>
        <div class="pilgrimages-actions">
          <a href="/peregrinaciones/turquia-islas-griegas-2026/" class="pilgrimages-button pilgrimages-button--teal">
            Ver peregrinación 2026
          </a>
          <a href="/peregrinaciones/turquia-islas-griegas-2026/#itinerario" class="pilgrimages-button pilgrimages-button--line">
            Itinerario
          </a>
        </div>
      </div>

      <div class="pilgrimages-poster">
        <img src={posterImage} alt="" loading="eager" />
      </div>
    </section>

    <section class="pilgrimages-shell pilgrimages-list">
      <header>
        <p class="pilgrimages-kicker">Peregrinaciones</p>
        <h2>Caminos que fortalecen la fe</h2>
        <p>
          Rutas bíblicas para aprender juntos, cuidar la experiencia del peregrino
          y caminar como comunidad Maná.
        </p>
      </header>

      <div class="pilgrimages-grid">
        {peregrinaciones.map(({ slug, data }) => (
          <article class="pilgrimages-card">
            <div>
              <p class="pilgrimages-card__meta">
                {data.location} · {new Date(data.date).toLocaleDateString('es-CO')}
              </p>
              <h3>{data.title}</h3>
              <p>{data.summary}</p>
            </div>
            <div class="pilgrimages-card__actions">
              <a href={`/eventos/${slug}/`} class="pilgrimages-card__link pilgrimages-card__link--main">
                Ver detalles
              </a>
              {data.brochurePdf && (
                <a
                  href={data.brochurePdf}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="pilgrimages-card__link"
                >
                  Ver PDF
                </a>
              )}
            </div>
          </article>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  @font-face {
    font-family: "Pilgrim Summer";
    src: url("/fonts/SUMMER FONT/Summer Loving Regular.otf") format("opentype");
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  .pilgrimages-home {
    --pilgrim-navy: #17243c;
    --pilgrim-deep: #07111f;
    --pilgrim-teal: #08aebe;
    --pilgrim-white: #ffffff;
    background: var(--pilgrim-navy);
    color: white;
    font-family: "Intro", ui-sans-serif, system-ui, sans-serif;
    overflow-x: hidden;
  }

  .pilgrimages-home *,
  .pilgrimages-home *::before,
  .pilgrimages-home *::after {
    box-sizing: border-box;
  }

  .pilgrimages-shell {
    width: min(1160px, calc(100% - 32px));
    margin-inline: auto;
  }

  .pilgrimages-feature {
    min-height: calc(100svh - 90px);
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(320px, 0.72fr);
    gap: 44px;
    align-items: center;
    padding: 80px 0;
    overflow: hidden;
  }

  .pilgrimages-feature__copy {
    min-width: 0;
    max-width: 100%;
  }

  .pilgrimages-kicker {
    margin: 0 0 16px;
    color: var(--pilgrim-teal);
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.42em;
    text-transform: uppercase;
  }

  .pilgrimages-feature h1,
  .pilgrimages-list h2 {
    margin: 0;
    font-family: "Intro", ui-sans-serif, system-ui, sans-serif;
    font-weight: 900;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .pilgrimages-feature h1 {
    max-width: min(100%, 900px);
    color: white;
    font-size: clamp(2.9rem, 5vw, 4.5rem);
    line-height: 0.92;
  }

  .pilgrimages-feature h1 span {
    display: block;
  }

  .pilgrimages-feature h1 strong {
    display: block;
    margin-top: 0.12em;
    font-size: 0.42em;
    line-height: 1.08;
    text-transform: none;
  }

  .pilgrimages-script {
    margin: 24px 0 0;
    color: white;
    font-family: "Pilgrim Summer", "Brush Script MT", cursive;
    font-size: clamp(3.2rem, 8vw, 6.4rem);
    line-height: 0.76;
  }

  .pilgrimages-feature__copy > p:not(.pilgrimages-kicker):not(.pilgrimages-script) {
    max-width: min(100%, 660px);
    margin: 34px 0 0;
    color: rgba(255, 255, 255, 0.78);
    font-size: clamp(1.04rem, 2vw, 1.24rem);
    line-height: 1.7;
  }

  .pilgrimages-feature__facts {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 30px;
  }

  .pilgrimages-feature__facts span {
    display: inline-flex;
    min-height: 38px;
    align-items: center;
    padding: 0 14px;
    border: 1px solid rgba(255, 255, 255, 0.18);
    color: white;
    font-size: 0.78rem;
    font-weight: 900;
  }

  .pilgrimages-actions,
  .pilgrimages-card__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 32px;
  }

  .pilgrimages-button,
  .pilgrimages-card__link {
    display: inline-flex;
    min-height: 50px;
    align-items: center;
    justify-content: center;
    padding: 0 22px;
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 900;
    letter-spacing: 0.14em;
    text-decoration: none;
    text-transform: uppercase;
  }

  .pilgrimages-button--teal,
  .pilgrimages-card__link--main {
    background: var(--pilgrim-teal);
    color: var(--pilgrim-deep);
  }

  .pilgrimages-button--line {
    border: 1px solid rgba(255, 255, 255, 0.28);
    color: white;
  }

  .pilgrimages-poster {
    position: relative;
    width: 100%;
    max-width: 520px;
    aspect-ratio: 1;
    justify-self: end;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.2);
    box-shadow: 0 34px 88px rgba(0, 0, 0, 0.32);
  }

  .pilgrimages-poster::after {
    content: "";
    position: absolute;
    inset: 18px;
    border: 1px solid rgba(255, 255, 255, 0.42);
  }

  .pilgrimages-poster img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .pilgrimages-list {
    padding: 72px 0 96px;
    border-top: 1px solid rgba(255, 255, 255, 0.16);
  }

  .pilgrimages-list header {
    max-width: 780px;
    margin-bottom: 36px;
  }

  .pilgrimages-list h2 {
    color: white;
    font-size: clamp(2.6rem, 5.6vw, 5.3rem);
    line-height: 0.95;
  }

  .pilgrimages-list header p:not(.pilgrimages-kicker) {
    margin: 20px 0 0;
    color: rgba(255, 255, 255, 0.74);
    font-size: 1.05rem;
    line-height: 1.75;
  }

  .pilgrimages-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
  }

  .pilgrimages-card {
    min-height: 250px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 28px;
    border: 1px solid rgba(255, 255, 255, 0.14);
    background: rgba(255, 255, 255, 0.04);
  }

  .pilgrimages-card__meta {
    margin: 0 0 14px;
    color: var(--pilgrim-teal);
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .pilgrimages-card h3 {
    margin: 0;
    color: white;
    font-size: 1.55rem;
    line-height: 1.12;
  }

  .pilgrimages-card p:not(.pilgrimages-card__meta) {
    margin: 14px 0 0;
    color: rgba(255, 255, 255, 0.72);
    line-height: 1.65;
  }

  .pilgrimages-card__link {
    border: 1px solid rgba(255, 255, 255, 0.18);
    color: white;
  }

  .pilgrimages-card__link--main {
    border-color: var(--pilgrim-teal);
    color: var(--pilgrim-deep);
  }

  @media (max-width: 900px) {
    .pilgrimages-feature {
      grid-template-columns: 1fr;
    }

    .pilgrimages-poster {
      max-width: 560px;
      justify-self: center;
    }
  }

  @media (max-width: 680px) {
    .pilgrimages-shell {
      width: min(100% - 24px, 1160px);
    }

    .pilgrimages-feature {
      min-height: auto;
      gap: 34px;
      padding: 46px 0 64px;
    }

    .pilgrimages-feature h1 {
      font-size: clamp(1.95rem, 8vw, 2.65rem);
      line-height: 1;
    }

    .pilgrimages-feature h1 strong {
      font-size: 0.52em;
    }

    .pilgrimages-script {
      font-size: clamp(2.6rem, 13vw, 4rem);
    }

    .pilgrimages-feature__copy > p:not(.pilgrimages-kicker):not(.pilgrimages-script) {
      max-width: 22rem;
      font-size: 1rem;
      line-height: 1.55;
    }

    .pilgrimages-poster {
      max-width: 100%;
    }

    .pilgrimages-actions,
    .pilgrimages-button {
      width: 100%;
    }

    .pilgrimages-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
