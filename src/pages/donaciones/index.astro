---
import BaseLayout from '@layouts/BaseLayout.astro';
import DonationGateway from '@components/DonationGateway.astro';
import VenAyudanosBackLink from '@components/ven-ayudanos/VenAyudanosBackLink.astro';
import { preferredGatewayForCountry } from '@lib/geo';

const geo = Astro.locals?.geo ?? { country: 'CO', lang: 'es' };
const requestedType = Astro.url.searchParams.get('type')?.toLowerCase() || '';
const requestedGateway = Astro.url.searchParams.get('gateway')?.toLowerCase() || '';
const initialDonationType = ['diezmos', 'ofrendas', 'misiones'].includes(requestedType)
  ? requestedType
  : '';
const preferred = requestedGateway === 'stripe' || requestedGateway === 'wompi'
  ? requestedGateway
  : preferredGatewayForCountry(geo.country);
export const prerender = false;
---
<BaseLayout title="Donaciones — Ministerio Maná" description="Dona para expandir la misión de Ministerio Maná.">
  <VenAyudanosBackLink tone="dark" />
  <DonationGateway preferred={preferred} country={geo.country} initialDonationType={initialDonationType} />
</BaseLayout>
