---
import BaseLayout from '@layouts/BaseLayout.astro';
import VenAyudanosBackLink from '@components/ven-ayudanos/VenAyudanosBackLink.astro';
export const prerender = false;

const title = "¡Gracias por Sembrar! · Campus Maná";
const description = "Tu siembra hace posible llevar el evangelio a las universidades. Gracias por ser socio de la Gran Comisión.";
---

<BaseLayout {title} {description} hideHeader={false} hideFooter={false}>
  <VenAyudanosBackLink tone="dark" />

  <!-- Campus Identity Fonts -->
  <style is:global>
    @font-face {
      font-family: 'Intro';
      src: url('/fonts/intro/Intro-Black.woff2') format('woff2');
      font-weight: 900;
      font-style: normal;
      font-display: swap;
    }
    @font-face {
      font-family: 'Intro';
      src: url('/fonts/intro/Intro-Regular.woff2') format('woff2');
      font-weight: 400;
      font-style: normal;
      font-display: swap;
    }
    @font-face {
      font-family: 'Summer Loving';
      src: url('/fonts/SUMMER%20FONT/Summer%20Loving%20Regular.otf') format('opentype');
      font-weight: 400;
      font-style: normal;
      font-display: swap;
    }
    
    .font-intro { font-family: 'Intro', sans-serif; font-weight: 900; }
    .font-intro-reg { font-family: 'Intro', sans-serif; font-weight: 400; }
    .font-summer { font-family: 'Summer Loving', cursive; }
  </style>

  <main class="min-h-screen bg-brand-teal relative overflow-hidden">
    <!-- Background texture -->
    <div class="absolute inset-0 opacity-5 bg-[url('https://www.transparenttextures.com/patterns/notebook.png')]"></div>
    
    <!-- Floating particles -->
    <div id="particles" class="absolute inset-0 pointer-events-none"></div>
    
    <!-- Content -->
    <div class="relative z-10 flex flex-col items-center justify-center min-h-screen px-4 py-16">
      
      <!-- Animated checkmark -->
      <div class="mb-8 animate-bounce-slow">
        <div class="w-24 h-24 rounded-full bg-white/10 backdrop-blur-sm border-2 border-white/30 flex items-center justify-center mx-auto">
          <svg class="w-12 h-12 text-white check-animate" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" class="check-path" />
          </svg>
        </div>
      </div>

      <!-- Main heading -->
      <div class="text-center mb-8">
        <span class="font-summer text-white block mb-[-10px] transform -rotate-2" style="font-size: clamp(3rem, 8vw, 5.5rem);">
          ¡Gracias por
        </span>
        <h1 class="font-intro text-[#001B3A] uppercase" style="font-size: clamp(2rem, 6vw, 4rem);">
          SEMBRAR!
        </h1>
      </div>

      <!-- Message card -->
      <div class="max-w-lg mx-auto bg-white/10 backdrop-blur-md rounded-3xl border border-white/20 p-8 text-center shadow-2xl mb-8">
        <p class="font-intro-reg text-white text-lg leading-relaxed mb-4">
          Tu siembra está haciendo posible que el evangelio llegue a las universidades de Colombia.
        </p>
        <p id="payment-status-message" class="font-intro-reg text-white/70 text-sm leading-relaxed" role="status" aria-live="polite">
          Tu pago está siendo procesado. Recibirás una confirmación una vez la pasarela lo apruebe.
          Si tienes alguna pregunta, escríbenos a
          <a href="mailto:info@ministeriomana.org" class="text-white font-intro underline underline-offset-4 decoration-white/40 hover:decoration-white transition-all">
            info@ministeriomana.org
          </a>
        </p>
      </div>

      <!-- Reference display -->
      <div id="ref-display" class="hidden mb-8">
        <div class="bg-[#001B3A]/30 backdrop-blur-sm rounded-2xl px-6 py-3 border border-white/10">
          <p class="text-white/50 text-[10px] font-intro uppercase tracking-widest mb-1">Referencia de pago</p>
          <p id="ref-code" class="font-intro text-white text-sm tracking-wider"></p>
        </div>
      </div>

      <!-- Verse -->
      <div class="max-w-md mx-auto text-center mb-10">
        <blockquote class="font-intro-reg text-white/80 italic text-base leading-relaxed mb-2">
          "El que siembra generosamente, generosamente también cosechará."
        </blockquote>
        <cite class="text-[11px] font-intro text-white/40 uppercase tracking-widest not-italic">
          — 2 Corintios 9:6
        </cite>
      </div>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row items-center gap-4">
        <a href="/ven-ayudanos" class="btn-scribble px-8 py-4 bg-[#001B3A] text-white font-intro text-sm uppercase tracking-wider text-center">
          ← Volver a Ven y Ayúdanos
        </a>
        <a href="/campus" class="btn-scribble px-8 py-4 bg-transparent text-white font-intro text-sm uppercase tracking-wider text-center border-none">
          Ver Campus
        </a>
      </div>

      <!-- Share section -->
      <div class="mt-12 text-center">
        <p class="text-white/40 text-[10px] font-intro uppercase tracking-widest mb-3">Comparte tu apoyo</p>
        <div class="flex items-center justify-center gap-4">
          <a href="https://wa.me/?text=Acabo%20de%20sembrar%20en%20Campus%20Man%C3%A1%20para%20llevar%20el%20evangelio%20a%20las%20universidades.%20%C2%A1%C3%9Anete!%20https://ministeriomana.org/campus"
             target="_blank" rel="noopener"
             class="w-10 h-10 rounded-full bg-white/10 border border-white/20 flex items-center justify-center hover:bg-white/20 transition-all"
             title="Compartir en WhatsApp">
            <svg class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </a>
          <button id="copy-link-btn"
                  class="w-10 h-10 rounded-full bg-white/10 border border-white/20 flex items-center justify-center hover:bg-white/20 transition-all"
                  title="Copiar enlace">
            <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" /></svg>
          </button>
        </div>
      </div>

    </div>
  </main>
</BaseLayout>

<style>
  /* Scribble Button */
  .btn-scribble {
    position: relative;
    z-index: 10;
    display: inline-block;
    transition: transform 0.2s, background-color 0.3s, color 0.3s;
  }
  .btn-scribble::before {
    content: '';
    position: absolute;
    inset: -6px;
    border: 2.5px solid currentColor;
    border-radius: 255px 15px 225px 15px / 15px 225px 15px 255px;
    z-index: -1;
    opacity: 0.7;
    transition: all 0.4s ease;
  }
  .btn-scribble:hover::before {
    border-radius: 15px 255px 15px 255px / 255px 15px 255px 15px;
    transform: scale(1.06);
    opacity: 1;
  }

  /* Checkmark animation */
  .check-path {
    stroke-dasharray: 30;
    stroke-dashoffset: 30;
    animation: drawCheck 0.8s ease-out 0.3s forwards;
  }
  @keyframes drawCheck {
    to { stroke-dashoffset: 0; }
  }

  /* Slow bounce */
  @keyframes bounceSlow {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }
  .animate-bounce-slow {
    animation: bounceSlow 3s ease-in-out infinite;
  }
</style>

<script>
  // Show reference if present in URL
  const params = new URLSearchParams(window.location.search);
  const ref = params.get('ref');
  const provider = params.get('provider');
  const transactionId = params.get('id');
  const paymentStatusMessage = document.getElementById('payment-status-message');
  if (ref) {
    const refDisplay = document.getElementById('ref-display');
    const refCode = document.getElementById('ref-code');
    if (refDisplay && refCode) {
      refCode.textContent = ref;
      refDisplay.classList.remove('hidden');
    }
  }

  async function reconcileWompiPayment(attempt = 0) {
    if (!ref || provider !== 'wompi' || !transactionId) return;
    try {
      const response = await fetch('/api/wompi/reconcile', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ reference: ref, transactionId }),
      });
      const payload = await response.json().catch(() => null);
      if (!response.ok || !payload?.ok) return;

      if (paymentStatusMessage && payload.status === 'APPROVED') {
        paymentStatusMessage.textContent = 'Tu pago fue aprobado y ya quedó registrado. Gracias por sembrar en Campus Maná.';
        return;
      }
      if (paymentStatusMessage && payload.status === 'FAILED') {
        paymentStatusMessage.textContent = 'Wompi no aprobó este intento. No se registró una donación pagada.';
        return;
      }
      if (attempt < 2) {
        window.setTimeout(() => reconcileWompiPayment(attempt + 1), 4_000 * (attempt + 1));
      }
    } catch {
      // El webhook y el reconciliador programado siguen funcionando si el navegador se cierra.
    }
  }

  reconcileWompiPayment();

  // Copy link button
  const copyBtn = document.getElementById('copy-link-btn');
  if (copyBtn) {
    copyBtn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText('https://ministeriomana.org/campus');
        const svg = copyBtn.querySelector('svg');
        if (svg) {
          const orig = svg.innerHTML;
          svg.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />';
          setTimeout(() => { svg.innerHTML = orig; }, 1500);
        }
      } catch {}
    });
  }

  // Floating particles
  const container = document.getElementById('particles');
  if (container) {
    for (let i = 0; i < 20; i++) {
      const particle = document.createElement('div');
      const size = Math.random() * 4 + 2;
      particle.style.cssText = `
        position: absolute;
        width: ${size}px;
        height: ${size}px;
        background: rgba(255, 255, 255, ${Math.random() * 0.15 + 0.05});
        border-radius: 50%;
        left: ${Math.random() * 100}%;
        top: ${Math.random() * 100}%;
        animation: float ${Math.random() * 10 + 10}s linear infinite;
      `;
      container.appendChild(particle);
    }

    const style = document.createElement('style');
    style.textContent = `
      @keyframes float {
        0% { transform: translateY(0) translateX(0); opacity: 0; }
        10% { opacity: 1; }
        90% { opacity: 1; }
        100% { transform: translateY(-100vh) translateX(${Math.random() * 40 - 20}px); opacity: 0; }
      }
    `;
    document.head.appendChild(style);
  }
</script>
