---
import BaseLayout from '@layouts/BaseLayout.astro';

const title = 'Cómo ser socio de la Gran Comisión | Campus Maná';
const description = 'Tutorial sencillo para apoyar mensualmente a los misioneros de Campus Maná.';
const image = '/images/campus/misioneros/GRUPO-COMPLETO.jpg';
const campusPath = '/campus';
const tutorialUrl = 'https://ministeriomana.org/campus/como-ser-socio';
const whatsappText = encodeURIComponent(
  `Hola, quiero compartirte el paso a paso para ser socio de la Gran Comisión de Campus Maná: ${tutorialUrl}`
);

const checklistItems = [
  'Nombre completo.',
  'Correo que sí revise.',
  'Teléfono o WhatsApp.',
  'Medio de pago listo.',
  'Cinco minutos tranquilos.',
  'Cuenta para siembra mensual.',
];

const singleSteps = [
  {
    title: 'Abre Campus Maná',
    text: 'Entra a ministeriomana.org/campus. En celular, espera unos segundos a que carguen las fotos y toca “Apoyar ahora”.',
    image: '/images/campus/tutorial/01-abrir-campus.jpg',
    caption: 'Inicio de Campus Maná.',
    marker: { x: 50, y: 76, label: 'Apoyar' },
  },
  {
    title: 'Baja hasta el equipo',
    text: 'Busca el título “Nuestro equipo”. Ahí aparecen las tarjetas de los misioneros Campus.',
    image: '/images/campus/tutorial/02-buscar-equipo.jpg',
    caption: 'La sección del equipo está debajo de la misión.',
    marker: { x: 52, y: 23, label: 'Equipo' },
  },
  {
    title: 'Escoge un misionero',
    text: 'Revisa el nombre del misionero y busca la parte donde puedes sembrar. Cada tarjeta tiene su propio botón para donar.',
    image: '/images/campus/tutorial/03-elegir-misionero.jpg',
    caption: 'Cada misionero tiene su propia tarjeta.',
    marker: { x: 30, y: 56, label: 'Escoge' },
  },
  {
    title: 'Deja “Mensual”',
    text: 'Para ser socio, deja marcada la opción “Mensual”. Si quieres sembrar solo una vez, toca “Única vez”.',
    image: '/images/campus/tutorial/04-marcar-mensual.jpg',
    caption: 'Mensual crea una siembra recurrente.',
    marker: { x: 34, y: 50, label: 'Mensual' },
  },
  {
    title: 'Escribe la donación',
    text: 'Escribe el valor que quieres sembrar. El sitio muestra pesos colombianos o dólares automáticamente. Si tocas un monto rápido, se oculta el campo escrito; para volver, toca “Cambiar monto”.',
    image: '/images/campus/tutorial/05-escoger-monto.jpg',
    caption: 'Al escribir, los montos rápidos desaparecen para no confundir.',
    marker: { x: 50, y: 42, label: 'Monto' },
  },
  {
    title: 'Toca “Donar Ahora”',
    text: 'Cuando el botón esté activo, tócalo una sola vez. No hay que tocar varias veces ni cambiar de pantalla.',
    image: '/images/campus/tutorial/06-donar-ahora.jpg',
    caption: 'El botón se activa cuando ya hay un monto válido.',
    marker: { x: 50, y: 68, label: 'Donar' },
  },
  {
    title: 'Inicia sesión o crea cuenta',
    text: 'Si la siembra es mensual, el sitio pide una cuenta. Eso te permite pausar, reactivar o cancelar después desde el portal.',
    image: '/images/campus/tutorial/07-cuenta-requerida.jpg',
    caption: 'La cuenta es necesaria para siembras mensuales.',
    marker: { x: 50, y: 63, label: 'Cuenta' },
  },
  {
    title: 'Completa datos si aparecen',
    text: 'Si el sitio pide datos, llena nombre, correo, teléfono y ciudad. En Colombia, Wompi también pide tipo y número de identificación.',
    image: '/images/campus/tutorial/08-datos-pago.jpg',
    caption: 'La identificación aplica para pagos procesados en Colombia.',
    marker: { x: 50, y: 64, label: 'Datos' },
  },
  {
    title: 'Finaliza el pago',
    text: 'Completa el pago seguro. Cuando aparezca la confirmación, guarda el comprobante o toma una captura.',
    image: '/images/campus/tutorial/08-pago-seguro.jpg',
    caption: 'La pantalla de gracias confirma que el proceso quedó enviado.',
    marker: { x: 50, y: 37, label: 'Listo' },
  },
];

const multiSteps = [
  {
    title: 'Escoge cuántos misioneros',
    text: 'Baja a “¿Quieres sembrar en varios misioneros?”. Elige 2, 3, 4, 5 o todos.',
    image: '/images/campus/tutorial/09-varios-cantidad.jpg',
    caption: 'Primero se elige la cantidad de misioneros.',
    marker: { x: 50, y: 64, label: 'Cantidad' },
  },
  {
    title: 'Selecciona nombres o “Al azar”',
    text: 'Toca los misioneros que quieres apoyar. Si no sabes a quién escoger, puedes usar “Al azar”.',
    image: '/images/campus/tutorial/10-varios-seleccionar.jpg',
    caption: 'Los seleccionados quedan marcados con un círculo verde.',
    marker: { x: 87, y: 22, label: 'Marcado' },
  },
  {
    title: 'Opción 1: presupuesto total',
    text: 'Si ya sabes cuánto quieres sembrar en total para Campus, escribe ese presupuesto. El sitio lo divide entre los misioneros; si bajas el monto de uno, lo que sobra se reparte entre los demás.',
    image: '/images/campus/tutorial/11-varios-presupuesto.jpg',
    caption: 'El presupuesto total se reparte automáticamente.',
    marker: { x: 50, y: 42, label: 'Total' },
  },
  {
    title: 'Opción 2: mismo monto rápido',
    text: 'Si quieres dar el mismo valor a cada misionero, toca un monto rápido. Luego puedes ajustar cualquier monto si quieres cambiar algo.',
    image: '/images/campus/tutorial/12-varios-monto-rapido.jpg',
    caption: 'El mismo monto queda aplicado a todos los seleccionados.',
    marker: { x: 50, y: 18, label: 'Igual' },
  },
  {
    title: 'Opción 3: monto manual',
    text: 'Si quieres dar valores diferentes, escribe directamente cuánto quieres sembrar en cada misionero. El total se calcula abajo.',
    image: '/images/campus/tutorial/13-varios-manual.jpg',
    caption: 'Cada misionero puede tener un monto diferente.',
    marker: { x: 74, y: 36, label: 'Ajusta' },
  },
  {
    title: 'Revisa el resumen',
    text: 'Antes de pagar, revisa nombres, montos y total. Si es mensual, el sitio pedirá iniciar sesión o crear cuenta.',
    image: '/images/campus/tutorial/14-varios-resumen.jpg',
    caption: 'El resumen muestra cuánto va para cada misionero.',
    marker: { x: 50, y: 56, label: 'Resumen' },
  },
];

const coachLines = [
  'Primero escogemos a quién quieres apoyar.',
  'Si quieres que sea mensual, dejamos “Mensual”.',
  'Ahora escribe cuánto quieres sembrar. Si prefieres un botón rápido, lo tocamos.',
  'Si el sitio pide cuenta, la creamos o iniciamos sesión para que después puedas manejar tu siembra.',
  'Si apoyas a varios, puedes repartir un presupuesto total, poner el mismo monto a todos o escribir un valor diferente para cada uno.',
  'Antes de pagar, revisamos nombres, montos y total.',
];

const supportItems = [
  {
    title: 'El botón no se activa',
    text: 'Revisa que el monto esté escrito o seleccionado y que sea mayor al mínimo.',
  },
  {
    title: 'Desaparece una opción',
    text: 'Es normal. El sitio oculta opciones para que no hagas dos cosas a la vez. Toca “Cambiar monto” para volver.',
  },
  {
    title: 'Pide identificación',
    text: 'En Colombia, Wompi pide tipo y número de identificación para procesar el pago.',
  },
  {
    title: 'El pago no carga',
    text: 'Espera unos segundos, revisa conexión y toca el botón una sola vez.',
  },
];
---

<BaseLayout {title} {description} {image}>
  <style is:global>
    @font-face {
      font-family: 'Intro';
      src: url('/fonts/intro/Intro-Black.woff2') format('woff2');
      font-weight: 900;
      font-style: normal;
      font-display: swap;
    }
    @font-face {
      font-family: 'Intro';
      src: url('/fonts/intro/Intro-Regular.woff2') format('woff2');
      font-weight: 400;
      font-style: normal;
      font-display: swap;
    }
    @font-face {
      font-family: 'Summer Loving';
      src: url('/fonts/SUMMER%20FONT/Summer%20Loving%20Regular.otf') format('opentype');
      font-weight: 400;
      font-style: normal;
      font-display: swap;
    }
    .font-intro { font-family: 'Intro', sans-serif; font-weight: 900; }
    .font-intro-reg { font-family: 'Intro', sans-serif; font-weight: 400; }
    .font-summer { font-family: 'Summer Loving', cursive; }
  </style>

  <section class="tutorial-hero relative overflow-hidden bg-[#001B3A] text-white">
    <div class="absolute inset-0">
      <img
        src={image}
        alt="Equipo de misioneros Campus Maná"
        class="h-full w-full object-cover opacity-60"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-[#001B3A]/96 via-[#001B3A]/84 to-[#001B3A]/94"></div>
      <div class="absolute inset-y-0 left-0 w-full bg-gradient-to-r from-[#001B3A]/96 via-[#001B3A]/76 to-[#001B3A]/50"></div>
    </div>

    <div class="container-tight relative z-10 flex min-h-[78vh] items-center px-4 py-24">
      <div class="tutorial-hero-copy max-w-4xl">
        <p class="inline-flex border-organic bg-[#FACC15] px-4 py-2 font-intro text-xs uppercase tracking-[0.16em] text-[#001B3A]">
          Tutorial para acompañar
        </p>
        <span class="font-summer mt-7 block -rotate-2 text-6xl leading-none text-[#2DD4BF] sm:text-7xl md:text-8xl">
          Paso a paso
        </span>
        <h1 class="font-intro mt-1 max-w-4xl text-4xl uppercase leading-[0.98] text-white sm:text-5xl md:text-7xl">
          Socios de la Gran Comisión
        </h1>
        <p class="mt-6 max-w-2xl font-intro-reg text-lg leading-relaxed text-white/82 md:text-xl">
          Una guía clara para ayudar a una persona a sembrar en Campus Maná sin enredarse con botones, cuentas o montos.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="#un-misionero" class="tutorial-action bg-[#2DD4BF] text-[#001B3A]">
            Ruta normal
          </a>
          <a href="#varios-misioneros" class="tutorial-action border border-[#2DD4BF] bg-[#001B3A]/95 text-white">
            Varios misioneros
          </a>
          <a href={campusPath} class="tutorial-action bg-[#FACC15] text-[#001B3A]">
            Ir a Campus
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-[#F3F0E6] py-10">
    <div class="container-tight px-4">
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {checklistItems.map((item) => (
          <div class="preflight-item">
            <span class="preflight-check">✓</span>
            <span>{item}</span>
          </div>
        ))}
      </div>
      <p class="mt-5 max-w-3xl font-intro-reg text-sm leading-relaxed text-[#001B3A]/70">
        No expliques todo de una sola vez. Primero confirma a quién quiere apoyar, luego el monto, después la cuenta si es mensual y por último el pago.
      </p>
    </div>
  </section>

  <section id="un-misionero" class="scroll-mt-24 bg-white py-16 md:py-24">
    <div class="container-tight px-4">
      <div class="tutorial-section-heading">
        <p class="section-eyebrow">Ruta normal desde Campus</p>
        <h2>Para apoyar a un misionero</h2>
        <p>
          Esta es la ruta más simple cuando entras a la página de Campus y quieres apoyar a un misionero específico. Lee cada pantalla antes de avanzar.
        </p>
      </div>

      <div class="tutorial-steps">
        {singleSteps.map((step, index) => (
          <article class="tutorial-card">
            <div class="tutorial-copy">
              <span class="step-badge">Paso {index + 1}</span>
              <h3>{step.title}</h3>
              <p>{step.text}</p>
              <small>{step.caption}</small>
            </div>
            <figure class="tutorial-shot-frame">
              <div class="tutorial-shot">
                <img
                  src={step.image}
                  alt={`Pantallazo del paso ${index + 1}: ${step.title}`}
                  loading="eager"
                />
                <span class="tap-marker" style={`--marker-x: ${step.marker.x}%; --marker-y: ${step.marker.y}%;`}>
                  <span class="tap-marker__target" aria-hidden="true">
                    <span class="tap-marker__dot"></span>
                  </span>
                  <span class="tap-marker__label">{step.marker.label}</span>
                </span>
              </div>
            </figure>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="varios-misioneros" class="multi-tutorial-section scroll-mt-24 bg-[#001B3A] py-16 text-white md:py-24">
    <div class="container-tight px-4">
      <div class="tutorial-section-heading tutorial-section-heading--dark">
        <p class="section-eyebrow section-eyebrow--teal">Ruta completa</p>
        <h2>Para apoyar a varios misioneros</h2>
        <p>
          Aquí puedes escoger nombres, usar “Al azar”, repartir un presupuesto total, dar el mismo monto a todos o ajustar montos diferentes.
        </p>
      </div>

      <div class="tutorial-steps tutorial-steps--dark">
        {multiSteps.map((step, index) => (
          <article class="tutorial-card tutorial-card--dark">
            <div class="tutorial-copy">
              <span class="step-badge step-badge--yellow">Paso {index + 1}</span>
              <h3>{step.title}</h3>
              <p>{step.text}</p>
              <small>{step.caption}</small>
            </div>
            <figure class="tutorial-shot-frame tutorial-shot-frame--dark">
              <div class="tutorial-shot">
                <img
                  src={step.image}
                  alt={`Pantallazo de varios misioneros ${index + 1}: ${step.title}`}
                  loading="eager"
                />
                <span class="tap-marker" style={`--marker-x: ${step.marker.x}%; --marker-y: ${step.marker.y}%;`}>
                  <span class="tap-marker__target" aria-hidden="true">
                    <span class="tap-marker__dot"></span>
                  </span>
                  <span class="tap-marker__label">{step.marker.label}</span>
                </span>
              </div>
            </figure>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-[#F3F0E6] py-16 md:py-24">
    <div class="container-tight px-4">
      <div class="grid gap-8 lg:grid-cols-[0.88fr_1.12fr]">
        <div class="tutorial-section-heading m-0">
          <p class="section-eyebrow">Guion coquito</p>
          <h2>Explícalo sin palabras raras</h2>
          <p>
            Úsalo como una conversación. La idea es que quien está donando sepa qué está pasando en cada paso.
          </p>
        </div>
        <div class="script-list">
          {coachLines.map((line, index) => (
            <div class="script-line">
              <span>{index + 1}</span>
              <p>{line}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white py-16 md:py-24">
    <div class="container-tight px-4">
      <div class="tutorial-section-heading">
        <p class="section-eyebrow">Si algo se ve diferente</p>
        <h2>Ayudas rápidas</h2>
      </div>
      <div class="support-grid">
        {supportItems.map((item) => (
          <article class="support-card">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
      <div class="mt-10 flex flex-wrap gap-3">
        <a href={`${campusPath}#misioneros`} class="tutorial-action bg-[#001B3A] text-white">
          Empezar en Campus
        </a>
        <a href={`https://wa.me/?text=${whatsappText}`} target="_blank" rel="noopener noreferrer" class="tutorial-action border border-[#001B3A]/20 bg-[#F3F0E6] text-[#001B3A]">
          Compartir por WhatsApp
        </a>
      </div>
    </div>
  </section>

  <script>
    if (window.location.hash === '#qr-cumbre') {
      history.replaceState(null, '', window.location.pathname + window.location.search);
    }

    const getHeaderOffset = () => {
      const header = document.querySelector('header');
      return header ? header.getBoundingClientRect().height + 18 : 18;
    };

    const moveToSection = (hash, behavior = 'smooth') => {
      if (!hash || hash === '#') return;
      const target = document.querySelector(hash);
      if (!target) {
        if (hash === '#qr-cumbre') {
          history.replaceState(null, '', window.location.pathname + window.location.search);
        }
        return;
      }
      const root = document.scrollingElement || document.documentElement;
      const top = target.getBoundingClientRect().top + window.scrollY - getHeaderOffset();

      if (typeof root.scrollTo === 'function') {
        root.scrollTo({ top, behavior });
      } else {
        root.scrollTop = top;
      }
    };

    document.addEventListener('click', (event) => {
      const link = event.target instanceof Element ? event.target.closest('a[href^="#"]') : null;
      const hash = link?.getAttribute('href');
      if (!hash) return;

      event.preventDefault();
      history.pushState(null, '', hash);
      moveToSection(hash);
    });

    const settleHash = () => {
      if (!window.location.hash) return;
      [0, 250, 900, 1800].forEach((delay) => {
        window.setTimeout(() => {
          requestAnimationFrame(() => moveToSection(window.location.hash, 'auto'));
        }, delay);
      });
    };

    settleHash();
    window.addEventListener('load', settleHash);
  </script>
</BaseLayout>

<style>
  .border-organic,
  .tutorial-action,
  .preflight-item,
  .tutorial-card,
  .tutorial-shot-frame,
  .support-card,
  .script-line {
    border-radius: 255px 15px 225px 15px / 15px 225px 15px 255px;
  }

  .tutorial-action {
    align-items: center;
    display: inline-flex;
    font-family: 'Intro', sans-serif;
    font-size: 0.78rem;
    font-weight: 900;
    justify-content: center;
    letter-spacing: 0.12em;
    min-height: 3.15rem;
    padding: 0.9rem 1.25rem;
    text-transform: uppercase;
    transition: transform 0.2s ease, background-color 0.2s ease, color 0.2s ease;
  }

  .tutorial-action:hover {
    transform: translateY(-2px);
  }

  .tutorial-hero-copy h1,
  .tutorial-hero-copy p,
  .tutorial-hero-copy span {
    text-shadow: 0 4px 22px rgba(0, 9, 28, 0.68);
  }

  .preflight-item {
    align-items: center;
    background: #fff;
    border: 2px solid rgba(0, 27, 58, 0.12);
    color: #001B3A;
    display: flex;
    font-family: 'Intro', sans-serif;
    font-size: 0.88rem;
    font-weight: 900;
    gap: 0.8rem;
    min-height: 4rem;
    padding: 0.9rem 1rem;
  }

  .preflight-check {
    align-items: center;
    background: #2DD4BF;
    border: 2px solid #001B3A;
    border-radius: 999px;
    display: inline-flex;
    flex: 0 0 auto;
    height: 1.85rem;
    justify-content: center;
    width: 1.85rem;
  }

  .tutorial-section-heading {
    color: #001B3A;
    margin: 0 auto 2.5rem;
    max-width: 52rem;
  }

  .tutorial-section-heading h2 {
    font-family: 'Intro', sans-serif;
    font-size: 2.25rem;
    font-weight: 900;
    line-height: 1.05;
    text-transform: uppercase;
  }

  .tutorial-section-heading p:last-child {
    color: rgba(0, 27, 58, 0.72);
    font-family: 'Intro', sans-serif;
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.75;
    margin-top: 1rem;
  }

  .tutorial-section-heading--dark {
    color: #fff;
  }

  .tutorial-section-heading--dark p:last-child {
    color: rgba(255, 255, 255, 0.78);
  }

  .section-eyebrow {
    color: #2DD4BF;
    font-family: 'Intro', sans-serif;
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.16em;
    margin-bottom: 0.9rem;
    text-transform: uppercase;
  }

  .section-eyebrow--teal {
    color: #FACC15;
  }

  .multi-tutorial-section {
    background:
      radial-gradient(circle at top right, rgba(45, 212, 191, 0.18), transparent 34rem),
      linear-gradient(180deg, #001B3A 0%, #000F25 100%);
  }

  .multi-tutorial-section .tutorial-section-heading h2 {
    color: #fff;
    text-shadow: 0 3px 18px rgba(0, 0, 0, 0.35);
  }

  .multi-tutorial-section .tutorial-section-heading p:last-child {
    color: rgba(255, 255, 255, 0.86);
  }

  .tutorial-steps {
    display: grid;
    gap: 1.3rem;
  }

  .tutorial-card {
    align-items: stretch;
    background: #F3F0E6;
    border: 2px solid #001B3A;
    box-shadow: 7px 7px 0 #2DD4BF;
    display: grid;
    gap: 1rem;
    overflow: hidden;
    padding: 1rem;
  }

  .tutorial-card--dark {
    background: rgba(243, 240, 230, 0.96);
    box-shadow: 7px 7px 0 #FACC15;
  }

  .tutorial-copy {
    color: #001B3A;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 0.5rem;
  }

  .step-badge {
    align-self: flex-start;
    background: #001B3A;
    color: #fff;
    font-family: 'Intro', sans-serif;
    font-size: 0.68rem;
    font-weight: 900;
    letter-spacing: 0.14em;
    padding: 0.48rem 0.62rem;
    text-transform: uppercase;
  }

  .step-badge--yellow {
    background: #FACC15;
    color: #001B3A;
  }

  .tutorial-copy h3 {
    font-family: 'Intro', sans-serif;
    font-size: 1.5rem;
    font-weight: 900;
    line-height: 1.1;
    margin-top: 1rem;
    text-transform: uppercase;
  }

  .tutorial-copy p {
    color: rgba(0, 27, 58, 0.74);
    font-family: 'Intro', sans-serif;
    font-size: 0.98rem;
    font-weight: 400;
    line-height: 1.7;
    margin-top: 0.9rem;
  }

  .tutorial-copy small {
    color: rgba(0, 27, 58, 0.55);
    display: block;
    font-family: 'Intro', sans-serif;
    font-size: 0.74rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    line-height: 1.5;
    margin-top: 1rem;
    text-transform: uppercase;
  }

  .tutorial-shot-frame {
    align-items: center;
    background: #001B3A;
    border: 2px solid #001B3A;
    display: flex;
    justify-content: center;
    margin: 0;
    overflow: hidden;
