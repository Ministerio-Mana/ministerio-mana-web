
---
import BaseLayout from '@layouts/BaseLayout.astro';
import DonationForm from '@components/campus/DonationForm.astro';
import { MISIONEROS } from '@data/misioneros';

const title = "Campus Maná | Socios de la Gran Comisión";
const description = "Únete a la misión en las universidades. Apoya a nuestros misioneros y se parte de la transformación.";
---

<BaseLayout {title} {description} hideHeader={false} hideFooter={false}>
  <!-- Local Maná Identity Fonts -->
  <style is:global>
    @font-face {
      font-family: 'Intro';
      src: url('/fonts/intro/Intro-Black.woff2') format('woff2');
      font-weight: 900;
      font-style: normal;
      font-display: swap;
    }
    @font-face {
      font-family: 'Intro';
      src: url('/fonts/intro/Intro-Regular.woff2') format('woff2');
      font-weight: 400;
      font-style: normal;
      font-display: swap;
    }
    @font-face {
      font-family: 'Summer Loving';
      src: url('/fonts/SUMMER%20FONT/Summer%20Loving%20Regular.otf') format('opentype');
      font-weight: 400;
      font-style: normal;
      font-display: swap;
    }
    
    .font-intro { font-family: 'Intro', sans-serif; font-weight: 900; }
    .font-intro-reg { font-family: 'Intro', sans-serif; font-weight: 400; }
    .font-summer { font-family: 'Summer Loving', cursive; }
    
    /* Scribble Button — the user-approved style from ESCRÍBENOS */
    .btn-scribble {
        position: relative;
        z-index: 10;
        transition: transform 0.2s, background-color 0.3s, color 0.3s;
    }
    .btn-scribble::before {
        content: '';
        position: absolute;
        inset: -6px;
        border: 2.5px solid currentColor;
        border-radius: 255px 15px 225px 15px / 15px 225px 15px 255px;
        z-index: -1;
        opacity: 0.6;
        transition: all 0.4s ease;
    }
    .btn-scribble:hover::before {
        border-radius: 15px 255px 15px 255px / 255px 15px 255px 15px;
        transform: scale(1.06);
        opacity: 1;
    }
    .btn-scribble:hover {
        transform: scale(1.02);
    }

    /* Glow Effect for hoverable cards/elements */
    .glow-hover {
        transition: box-shadow 0.4s ease;
    }
    .glow-hover:hover {
        box-shadow: 0 0 40px rgba(45, 212, 191, 0.35), 0 0 80px rgba(45, 212, 191, 0.15);
    }

    /* Organic selector */
    .select-organic {
        border-radius: 255px 15px 225px 15px / 15px 225px 15px 255px;
        border: 2px solid #001B3A;
        background: transparent;
        transition: border-color 0.3s;
    }
    .select-organic:focus, .select-organic:hover {
        border-color: #2DD4BF;
    }
  </style>

  <!-- RoughNotation for hand-drawn scribble effects -->
  <script src="https://unpkg.com/rough-notation/lib/rough-notation.iife.js"></script>

  <!-- Scripts -->
  <script src="../../scripts/campus-donation.js"></script>

  <!-- Hero Section -->
  <section class="relative min-h-[92vh] flex items-center justify-center overflow-hidden bg-[#001B3A]">
    <!-- Paper Texture Background -->
    <div class="absolute inset-0 opacity-5 bg-[url('https://www.transparenttextures.com/patterns/notebook.png')]"></div>

    <!-- Content -->
    <div class="container-tight relative z-10 text-center px-4">
      
      <div class="relative inline-block mb-6">
          <!-- Summer Loving as COMPANION, almost same size as Intro title -->
          <span class="font-summer text-brand-teal text-7xl md:text-8xl block mb-[-4px] transform -rotate-2">Campus</span>
          <h1 class="text-8xl md:text-[10rem] font-intro text-white leading-none tracking-tighter uppercase relative z-10">
            MANÁ
          </h1>
      </div>

      <p class="text-xl md:text-2xl text-white/90 font-intro-reg max-w-2xl mx-auto mb-12 leading-relaxed">
        Levantando una generación <span id="hero-apasionada" class="font-intro text-white">apasionada</span> por Jesús en las universidades.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-8 justify-center items-center">
        <a href="#misioneros" class="btn-scribble px-10 py-4 bg-brand-teal text-[#001B3A] font-intro text-xl uppercase tracking-wider hover:bg-white hover:text-[#001B3A]">
          APOYAR AHORA
        </a>
        <a href="#vision" class="btn-scribble px-8 py-3 bg-transparent text-white font-intro text-lg uppercase tracking-wide hover:text-brand-teal">
          VER VIDEO
        </a>
      </div>
    </div>
  </section>

  <!-- Vision Section (Cream/Organic) -->
  <section id="vision" class="py-24 bg-[#F3F0E6] relative overflow-hidden">
    <div class="container-tight px-4 relative z-10">
        <div class="grid md:grid-cols-2 gap-16 items-center">
            <div class="relative group">
                <!-- Organic Image Container with GLOW on hover -->
                <div class="aspect-video relative z-10 overflow-hidden glow-hover" 
                     style="border-radius: 2% 98% 2% 98% / 98% 2% 98% 2%; box-shadow: 15px 15px 0px #001B3A;">
                     <div class="absolute inset-0 bg-gradient-to-tr from-[#001B3A]/40 to-transparent z-10"></div>
                     <div class="w-full h-full bg-[#001B3A] flex items-center justify-center">
                         <span class="font-intro text-white/20 text-6xl">VIDEO</span>
                     </div>
                     
                     <!-- Play Button (Organic/Hand-drawn) -->
                     <div class="absolute inset-0 flex items-center justify-center cursor-pointer z-20">
                        <div class="w-20 h-20 border-4 border-white flex items-center justify-center transition-transform group-hover:scale-110" style="border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%;">
                            <svg class="w-8 h-8 text-white ml-2 fill-current" viewBox="0 0 20 20"><path d="M6 4l10 6-10 6V4z"/></svg>
                        </div>
                     </div>
                </div>

                <!-- Organic Quote (NOT rectangular — blob shape) -->
                <div class="absolute -bottom-8 -right-4 bg-yellow-400 p-5 shadow-lg max-w-[280px] transform rotate-2 z-20"
                     style="border-radius: 30% 70% 70% 30% / 60% 40% 60% 40%;">
                    <p class="font-intro-reg text-[#001B3A] text-base leading-snug">
                        "La universidad es el campo misionero más <span id="quote-estrategico" class="font-intro">estratégico</span> del mundo."
                    </p>
                </div>
            </div>
            
            <div class="text-[#001B3A]">
                <div class="mb-8">
                    <!-- Nuestra: Summer Loving BIGGER and more separated -->
                    <span class="font-summer text-brand-teal text-7xl block transform -rotate-3 mb-2 ml-2">Nuestra</span>
                    <h2 class="text-7xl md:text-8xl font-intro uppercase leading-none relative inline-block">
                        MISIÓN
                    </h2>
                </div>

                <h3 class="text-3xl font-intro mb-6 leading-tight">
                    LLEVANDO EL EVANGELIO <br>
                    <span class="relative inline-block mt-2">
                        A LA ACADEMIA
                        <svg class="absolute -inset-2 w-[110%] h-[120%] -z-10 text-yellow-400/50" viewBox="0 0 100 100" preserveAspectRatio="none">
                             <path d="M0,20 Q50,0 100,20 L100,80 Q50,100 0,80 Z" fill="currentColor" />
                        </svg>
                    </span>
                </h3>
                
                <p class="text-lg mb-8 leading-relaxed font-intro-reg">
                    Es allí donde se forman los <span id="vision-lideres" class="font-intro">líderes</span> del mañana. Queremos impactar su entorno cercano y el <span id="vision-mundo" class="font-intro">mundo</span> a través del discipulado y la comunidad.
                </p>
                
                <div class="space-y-6">
                    <div class="flex items-start gap-4 group">
                        <!-- Scribble circle icon -->
                        <div class="w-12 h-12 flex items-center justify-center text-brand-teal shrink-0 relative">
                             <svg class="absolute inset-0 w-full h-full" viewBox="0 0 50 50">
                                 <ellipse cx="25" cy="25" rx="22" ry="20" fill="none" stroke="currentColor" stroke-width="2" style="transform: rotate(-5deg); transform-origin: center;" class="group-hover:stroke-[3]" transition="stroke-width 0.3s"/>
                             </svg>
                             <svg class="w-5 h-5 relative z-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
                        </div>
                        <div>
                            <h3 class="font-intro text-xl uppercase">Discipulado Personal</h3>
                            <p class="text-gray-600 font-intro-reg">Acompañamiento uno a uno para crecer en la fe.</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-4 group">
                        <div class="w-12 h-12 flex items-center justify-center text-brand-teal shrink-0 relative">
                             <svg class="absolute inset-0 w-full h-full" viewBox="0 0 50 50">
                                 <ellipse cx="25" cy="25" rx="22" ry="20" fill="none" stroke="currentColor" stroke-width="2" style="transform: rotate(3deg); transform-origin: center;" class="group-hover:stroke-[3]" transition="stroke-width 0.3s"/>
                             </svg>
                             <svg class="w-5 h-5 relative z-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
                        </div>
                        <div>
                            <h3 class="font-intro text-xl uppercase">Comunidad</h3>
                            <p class="text-gray-600 font-intro-reg">Grupos de crecimiento en la universidad.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
  </section>

  <!-- Missionaries Section -->
  <section id="misioneros" class="py-24 bg-[#001B3A] relative">
      <!-- Grid Paper Pattern -->
      <div class="absolute inset-0 opacity-5" style="background-image: radial-gradient(#fff 1px, transparent 1px); background-size: 20px 20px;"></div>

    <div class="container-tight px-4 relative z-10">
      <div class="text-center mb-24">
        <!-- "Nuestro" almost same size as "EQUIPO" (singular!) -->
        <span class="font-summer text-brand-teal text-7xl md:text-8xl block mb-[-4px] transform -rotate-2">Nuestro</span>
        <h2 class="text-7xl md:text-9xl font-intro text-white uppercase inline-block">
          EQUIPO
        </h2>
      </div>

      <div class="grid md:grid-cols-2 gap-12 lg:gap-20">
        {MISIONEROS.map((m) => (
          <article class="relative group">
            <!-- Organic Card Background with GLOW on hover -->
            <div class="absolute inset-0 bg-[#F3F0E6] transform rotate-1 group-hover:rotate-0 transition-transform duration-300 rounded-3xl" style="box-shadow: 10px 10px 0px #2DD4BF;"></div>
            
            <div class="relative z-10 bg-white overflow-hidden p-2 h-full flex flex-col glow-hover" style="border-radius: 255px 15px 225px 15px / 15px 225px 15px 255px; border: 2px solid #001B3A;">
                <!-- Video/Image Header -->
                <div class="relative h-72 bg-[#001B3A] overflow-hidden" style="border-radius: 200px 10px 180px 10px / 10px 180px 10px 200px;">
                    <iframe src={m.video} class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500"></iframe>
                    
                    <!-- Sticker Name Tag (organic shape) -->
                    <div class="absolute -bottom-4 -left-2 bg-yellow-400 px-6 py-2 transform -rotate-2 shadow-md z-20" style="border-radius: 255px 15px 225px 15px / 15px 225px 15px 255px; border: 2px solid #001B3A;">
                        <h3 class="font-intro text-[#001B3A] text-2xl uppercase">{m.nombre}</h3>
                    </div>
                </div>

                <div class="p-6 pt-10 flex-1 flex flex-col">
                     <div class="mb-6">
                        <span class="font-intro text-brand-teal text-sm uppercase tracking-widest bg-brand-teal/10 px-3 py-1 rounded-full">{m.rol || "Misionero Campus"}</span>
                     </div>

                    <p class="text-gray-600 mb-8 flex-1 font-intro-reg text-lg leading-relaxed">
                        "Tu apoyo me permite seguir predicando el evangelio en el campus."
                    </p>
                    
                    <!-- Donation Widget -->
                    <DonationForm 
                        missionaryName={m.nombre.split(' ')[0]}
                        wompiLink={m.wompiLink}
                        stripePriceId={m.stripePriceId}
                        slug={m.slug}
                    />
                </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA General -->
  <section class="py-24 bg-brand-teal relative overflow-hidden">
     <div class="container-tight px-4 text-center relative z-10">
        <!-- Summer Loving as companion: BIGGER, almost same size -->
        <span class="font-summer text-white text-7xl md:text-8xl block mb-2 transform -rotate-2">¿Te unes</span>
        <h2 class="text-6xl md:text-8xl font-intro text-[#001B3A] mb-12 uppercase">
            AL EQUIPO?
        </h2>
        <a href="https://wa.me/573000000000" target="_blank" class="btn-scribble inline-block px-12 py-5 bg-[#001B3A] text-white font-intro text-2xl uppercase hover:bg-white hover:text-[#001B3A] shadow-2xl">
            ESCRÍBENOS
        </a>
     </div>
  </section>

  <!-- RoughNotation Initialization Script -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      if (typeof RoughNotation === 'undefined') return;
      
      const { annotate } = RoughNotation;
      
      // Hero: Circle around "apasionada"
      const apasionada = document.getElementById('hero-apasionada');
      if (apasionada) {
        const a = annotate(apasionada, { type: 'circle', color: '#2DD4BF', strokeWidth: 2, padding: 8, animationDuration: 1200 });
        // Animate on scroll into view
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) { a.show(); observer.unobserve(entry.target); }
          });
        }, { threshold: 0.5 });
        observer.observe(apasionada);
      }

      // Quote: underline "estratégico"
      const estrategico = document.getElementById('quote-estrategico');
      if (estrategico) {
        const a = annotate(estrategico, { type: 'underline', color: '#001B3A', strokeWidth: 2, animationDuration: 800 });
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) { a.show(); observer.unobserve(entry.target); }
          });
        }, { threshold: 0.5 });
        observer.observe(estrategico);
      }

      // Vision: circle around "líderes"
      const lideres = document.getElementById('vision-lideres');
      if (lideres) {
        const a = annotate(lideres, { type: 'circle', color: '#2DD4BF', strokeWidth: 2, padding: 5, animationDuration: 1000 });
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) { a.show(); observer.unobserve(entry.target); }
          });
        }, { threshold: 0.5 });
        observer.observe(lideres);
      }

      // Vision: underline "mundo"
      const mundo = document.getElementById('vision-mundo');
      if (mundo) {
        const a = annotate(mundo, { type: 'underline', color: '#2DD4BF', strokeWidth: 3, animationDuration: 800 });
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) { a.show(); observer.unobserve(entry.target); }
          });
        }, { threshold: 0.5 });
        observer.observe(mundo);
      }
    });
  </script>
</BaseLayout>
