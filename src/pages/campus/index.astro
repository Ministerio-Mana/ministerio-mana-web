
---
import BaseLayout from '@layouts/BaseLayout.astro';
import DonationForm from '@components/campus/DonationForm.astro';
import { MISIONEROS } from '@data/misioneros';

const title = "Campus Maná | Socios de la Gran Comisión";
const description = "Únete a la misión en las universidades. Apoya a nuestros misioneros y se parte de la transformación.";
---

<BaseLayout {title} {description} hideHeader={false} hideFooter={false}>
  <!-- Local Maná Identity Fonts -->
  <style is:global>
    @font-face {
      font-family: 'Intro';
      src: url('/fonts/intro/Intro-Black.woff2') format('woff2');
      font-weight: 900;
      font-style: normal;
      font-display: swap;
    }
    @font-face {
      font-family: 'Intro';
      src: url('/fonts/intro/Intro-Regular.woff2') format('woff2');
      font-weight: 400;
      font-style: normal;
      font-display: swap;
    }
    @font-face {
      font-family: 'Summer Loving';
      src: url('/fonts/SUMMER%20FONT/Summer%20Loving%20Regular.otf') format('opentype');
      font-weight: 400;
      font-style: normal;
      font-display: swap;
    }
    
    .font-intro { font-family: 'Intro', sans-serif; font-weight: 900; }
    .font-intro-reg { font-family: 'Intro', sans-serif; font-weight: 400; }
    .font-summer { font-family: 'Summer Loving', cursive; }
    
    /* Hand-drawn Button Style */
    .btn-hand {
        position: relative;
        z-index: 10;
        transition: transform 0.2s;
    }
    .btn-hand::before {
        content: '';
        position: absolute;
        inset: -4px;
        border: 2px solid currentColor;
        border-radius: 255px 15px 225px 15px / 15px 225px 15px 255px;
        z-index: -1;
        transition: all 0.3s ease;
    }
    .btn-hand:hover::before {
        border-radius: 25px 155px 25px 155px / 155px 25px 155px 25px;
        transform: scale(1.05);
    }

    /* Hand-drawn Underline */
    .underline-hand {
        position: relative;
        display: inline-block;
    }
    .underline-hand::after {
        content: '';
        position: absolute;
        bottom: -5px;
        left: 0;
        width: 100%;
        height: 8px;
        background-image: url("data:image/svg+xml,%3Csvg width='100' height='10' viewBox='0 0 100 10' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M2 5C20 8 40 2 98 5' stroke='%232DD4BF' stroke-width='3' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
        background-repeat: no-repeat;
        background-size: 100% 100%;
        pointer-events: none;
    }

    /* Organic Container */
    .box-organic {
        border-radius: 255px 15px 225px 15px / 15px 225px 15px 255px;
        border: 2px solid #001B3A;
    }
  </style>

  <!-- Scripts -->
  <script src="../../scripts/campus-donation.js"></script>

  <!-- Hero Section -->
  <section class="relative min-h-[92vh] flex items-center justify-center overflow-hidden bg-[#001B3A]">
    <!-- Paper Texture Background -->
    <div class="absolute inset-0 opacity-5 bg-[url('https://www.transparenttextures.com/patterns/notebook.png')]"></div>
    
    <!-- Hand-drawn Circles Bg -->
    <svg class="absolute top-10 right-10 w-64 h-64 text-brand-teal/10 animate-pulse-slow" viewBox="0 0 200 200">
        <path d="M40,100 Q100,20 160,100 T40,100" stroke="currentColor" stroke-width="2" fill="none" class="hand-path"/>
    </svg>

    <!-- Content -->
    <div class="container-tight relative z-10 text-center px-4">
      
      <div class="mb-4 inline-block relative group">
        <span class="font-intro text-brand-teal text-xl tracking-widest uppercase relative z-10 px-4">Ministerio Maná</span>
        <!-- Hand-drawn Border around tag -->
        <svg class="absolute inset-0 w-full h-full -z-10 text-brand-teal pointer-events-none" viewBox="0 0 300 60" preserveAspectRatio="none">
             <path d="M5,30 Q150,5 295,30 Q150,55 5,30" stroke="currentColor" stroke-width="2" fill="none" class="group-hover:stroke-[3px] transition-all"/>
        </svg>
      </div>
      
      <div class="relative inline-block mb-10">
          <h1 class="text-7xl md:text-9xl font-intro text-white leading-none tracking-tighter uppercase relative z-10">
            CAMPUS <br />
            <span class="text-brand-teal">MANÁ</span>
          </h1>
          
          <!-- Hand-drawn Arrow pointing to Maná -->
          <svg class="absolute -right-20 bottom-10 w-24 h-24 text-yellow-400 hidden md:block transform rotate-12" viewBox="0 0 100 100">
              <path d="M10,10 Q50,50 90,90 M80,90 L90,90 L90,80" stroke="currentColor" stroke-width="4" fill="none" stroke-linecap="round" />
          </svg>
      </div>

      <p class="text-xl md:text-2xl text-white/90 font-intro-reg max-w-2xl mx-auto mb-12 leading-relaxed">
        Levantando una generación <span class="underline-hand font-intro text-white">apasionada</span> <span class="font-summer text-yellow-400 text-3xl mx-2">por</span> Jesús en las universidades.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-8 justify-center items-center">
        <a href="#misioneros" class="btn-hand px-10 py-4 bg-brand-teal text-[#001B3A] font-intro text-xl uppercase tracking-wider hover:bg-white hover:text-[#001B3A]">
          APOYAR AHORA
        </a>
        <a href="#vision" class="group flex items-center gap-3 font-intro text-white text-lg hover:text-brand-teal transition-colors tracking-wide">
          <span class="relative">
             VER VIDEO
             <svg class="absolute -bottom-1 left-0 w-full h-2 text-brand-teal scale-x-0 group-hover:scale-x-100 transition-transform origin-left" viewBox="0 0 100 10" preserveAspectRatio="none">
                 <path d="M0,5 Q50,10 100,5" stroke="currentColor" stroke-width="3" fill="none" />
             </svg>
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- Vision Section (Cream/Organic) -->
  <section id="vision" class="py-24 bg-[#F3F0E6] relative overflow-hidden">
    <div class="container-tight px-4 relative z-10">
        <div class="grid md:grid-cols-2 gap-16 items-center">
            <div class="relative group">
                <!-- Organic Image Container -->
                <div class="aspect-video relative z-10 overflow-hidden" 
                     style="border-radius: 2% 98% 2% 98% / 98% 2% 98% 2%; box-shadow: 15px 15px 0px #001B3A;">
                     <div class="absolute inset-0 bg-gradient-to-tr from-[#001B3A]/40 to-transparent z-10"></div>
                     <!-- Placeholder for actual video thumbnail if available, using strict color block for now -->
                     <div class="w-full h-full bg-[#001B3A] flex items-center justify-center">
                         <span class="font-intro text-white/20 text-6xl">VIDEO</span>
                     </div>
                     
                     <!-- Play Button (Hand-drawn) -->
                     <div class="absolute inset-0 flex items-center justify-center cursor-pointer">
                        <div class="w-20 h-20 border-4 border-white rounded-full flex items-center justify-center transition-transform group-hover:scale-110" style="border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%;">
                            <svg class="w-8 h-8 text-white ml-2 fill-current" viewBox="0 0 20 20"><path d="M6 4l10 6-10 6V4z"/></svg>
                        </div>
                     </div>
                </div>

                <!-- Sticky Note Quote -->
                <div class="absolute -bottom-10 -right-4 bg-yellow-400 p-6 shadow-lg max-w-xs transform rotate-2 z-20"
                     style="clip-path: polygon(0% 0%, 100% 0%, 100% 90%, 95% 100%, 0% 100%);">
                     <div class="absolute -top-3 left-1/2 -translate-x-1/2 w-8 h-4 bg-yellow-600/20 opacity-50 blur-sm"></div> <!-- Tape effect -->
                    <p class="font-intro-reg text-[#001B3A] text-lg leading-tight">
                        "La universidad es el campo misionero más estratégico <br> 
                        <span class="font-summer text-[#001B3A] text-2xl block text-right mt-2">- del mundo.</span>"
                    </p>
                </div>
            </div>
            
            <div class="text-[#001B3A]">
                <div class="mb-4 relative">
                    <span class="font-summer text-brand-teal text-5xl absolute -top-8 left-0 transform -rotate-12">Nuestra</span>
                    <h2 class="text-6xl md:text-8xl font-intro uppercase leading-none mt-4 relative inline-block">
                        MISIÓN
                        <!-- Underline scribble -->
                        <svg class="absolute -bottom-2 left-0 w-full h-4 text-brand-teal" viewBox="0 0 200 10" preserveAspectRatio="none">
                            <path d="M0,5 Q50,10 100,5 T200,5" stroke="currentColor" stroke-width="4" fill="none" stroke-linecap="round" />
                        </svg>
                    </h2>
                </div>

                <h3 class="text-3xl font-intro mb-6 leading-tight">
                    LLEVANDO EL EVANGELIO <br>
                    <span class="relative inline-block mt-2">
                        A LA ACADEMIA
                        <svg class="absolute -inset-2 w-[110%] h-[120%] -z-10 text-yellow-400/50" viewBox="0 0 100 100" preserveAspectRatio="none">
                             <path d="M0,20 Q50,0 100,20 L100,80 Q50,100 0,80 Z" fill="currentColor" />
                        </svg>
                    </span>
                </h3>
                
                <p class="text-lg mb-8 leading-relaxed font-intro-reg">
                    Es allí donde se forman los líderes <span class="font-summer text-brand-teal text-2xl px-1">del</span> mañana. Queremos impactar su entorno cercano <span class="font-summer text-brand-teal text-2xl px-1">y</span> el mundo a través del discipulado y la comunidad.
                </p>
                
                <div class="space-y-6">
                    <div class="flex items-start gap-4">
                        <div class="mt-1">
                             <svg class="w-8 h-8 text-brand-teal" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M12 16v-4"></path><path d="M12 8h.01"></path></svg>
                        </div>
                        <div>
                            <h3 class="font-intro text-xl uppercase underline decoration-wavy decoration-brand-teal decoration-2">Discipulado Personal</h3>
                            <p class="text-gray-600 font-intro-reg">Acompañamiento uno a uno para crecer en la fe.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
  </section>

  <!-- Missionaries Section -->
  <section id="misioneros" class="py-24 bg-[#001B3A] relative">
      <!-- Grid Paper Pattern -->
      <div class="absolute inset-0 opacity-5" style="background-image: radial-gradient(#fff 1px, transparent 1px); background-size: 20px 20px;"></div>

    <div class="container-tight px-4 relative z-10">
      <div class="text-center mb-24">
        <h2 class="text-5xl md:text-8xl font-intro text-white uppercase relative inline-block">
          <span class="font-summer text-brand-teal text-5xl absolute -top-8 -left-4 transform -rotate-12">Nuestros</span>
          EQUIPOS
          <svg class="absolute -bottom-4 right-0 w-32 h-4 text-brand-teal" viewBox="0 0 100 10" preserveAspectRatio="none">
             <path d="M0,5 Q50,0 100,5" stroke="currentColor" stroke-width="5" fill="none" stroke-linecap="round"/>
          </svg>
        </h2>
      </div>

      <div class="grid md:grid-cols-2 gap-12 lg:gap-20">
        {MISIONEROS.map((m) => (
          <article class="relative group">
            <!-- Organic Card Bg -->
            <div class="absolute inset-0 bg-[#F3F0E6] transform rotate-1 group-hover:rotate-0 transition-transform duration-300 rounded-3xl" style="box-shadow: 10px 10px 0px #2DD4BF;"></div>
            
            <div class="relative z-10 bg-white rounded-2xl overflow-hidden border-2 border-[#001B3A] p-2 h-full flex flex-col">
                <!-- Video/Image Header -->
                <div class="relative h-72 bg-[#001B3A] overflow-hidden rounded-xl border border-[#001B3A]/10">
                    <iframe src={m.video} class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500"></iframe>
                    
                    <!-- Sticker Name Tag -->
                    <div class="absolute -bottom-4 -left-2 bg-yellow-400 px-6 py-2 transform -rotate-2 border-2 border-[#001B3A] shadow-md z-20">
                        <h3 class="font-intro text-[#001B3A] text-2xl uppercase">{m.nombre}</h3>
                    </div>
                </div>

                <div class="p-6 pt-10 flex-1 flex flex-col">
                     <div class="flex justify-between items-start mb-6">
                        <span class="font-intro text-brand-teal text-sm uppercase tracking-widest bg-brand-teal/10 px-3 py-1 rounded-full">{m.rol || "Misionero"}</span>
                        <!-- Hand-drawn Arrow -->
                        <svg class="w-10 h-10 text-[#001B3A] transform rotate-90" viewBox="0 0 50 50"><path d="M5,25 Q25,5 45,25 M35,25 L45,25 L45,15" fill="none" stroke="currentColor" stroke-width="2" /></svg>
                     </div>

                    <p class="text-gray-600 mb-8 flex-1 font-intro-reg text-lg leading-relaxed">
                        "Tu apoyo me permite seguir predicando el evangelio <span class="font-summer text-brand-teal text-xl px-1">en</span> el campus."
                    </p>
                    
                    <!-- Donation Widget -->
                    <DonationForm 
                        missionaryName={m.nombre.split(' ')[0]}
                        wompiLink={m.wompiLink}
                        stripePriceId={m.stripePriceId}
                        slug={m.slug}
                    />
                </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA General -->
  <section class="py-24 bg-brand-teal relative overflow-hidden">
     <div class="container-tight px-4 text-center relative z-10">
        <h2 class="text-5xl md:text-7xl font-intro text-[#001B3A] mb-12 uppercase">
            ¿TE UNES <br> 
            <span class="font-summer text-white text-6xl lowercase relative top-[-10px] inline-block transform rotate-[-5deg]">al</span> 
            EQUIPO?
        </h2>
        <a href="https://wa.me/573000000000" target="_blank" class="btn-hand inline-block px-12 py-5 bg-[#001B3A] text-white font-intro text-2xl uppercase hover:bg-white hover:text-[#001B3A] shadow-2xl">
            ESCRÍBENOS
        </a>
     </div>
  </section>
</BaseLayout></BaseLayout>
