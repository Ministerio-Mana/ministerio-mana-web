
---
import BaseLayout from '@layouts/BaseLayout.astro';
import DonationForm from '@components/campus/DonationForm.astro';
import MultiDonationFlow from '@components/campus/MultiDonationFlow.astro';
import { MISIONEROS } from '@data/misioneros';

const title = "Campus Maná | Socios de la Gran Comisión";
const description = "Únete a la misión en las universidades. Apoya a nuestros misioneros y se parte de la transformación.";

// Server-side geo detection (Vercel / Cloudflare headers)
const country = Astro.request.headers.get('x-vercel-ip-country') || 'CO';
const hasPlayableVideo = (url?: string) => Boolean(url && !url.includes('VIDEO_ID_'));
---

<BaseLayout {title} {description} hideHeader={false} hideFooter={false}>
  <!-- Local Maná Identity Fonts -->
  <style is:global>
    @font-face {
      font-family: 'Intro';
      src: url('/fonts/intro/Intro-Black.woff2') format('woff2');
      font-weight: 900;
      font-style: normal;
      font-display: swap;
    }
    @font-face {
      font-family: 'Intro';
      src: url('/fonts/intro/Intro-Regular.woff2') format('woff2');
      font-weight: 400;
      font-style: normal;
      font-display: swap;
    }
    @font-face {
      font-family: 'Summer Loving';
      src: url('/fonts/SUMMER%20FONT/Summer%20Loving%20Regular.otf') format('opentype');
      font-weight: 400;
      font-style: normal;
      font-display: swap;
    }
    
    .font-intro { font-family: 'Intro', sans-serif; font-weight: 900; }
    .font-intro-reg { font-family: 'Intro', sans-serif; font-weight: 400; }
    .font-summer { font-family: 'Summer Loving', cursive; }
    
    /* Scribble Button — animated hand-drawn border */
    .btn-scribble {
        position: relative;
        z-index: 10;
        display: inline-block;
        transition: transform 0.2s, background-color 0.3s, color 0.3s;
    }
    .btn-scribble::before {
        content: '';
        position: absolute;
        inset: -6px;
        border: 2.5px solid currentColor;
        border-radius: 255px 15px 225px 15px / 15px 225px 15px 255px;
        z-index: -1;
        opacity: 0.7;
        transition: all 0.4s ease;
    }
    .btn-scribble:hover::before {
        border-radius: 15px 255px 15px 255px / 255px 15px 255px 15px;
        transform: scale(1.06);
        opacity: 1;
    }
    .btn-scribble:hover {
        transform: scale(1.02);
    }

    /* Glow Effect for hoverable elements */
    .glow-hover {
        transition: box-shadow 0.4s ease;
    }
    .glow-hover:hover {
        box-shadow: 0 0 40px rgba(45, 212, 191, 0.35), 0 0 80px rgba(45, 212, 191, 0.15);
    }

    /* Organic container border */
    .border-organic {
        border-radius: 255px 15px 225px 15px / 15px 225px 15px 255px;
    }
  </style>

  <!-- Scripts -->
  <script src="../../scripts/campus-donation.js"></script>

  <!-- ===== HERO SECTION ===== -->
  <section class="relative min-h-[92vh] flex items-center justify-center overflow-hidden bg-[#001B3A]">
    <div class="absolute inset-0 opacity-5 bg-[url('https://www.transparenttextures.com/patterns/notebook.png')]"></div>

    <div class="container-tight relative z-10 text-center px-4">
      
      <div class="relative inline-block mb-6">
          <!-- "Campus" in Summer Loving — SAME visual weight as "MANÁ" -->
          <span class="font-summer text-brand-teal block mb-[-20px] transform -rotate-2" style="font-size: clamp(8rem, 14vw, 12rem);">Campus</span>
          <h1 class="font-intro text-white leading-none tracking-tighter uppercase relative z-10" style="font-size: clamp(6rem, 14vw, 12rem);">
            MANÁ
          </h1>
      </div>

      <p class="text-xl md:text-2xl text-white/90 font-intro-reg max-w-2xl mx-auto mb-12 leading-relaxed">
        Levantando una generación <span id="rn-apasionada" class="font-intro text-white relative z-10">apasionada</span> por Jesús en las universidades.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-8 justify-center items-center">
        <!-- Both buttons use EXACT same scribble style as ESCRÍBENOS -->
        <a href="#misioneros" class="btn-scribble px-10 py-4 bg-[#001B3A] text-white font-intro text-xl uppercase tracking-wider">
          APOYAR AHORA
        </a>
        <a href="#vision" class="btn-scribble px-8 py-3 bg-transparent text-white font-intro text-lg uppercase tracking-wide border-none">
          VER VIDEO
        </a>
      </div>
    </div>
  </section>

  <!-- ===== VISION SECTION (Cream) ===== -->
  <section id="vision" class="py-24 bg-[#F3F0E6] relative overflow-hidden">
    <div class="container-tight px-4 relative z-10">
        <div class="grid md:grid-cols-2 gap-16 items-center">
            <div class="relative group">
                <!-- Video Container with GLOW on hover -->
                <div class="aspect-video relative z-10 overflow-hidden glow-hover" 
                     style="border-radius: 2% 98% 2% 98% / 98% 2% 98% 2%; box-shadow: 15px 15px 0px #001B3A;">
                     <div class="absolute inset-0 bg-gradient-to-tr from-[#001B3A]/40 to-transparent z-10"></div>
                     <div class="w-full h-full bg-[#001B3A] flex items-center justify-center">
                         <span class="font-intro text-white/20 text-6xl">VIDEO</span>
                     </div>
                     
                     <!-- Organic Play Button -->
                     <div class="absolute inset-0 flex items-center justify-center cursor-pointer z-20">
                        <div class="w-20 h-20 border-4 border-white flex items-center justify-center transition-transform group-hover:scale-110" style="border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%;">
                            <svg class="w-8 h-8 text-white ml-2 fill-current" viewBox="0 0 20 20"><path d="M6 4l10 6-10 6V4z"/></svg>
                        </div>
                     </div>
                </div>

                <!-- Quote: organic scribble border (like the donation form containers, NOT blob) -->
                <div class="absolute -bottom-6 -right-4 bg-yellow-400 p-5 shadow-lg max-w-[280px] transform rotate-2 z-20 border-organic border-2 border-[#001B3A]">
                    <p class="font-intro-reg text-[#001B3A] text-base leading-snug">
                        "La universidad es el campo misionero más <span id="rn-estrategico" class="font-intro">estratégico</span> del mundo."
                    </p>
                </div>
            </div>
            
            <div class="text-[#001B3A]">
                <div class="mb-10">
                    <!-- "Nuestra" MUCH BIGGER, well separated from "MISIÓN" -->
                    <span class="font-summer text-brand-teal block transform -rotate-3 mb-[-10px] ml-2" style="font-size: clamp(6rem, 12vw, 10rem);">Nuestra</span>
                    <h2 class="font-intro uppercase leading-none relative inline-block" style="font-size: clamp(5rem, 10vw, 8rem);">
                        MISIÓN
                    </h2>
                </div>

                <h3 class="text-3xl font-intro mb-6 leading-tight">
                    LLEVANDO EL EVANGELIO <br>
                    <span class="relative inline-block mt-2">
                        A LA ACADEMIA
                        <svg class="absolute -inset-2 w-[110%] h-[120%] -z-10 text-yellow-400/50" viewBox="0 0 100 100" preserveAspectRatio="none">
                             <path d="M0,20 Q50,0 100,20 L100,80 Q50,100 0,80 Z" fill="currentColor" />
                        </svg>
                    </span>
                </h3>
                
                <p class="text-lg mb-8 leading-relaxed font-intro-reg">
                    Es allí donde se forman los <span id="rn-lideres" class="font-intro">líderes</span> del mañana. Queremos impactar su entorno cercano y el <span id="rn-mundo" class="font-intro">mundo</span> a través del discipulado y la comunidad.
                </p>
                
                <div class="space-y-6">
                    <div class="flex items-start gap-4 group">
                        <!-- Scribble circle icon (imperfect SVG) -->
                        <div class="w-12 h-12 flex items-center justify-center text-brand-teal shrink-0 relative">
                             <svg class="absolute inset-0 w-full h-full" viewBox="0 0 50 50" fill="none">
                                 <path d="M25,3 C35,2 47,10 48,22 C49,34 40,47 28,48 C16,49 3,40 2,27 C1,14 12,4 25,3Z" stroke="currentColor" stroke-width="2" fill="none" class="transition-all group-hover:stroke-[3px]"/>
                             </svg>
                             <svg class="w-5 h-5 relative z-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
                        </div>
                        <div>
                            <h3 class="font-intro text-xl uppercase">Discipulado Personal</h3>
                            <p class="text-gray-600 font-intro-reg">Acompañamiento uno a uno para crecer en la fe.</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-4 group">
                        <div class="w-12 h-12 flex items-center justify-center text-brand-teal shrink-0 relative">
                             <svg class="absolute inset-0 w-full h-full" viewBox="0 0 50 50" fill="none">
                                 <path d="M24,2 C36,1 48,12 49,25 C50,38 38,49 26,48 C14,47 2,37 3,24 C4,11 13,3 24,2Z" stroke="currentColor" stroke-width="2" fill="none" class="transition-all group-hover:stroke-[3px]"/>
                             </svg>
                             <svg class="w-5 h-5 relative z-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
                        </div>
                        <div>
                            <h3 class="font-intro text-xl uppercase">Comunidad</h3>
                            <p class="text-gray-600 font-intro-reg">Grupos de crecimiento en la universidad.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
  </section>

  <!-- ===== MISSIONARIES SECTION ===== -->
  <section id="misioneros" class="py-24 bg-[#001B3A] relative">
      <div class="absolute inset-0 opacity-5" style="background-image: radial-gradient(#fff 1px, transparent 1px); background-size: 20px 20px;"></div>

    <div class="container-tight px-4 relative z-10">
      <div class="text-center mb-24">
        <!-- "Nuestro" SAME visual weight as "EQUIPO" -->
        <span class="font-summer text-brand-teal block mb-[-16px] transform -rotate-2" style="font-size: clamp(7rem, 12vw, 10rem);">Nuestro</span>
        <h2 class="font-intro text-white uppercase inline-block" style="font-size: clamp(6rem, 12vw, 10rem);">
          EQUIPO
        </h2>
      </div>

      <!-- Flex grid: 3 cards first row, 2 centered on second row -->
      <div class="missionaries-grid flex flex-wrap justify-center gap-8 lg:gap-12">
        {MISIONEROS.map((m) => {
          const showVideo = hasPlayableVideo(m.video);
          return (
          <article class="relative group missionary-card w-full md:w-[calc(33.333%-2rem)] min-w-[280px]">
            <!-- Card Background with GLOW -->
            <div class="absolute inset-0 bg-[#F3F0E6] transform rotate-1 group-hover:rotate-0 transition-transform duration-300 rounded-3xl" style="box-shadow: 10px 10px 0px #2DD4BF;"></div>
            
            <div class="relative z-10 bg-white overflow-hidden p-2 h-full flex flex-col glow-hover border-organic border-2 border-[#001B3A]">
                <!-- Video/Image Header -->
                <div class="relative h-56 bg-[#001B3A] overflow-hidden border-organic">
                    {showVideo ? (
                      <iframe
                        src={m.video}
                        class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500"
                        title={m.nombre}
                        loading="lazy"
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                        allowFullScreen
                      ></iframe>
                    ) : m.foto ? (
                      <img
                        src={m.foto}
                        alt={m.nombre}
                        class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500"
                        loading="lazy"
                      />
                    ) : (
                      <div class="w-full h-full bg-[#001B3A] flex items-center justify-center">
                        <span class="font-intro text-white/30 text-lg uppercase">Campus Maná</span>
                      </div>
                    )}
                    
                    <!-- Name Tag (organic border) -->
                    <div class="absolute -bottom-4 -left-2 bg-yellow-400 px-5 py-2 transform -rotate-2 shadow-md z-20 border-organic border-2 border-[#001B3A]">
                        <h3 class="font-intro text-[#001B3A] text-lg md:text-xl uppercase">{m.nombre}</h3>
                    </div>
                </div>

                <div class="p-5 pt-8 flex-1 flex flex-col">
                     <div class="mb-4">
                        <span class="font-intro text-brand-teal text-xs uppercase tracking-widest bg-brand-teal/10 px-3 py-1 border-organic">{m.rol || "Misionero Campus"}</span>
                     </div>

                    <p class="text-gray-600 mb-6 flex-1 font-intro-reg text-base leading-relaxed">
                        "Tu apoyo me permite seguir predicando el evangelio en el campus."
                    </p>
                    
                    <DonationForm 
                        missionaryName={m.nombre.split(' ')[0]}
                        slug={m.slug}
                        country={country}
                    />
                </div>
            </div>
          </article>
        );
        })}
      </div>
    </div>
  </section>

  <!-- ===== MULTI-MISSIONARY DONATION (replaces CTA) ===== -->
  <MultiDonationFlow country={country} />
  <script src="../../scripts/campus-multi-donation.js"></script>

  <!-- ===== RoughNotation — bundled by Astro/Vite ===== -->
  <script src="../../scripts/campus-annotations.js"></script>
</BaseLayout>
