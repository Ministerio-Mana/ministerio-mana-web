
---
import BaseLayout from '@layouts/BaseLayout.astro';
import DonationForm from '@components/campus/DonationForm.astro';
import { MISIONEROS } from '@data/misioneros';

const title = "Campus Maná | Socios de la Gran Comisión";
const description = "Únete a la misión en las universidades. Apoya a nuestros misioneros y se parte de la transformación.";
---

<BaseLayout {title} {description} hideHeader={false} hideFooter={false}>
  <!-- Scripts -->
  <script src="../../scripts/campus-donation.js"></script>

  <!-- Hero Section -->
  <section class="relative min-h-[90vh] flex items-center justify-center overflow-hidden bg-brand-navy">
    <!-- Background Overlay -->
    <div class="absolute inset-0 bg-gradient-to-br from-brand-navy via-brand-navy/90 to-brand-teal/20 opacity-40"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-brand-teal/10 via-brand-navy/50 to-brand-navy"></div>
    
    <!-- Decorative Elements -->
    <div class="absolute top-0 right-0 p-20 opacity-20 hidden md:block">
        <div class="w-96 h-96 bg-brand-teal rounded-full blur-[120px]"></div>
    </div>
    <div class="absolute bottom-0 left-0 p-20 opacity-10 hidden md:block">
        <div class="w-72 h-72 bg-purple-600 rounded-full blur-[100px]"></div>
    </div>

    <!-- Content -->
    <div class="container-tight relative z-10 text-center px-4">
      <span class="inline-block py-1 px-3 rounded-full bg-brand-teal/10 border border-brand-teal/20 text-brand-teal text-xs font-bold uppercase tracking-widest mb-6">
        Ministerio Maná
      </span>
      <h1 class="text-5xl md:text-7xl font-black text-white mb-6 leading-tight">
        CAMPUS <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-teal to-cyan-400">MANÁ</span>
      </h1>
      <p class="text-lg md:text-xl text-white/70 max-w-2xl mx-auto mb-10 leading-relaxed">
        Socios de la Gran Comisión. Levantando una generación apasionada por Jesús en las universidades de Colombia y el mundo.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#misioneros" class="px-8 py-4 bg-brand-teal text-brand-navy font-bold rounded-full hover:brightness-110 transition-all shadow-lg shadow-brand-teal/20">
          Apoyar a un misionero
        </a>
        <a href="#vision" class="px-8 py-4 bg-white/5 border border-white/10 text-white font-bold rounded-full hover:bg-white/10 transition-all backdrop-blur-sm">
          Conocer la visión
        </a>
      </div>
    </div>

    <!-- Scroll Indicator -->
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce text-white/30">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7-7-7" />
        </svg>
    </div>
  </section>

  <!-- Vision Section -->
  <section id="vision" class="py-24 bg-brand-navy relative border-t border-white/5">
    <div class="container-tight px-4">
        <div class="grid md:grid-cols-2 gap-12 items-center">
            <div class="relative">
                <div class="aspect-video rounded-2xl overflow-hidden shadow-2xl border border-white/10 bg-black/50 relative group">
                     <div class="absolute inset-0 flex items-center justify-center bg-gradient-to-br from-brand-navy to-black">
                        <div class="w-16 h-16 bg-white/10 rounded-full flex items-center justify-center backdrop-blur-md group-hover:scale-110 transition-transform cursor-pointer shadow-xl border border-white/10">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-white ml-1" viewBox="0 0 20 20" fill="currentColor">
                                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z" clip-rule="evenodd" />
                            </svg>
                        </div>
                     </div>
                </div>
                <!-- Decoration -->
                <div class="absolute -bottom-6 -right-6 w-full h-full border-2 border-brand-teal/20 rounded-2xl -z-10 hidden md:block"></div>
            </div>
            <div>
                <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">Llevando el Evangelio a la Academia</h2>
                <p class="text-white/60 mb-6 leading-relaxed">
                    Creemos que la universidad es uno de los campos misioneros más estratégicos hoy en día. Es allí donde se forman los líderes del mañana, donde se debaten las ideas que moldearán la cultura y donde miles de jóvenes toman decisiones que definirán su futuro.
                </p>
                <div class="space-y-4">
                    <div class="flex items-start gap-4">
                        <div class="p-2 bg-brand-teal/10 rounded-lg text-brand-teal">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
                        </div>
                        <div>
                            <h3 class="text-white font-bold text-lg">Discipulado</h3>
                            <p class="text-white/50 text-sm">Acompañamiento personal y grupos de estudio bíblico.</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-4">
                        <div class="p-2 bg-purple-500/10 rounded-lg text-purple-400">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
                        </div>
                        <div>
                            <h3 class="text-white font-bold text-lg">Comunidad</h3>
                            <p class="text-white/50 text-sm">Creando espacios seguros de pertenencia y crecimiento.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
  </section>

  <!-- Missionaries Section -->
  <section id="misioneros" class="py-24 bg-black/20 border-t border-white/5">
    <div class="container-tight px-4">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-5xl font-black text-white mb-4">Nuestros Misioneros</h2>
        <p class="text-white/60 max-w-2xl mx-auto">
           Hombres y mujeres que han decidido dedicar sus vidas a tiempo completo para servir a los estudiantes universitarios. Tu apoyo hace posible su labor.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-8 lg:gap-12">
        {MISIONEROS.map((m) => (
          <article class="bg-brand-navy border border-white/10 rounded-3xl overflow-hidden shadow-2xl flex flex-col group hover:border-brand-teal/30 transition-all">
            <!-- Header / Video -->
            <div class="relative h-64 bg-black">
                 {m.video ? (
                    <iframe src={m.video} class="w-full h-full opacity-80 group-hover:opacity-100 transition-opacity" title={m.nombre} allow="accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
                 ) : (
                    <div class="w-full h-full flex items-center justify-center bg-white/5">
                        <span class="text-white/20 font-bold text-xl uppercase tracking-widest">Video</span>
                    </div>
                 )}
                 <div class="absolute bottom-0 left-0 w-full p-6 bg-gradient-to-t from-brand-navy to-transparent">
                    <h3 class="text-2xl font-bold text-white">{m.nombre}</h3>
                    <p class="text-brand-teal font-medium text-sm">{m.rol || "Misionero Campus"}</p>
                 </div>
            </div>
            
            <!-- Body -->
            <div class="p-6 md:p-8 flex-1 flex flex-col">
                <p class="text-white/60 text-sm leading-relaxed mb-8 flex-1">
                    Apoya el ministerio de {m.nombre.split(' ')[0]} para que pueda continuar compartiendo el evangelio, discipulando estudiantes y formándolos como líderes en su campus universitario.
                </p>
                
                <!-- Donation Widget -->
                <DonationForm 
                    missionaryName={m.nombre.split(' ')[0]}
                    wompiLink={m.wompiLink}
                    stripePriceId={m.stripePriceId}
                    slug={m.slug}
                />
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA General -->
  <section class="py-20 bg-gradient-to-br from-brand-teal to-cyan-700 relative overflow-hidden">
     <div class="absolute inset-0 bg-[url('/images/pattern-dots.png')] opacity-20"></div>
     <div class="container-tight px-4 text-center relative z-10">
        <h2 class="text-3xl md:text-4xl font-black text-white mb-6">¿Quieres ser parte del equipo?</h2>
        <p class="text-white/90 max-w-2xl mx-auto mb-8 text-lg font-medium">
            Si sientes el llamado a servir en el campus universitario o quieres que visitemos tu universidad, contáctanos.
        </p>
        <a href="https://wa.me/573000000000?text=Hola,%20quiero%20saber%20más%20de%20Campus%20Maná" target="_blank" class="inline-flex items-center gap-2 px-8 py-4 bg-white text-brand-teal font-black rounded-full hover:bg-white/90 transition-all shadow-xl">
            <span>Escríbenos al WhatsApp</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
               <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-8.707l-3-3a1 1 0 00-1.414 1.414L10.586 9H7a1 1 0 100 2h3.586l-1.293 1.293a1 1 0 101.414 1.414l3-3a1 1 0 000-1.414z" clip-rule="evenodd" />
            </svg>
        </a>
     </div>
  </section>
</BaseLayout>
