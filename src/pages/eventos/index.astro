---
import BaseLayout from '@layouts/BaseLayout.astro';
import PublicEventCard from '@components/events/PublicEventCard.astro';
import { getCollection } from 'astro:content';
import { getPublicEventPath, listPublicDatabaseEvents } from '@lib/publicEvents';

export const prerender = false;

const [contentEvents, databaseEvents] = await Promise.all([
  getCollection('events'),
  listPublicDatabaseEvents(),
]);

const events = [
  ...contentEvents.map((entry) => ({
    key: `content-${entry.id}`,
    title: entry.data.title,
    summary: entry.data.summary,
    startDate: entry.data.date,
    endDate: entry.data.date,
    location: entry.data.location,
    image: entry.data.heroImage || null,
    href: `/eventos/${entry.id}`,
    category: entry.data.category,
  })),
  ...databaseEvents.map((event) => ({
    key: `database-${event.id}`,
    title: event.title,
    summary: event.description,
    startDate: event.start_date,
    endDate: event.end_date,
    location: [event.location_name, event.city, event.country].filter(Boolean).join(' · '),
    image: event.banner_url,
    href: getPublicEventPath(event),
    category: event.category || event.scope?.toLowerCase(),
  })),
];

const now = Date.now();
const upcoming = events
  .filter((event) => new Date(event.endDate || event.startDate).getTime() >= now)
  .sort((a, b) => new Date(a.startDate).getTime() - new Date(b.startDate).getTime());
const completed = events
  .filter((event) => new Date(event.endDate || event.startDate).getTime() < now)
  .sort((a, b) => new Date(b.startDate).getTime() - new Date(a.startDate).getTime());
---

<BaseLayout title="Eventos — Ministerio Maná" description="Encuentros, conferencias y peregrinaciones del Ministerio Maná.">
  <div class="bg-slate-50 py-10 sm:py-14">
    <div class="container-tight">
      <header class="max-w-3xl border-b border-slate-200 pb-7">
        <p class="text-xs font-bold uppercase text-slate-500">Agenda Maná</p>
        <h1 class="mt-2 text-3xl font-bold text-[#293C74] sm:text-4xl">Eventos</h1>
        <p class="mt-3 text-base leading-relaxed text-slate-600">Encuentros para crecer, servir y caminar juntos como iglesia.</p>
      </header>

      <section class="py-8" aria-labelledby="upcoming-events-title">
        <div class="mb-5 flex items-end justify-between gap-4">
          <div>
            <h2 id="upcoming-events-title" class="text-xl font-bold text-slate-900">Próximos eventos</h2>
            <p class="mt-1 text-sm text-slate-500">Inscripciones y encuentros que están por comenzar.</p>
          </div>
          <span class="text-sm font-semibold text-slate-500">{upcoming.length}</span>
        </div>

        {upcoming.length ? (
          <div class="grid gap-4 lg:grid-cols-2">
            {upcoming.map((event) => <PublicEventCard {...event} />)}
          </div>
        ) : (
          <div class="rounded-lg border border-slate-200 bg-white px-5 py-8 text-center">
            <p class="font-semibold text-slate-800">No hay eventos próximos publicados.</p>
            <p class="mt-1 text-sm text-slate-500">La agenda se actualizará cuando haya una nueva convocatoria.</p>
          </div>
        )}
      </section>

      {completed.length > 0 && (
        <section class="border-t border-slate-200 py-8" aria-labelledby="completed-events-title">
          <div class="mb-5 flex items-end justify-between gap-4">
            <div>
              <h2 id="completed-events-title" class="text-xl font-bold text-slate-900">Archivo de eventos</h2>
              <p class="mt-1 text-sm text-slate-500">Información y memoria de encuentros finalizados.</p>
            </div>
            <span class="text-sm font-semibold text-slate-500">{completed.length}</span>
          </div>
          <div class="grid gap-4 lg:grid-cols-2">
            {completed.map((event) => <PublicEventCard {...event} />)}
          </div>
        </section>
      )}
    </div>
  </div>
</BaseLayout>
