---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getEntry, render } from 'astro:content';
import { getPublicDatabaseEvent, listPublicEventPaymentOptions } from '@lib/publicEvents';
import { getEventProviderPrice } from '@lib/eventPaymentContract.js';
import { normalizeEventRegistrationFormConfig, normalizeWhatsAppNumber } from '@lib/eventRegistrationForm.js';
import TurnstileProvider from '@components/TurnstileProvider.astro';
import TurnstileWidget from '@components/TurnstileWidget.astro';

type RegistrationCustomField = {
  id: string;
  type: 'SHORT_TEXT' | 'LONG_TEXT' | 'SINGLE_CHOICE' | 'MULTIPLE_CHOICE' | 'YES_NO' | 'DATE';
  label: string;
  help_text: string;
  required: boolean;
  options: string[];
};

export const prerender = false;

const slug = String(Astro.params.slug || '').replace(/\/$/, '').toLowerCase();
const contentEntry = slug ? await getEntry('events', slug) : undefined;
const databaseEvent = contentEntry ? null : await getPublicDatabaseEvent(slug);

if (!contentEntry && !databaseEvent) Astro.response.status = 404;

const rendered = contentEntry ? await render(contentEntry) : null;
const Content = rendered?.Content;
const title = contentEntry?.data.title || databaseEvent?.title || 'Evento no encontrado';
const description = contentEntry?.data.summary || databaseEvent?.description || 'El evento solicitado no está disponible.';
const startDateValue = contentEntry?.data.date || databaseEvent?.start_date || '';
const endDateValue = contentEntry?.data.date || databaseEvent?.end_date || databaseEvent?.start_date || '';
const startDate = new Date(startDateValue);
const endDate = new Date(endDateValue);
const isValidDate = Number.isFinite(startDate.getTime());
const isCompleted = Number.isFinite(endDate.getTime()) && endDate.getTime() < Date.now();
const location = contentEntry?.data.location || [databaseEvent?.location_name, databaseEvent?.city, databaseEvent?.country].filter(Boolean).join(' · ');
const address = databaseEvent?.location_address || '';
const image = contentEntry?.data.heroImage || databaseEvent?.banner_url || undefined;
const imageLayout = contentEntry ? 'HORIZONTAL' : databaseEvent?.banner_layout || 'HORIZONTAL';
const useImageHero = Boolean(image && !image.toLowerCase().endsWith('.svg'));
const brochure = contentEntry?.data.brochurePdf;
const registrationMode = String(databaseEvent?.registration_mode || 'NONE').toUpperCase();
const registrationUrl = registrationMode === 'EXTERNAL'
  && databaseEvent?.registration_url
  && (/^https:\/\//i.test(databaseEvent.registration_url) || (databaseEvent.registration_url.startsWith('/') && !databaseEvent.registration_url.startsWith('//')))
  ? databaseEvent.registration_url
  : '';
const registrationOpens = databaseEvent?.registration_opens_at ? new Date(databaseEvent.registration_opens_at).getTime() : null;
const registrationCloses = databaseEvent?.registration_closes_at ? new Date(databaseEvent.registration_closes_at).getTime() : null;
const now = Date.now();
const registrationWindowIsOpen = Boolean(
  !isCompleted
  && (registrationOpens === null || registrationOpens <= now)
  && (registrationCloses === null || registrationCloses >= now)
);
const externalRegistrationIsOpen = Boolean(registrationUrl && registrationWindowIsOpen);
const internalRegistrationIsOpen = Boolean(databaseEvent && registrationMode === 'INTERNAL' && registrationWindowIsOpen);
const pricingModel = String(databaseEvent?.pricing_model || (Number(databaseEvent?.price || 0) > 0 ? 'PAID' : 'FREE')).toUpperCase();
const eventPaymentOptions = internalRegistrationIsOpen && databaseEvent
  ? await listPublicEventPaymentOptions(databaseEvent.id)
  : [];
const hasWompi = eventPaymentOptions.some((option) => option.kind === 'ONLINE' && option.provider === 'WOMPI');
const hasStripe = eventPaymentOptions.some((option) => option.kind === 'ONLINE' && option.provider === 'STRIPE');
const priceCop = databaseEvent ? getEventProviderPrice(databaseEvent, 'WOMPI') : 0;
const priceUsd = databaseEvent ? getEventProviderPrice(databaseEvent, 'STRIPE') : 0;
const formatEventPrice = (amount: number, currency: string) => new Intl.NumberFormat(
  currency === 'USD' ? 'en-US' : 'es-CO',
  { style: 'currency', currency, maximumFractionDigits: currency === 'COP' ? 0 : 2 },
).format(amount);
const getPaymentOptionUnitPrice = (option: typeof eventPaymentOptions[number]) => {
  if (pricingModel !== 'PAID') return 0;
  if (option.provider === 'WOMPI') return priceCop;
  if (option.provider === 'STRIPE') return priceUsd;
  const optionCurrency = String(option.currency || '').toUpperCase();
  if (optionCurrency === 'COP' && priceCop > 0) return priceCop;
  if (optionCurrency === 'USD' && priceUsd > 0) return priceUsd;
  return optionCurrency === String(databaseEvent?.currency || '').toUpperCase()
    ? Number(databaseEvent?.price || 0)
    : 0;
};
const internalRegistrationReady = internalRegistrationIsOpen
  && (pricingModel === 'FREE' || eventPaymentOptions.length > 0);
const registrationHref = externalRegistrationIsOpen ? registrationUrl : internalRegistrationReady ? '#inscripcion' : '';
const paymentReturnRaw = String(Astro.url.searchParams.get('payment') || '').toLowerCase();
const paymentReturnState = ['success', 'return', 'cancelled'].includes(paymentReturnRaw) ? paymentReturnRaw : '';
const eventTimeZone = databaseEvent?.timezone || 'America/Bogota';
const registrationFormConfig = normalizeEventRegistrationFormConfig(databaseEvent?.registration_form_config);
const registrationCustomFields = registrationFormConfig.fields as RegistrationCustomField[];
const contactWhatsApp = normalizeWhatsAppNumber(databaseEvent?.contact_whatsapp);
const whatsappMessage = String(databaseEvent?.contact_whatsapp_message || `Hola, quiero información sobre ${title}.`).trim();
const whatsappHref = contactWhatsApp
  ? `https://wa.me/${contactWhatsApp}?text=${encodeURIComponent(whatsappMessage.slice(0, 280))}`
  : '';
const formattedDate = isValidDate
  ? new Intl.DateTimeFormat('es-CO', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric', timeZone: eventTimeZone }).format(startDate)
  : 'Fecha por confirmar';
const formattedTime = isValidDate
  ? new Intl.DateTimeFormat('es-CO', { hour: 'numeric', minute: '2-digit', timeZone: eventTimeZone }).format(startDate)
  : '';
const heroDay = isValidDate
  ? new Intl.DateTimeFormat('es-CO', { day: '2-digit', timeZone: eventTimeZone }).format(startDate)
  : '';
const heroMonth = isValidDate
  ? new Intl.DateTimeFormat('es-CO', { month: 'short', timeZone: eventTimeZone }).format(startDate).replace('.', '').toUpperCase()
  : '';
const attendanceLabel = databaseEvent?.attendance_mode === 'ONLINE'
  ? 'Virtual'
  : databaseEvent?.attendance_mode === 'HYBRID'
    ? 'Híbrido'
    : 'Presencial';
const priceLabel = pricingModel === 'DONATION'
  ? hasWompi && hasStripe
    ? 'Aporte voluntario · COP en Colombia o USD desde el exterior'
    : 'Aporte voluntario'
  : priceCop > 0 && priceUsd > 0 && hasWompi && hasStripe
    ? `${formatEventPrice(priceCop, 'COP')} en Colombia · ${formatEventPrice(priceUsd, 'USD')} desde el exterior`
    : Number(databaseEvent?.price || 0) > 0
      ? formatEventPrice(Number(databaseEvent?.price), databaseEvent?.currency || 'COP')
      : 'Sin costo';
const canonical = `${Astro.url.origin}/eventos/${slug}`;
const structured = (contentEntry || databaseEvent) ? {
  '@context': 'https://schema.org',
  '@type': 'Event',
  name: title,
  description,
  startDate: isValidDate ? startDate.toISOString() : undefined,
  endDate: Number.isFinite(endDate.getTime()) ? endDate.toISOString() : undefined,
  eventStatus: isCompleted ? 'https://schema.org/EventCompleted' : 'https://schema.org/EventScheduled',
  location: location ? { '@type': 'Place', name: location, address: address || undefined } : undefined,
  image: image ? [new URL(image, Astro.url.origin).toString()] : undefined,
  url: canonical,
} : undefined;
---

<BaseLayout title={`${title} — Evento`} description={description} image={image} type="event" structuredData={structured} noindex={!contentEntry && databaseEvent?.visibility === 'UNLISTED'}>
  {(contentEntry || databaseEvent) ? (
    <div class="bg-slate-50">
      <header class:list={["event-public-hero relative overflow-hidden", `event-public-hero--${imageLayout.toLowerCase()}`, !useImageHero && "bg-[#293C74]"]}>
        {useImageHero && imageLayout === 'HORIZONTAL' && <img src={image} alt="" class="absolute inset-0 z-0 h-full w-full object-cover" fetchpriority="high" />}
        <div class="event-public-hero-scrim absolute inset-0 z-0" aria-hidden="true"></div>
        <div class="event-public-hero-orbit event-public-hero-orbit--one" aria-hidden="true"></div>
        <div class="event-public-hero-orbit event-public-hero-orbit--two" aria-hidden="true"></div>
        <div class:list={["container-tight relative z-10 w-full py-10 text-white sm:py-14", imageLayout !== 'HORIZONTAL' && "event-public-hero-poster"]}>
          {useImageHero && imageLayout !== 'HORIZONTAL' && <div class:list={["event-public-hero-image", `event-public-hero-image--${imageLayout.toLowerCase()}`]}><img src={image} alt="" fetchpriority="high" /></div>}
          <div class="event-public-hero-copy max-w-4xl">
            <p class="event-public-hero-kicker mb-4 text-xs font-bold uppercase text-white/90"><span aria-hidden="true"></span>{isCompleted ? 'Evento finalizado' : databaseEvent?.category || 'Evento Maná'}</p>
            <h1 class="event-public-title text-white">{title}</h1>
            <p class="event-public-lead mt-4 max-w-2xl text-white/90">{description}</p>
            {isValidDate && (
              <div class="event-public-hero-details mt-8" aria-label={`Detalles de ${title}`}>
                <div class="event-public-hero-date" aria-hidden="true">
                  <strong>{heroDay}</strong>
                  <span>{heroMonth}</span>
                </div>
                <div>
                  <p class="font-semibold capitalize text-white">{formattedDate}{formattedTime && ` · ${formattedTime}`}</p>
                  {location && <p class="mt-2 text-sm text-white/75">{location}</p>}
                </div>
              </div>
            )}
            {(registrationHref || whatsappHref) && (
              <div class="mt-6 flex flex-wrap gap-4">
                {registrationHref && <a href={registrationHref} class="event-public-hero-action event-public-hero-action--primary">{registrationMode === 'INTERNAL' ? 'Reservar mi lugar' : 'Inscribirme'}</a>}
                {whatsappHref && <a href={whatsappHref} target="_blank" rel="noopener noreferrer" class="event-public-hero-action event-public-hero-action--secondary">Hablar por WhatsApp</a>}
              </div>
            )}
          </div>
        </div>
      </header>

      <section class="event-public-facts-band border-b border-slate-200 bg-white">
        <div class="container-tight grid gap-4 py-6 sm:grid-cols-2 lg:grid-cols-[1fr_1fr_0.78fr_auto] lg:items-stretch">
          <article class="event-public-fact">
            <p>Fecha</p>
            <strong class="capitalize">{formattedDate}{formattedTime && ` · ${formattedTime}`}</strong>
          </article>
          <article class="event-public-fact">
            <p>Lugar</p>
            <strong>{location || 'Lugar por confirmar'}</strong>
            {address && <span>{address}</span>}
          </article>
          <article class="event-public-fact">
            <p>Modalidad</p>
            <strong>{attendanceLabel}</strong>
            <span>{databaseEvent?.capacity ? `${databaseEvent.capacity} cupos` : 'Cupo abierto'}</span>
          </article>
          <div class="flex flex-wrap items-center gap-2 sm:col-span-2 lg:col-span-1 lg:justify-end">
            {registrationHref && <a href={registrationHref} class="inline-flex min-h-11 items-center justify-center rounded-md bg-[#293C74] px-6 py-2 text-sm font-bold text-white hover:bg-[#20315f]">Inscribirme</a>}
            {brochure && <a href={brochure} target="_blank" rel="noopener noreferrer" class="inline-flex min-h-11 items-center justify-center rounded-md border border-slate-300 px-6 py-2 text-sm font-bold text-slate-700 hover:bg-slate-50">Ver brochure</a>}
          </div>
        </div>
      </section>

      <section class="container-tight py-10 sm:py-14">
        <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_280px]">
          <article class="event-public-about min-w-0">
            <p class="event-public-section-label">Información del evento</p>
            {Content ? <div class="prose max-w-none prose-slate"><Content /></div> : (
              <div>
                <h2 class="text-2xl font-bold text-[#293C74]">Acerca del evento</h2>
                <p class="mt-4 max-w-3xl whitespace-pre-line leading-relaxed text-slate-600">{description}</p>
              </div>
            )}
          </article>
          <aside class="event-public-sidebar border-l-0 border-slate-200 lg:border-l lg:pl-6">
            <h2 class="text-sm font-bold uppercase tracking-[0.12em] text-slate-500">Estado</h2>
            <p class="mt-2 text-lg font-bold text-slate-900">{isCompleted ? 'Finalizado' : 'Programado'}</p>
            {databaseEvent?.capacity != null && databaseEvent.capacity > 0 && <p class="mt-2 text-sm text-slate-600">Cupo: {databaseEvent.capacity} personas</p>}
            <p class="mt-2 text-sm font-bold text-[#293C74]">{priceLabel}</p>
            {(whatsappHref || databaseEvent?.contact_email) && (
              <div class="event-public-contact mt-6">
                <p class="text-xs font-bold uppercase tracking-[0.08em] text-[#293C74]">¿Necesitas ayuda?</p>
                <p class="mt-2 text-sm leading-relaxed text-slate-600">El equipo del evento está disponible para orientarte.</p>
                <div class="mt-4 grid gap-2">
                  {whatsappHref && <a href={whatsappHref} target="_blank" rel="noopener noreferrer" class="event-public-contact-action event-public-contact-action--whatsapp">Escribir por WhatsApp</a>}
                  {databaseEvent?.contact_email && <a href={`mailto:${databaseEvent.contact_email}`} class="event-public-contact-action">Enviar correo</a>}
                </div>
              </div>
            )}
          </aside>
        </div>
      </section>

      {paymentReturnState && databaseEvent && (
        <section class="border-t border-slate-200 bg-white" aria-labelledby="event-payment-result-title">
          <div class="container-tight py-6">
            <div id="event-payment-result" data-event-id={databaseEvent.id} data-payment-state={paymentReturnState} class="rounded-md border border-slate-200 bg-slate-50 px-4 py-4" role="status" aria-live="polite">
              <h2 id="event-payment-result-title" class="text-base font-bold text-[#293C74]">
                {paymentReturnState === 'cancelled' ? 'Pago no completado' : 'Validando tu pago'}
              </h2>
              <p data-payment-result-message class="mt-2 text-sm text-slate-600">
                {paymentReturnState === 'cancelled'
                  ? 'Tu inscripción todavía no está confirmada.'
                  : 'Estamos esperando la confirmación segura del proveedor.'}
              </p>
            </div>
          </div>
        </section>
      )}

      {internalRegistrationIsOpen && databaseEvent && (
        <section id="inscripcion" class="scroll-mt-24 border-t border-slate-200 bg-white" aria-labelledby="event-registration-title">
          <div class="container-tight grid gap-8 py-10 sm:py-14 lg:grid-cols-[minmax(0,1fr)_minmax(320px,520px)] lg:items-start">
            <div class="max-w-xl">
              <p class="text-xs font-bold uppercase text-slate-500">Inscripción</p>
              <h2 id="event-registration-title" class="mt-2 text-2xl font-bold text-[#293C74] sm:text-3xl">Reserva tu lugar</h2>
              <p class="mt-4 leading-relaxed text-slate-600">
                {pricingModel === 'FREE'
                  ? 'Completa tus datos para registrar la asistencia.'
                  : 'Elige un método de pago. Las transferencias manuales se confirman después de que el organizador las revise.'}
              </p>
              <dl class="mt-6 grid gap-4 text-sm sm:grid-cols-2 lg:grid-cols-1">
                <div>
                  <dt class="font-bold text-slate-500">Modalidad</dt>
                  <dd class="mt-2 text-slate-900">{databaseEvent.attendance_mode === 'ONLINE' ? 'Virtual' : databaseEvent.attendance_mode === 'HYBRID' ? 'Híbrido' : 'Presencial'}</dd>
                </div>
                <div>
                  <dt class="font-bold text-slate-500">Valor</dt>
                  <dd class="mt-2 text-slate-900">{priceLabel}</dd>
                </div>
              </dl>
            </div>

            {internalRegistrationReady ? (
              <form
                id="public-event-registration-form"
                class="event-public-registration-card rounded-md border border-slate-200 bg-white p-6 shadow-sm sm:p-6"
                data-event-id={databaseEvent.id}
                data-pricing-model={pricingModel}
                data-unit-price={Number(databaseEvent.price || 0)}
                data-price-cop={priceCop}
                data-price-usd={priceUsd}
                data-currency={databaseEvent.currency || 'COP'}
                data-event-country={databaseEvent.country || ''}
                data-attendee-age-mode={registrationFormConfig.attendee_age}
                data-attendee-gender-mode={registrationFormConfig.attendee_gender}
                data-payer-document-mode={registrationFormConfig.payer_document}
                novalidate>
                <div class="grid gap-4 sm:grid-cols-2">
                  <label class="text-sm font-bold text-slate-700 sm:col-span-2">Nombre completo
                    <input name="contact_name" type="text" required minlength="3" maxlength="120" autocomplete="name" class="mt-2 block min-h-11 w-full rounded-md border-slate-300" />
                  </label>
                  <label class="text-sm font-bold text-slate-700">Correo
                    <input name="contact_email" type="email" required maxlength="254" autocomplete="email" class="mt-2 block min-h-11 w-full rounded-md border-slate-300" />
                  </label>
                  {registrationFormConfig.phone !== 'HIDDEN' && (
                    <label class="text-sm font-bold text-slate-700">WhatsApp o teléfono {registrationFormConfig.phone === 'REQUIRED' ? '' : <span class="font-normal text-slate-500">(opcional)</span>}
                      <input name="contact_phone" type="tel" maxlength="40" autocomplete="tel" required={registrationFormConfig.phone === 'REQUIRED'} placeholder="Ej. 573001234567" class="mt-2 block min-h-11 w-full rounded-md border-slate-300" />
                    </label>
                  )}
                  {registrationFormConfig.church && (
                    <label class="text-sm font-bold text-slate-700">Iglesia o congregación <span class="font-normal text-slate-500">(opcional)</span>
                      <input name="church" type="text" maxlength="120" autocomplete="organization" class="mt-2 block min-h-11 w-full rounded-md border-slate-300" />
                    </label>
                  )}
                  <label class="text-sm font-bold text-slate-700">Asistentes
                    <input id="event-registration-quantity" name="quantity" type="number" required min="1" max={Math.min(100, Number(databaseEvent.capacity || 100))} step="1" value="1" class="mt-2 block min-h-11 w-full rounded-md border-slate-300" />
                  </label>
                  {pricingModel === 'DONATION' && (
                    <label class="text-sm font-bold text-slate-700">Valor del aporte
                      <input name="donation_amount" type="number" required min="1" max="1000000000" step={databaseEvent.currency === 'COP' ? '1000' : '1'} class="mt-2 block min-h-11 w-full rounded-md border-slate-300" />
                    </label>
                  )}
                  {registrationCustomFields.map((field) => (
                    <fieldset class:list={['min-w-0', field.type === 'LONG_TEXT' || field.type === 'MULTIPLE_CHOICE' ? 'sm:col-span-2' : '']} data-custom-field-id={field.id} data-custom-field-type={field.type} data-custom-field-required={field.required ? 'true' : 'false'}>
                      <legend class="text-sm font-bold text-slate-700">{field.label}{field.required && <span aria-hidden="true" class="ml-2 text-[#293C74]">*</span>}</legend>
                      {field.help_text && <p class="mt-2 text-xs leading-relaxed text-slate-500">{field.help_text}</p>}
                      {field.type === 'SHORT_TEXT' && <input name={`custom_${field.id}`} type="text" maxlength="160" required={field.required} class="mt-2 block min-h-11 w-full rounded-md border-slate-300" />}
                      {field.type === 'LONG_TEXT' && <textarea name={`custom_${field.id}`} rows="4" maxlength="1000" required={field.required} class="mt-2 block w-full rounded-md border-slate-300"></textarea>}
                      {field.type === 'DATE' && <input name={`custom_${field.id}`} type="date" required={field.required} class="mt-2 block min-h-11 w-full rounded-md border-slate-300" />}
                      {field.type === 'YES_NO' && (
                        <select name={`custom_${field.id}`} required={field.required} class="mt-2 block min-h-11 w-full rounded-md border-slate-300">
                          <option value="">Selecciona una opción</option>
                          <option value="Sí">Sí</option>
                          <option value="No">No</option>
                        </select>
                      )}
                      {field.type === 'SINGLE_CHOICE' && (
                        <div class="mt-2 grid gap-2">
                          {field.options.map((option, optionIndex) => (
                            <label class="flex min-h-11 items-center gap-4 rounded-md border border-slate-200 px-4 text-sm text-slate-700 hover:border-[#293C74]/40">
                              <input name={`custom_${field.id}`} type="radio" value={option} required={field.required && optionIndex === 0} class="h-4 w-4 border-slate-300 text-[#293C74] focus:ring-[#293C74]" />
                              <span>{option}</span>
                            </label>
                          ))}
                        </div>
                      )}
                      {field.type === 'MULTIPLE_CHOICE' && (
                        <div class="mt-2 grid gap-2">
                          {field.options.map((option) => (
                            <label class="flex min-h-11 items-center gap-4 rounded-md border border-slate-200 px-4 text-sm text-slate-700 hover:border-[#293C74]/40">
                              <input name={`custom_${field.id}`} type="checkbox" value={option} class="h-4 w-4 rounded border-slate-300 text-[#293C74] focus:ring-[#293C74]" />
                              <span>{option}</span>
                            </label>
                          ))}
                        </div>
                      )}
                    </fieldset>
                  ))}
                  {pricingModel !== 'FREE' && (
                    <label class="text-sm font-bold text-slate-700 sm:col-span-2">Método de pago
                      <select name="provider" required class="mt-2 block min-h-11 w-full rounded-md border-slate-300">
                        {eventPaymentOptions.map((option) => (
                          <option
                            value={option.id}
                            data-provider={option.provider}
                            data-kind={option.kind}
                            data-currency={option.currency}
                            data-unit-price={getPaymentOptionUnitPrice(option)}
                            data-requires-evidence={option.requires_evidence ? 'true' : 'false'}>{option.label}</option>
                        ))}
                      </select>
                    </label>
                  )}
                </div>

                <section class="mt-6 rounded-md border border-[#293C74]/15 bg-[#F7F9FF] p-4" aria-labelledby="event-attendees-title">
                  <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
                    <div>
                      <h3 id="event-attendees-title" class="text-sm font-bold text-[#293C74]">Información de los asistentes</h3>
                      <p class="mt-2 text-xs leading-relaxed text-slate-600">Se crea una ficha por cada cupo. El nombre sí es necesario; edad y género solo aparecen si el organizador los activó.</p>
                    </div>
                    <label class="flex min-h-11 items-center gap-2 text-sm font-semibold text-slate-700">
                      <input id="event-contact-is-attendee" name="contact_is_attendee" type="checkbox" checked class="h-4 w-4 rounded border-slate-300 text-[#293C74] focus:ring-[#293C74]" />
                      <span>El responsable también asiste</span>
                    </label>
                  </div>
                  <div id="event-attendee-fields" class="mt-4 grid gap-4" aria-live="polite"></div>
                </section>

                {pricingModel !== 'FREE' && registrationFormConfig.payer_document !== 'HIDDEN' && (
                  <section class="mt-6 rounded-md border border-amber-200 bg-amber-50/70 p-4" aria-labelledby="event-payer-title">
                    <div>
                      <p class="text-xs font-bold uppercase tracking-[0.06em] text-amber-800">Conciliación financiera</p>
                      <h3 id="event-payer-title" class="mt-2 text-sm font-bold text-slate-900">¿Quién realiza el pago?</h3>
                      <p class="mt-2 text-xs leading-relaxed text-slate-600">Estos datos se guardan separados del formulario pastoral. Finanzas los usa para relacionar el pago, emitir el soporte solicitado y evitar confusiones entre personas con nombres similares.</p>
                    </div>
                    <label class="mt-4 flex min-h-11 items-center gap-2 text-sm font-semibold text-slate-700">
                      <input id="event-payer-is-contact" name="payer_is_contact" type="checkbox" checked class="h-4 w-4 rounded border-slate-300 text-[#293C74] focus:ring-[#293C74]" />
                      <span>El responsable también realiza el pago</span>
                    </label>
                    <div class="mt-4 grid gap-4 sm:grid-cols-2">
                      <label class="text-sm font-bold text-slate-700">Tipo de persona
                        <select name="payer_person_type" required class="mt-2 block min-h-11 w-full rounded-md border-slate-300">
                          <option value="NATURAL">Persona natural</option>
                          <option value="LEGAL">Empresa u organización</option>
                        </select>
                      </label>
                      <label class="text-sm font-bold text-slate-700">País del documento
                        <input name="payer_document_country" type="text" required maxlength="80" value={databaseEvent.country || ''} autocomplete="country-name" class="mt-2 block min-h-11 w-full rounded-md border-slate-300" />
                      </label>
                      <label class="text-sm font-bold text-slate-700">Tipo de identificación {registrationFormConfig.payer_document === 'OPTIONAL' && <span class="font-normal text-slate-500">(opcional)</span>}
                        <select name="payer_document_type" required={registrationFormConfig.payer_document === 'REQUIRED'} class="mt-2 block min-h-11 w-full rounded-md border-slate-300">
                          <option value="">Selecciona</option>
                          <option value="CC">Cédula de ciudadanía</option>
                          <option value="CE">Cédula de extranjería</option>
                          <option value="PPT">Permiso por protección temporal</option>
                          <option value="PASSPORT">Pasaporte</option>
                          <option value="NIT">NIT / identificación tributaria</option>
                          <option value="FOREIGN_ID">Documento de identidad extranjero</option>
                          <option value="OTHER">Otro</option>
                        </select>
                      </label>
                      <label class="text-sm font-bold text-slate-700">Número de identificación {registrationFormConfig.payer_document === 'OPTIONAL' && <span class="font-normal text-slate-500">(opcional)</span>}
                        <input name="payer_document_number" type="text" required={registrationFormConfig.payer_document === 'REQUIRED'} minlength="3" maxlength="40" inputmode="text" autocomplete="off" class="mt-2 block min-h-11 w-full rounded-md border-slate-300" />
                      </label>
                      <label class="text-sm font-bold text-slate-700">Nombre o razón social
                        <input name="payer_legal_name" type="text" required minlength="3" maxlength="160" autocomplete="name" class="mt-2 block min-h-11 w-full rounded-md border-slate-300" />
                      </label>
                      <label class="text-sm font-bold text-slate-700">Correo para el soporte
                        <input name="payer_billing_email" type="email" required maxlength="254" autocomplete="email" class="mt-2 block min-h-11 w-full rounded-md border-slate-300" />
                      </label>
                    </div>
                    <label class="mt-4 flex min-h-11 items-start gap-2 text-sm text-slate-700">
                      <input name="payer_tax_document_requested" type="checkbox" class="mt-2 h-4 w-4 rounded border-slate-300 text-[#293C74] focus:ring-[#293C74]" />
                      <span><strong>Solicito factura o certificado, si aplica.</strong><small class="mt-2 block text-xs leading-relaxed text-slate-500">La expedición depende del tipo de operación y de las obligaciones tributarias del Ministerio.</small></span>
                    </label>
                  </section>
                )}

                {pricingModel !== 'FREE' && eventPaymentOptions.some((option) => option.kind !== 'ONLINE') && (
                  <div class="mt-4 space-y-4">
                    {eventPaymentOptions.filter((option) => option.kind !== 'ONLINE').map((option) => (
                      <article
                        class="hidden rounded-md border border-slate-200 bg-slate-50 p-4"
                        data-manual-payment-details
                        data-option-id={option.id}>
                        <p class="text-sm font-bold text-slate-800">{option.label}</p>
                        {option.instructions && <p class="mt-2 whitespace-pre-line text-sm leading-relaxed text-slate-600">{option.instructions}</p>}
                        {option.qr_url && (
                          <img
                            src={option.qr_url}
                            alt={`Código QR para ${option.label}`}
                            class="mx-auto mt-4 aspect-square w-full max-w-64 rounded-md border border-slate-200 bg-white object-contain p-2"
                            loading="lazy"
                            decoding="async" />
                        )}
                        {option.external_url && (
                          <a
                            href={option.external_url}
                            target="_blank"
                            rel="noopener noreferrer nofollow"
                            class="mt-4 inline-flex min-h-11 items-center justify-center rounded-md border border-[#293C74] px-4 py-2 text-sm font-bold text-[#293C74] hover:bg-white">
                            Abrir enlace seguro · {new URL(option.external_url).hostname}
                          </a>
                        )}
                        <p class="mt-4 text-xs leading-relaxed text-slate-500">Este pago no se confirma automáticamente. El organizador revisará el movimiento en su cuenta.</p>
                      </article>
                    ))}
                    <label id="event-manual-reference-wrapper" class="hidden text-sm font-bold text-slate-700">Referencia del pago
                      <input
                        name="manual_reference"
                        type="text"
                        minlength="3"
                        maxlength="120"
                        autocomplete="off"
                        placeholder="Referencia, titular o últimos 4 dígitos"
                        class="mt-2 block min-h-11 w-full rounded-md border-slate-300" />
                      <span class="mt-2 block text-xs font-normal text-slate-500">No escribas claves, números completos de tarjeta ni información bancaria privada.</span>
                    </label>
                    <label id="event-payment-evidence-wrapper" class="hidden text-sm font-bold text-slate-700">Comprobante de pago
                      <input
                        name="payment_evidence"
                        type="file"
                        accept="image/jpeg,image/png,image/webp,application/pdf"
                        class="mt-2 block min-h-11 w-full rounded-md border border-slate-300 bg-white text-sm font-normal text-slate-700 file:mr-4 file:min-h-11 file:border-0 file:border-r file:border-slate-200 file:bg-slate-50 file:px-4 file:text-sm file:font-bold file:text-[#293C74]" />
                      <span class="mt-2 block text-xs font-normal leading-relaxed text-slate-500">Captura JPG, PNG o WebP de máximo 4 MB, o PDF de máximo 2 MB. La imagen se optimiza y se guarda de forma privada.</span>
                    </label>
                  </div>
                )}

                {pricingModel !== 'FREE' && (
                  <div class="mt-6 flex items-center justify-between border-y border-slate-200 py-4 text-sm">
                    <span class="font-semibold text-slate-600">Total</span>
                    <strong id="event-registration-total" class="text-base text-[#293C74]">—</strong>
                  </div>
                )}

                <label class="mt-6 flex items-start gap-4 text-sm text-slate-600">
                  <input name="privacy_accepted" type="checkbox" required class="mt-0 h-4 w-4 rounded border-slate-300 text-[#293C74] focus:ring-[#293C74]" />
                  <span>Autorizo el tratamiento de mis datos según la <a href="/privacidad" target="_blank" rel="noopener noreferrer" class="font-bold text-[#293C74] underline">política de privacidad</a>.</span>
                </label>

                {registrationFormConfig.whatsapp_updates && (
                  <label class="mt-4 flex items-start gap-4 text-sm text-slate-600">
                    <input name="whatsapp_updates" type="checkbox" class="mt-0 h-4 w-4 rounded border-slate-300 text-[#293C74] focus:ring-[#293C74]" />
                    <span>Quiero recibir recordatorios y novedades de este evento por WhatsApp.</span>
                  </label>
                )}

                <TurnstileProvider />
                <TurnstileWidget id="event-registration-turnstile" appearance="interaction-only" theme="light" />

                <p id="event-registration-status" class="mt-4 hidden rounded-md px-4 py-2 text-sm" role="status" aria-live="polite"></p>
                <button type="submit" class="mt-6 inline-flex min-h-11 w-full items-center justify-center rounded-md bg-[#293C74] px-6 py-2 text-sm font-bold text-white hover:bg-[#20315f] disabled:cursor-not-allowed disabled:opacity-60">
                  {pricingModel === 'FREE' ? 'Confirmar inscripción' : 'Continuar al pago'}
                </button>
              </form>
            ) : (
              <div class="rounded-md border border-slate-200 bg-slate-50 px-6 py-6">
                <p class="font-bold text-slate-800">Inscripciones temporalmente no disponibles</p>
                {databaseEvent.contact_email && <a href={`mailto:${databaseEvent.contact_email}`} class="mt-4 inline-block text-sm font-bold text-[#293C74] underline">Contactar al organizador</a>}
              </div>
            )}
          </div>
        </section>
      )}
    </div>
  ) : (
    <div class="container-tight py-20 text-center">
      <h1 class="text-3xl font-bold text-[#293C74]">Evento no encontrado</h1>
      <p class="mt-4 text-slate-600">El evento solicitado no existe o ya no está publicado.</p>
      <a href="/eventos" class="mt-6 inline-flex min-h-11 items-center rounded-md bg-[#293C74] px-6 py-2 text-sm font-bold text-white">Ver eventos</a>
    </div>
  )}
  <script>
    import '@scripts/public-event-registration.js';
  </script>
</BaseLayout>

<style>
