  .event-public-hero-poster {
    display: grid;
    grid-template-columns: minmax(180px, 280px) minmax(0, 1fr);
    align-items: center;
    gap: clamp(var(--space-3), 4vw, var(--space-8));
  }

  .event-public-hero-image {
    overflow: hidden;
    border: 1px solid rgb(255 255 255 / 28%);
    border-radius: 0.75rem;
    background: rgb(15 23 42 / 42%);
    box-shadow: 0 20px 45px rgb(15 23 42 / 35%);
  }

  .event-public-hero-image--square { aspect-ratio: 1; }
  .event-public-hero-image--vertical { aspect-ratio: 4 / 5; }

  .event-public-hero-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  @media (max-width: 639px) {
    .event-public-hero {
      min-height: 0;
      align-items: stretch;
