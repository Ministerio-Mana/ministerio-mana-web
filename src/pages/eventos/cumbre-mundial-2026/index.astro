---
import CumbreLayout from '@components/cumbre2026/CumbreLayout.astro';
import PortalIcon from '@components/portal/PortalIcon.astro';
import { isCumbreRegistrationClosed } from '@lib/cumbreLifecycle';
import { CUMBRE_GALLERY_ALBUMS, cumbreGalleryFolder } from '@lib/cumbreGallery';
import { supabaseAdmin } from '@lib/supabaseAdmin';
const cspNonce = Astro.locals?.cspNonce;
const eventClosed = isCumbreRegistrationClosed();

const galleryAlbums = eventClosed && supabaseAdmin
  ? await Promise.all(CUMBRE_GALLERY_ALBUMS.map(async (album) => {
      const result = await supabaseAdmin
        .from('cms_media')
        .select('public_url', { count: 'exact' })
        .eq('provider', 'imagekit')
        .eq('folder', cumbreGalleryFolder(album.slug))
        .order('path', { ascending: true })
        .range(0, 0);
      return {
        ...album,
        count: Number(result.count || 0),
        cover: result.data?.[0]?.public_url || null,
      };
    }))
  : [];
const galleryPhotoCount = galleryAlbums.reduce((total, album) => total + album.count, 0);
const galleryCovers = galleryAlbums.filter((album) => album.cover);
const firstGalleryAlbum = galleryAlbums.find((album) => album.count > 0);

const whatsappOnly =
  (import.meta.env?.PUBLIC_CUMBRE_WHATSAPP_ONLY ?? process.env?.PUBLIC_CUMBRE_WHATSAPP_ONLY) === 'true';

const ctaHref = whatsappOnly
  ? 'https://wa.me/573148297534?text=Hola%20quiero%20inscribirme%20a%20la%20Cumbre%20Mundial%202026'
  : '/eventos/cumbre-mundial-2026/inscripcion';

const ctaLabel = whatsappOnly ? 'Inscripciones por WhatsApp' : 'Reservar Cupo';
const ctaLabelCaps = whatsappOnly ? 'INSCRIBIRME POR WHATSAPP' : 'COMENZAR REGISTRO';
---

<CumbreLayout title="Cumbre Mundial 2026 | Ministerio Maná" description="Únete a la gran reunión de la familia Maná en Rionegro, Colombia.">
  
  <!-- Hero Section -->
  <section class="relative min-h-screen flex flex-col justify-center items-center text-center px-6 py-20 overflow-hidden bg-brand-void">
    
    <!-- Background Elements -->
    <div class="absolute inset-0 z-0">
        <!-- High Quality Fishermen Background -->
        <div class="absolute inset-0 bg-[url('/images/cumbre/fishermen-bg-highres.jpg')] bg-cover bg-center opacity-40 mix-blend-luminosity"></div>
        
        <!-- Gradient Mesh for Depth -->
        <div class="absolute inset-0 bg-gradient-to-b from-brand-void/90 via-brand-void/70 to-brand-void"></div>
        <div class="absolute inset-0 bg-gradient-to-r from-brand-void/80 via-transparent to-brand-void/80"></div>
        
        <!-- Glow effects -->
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-[500px] bg-brand-ocean/20 blur-[120px] mix-blend-screen opacity-50 rounded-full pointer-events-none"></div>
    </div>

    <!-- Content -->
    <div class="relative z-10 w-full max-w-7xl mx-auto flex flex-col items-center justify-center space-y-10 animate-fade-in-up">
      
      <!-- Top Badge: Ministry Name -->
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 border border-white/10 backdrop-blur-md mb-4 shadow-[0_0_20px_rgba(255,255,255,0.05)]">
        <span class="w-1.5 h-1.5 rounded-full bg-brand-gold animate-pulse"></span>
        <span class="text-xs md:text-sm font-bold tracking-[0.3em] text-white/80 uppercase">Ministerio Maná</span>
      </div>

      <!-- Main Visual Stack -->
      <div class="relative flex flex-col items-center">
        
        <!-- Massive Title -->
        <h1 class="font-display font-black text-6xl md:text-8xl lg:text-9xl tracking-tighter leading-[0.85] text-white drop-shadow-2xl uppercase">
          <span class="block bg-clip-text text-transparent bg-gradient-to-b from-white via-white to-gray-400">Cumbre</span>
          <span class="block bg-clip-text text-transparent bg-gradient-to-b from-white via-white to-gray-400">Mundial</span>
        </h1>

        <!-- Year & Subtitle -->
        <div class="relative mt-2 md:mt-4">
             <span class="block font-display font-black text-5xl md:text-7xl lg:text-[8rem] text-brand-ocean/10 absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 -z-10 scale-150 select-none">
                2026
             </span>
             <h2 class="font-display font-black text-2xl md:text-4xl lg:text-5xl text-brand-ocean tracking-wide uppercase drop-shadow-lg">
                De Discipulado
             </h2>
        </div>

        <!-- Integrated High-Res Logo -->
        <div class="mt-12 md:mt-16 relative group">
           <div class="absolute inset-0 bg-brand-gold/20 blur-[40px] rounded-full group-hover:bg-brand-gold/30 transition-all duration-700"></div>
           <img 
              src="/images/cumbre/cumbre-2026-logo-white.svg" 
              alt="Ven y Ayúdanos" 
              class="relative w-72 md:w-96 h-auto object-contain animate-float-slow drop-shadow-[0_0_20px_rgba(255,255,255,0.3)]"
           />
           <!-- Arched Text Effect (Visual Reinforcement if needed, but logo has text) -->
        </div>

      </div>

      <!-- Action Area -->
      <div class="flex flex-col items-center gap-6 mt-8">
         <p class="text-lg md:text-2xl text-white/80 font-light max-w-2xl text-center leading-relaxed">
            Un tiempo sobrenatural de conexión, visión y renovación espiritual.
         </p>
	         <p class="max-w-2xl rounded-2xl border border-brand-gold/30 bg-brand-gold/10 px-5 py-3 text-sm font-bold text-brand-gold">
	            {eventClosed ? 'La Cumbre Mundial 2026 finalizó. Conservamos aquí la memoria de lo que vivimos juntos.' : 'Hospedaje dentro del evento agotado. Las inscripciones continúan abiertas sin alojamiento.'}
	         </p>
         
         <div class="flex flex-col sm:flex-row gap-4">
             <!-- Primary CTA -->
	             {eventClosed ? (
	               <a href="#galeria" class="cumbre-action cumbre-action--teal group relative inline-flex px-10 py-4 font-black text-lg rounded-full shadow-[0_0_40px_rgba(40,166,189,0.3)] transition-all duration-300 hover:-translate-y-1">
	                 VER GALERÍA
	               </a>
	             ) : (
	             <a href={ctaHref} {...(whatsappOnly ? { target: '_blank', rel: 'noopener noreferrer' } : {})} class="cumbre-action cumbre-action--teal group relative inline-flex px-10 py-4 font-black text-lg rounded-full shadow-[0_0_40px_rgba(40,166,189,0.3)] hover:shadow-[0_0_60px_rgba(40,166,189,0.5)] hover:-translate-y-1 transition-all duration-300 overflow-hidden">
                <span class="relative z-10 flex items-center gap-2 uppercase tracking-wider">
                  {ctaLabel}
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
                </span>
	             </a>
	             )}
         </div>
      </div>

    </div>
  </section>


  <!-- Info Section -->
  <section id="detalles" class="relative py-24 px-6 bg-black/20 backdrop-blur-sm border-y border-white/5">
    <div class="container mx-auto max-w-5xl">
      <div class="grid md:grid-cols-3 gap-12">
        <!-- Feature 1 -->
        <div class="space-y-4 text-center md:text-left">
          <div class="w-16 h-16 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center mx-auto md:mx-0 text-brand-teal">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
               <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white">Familia Global</h3>
          <p class="text-white/60 leading-relaxed text-sm">
            Reúnete con pastores, líderes y familias de todas las sedes nacionales e internacionales.
          </p>
        </div>

        <!-- Feature 2 -->
        <div class="space-y-4 text-center md:text-left">
          <div class="w-16 h-16 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center mx-auto md:mx-0 text-brand-teal">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
          </div>
	          <h3 class="text-xl font-bold text-white">{eventClosed ? 'Evento realizado' : 'Inscripción sin alojamiento'}</h3>
	          <p class="text-white/60 leading-relaxed text-sm">
	            {eventClosed ? 'La Cumbre se realizó del 6 al 8 de junio de 2026 en Rionegro, Colombia.' : 'El hospedaje dentro del evento ya está agotado. Puedes asistir a la Cumbre y gestionar tu estadía por fuera.'}
          </p>
        </div>

        <!-- Feature 3 -->
        <div class="space-y-4 text-center md:text-left">
          <div class="w-16 h-16 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center mx-auto md:mx-0 text-brand-teal">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
	          <h3 class="text-xl font-bold text-white">{eventClosed ? 'Información histórica' : 'Pago flexible'}</h3>
	          <p class="text-white/60 leading-relaxed text-sm">
	            {eventClosed ? 'El portal conserva registros y pagos para consulta y conciliación administrativa.' : 'Puedes pagar a cuotas o de forma diferida. La reserva cubre la asistencia a la Cumbre según el paquete que selecciones.'}
          </p>
        </div>
      </div>
    </div>
  </section>

  {eventClosed && galleryCovers.length > 0 && (
    <section id="galeria" class="relative border-y border-white/10 bg-white/[0.03] px-6 py-20" aria-labelledby="cumbre-gallery-title" data-cumbre-event-gallery>
      <div class="mx-auto max-w-6xl">
        <header class="max-w-3xl">
          <p class="cumbre-memory-script">Nuestra memoria</p>
          <h2 id="cumbre-gallery-title" class="cumbre-memory-title text-4xl font-black uppercase text-white md:text-6xl">
            <span class="block">Revive la</span>
            <span class="cumbre-memory-outline block">Cumbre</span>
          </h2>
          <p class="mt-5 max-w-2xl text-base leading-relaxed text-white/70">
            {galleryPhotoCount} fotografías organizadas en {galleryCovers.length} álbumes para recordar lo que vivimos juntos.
          </p>
        </header>

        <div class="mt-10 border-y border-white/10 py-6">
          <h3 class="text-lg font-bold text-white">Álbumes</h3>
          <p class="mt-1 text-sm text-white/60">Selecciona una categoría para recorrer sus fotografías sin salir de esta página.</p>
          <div class="mt-5 flex gap-2 overflow-x-auto pb-2" role="tablist" aria-label="Álbumes de la Cumbre">
            {galleryAlbums.map((album) => (
              <button
                type="button"
                role="tab"
                aria-selected={album.slug === firstGalleryAlbum?.slug ? 'true' : 'false'}
                disabled={album.count === 0}
                class="cumbre-gallery-tab shrink-0 rounded-md border border-white/20 bg-white/5 px-4 py-2.5 text-left text-sm font-bold text-white transition hover:border-brand-teal hover:text-brand-teal disabled:cursor-not-allowed disabled:opacity-35"
                data-album={album.slug}
                data-title={album.title}
                data-description={album.description}
              >
                {album.title} <span class="ml-1 text-xs text-white/55">{album.count}</span>
              </button>
            ))}
          </div>
        </div>

        <div class="mt-8 border-b border-white/10 pb-5">
          <h3 data-gallery-title class="text-2xl font-black text-white">{firstGalleryAlbum?.title}</h3>
          <p data-gallery-description class="mt-1 max-w-3xl text-sm leading-relaxed text-white/65">{firstGalleryAlbum?.description}</p>
        </div>

        <div data-gallery-status class="py-10 text-center text-sm font-semibold text-white/65" aria-live="polite">Cargando fotografías...</div>
        <div data-gallery-grid class="grid grid-cols-2 gap-2 sm:gap-3 md:grid-cols-3 lg:grid-cols-4" aria-live="polite"></div>
        <div data-gallery-sentinel class="h-8" aria-hidden="true"></div>
        <div class="mt-5 flex flex-wrap items-center justify-center gap-3">
          <button data-gallery-load-more type="button" class="hidden cumbre-action cumbre-action--dark-ghost rounded-md px-5 py-2.5 text-sm font-bold">Cargar más</button>
          <a href="/galeria/cumbre-mundial-2026" class="cumbre-inline-link text-sm font-bold text-white/75 underline underline-offset-4 hover:text-white">Abrir galería en página completa</a>
        </div>
      </div>

      <dialog data-gallery-lightbox class="m-0 h-full max-h-none w-full max-w-none bg-transparent p-0 backdrop:bg-black/95">
        <div class="flex h-full w-full flex-col bg-black text-white">
          <div class="flex h-16 shrink-0 items-center justify-between gap-4 px-4 sm:px-6">
            <span data-gallery-lightbox-count class="text-sm font-bold text-white/70"></span>
            <button data-gallery-lightbox-close type="button" class="inline-flex h-11 w-11 items-center justify-center rounded-md border border-white/20 text-white hover:bg-white/10" aria-label="Cerrar visor"><PortalIcon name="x" size={22} /></button>
          </div>
          <div class="relative flex min-h-0 flex-1 items-center justify-center px-14 pb-5 sm:px-20">
            <img data-gallery-lightbox-image src="" alt="" class="max-h-full max-w-full object-contain" />
            <button data-gallery-lightbox-prev type="button" class="absolute left-2 inline-flex h-12 w-12 items-center justify-center rounded-md border border-white/20 bg-black/50 text-white hover:bg-white/10 sm:left-5" aria-label="Fotografía anterior"><PortalIcon name="arrow-left" size={24} /></button>
            <button data-gallery-lightbox-next type="button" class="absolute right-2 inline-flex h-12 w-12 rotate-180 items-center justify-center rounded-md border border-white/20 bg-black/50 text-white hover:bg-white/10 sm:right-5" aria-label="Fotografía siguiente"><PortalIcon name="arrow-left" size={24} /></button>
          </div>
        </div>
      </dialog>
    </section>
  )}

  <!-- CTA Section -->
  <section class="py-24 px-6 text-center">
    <div class="max-w-2xl mx-auto space-y-8 bg-gradient-to-b from-white/5 to-transparent p-12 rounded-[3rem] border border-white/10 backdrop-blur-md">
	      <h2 class="text-3xl md:text-4xl font-bold text-white">{eventClosed ? 'Cumbre Mundial 2026 finalizada' : '¿Listo para ser parte?'}</h2>
	      <p class="text-white/70">
	        {eventClosed ? 'Revive el encuentro en la galería o ingresa al portal para revisar tu información.' : 'Los cupos son limitados. Asegura tu asistencia y la de tu familia hoy mismo.'}
	      </p>
	      {eventClosed ? (
	        <div class="flex flex-wrap justify-center gap-3">
	          <a href="#galeria" class="cumbre-action cumbre-action--white inline-flex px-8 py-4 font-bold rounded-full">Ver galería</a>
	          <a href="/portal" class="cumbre-action cumbre-action--dark-ghost inline-flex px-8 py-4 font-bold rounded-full">Ir al portal</a>
	        </div>
	      ) : (
	        <>
	          <a href={ctaHref} {...(whatsappOnly ? { target: '_blank', rel: 'noopener noreferrer' } : {})} class="cumbre-action cumbre-action--white inline-flex px-10 py-5 font-black text-xl rounded-full hover:scale-105 transition-transform">
	            {ctaLabelCaps}
	          </a>
	          <a id="cta-registro" href="#" class="hidden cumbre-inline-link text-sm underline">
	            ¿Ya pagaste? Completa o modifica tu registro
	          </a>
	        </>
	      )}
      <p class="text-xs text-white/50">
        <a href="/eventos/cumbre-mundial-2026/condiciones" class="cumbre-inline-link underline underline-offset-4 transition-colors">Ver condiciones comerciales</a>.
      </p>
    </div>
  </section>

</CumbreLayout>

<script nonce={cspNonce}>
  const registroCta = document.getElementById('cta-registro');
  if (registroCta) {
    try {
      const bookingId = localStorage.getItem('cumbre-last-booking');
      const token = sessionStorage.getItem('cumbre-last-token') || localStorage.getItem('cumbre-last-token');
      if (bookingId && token) {
        registroCta.href = `/eventos/cumbre-mundial-2026/registro?bookingId=${encodeURIComponent(bookingId)}&token=${encodeURIComponent(token)}`;
        registroCta.classList.remove('hidden');
      }
    } catch (err) {
      console.warn('No se pudo leer almacenamiento local', err);
    }
  }
</script>

{eventClosed && galleryCovers.length > 0 && <script src="../../../scripts/cumbre-event-gallery.js"></script>}

<style>
  @font-face {
    font-family: 'Summer Loving';
    src: url('/fonts/SUMMER FONT/Summer Loving Regular.otf') format('opentype');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  .cumbre-memory-script {
    margin: 0 0 -0.12em;
    color: #fff;
    font-family: 'Summer Loving', 'Brush Script MT', cursive;
    font-size: 3rem;
    line-height: 1;
    letter-spacing: 0;
  }

  .cumbre-memory-title {
    font-family: 'Intro', ui-sans-serif, system-ui, sans-serif;
    line-height: 0.88;
    letter-spacing: 0;
  }

  .cumbre-memory-outline {
    color: transparent;
    -webkit-text-stroke: 1.5px #66c7db;
  }

  .cumbre-gallery-tab[aria-selected='true'] {
    border-color: var(--color-brand-teal, #28a6bd);
    background: var(--color-brand-teal, #28a6bd);
    color: #071828;
  }

  .cumbre-gallery-tab[aria-selected='true'] span {
    color: rgb(7 24 40 / 0.7);
  }
</style>
