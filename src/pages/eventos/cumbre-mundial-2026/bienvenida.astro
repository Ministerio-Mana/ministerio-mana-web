---
import CumbreLayout from '@components/cumbre2026/CumbreLayout.astro';

const unityReminders = [
  'la obra no se hace solos',
  'la red no se sostiene solos',
  'el Reino avanza cuando caminamos en unidad, humildad y obediencia',
];

const climateFacts = [
  { label: 'Día', value: '18°-22°C' },
  { label: 'Noche / madrugada', value: '10°-13°C' },
];

const weatherItems = ['lluvia ligera', 'neblina', 'mañanas y noches frías'];

const clothingItems = [
  'Chaqueta abrigada',
  'Buzo o saco cómodo',
  'Zapatos cómodos y cerrados',
  'Ropa casual y cómoda para las sesiones',
  'Paraguas pequeño o impermeable',
  'Ropa para clima frío en las noches',
];

const specialRecommendations = [
  'ropa cómoda pero apropiada',
  'evitar prendas excesivamente ajustadas o llamativas',
  'llevar una presentación práctica para servir y moverse con facilidad',
];

const bringItems = [
  'Biblia',
  'Cuaderno y lapicero',
  'Medicamentos personales',
  'Botella de agua reutilizable',
  'Disposición para servir y aprender',
  'Corazón sensible a la voz de Dios',
];

const prayerItems = [
  'vuelva a llenar las redes',
  'renueve nuestras fuerzas',
  'afirme nuestro llamado',
  'nos recuerde que el discipulado verdadero siempre ocurre cerca de Cristo y junto a otros',
];

const venueLinks = {
  google: 'https://www.google.com/maps/place/De+La+Salle+Casa+de+Encuentros/data=!4m2!3m1!1s0x0:0x4e396d4a9a3349a5?sa=X&ved=1t:2428&ictx=111&cshid=1778777449001802',
  waze: 'https://www.waze.com/es/live-map/directions/co/antioquia/rionegro/de-la-salle-casa-de-encuentros?to=place.ChIJi_SE7SOfRo4RpUkzmkptOU4',
  share: 'https://share.google/6ik8ZELGiqsuu1cle',
};

const venueHighlights = [
  { label: 'Lugar', value: 'De La Salle Casa de Encuentros' },
  { label: 'Ciudad', value: 'Rionegro, Antioquia' },
];

const schedule = [
  {
    day: 'Sábado',
    title: 'Bienvenida y comunión',
    items: [
      'Mesa de bienvenida desde las 7:00 a.m.',
      'Enseñanzas y talleres.',
      'Tarde familiar en Comfama Tutucán.',
      'Llevar traje de baño para piscinas climatizadas.',
    ],
    href: 'https://www.comfama.com/cultura-y-ocio/parques/parque-rionegro/',
  },
  {
    day: 'Domingo',
    title: 'Palabra y oración',
    items: ['Devocional.', 'Enseñanzas y talleres.', 'Tiempos de oración.'],
  },
  {
    day: 'Lunes',
    title: 'Clausura y envío',
    items: [
      'Devocional.',
      'Enseñanzas y talleres.',
      'Tiempo de clausura.',
      'Almuerzo incluido y cierre de la cumbre discipular.',
    ],
  },
];
---

<CumbreLayout
  title="Bienvenida | Cumbre Mundial de Discipulado"
  description="Guía de bienvenida para la Cumbre Mundial de Discipulado, basada en Lucas 5."
  image="/images/cumbre/bienvenida-og.jpg"
  imageAlt="Bienvenidos a la Cumbre Mundial de Discipulado - Ministerio Maná"
  imageWidth={1200}
  imageHeight={630}
  imageType="image/jpeg"
  flush
  showEventBadge={false}
>
  <main class="cumbre-welcome-story" data-cumbre-story style="--panel-count: 7;">
    <section
      class="cumbre-panel isolate min-h-screen overflow-hidden bg-[#07111c] text-white"
      data-cumbre-panel
      data-panel-theme="dark"
    >
      <div class="absolute inset-0" data-panel-bg>
        <img src="/images/cumbre/fishermen-bg-highres.jpg" alt="" class="h-full w-full object-cover" />
        <div class="absolute inset-0 bg-[linear-gradient(105deg,rgba(7,17,28,0.98)_0%,rgba(7,17,28,0.86)_44%,rgba(7,17,28,0.46)_100%)]"></div>
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_78%_18%,rgba(40,166,189,0.28),transparent_34%)]"></div>
      </div>

      <div class="cumbre-panel-inner container-tight relative z-10 flex min-h-screen items-center px-6 py-24 md:px-10" data-panel-inner>
        <div class="grid w-full items-center gap-12 lg:grid-cols-[1.15fr_0.85fr]">
          <div class="max-w-3xl space-y-7">
            <div class="inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-3 py-1 backdrop-blur-sm" data-reveal>
              <span class="h-2 w-2 rounded-full bg-brand-gold"></span>
              <span class="text-xs font-black uppercase tracking-[0.24em] text-white/90">Bienvenida oficial</span>
            </div>

            <img
              src="/images/cumbre/cumbre-2026-logo-white.svg"
              alt="Cumbre Mundial de Discipulado"
              class="h-24 w-auto md:h-32"
              data-reveal
            />

            <h1 class="max-w-4xl text-5xl font-black leading-[0.92] tracking-tight text-white drop-shadow-[0_12px_28px_rgba(0,0,0,0.6)] md:text-7xl" data-split-title>
              Bienvenidos a la Cumbre Mundial de Discipulado
            </h1>

            <p class="max-w-2xl text-lg font-light leading-relaxed text-white/88 drop-shadow md:text-xl" data-reveal>
              “Ven y ayúdanos”. Basado en Lucas 5. Nos reunimos como una sola familia para buscar a Cristo, servir juntos y responder al llamado del Señor.
            </p>
          </div>

          <aside class="mana-glass relative space-y-5 rounded-3xl border border-white/15 bg-black/35 p-7 shadow-2xl shadow-black/25 backdrop-blur-xl md:p-9" data-reveal>
            <p class="text-xs font-black uppercase tracking-[0.24em] text-brand-gold">Información general</p>
            <div class="space-y-5">
              <div>
                <p class="text-sm font-medium text-white/60">Fecha</p>
                <h2 class="text-3xl font-black leading-tight text-white">6 al 8 de junio</h2>
              </div>
              <div class="h-px w-full bg-gradient-to-r from-white/25 to-transparent"></div>
              <div>
                <p class="text-sm font-medium text-white/60">Lugar</p>
                <h2 class="text-3xl font-black leading-tight text-white">Casa de Encuentros La Salle</h2>
                <p class="mt-2 text-sm leading-relaxed text-white/75">Rionegro, Antioquia, Colombia.</p>
              </div>
              <div class="h-px w-full bg-gradient-to-r from-white/25 to-transparent"></div>
              <div>
                <p class="text-sm font-medium text-white/60">Base bíblica</p>
                <p class="mt-1 text-base leading-relaxed text-white/82">“Bogando mar adentro… echaron sus redes para pescar… y encerraron gran cantidad de peces.”</p>
                <p class="mt-2 text-xs font-black uppercase tracking-[0.18em] text-brand-gold">Lucas 5:4-6</p>
              </div>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <section
      class="cumbre-panel cumbre-venue-panel isolate min-h-screen overflow-hidden bg-[#edf6f4] text-brand-dark"
      data-cumbre-panel
      data-panel-theme="light"
    >
      <div class="absolute inset-0" data-panel-bg>
        <div class="absolute inset-0 bg-[linear-gradient(120deg,rgba(255,255,255,0.94),rgba(237,246,244,0.9)_48%,rgba(40,166,189,0.22))]"></div>
        <div class="cumbre-soft-grid absolute inset-0 opacity-[0.09]"></div>
        <div class="absolute right-[-16%] top-[-12%] h-[620px] w-[620px] rounded-full bg-brand-teal/20 blur-[110px]"></div>
        <div class="absolute bottom-[-18%] left-[-10%] h-[540px] w-[540px] rounded-full bg-brand-gold/18 blur-[120px]"></div>
      </div>

      <div class="cumbre-panel-inner container-tight relative z-10 flex min-h-screen items-center px-6 py-24 md:px-10" data-panel-inner>
        <div class="grid w-full items-center gap-10 lg:grid-cols-[0.88fr_1.12fr]">
          <div class="space-y-6">
            <div class="space-y-4" data-reveal>
              <p class="text-xs font-black uppercase tracking-[0.26em] text-brand-medium/70">Lugar de encuentro</p>
              <h2 class="text-5xl font-black leading-tight text-brand-dark md:text-6xl" data-split-title>
                Casa de Encuentros La Salle
              </h2>
              <p class="cumbre-venue-copy text-xl leading-relaxed text-slate-700">
                Llegaremos a Rionegro para vivir la Cumbre como una sola familia. Guarda la ruta y compártela con quienes viajan contigo.
              </p>
            </div>

            <div class="cumbre-venue-meta grid gap-3 sm:grid-cols-2" data-reveal>
              {venueHighlights.map((item) => (
                <article class="rounded-3xl border border-white/80 bg-white/82 p-5 shadow-xl shadow-brand-dark/8 backdrop-blur-md">
                  <p class="text-xs font-black uppercase tracking-[0.18em] text-brand-medium/70">{item.label}</p>
                  <p class="mt-2 text-lg font-black leading-tight text-brand-dark">{item.value}</p>
                </article>
              ))}
            </div>

            <div class="cumbre-venue-actions grid gap-3 sm:grid-cols-2" data-reveal>
              <a href={venueLinks.google} target="_blank" rel="noopener noreferrer" class="group inline-flex items-center justify-center gap-3 rounded-full bg-brand-dark px-6 py-4 text-sm font-black uppercase tracking-[0.16em] text-white shadow-2xl shadow-brand-dark/18 transition hover:-translate-y-0.5 hover:bg-brand-medium">
                <svg aria-hidden="true" class="h-5 w-5 flex-none text-brand-gold" viewBox="0 0 24 24" fill="none">
                  <path d="M12 21s7-6.1 7-12a7 7 0 1 0-14 0c0 5.9 7 12 7 12Z" stroke="currentColor" stroke-width="2" />
                  <path d="M12 12.2a3.2 3.2 0 1 0 0-6.4 3.2 3.2 0 0 0 0 6.4Z" stroke="currentColor" stroke-width="2" />
                </svg>
                Google Maps
              </a>
              <a href={venueLinks.waze} target="_blank" rel="noopener noreferrer" class="group inline-flex items-center justify-center gap-3 rounded-full border border-brand-dark/12 bg-white px-6 py-4 text-sm font-black uppercase tracking-[0.16em] text-brand-dark shadow-xl shadow-brand-dark/8 transition hover:-translate-y-0.5 hover:border-brand-teal hover:text-brand-medium">
                <svg aria-hidden="true" class="h-5 w-5 flex-none text-brand-teal" viewBox="0 0 24 24" fill="none">
                  <path d="M4.2 14.5c-.9-1.1-1.2-2.4-.9-3.9C4 7 7.5 4.5 12 4.5c5 0 8.5 3 8.5 7.3 0 4.1-3.4 7.2-8.4 7.2-1.1 0-2.1-.14-3-.42L6.6 20.2l.2-2.8a7.1 7.1 0 0 1-2.6-2.9Z" stroke="currentColor" stroke-width="1.9" stroke-linejoin="round" />
                  <path d="M9 11.6h.01M15 11.6h.01M9.7 14.8c1.2.8 3.4.8 4.6 0" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                </svg>
                Waze
              </a>
            </div>

            <a href={venueLinks.share} target="_blank" rel="noopener noreferrer" class="cumbre-venue-share inline-flex text-xs font-black uppercase tracking-[0.18em] text-brand-medium hover:text-brand-dark" data-reveal>
              Compartir ubicación
            </a>
          </div>

          <article class="cumbre-venue-map-card relative overflow-hidden rounded-[2rem] border border-white/80 bg-white/78 p-4 shadow-2xl shadow-brand-dark/14 backdrop-blur-md" data-reveal>
            <div class="cumbre-venue-map relative overflow-hidden rounded-[1.5rem] bg-[#07111c]">
              <svg class="absolute inset-0 h-full w-full" viewBox="0 0 640 420" aria-hidden="true">
                <defs>
                  <filter id="map-pin-shadow" x="-40%" y="-20%" width="180%" height="180%">
                    <feDropShadow dx="0" dy="8" stdDeviation="5" flood-color="#07111c" flood-opacity="0.28" />
                  </filter>
                  <linearGradient id="venue-map-bg" x1="0" y1="0" x2="1" y2="1">
                    <stop offset="0" stop-color="#17235a" />
                    <stop offset="0.58" stop-color="#123b5b" />
                    <stop offset="1" stop-color="#0f6d80" />
                  </linearGradient>
                  <radialGradient id="venue-map-glow" cx="28%" cy="22%" r="70%">
                    <stop offset="0" stop-color="#28A6BD" stop-opacity="0.34" />
                    <stop offset="1" stop-color="#28A6BD" stop-opacity="0" />
                  </radialGradient>
                </defs>

                <rect width="640" height="420" fill="url(#venue-map-bg)" />
                <rect width="640" height="420" fill="url(#venue-map-glow)" />
                <g opacity="0.16" stroke="#ffffff" stroke-width="1">
                  <path d="M0 48H640M0 96H640M0 144H640M0 192H640M0 240H640M0 288H640M0 336H640M0 384H640" />
                  <path d="M64 0V420M128 0V420M192 0V420M256 0V420M320 0V420M384 0V420M448 0V420M512 0V420M576 0V420" />
                </g>

                <path d="M0 338 C92 330 150 360 226 346 C299 333 338 282 430 290 C512 296 552 334 640 318" fill="none" stroke="rgba(255,255,255,0.16)" stroke-width="28" />
                <path d="M-24 260 C68 234 138 250 214 212 C295 171 382 190 458 154 C530 120 574 132 662 100" fill="none" stroke="rgba(255,255,255,0.12)" stroke-width="22" />
                <path d="M90 420 C116 350 118 286 148 226 C179 165 212 123 218 -8" fill="none" stroke="rgba(255,255,255,0.12)" stroke-width="20" />
                <path d="M520 -20 C502 48 495 101 514 165 C535 238 586 288 584 430" fill="none" stroke="rgba(255,255,255,0.12)" stroke-width="20" />

                <path d="M34 104 L198 46 L294 106 L250 220 L110 214 Z" fill="#28A6BD" opacity="0.2" />
                <path d="M126 66 C155 85 150 126 173 150 C151 164 124 190 112 216 C88 181 86 144 105 112 C116 94 117 78 126 66Z" fill="#8ee2ee" opacity="0.28" />
                <path d="M44 116 C98 93 153 76 210 68" fill="none" stroke="rgba(255,255,255,0.36)" stroke-width="7" stroke-linecap="round" opacity="0.58" />

                <path d="M510 -22 C500 42 494 91 508 142 C525 203 577 248 574 420" fill="none" stroke="rgba(40,166,189,0.42)" stroke-width="28" stroke-linecap="round" />
                <path d="M510 -22 C500 42 494 91 508 142 C525 203 577 248 574 420" fill="none" stroke="rgba(7,17,28,0.92)" stroke-width="16" stroke-linecap="round" />
                <path d="M510 -22 C500 42 494 91 508 142 C525 203 577 248 574 420" fill="none" stroke="rgba(203,217,230,0.7)" stroke-width="4" stroke-linecap="round" />

                <path d="M360 420 C354 355 374 313 422 284 C469 255 511 228 526 178" fill="none" stroke="rgba(40,166,189,0.42)" stroke-width="26" stroke-linecap="round" />
                <path d="M360 420 C354 355 374 313 422 284 C469 255 511 228 526 178" fill="none" stroke="rgba(7,17,28,0.92)" stroke-width="15" stroke-linecap="round" />
                <path d="M360 420 C354 355 374 313 422 284 C469 255 511 228 526 178" fill="none" stroke="rgba(203,217,230,0.7)" stroke-width="4" stroke-linecap="round" />

                <path class="cumbre-route-gold" d="M574 420 C570 340 548 260 526 178 C476 188 415 204 334 190" fill="none" stroke="#F2C94C" stroke-width="6" stroke-linecap="round" stroke-dasharray="16 14" />
                <circle cx="526" cy="178" r="23" fill="none" stroke="rgba(242,201,76,0.5)" stroke-width="4" />

                <g stroke="rgba(255,255,255,0.18)" stroke-width="4" stroke-linecap="round" fill="none">
                  <path d="M-10 386 L330 386" />
                  <path d="M-8 362 L318 404" />
                  <path d="M36 420 C86 362 148 344 230 338" />
                  <path d="M48 306 C126 292 202 294 282 312" />
                  <path d="M52 258 L240 234" />
                  <path d="M64 228 L282 224" />
                  <path d="M12 188 L148 180" />
                  <path d="M17 156 L98 128" />
                  <path d="M550 110 L648 92" />
                  <path d="M548 144 L656 150" />
                  <path d="M540 220 L658 208" />
                </g>

                <text x="145" y="130" class="cumbre-map-label cumbre-map-secondary" text-anchor="middle">
                  <tspan x="145" dy="0">Parque Recreativo</tspan>
                  <tspan x="145" dy="20">Comfama Tutucán</tspan>
                </text>
                <text x="238" y="54" class="cumbre-map-label cumbre-map-secondary">Parqueadero</text>
                <text x="514" y="68" class="cumbre-map-road cumbre-map-secondary" transform="rotate(82 514 68)">Calle 38</text>
                <text x="566" y="342" class="cumbre-map-road" transform="rotate(88 566 342)">Carrera 55A</text>
                <text x="350" y="352" class="cumbre-map-road" transform="rotate(-62 350 352)">Variante San Antonio</text>
                <text x="118" y="386" class="cumbre-map-road cumbre-map-secondary" transform="rotate(8 118 386)">Calle 24</text>
                <text x="154" y="312" class="cumbre-map-label cumbre-map-secondary" text-anchor="middle">
                  <tspan x="154" dy="0">Conjunto Residencial</tspan>
                  <tspan x="154" dy="18">Pietra Santa</tspan>
                </text>
                <text x="576" y="134" class="cumbre-map-label cumbre-map-secondary">Parcela</text>
                <text x="576" y="152" class="cumbre-map-label cumbre-map-secondary">Badén</text>

                <g filter="url(#map-pin-shadow)">
                  <circle cx="334" cy="190" r="18" fill="#F2C94C" />
                  <circle cx="334" cy="190" r="8" fill="#07111c" />
                  <circle cx="334" cy="190" r="30" fill="none" stroke="#F2C94C" stroke-width="2" opacity="0.42" />
                </g>

                <g class="cumbre-map-destination">
                  <path d="M354 190 H452" stroke="#F2C94C" stroke-width="2" stroke-linecap="round" opacity="0.75" />
                  <text x="462" y="185" class="cumbre-map-destination-title">De La Salle</text>
                  <text x="462" y="204" class="cumbre-map-destination-subtitle">Casa de Encuentros</text>
                </g>
              </svg>
              <div class="cumbre-map-reference absolute left-5 top-5 rounded-2xl border border-white/12 bg-white/10 px-4 py-3 text-white shadow-lg shadow-brand-dark/10 backdrop-blur-md">
                <p class="text-[10px] font-black uppercase tracking-[0.2em] text-brand-gold">Referencia</p>
                <p class="mt-1 text-sm font-black leading-none">Comfama Tutucán · La Salle</p>
              </div>
              <div class="cumbre-venue-pulse absolute left-[45.5%] top-[36%] h-24 w-24 rounded-full border border-brand-gold/50"></div>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section
      class="cumbre-panel isolate min-h-screen overflow-hidden bg-[#1A255C] text-white"
      data-cumbre-panel
      data-panel-theme="dark"
    >
      <div class="absolute inset-0" data-panel-bg>
        <img src="/images/cumbre/fishermen-sunset.jpg" alt="" class="h-full w-full object-cover opacity-45" />
        <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(7,17,28,0.98),rgba(26,37,92,0.9)_55%,rgba(26,37,92,0.72))]"></div>
        <div class="absolute right-[-12%] top-[10%] h-[760px] w-[760px] rounded-full bg-brand-teal/12 blur-[120px] mix-blend-screen"></div>
      </div>

      <div class="cumbre-panel-inner container-tight relative z-10 flex min-h-screen items-center px-6 py-24 md:px-10" data-panel-inner>
        <div class="grid w-full items-center gap-12 lg:grid-cols-[0.92fr_1.08fr]">
          <div class="relative hidden lg:block" data-reveal>
            <article class="rounded-[2rem] border border-white/14 bg-black/34 p-8 shadow-2xl shadow-black/25 backdrop-blur-xl">
              <p class="text-xs font-black uppercase tracking-[0.24em] text-brand-gold">Lucas 5:4-6</p>
              <blockquote class="mt-6 text-3xl font-black leading-tight text-white">
                “Bogando mar adentro… echaron sus redes para pescar… y encerraron gran cantidad de peces.”
              </blockquote>
              <p class="mt-6 border-l-2 border-brand-teal pl-5 text-base leading-relaxed text-white/74">
                Así como en Lucas 5 la red se llenó cuando trabajaron juntos bajo la dirección de Cristo, creemos que Dios quiere recordarnos que nadie sostiene la red solo.
              </p>
              <div class="mt-8 grid grid-cols-2 gap-3">
                {['Barca', 'Red', 'Obediencia', 'Unidad'].map((item) => (
                  <p class="rounded-2xl border border-white/12 bg-white/8 px-4 py-3 text-sm font-black uppercase tracking-[0.16em] text-white/84">{item}</p>
                ))}
              </div>
            </article>
          </div>

          <div class="max-w-3xl space-y-6">
            <p class="font-display text-2xl font-light tracking-[0.2em] text-brand-gold/90" data-reveal>
              Lucas 5:4-6
            </p>
            <h2 class="text-4xl font-black leading-[0.94] text-white drop-shadow-[0_10px_24px_rgba(0,0,0,0.45)] md:text-6xl" data-split-title>
              Entrar nuevamente en la barca con Jesús
            </h2>
            <div class="space-y-4 border-l-2 border-brand-teal/60 pl-6" data-reveal>
              <p class="text-lg font-light leading-relaxed text-white/86">
                Amados hermanos y hermanas, con gozo les damos la bienvenida a este tiempo especial donde nos reuniremos como una sola familia para buscar a Cristo, servir juntos y responder al llamado del Señor: “Ven y ayúdanos.”
              </p>
              <p class="text-base leading-relaxed text-white/74">
                Esta cumbre no es solo un evento. Es una invitación a entrar nuevamente en la barca con Jesús.
              </p>
            </div>
            <div class="grid gap-3 sm:grid-cols-3" data-reveal>
              {unityReminders.map((item) => (
                <p class="rounded-2xl border border-white/12 bg-white/8 p-4 text-sm font-semibold leading-snug text-white/84 backdrop-blur-sm">{item}</p>
              ))}
            </div>
            <p class="text-lg font-semibold leading-relaxed text-brand-gold" data-reveal>
              Venimos a ser fortalecidos, equipados y enviados.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section
      class="cumbre-panel isolate min-h-screen overflow-hidden bg-[#f7f2e7] text-brand-dark"
      data-cumbre-panel
      data-panel-theme="light"
    >
      <div class="absolute inset-0" data-panel-bg>
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_18%_15%,rgba(242,201,76,0.28),transparent_34%),radial-gradient(circle_at_78%_28%,rgba(40,166,189,0.18),transparent_30%)]"></div>
        <div class="cumbre-soft-grid absolute inset-0 opacity-[0.08]"></div>
      </div>

      <div class="cumbre-panel-inner container-tight relative z-10 flex min-h-screen items-center px-6 py-24 md:px-10" data-panel-inner>
        <div class="w-full space-y-12">
          <div class="max-w-3xl space-y-4" data-reveal>
            <p class="text-xs font-black uppercase tracking-[0.26em] text-brand-medium/70">Preparación</p>
            <h2 class="text-5xl font-black leading-tight text-brand-dark md:text-6xl" data-split-title>Clima y vestuario</h2>
            <p class="text-xl leading-relaxed text-slate-700">
