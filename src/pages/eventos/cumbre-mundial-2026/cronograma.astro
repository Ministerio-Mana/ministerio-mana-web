---
import CumbreLayout from '@components/cumbre2026/CumbreLayout.astro';
import {
  cumbreAudienceFilters,
  cumbreDays,
  formatDisplayTime,
  getEventsForDay,
  getPublicScheduleEvents,
} from '@data/cumbreSchedule';

const cspNonce = Astro.locals?.cspNonce;
const publicEvents = getPublicScheduleEvents();
const firstDayDate = cumbreDays[0]?.date ?? '2026-06-06';
const whatsappHref =
  'https://wa.me/573148297534?text=Hola%20quiero%20informaci%C3%B3n%20del%20cronograma%20de%20la%20Cumbre%20Mundial%202026';

const audienceHelpers: Record<string, string> = {
  all: 'Todo el evento',
  todos: 'Solo espacios generales',
  ninos: 'General + niños',
  mujeres: 'General + mujeres',
  varones: 'General + varones',
  campus: 'General + campus',
};

const audienceOptions = cumbreAudienceFilters.map((filter) => {
  return {
    ...filter,
    href: `/eventos/cumbre-mundial-2026/calendario.ics?track=${filter.id}`,
    helper: audienceHelpers[filter.id] ?? filter.label,
    calendarLabel: filter.id === 'all' ? 'Todos' : filter.label,
  };
});

const groupEventsByStart = (events: typeof publicEvents) => {
  const groups = new Map<string, typeof publicEvents>();

  events.forEach((event) => {
    const current = groups.get(event.startsAt) ?? [];
    current.push(event);
    groups.set(event.startsAt, current);
  });

  return Array.from(groups.entries()).map(([startsAt, groupEvents]) => ({
    startsAt,
    events: groupEvents,
  }));
};

const agendaByDay = cumbreDays.map((day) => {
  const events = getEventsForDay(day.date, publicEvents);

  return {
    day,
    events,
    groups: groupEventsByStart(events),
  };
});
---

<CumbreLayout
  title="Cronograma | Cumbre Mundial de Discipulado"
  description="Cronograma para asistentes de la Cumbre Mundial de Discipulado 2026 en Rionegro."
  image="/images/cumbre/bienvenida-og.jpg"
  imageAlt="Cronograma de la Cumbre Mundial de Discipulado"
  imageWidth={1200}
  imageHeight={630}
  imageType="image/jpeg"
  showEventBadge={false}
>
  <main class="schedule-page" data-schedule-root data-default-day={firstDayDate}>
    <section class="schedule-hero relative overflow-hidden px-5 pb-8 pt-32 md:px-8 md:pb-10 md:pt-32">
      <div class="absolute inset-0 -z-10">
        <img src="/images/cumbre/fishermen-bg-highres.jpg" alt="" class="h-full w-full object-cover opacity-[0.28]" />
        <div class="absolute inset-0 bg-[linear-gradient(105deg,rgba(7,17,28,0.98)_0%,rgba(7,17,28,0.9)_48%,rgba(7,17,28,0.66)_100%)]"></div>
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_76%_12%,rgba(40,166,189,0.3),transparent_32%)]"></div>
      </div>

      <div class="mx-auto max-w-7xl">
        <div class="max-w-4xl space-y-5">
          <div class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/[0.08] px-3 py-1.5 text-xs font-black uppercase tracking-[0.22em] text-brand-gold backdrop-blur-md">
            <span class="h-2 w-2 rounded-full bg-brand-teal"></span>
            Para asistentes
          </div>
          <div class="space-y-3">
            <p class="text-sm font-black uppercase tracking-[0.28em] text-brand-teal">6 al 8 de junio · Rionegro</p>
            <h1 class="max-w-5xl text-4xl font-black leading-[0.94] text-white md:text-6xl lg:text-7xl">
              Cronograma Cumbre
            </h1>
          </div>
          <p class="max-w-2xl text-base leading-relaxed text-white/72 md:text-lg">
            Elige tu día y tu agenda. Los espacios generales ya vienen incluidos.
          </p>
          <div class="flex flex-wrap gap-3">
            <a href={whatsappHref} target="_blank" rel="noopener noreferrer" class="cumbre-action cumbre-action--dark-ghost inline-flex rounded-full px-5 py-3 text-sm font-black uppercase tracking-[0.12em]">
              WhatsApp
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="schedule-content px-5 py-6 md:px-8 md:py-8">
      <div class="schedule-workspace mx-auto max-w-7xl">
        <div class="agenda-control-panel">
          <div class="agenda-control-main">
            <div>
              <p class="toolbar-label">Día</p>
              <div class="day-tabs" aria-label="Filtrar por día">
                {cumbreDays.map((day) => (
                  <button
                    type="button"
                    class={`schedule-pill ${day.date === firstDayDate ? 'is-active' : ''}`}
                    data-day-filter={day.date}
                    aria-pressed={day.date === firstDayDate ? 'true' : 'false'}
                  >
                    <span>{day.shortLabel}</span>
                    <small>{day.title}</small>
                  </button>
                ))}
              </div>
            </div>

            <a
              href={audienceOptions[0]?.href ?? '/eventos/cumbre-mundial-2026/calendario.ics?track=all'}
              download
              class="calendar-cta"
              data-calendar-cta
            >
              Agregar calendario de Todos
            </a>
          </div>

          <div>
            <p class="toolbar-label">Tu agenda</p>
            <div class="audience-picker" aria-label="Filtrar por agenda">
              {audienceOptions.map((option) => (
                <button
                  type="button"
                  class={`schedule-chip ${option.id === 'all' ? 'is-active' : ''}`}
                  data-track-filter={option.id}
                  data-calendar-href={option.href}
                  data-calendar-label={option.calendarLabel}
                  aria-pressed={option.id === 'all' ? 'true' : 'false'}
                >
                  <span>{option.label}</span>
                  <small>{option.helper}</small>
                </button>
              ))}
            </div>
          </div>
        </div>

        <div class="schedule-stage">
          {agendaByDay.map(({ day, groups }) => (
            <section class="schedule-day" data-day-section={day.date} hidden={day.date !== firstDayDate}>
              <header class="day-heading">
                <div>
                  <p>{day.label}</p>
                  <h2>{day.title}</h2>
                </div>
                <span>{day.summary}</span>
              </header>

              <div class="agenda-board">
                {groups.map((group) => (
                  <article class="agenda-row" data-public-group data-day={day.date}>
                    <div class="agenda-time">
                      <span>{formatDisplayTime(group.startsAt)}</span>
                    </div>
                    <div class="agenda-events">
                      {group.events.map((event) => (
                        <article class="agenda-card" data-public-event data-day={event.date} data-track={event.audience}>
                          <div class="agenda-card-top">
                            {event.audience !== 'todos' && <span>{event.trackLabel}</span>}
                            <small>hasta {formatDisplayTime(event.endsAt)}</small>
                          </div>
                          <h3>{event.title}</h3>
                          <p class="agenda-copy">{event.description}</p>
                          {event.speaker && <p class="agenda-speaker">{event.speaker}</p>}
                        </article>
                      ))}
                    </div>
                  </article>
                ))}
              </div>
            </section>
          ))}
        </div>
      </div>
    </section>
  </main>
</CumbreLayout>

<script nonce={cspNonce}>
  const scheduleRoot = document.querySelector('[data-schedule-root]');
  if (scheduleRoot) {
    let activeDay = scheduleRoot.getAttribute('data-default-day') || '2026-06-06';
    let activeTrack = 'all';
    const dayButtons = Array.from(scheduleRoot.querySelectorAll('[data-day-filter]'));
    const trackButtons = Array.from(scheduleRoot.querySelectorAll('[data-track-filter]'));
	    const events = Array.from(scheduleRoot.querySelectorAll('[data-public-event]'));
	    const groups = Array.from(scheduleRoot.querySelectorAll('[data-public-group]'));
	    const sections = Array.from(scheduleRoot.querySelectorAll('[data-day-section]'));
	    const calendarCta = scheduleRoot.querySelector('[data-calendar-cta]');

    const setActive = (buttons, attr, value) => {
      buttons.forEach((button) => {
        const active = button.getAttribute(attr) === value;
        button.classList.toggle('is-active', active);
        button.setAttribute('aria-pressed', String(active));
      });
    };

	    const updateCalendarCta = () => {
	      if (!calendarCta) return;
	      const activeTrackButton = trackButtons.find((button) => button.getAttribute('data-track-filter') === activeTrack);
	      const href = activeTrackButton?.getAttribute('data-calendar-href');
	      const label = activeTrackButton?.getAttribute('data-calendar-label') || 'Todos';

	      if (href) {
	        calendarCta.setAttribute('href', href);
	      }

	      calendarCta.textContent = `Agregar calendario de ${label}`;
	    };

	    const applyFilters = () => {

	      events.forEach((event) => {
	        const dayMatch = event.getAttribute('data-day') === activeDay;
	        const track = event.getAttribute('data-track');
	        const trackMatch = activeTrack === 'all' || track === activeTrack || track === 'todos';
	        const visible = dayMatch && trackMatch;
	        event.hidden = !visible;
	      });

      groups.forEach((group) => {
        const groupDayMatch = group.getAttribute('data-day') === activeDay;
        const visibleItems = Array.from(group.querySelectorAll('[data-public-event]')).some((item) => !item.hidden);
        group.hidden = !(groupDayMatch && visibleItems);
      });

      sections.forEach((section) => {
        section.hidden = section.getAttribute('data-day-section') !== activeDay;
      });

	      updateCalendarCta();
	    };

    dayButtons.forEach((button) => {
      button.addEventListener('click', () => {
        activeDay = button.getAttribute('data-day-filter') || activeDay;
        setActive(dayButtons, 'data-day-filter', activeDay);
        applyFilters();
      });
    });

    trackButtons.forEach((button) => {
      button.addEventListener('click', () => {
        activeTrack = button.getAttribute('data-track-filter') || 'all';
        setActive(trackButtons, 'data-track-filter', activeTrack);
        applyFilters();
      });
    });

    applyFilters();
  }
</script>

