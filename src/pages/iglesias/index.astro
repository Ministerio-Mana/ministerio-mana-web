---
export const prerender = false;
import BaseLayout from '@layouts/BaseLayout.astro';
import ChurchesMap from '@components/ChurchesMap.astro';
import churchesData from '@data/churches.json';

const toMapsHref = (church: any) => {
  if (typeof church.maps_url === 'string' && church.maps_url.trim()) return church.maps_url.trim();
  if (typeof church.lat === 'number' && typeof church.lng === 'number') {
    return `https://www.google.com/maps?q=${church.lat},${church.lng}`;
  }

  const query = [church.address, church.city, church.country || 'Colombia'].filter(Boolean).join(', ');
  return query
    ? `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(query)}`
    : 'https://maps.google.com';
};

const churchesRaw = (churchesData as any[]).map((church, index) => ({
  ...church,
  country: church.country ?? 'Colombia',
  continent: church.continent ?? 'América',
  mapsHref: toMapsHref(church),
  id: `${church.country ?? 'Colombia'}-${church.city ?? 'sin-ciudad'}-${church.name ?? index}`
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/(^-|-$)/g, ''),
}));

const churches = churchesRaw.sort((a, b) => {
  const countryCompare = (a.country || '').localeCompare(b.country || '', 'es');
  if (countryCompare !== 0) return countryCompare;
  const cityCompare = (a.city || '').localeCompare(b.city || '', 'es');
  if (cityCompare !== 0) return cityCompare;
  return (a.name || '').localeCompare(b.name || '', 'es');
});

const continents = Array.from(new Set(churches.map((church) => church.continent))).sort((a, b) =>
  String(a).localeCompare(String(b), 'es'),
);

const countries = Array.from(new Set(churches.map((church) => church.country))).sort((a, b) =>
  String(a).localeCompare(String(b), 'es'),
);

const countryStats = countries.map((country) => ({
  country,
  count: churches.filter((church) => church.country === country).length,
  continent: churches.find((church) => church.country === country)?.continent || 'América',
}));

const cityStats = Array.from(
  churches.reduce((acc, church) => {
    const city = String(church.city || '').trim();
    if (!city) return acc;
    const country = String(church.country || 'Colombia');
    const continent = String(church.continent || 'América');
    const key = `${continent}||${country}||${city}`;
    const current = acc.get(key);
    if (current) {
      current.count += 1;
      return acc;
    }
    acc.set(key, { city, country, continent, count: 1 });
    return acc;
  }, new Map<string, { city: string; country: string; continent: string; count: number }>()).values(),
).sort((a, b) => {
  const continentCompare = a.continent.localeCompare(b.continent, 'es');
  if (continentCompare !== 0) return continentCompare;
  const countryCompare = a.country.localeCompare(b.country, 'es');
  if (countryCompare !== 0) return countryCompare;
  return a.city.localeCompare(b.city, 'es');
});

const cspNonce = Astro.locals?.cspNonce;
const title = 'Iglesias Maná Global';
const description = 'Encuentra la sede de Ministerio Maná más cercana y contacta fácilmente por WhatsApp o Google Maps.';
---

<BaseLayout {title} {description} hideHeader={false} hideFooter={false}>
  <div class="fixed inset-0 bg-brand-void -z-50">
    <div class="absolute inset-0 opacity-20 bg-[url('https://www.transparenttextures.com/patterns/stardust.png')]"></div>
    <div class="absolute top-0 right-0 w-[780px] h-[780px] bg-brand-navy/30 rounded-full blur-3xl opacity-45 pointer-events-none mix-blend-screen"></div>
    <div class="absolute bottom-0 left-0 w-[620px] h-[620px] bg-brand-teal/10 rounded-full blur-3xl opacity-35 pointer-events-none mix-blend-screen"></div>
  </div>

  <section class="relative pt-32 pb-24 overflow-hidden">
    <div class="container-tight px-4 relative z-10">
      <div class="text-center mb-14 space-y-4">
        <span class="inline-block py-1 px-3 rounded-full bg-white/10 border border-white/20 backdrop-blur-md text-[10px] font-intro tracking-widest text-brand-teal uppercase mb-2 animate-fade-in-up">
          Red global de sedes
        </span>

        <h1 class="font-intro font-black text-5xl md:text-7xl lg:text-8xl tracking-tighter leading-[0.9] text-white drop-shadow-2xl uppercase mb-6 animate-fade-in-up delay-100">
          <span class="block bg-clip-text text-transparent bg-gradient-to-b from-white via-white to-gray-300">Iglesias</span>
          <span class="block bg-clip-text text-transparent bg-gradient-to-b from-brand-teal via-brand-teal to-[#1a7f72]">Maná</span>
        </h1>

        <p class="text-lg md:text-xl text-white/75 max-w-3xl mx-auto font-light leading-relaxed animate-fade-in-up delay-200">
          Encuentra la sede más cercana, abre ubicación exacta y contacta directamente por WhatsApp.
          Esta vista ya está preparada para crecer por países y continentes.
        </p>
      </div>

      <div class="mb-14 animate-fade-in-up delay-300 relative group">
        <ChurchesMap />
        <div class="absolute inset-0 pointer-events-none z-10 opacity-25 mix-blend-overlay">
          <svg width="100%" height="100%">
            <pattern id="dot-pattern" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse">
              <circle cx="2" cy="2" r="1" fill="white" />
            </pattern>
            <rect width="100%" height="100%" fill="url(#dot-pattern)" />
          </svg>
        </div>
      </div>

      <div class="mb-10 animate-fade-in-up delay-400 bg-white/[0.04] border border-white/10 rounded-3xl p-5 md:p-6 backdrop-blur-sm">
        <div class="mb-4">
          <p class="text-xs font-intro tracking-[0.2em] text-brand-teal uppercase">Navegación rápida</p>
          <h2 class="text-white font-intro text-2xl mt-1">Continentes y países</h2>
        </div>

        <div class="space-y-4">
          <div>
            <p class="text-[11px] font-intro uppercase tracking-widest text-white/50 mb-2">Continente</p>
            <div id="continent-chips" class="flex flex-wrap gap-2">
              <button type="button" data-continent="" class="filter-chip filter-chip-active" aria-pressed="true">Todos</button>
              {continents.map((continent) => (
                <button type="button" data-continent={continent} class="filter-chip" aria-pressed="false">{continent}</button>
              ))}
            </div>
          </div>

          <div>
            <p class="text-[11px] font-intro uppercase tracking-widest text-white/50 mb-2">País</p>
            <div id="country-chips" class="flex flex-wrap gap-2">
              <button type="button" data-country="" data-continent="" class="filter-chip filter-chip-active" aria-pressed="true">
                Todos
                <span class="chip-count">{churches.length}</span>
              </button>
              {countryStats.map((entry) => (
                <button
                  type="button"
                  data-country={entry.country}
                  data-continent={entry.continent}
                  class="filter-chip"
                  aria-pressed="false"
                >
                  {entry.country}
                  <span class="chip-count">{entry.count}</span>
                </button>
              ))}
            </div>
          </div>

          <div>
            <p class="text-[11px] font-intro uppercase tracking-widest text-white/50 mb-2">Ciudad</p>
            <div id="city-chips" class="flex flex-wrap gap-2">
              <button type="button" data-city="" data-country="" data-continent="" class="filter-chip filter-chip-active" aria-pressed="true">
                Todas
              </button>
              {cityStats.map((entry) => (
                <button
                  type="button"
                  data-city={entry.city}
                  data-country={entry.country}
                  data-continent={entry.continent}
                  class="filter-chip"
                  aria-pressed="false"
                >
                  {entry.city}
                  <span class="chip-count">{entry.count}</span>
                </button>
              ))}
            </div>
          </div>
        </div>
      </div>

      <div class="flex flex-col lg:flex-row gap-6 items-end justify-between mb-8 pb-6 border-b border-white/10 animate-fade-in-up delay-500">
        <div class="flex-1 w-full lg:max-w-xl space-y-2">
          <label for="churches-search" class="text-xs font-intro tracking-widest text-brand-teal uppercase ml-1">Buscar ciudad, país o sede</label>
          <div class="relative group">
            <input
              id="churches-search"
              type="search"
              class="w-full bg-white/5 border border-white/10 rounded-2xl px-5 py-4 text-white placeholder-white/30 focus:outline-none focus:ring-2 focus:ring-brand-teal/50 focus:border-brand-teal/50 transition-all font-intro-reg"
              placeholder="Ej: Pereira, Cuenca, París, Maná México..."
              autocomplete="off"
            />
            <svg class="absolute right-4 top-1/2 -translate-y-1/2 w-5 h-5 text-white/30 group-focus-within:text-brand-teal transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
          </div>
        </div>

        <div class="flex flex-wrap gap-3 w-full lg:w-auto">
          <div class="h-14 flex items-center px-4 rounded-2xl bg-white/5 border border-white/10 min-w-[130px]">
            <span id="churches-count" class="text-2xl font-intro text-white mr-2">{churches.length}</span>
            <span class="text-xs font-intro tracking-widest text-white/55 uppercase">Sedes</span>
          </div>
          <div class="h-14 flex items-center px-4 rounded-2xl bg-white/5 border border-white/10 min-w-[130px]">
            <span class="text-2xl font-intro text-white mr-2">{countries.length}</span>
            <span class="text-xs font-intro tracking-widest text-white/55 uppercase">Países</span>
          </div>
          <div class="h-14 flex items-center px-4 rounded-2xl bg-white/5 border border-white/10 min-w-[140px]">
            <span class="text-2xl font-intro text-white mr-2">{continents.length}</span>
            <span class="text-xs font-intro tracking-widest text-white/55 uppercase">Continentes</span>
          </div>
        </div>
      </div>

      <div id="churches-grid" class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 animate-fade-in-up delay-500">
        {churches.map((church) => (
          <article
            id={`church-card-${church.id}`}
            class="group relative bg-white/5 backdrop-blur-sm border border-white/10 rounded-3xl p-6 hover:bg-white/10 hover:border-brand-teal/30 hover:-translate-y-1 transition-all duration-300 flex flex-col h-full"
            data-city={church.city}
            data-country={church.country}
            data-continent={church.continent}
            data-name={church.name}
            data-address={church.address}
            data-notes={church.notes || ''}
            data-service={church.service || ''}
          >
            <div class="absolute top-5 right-5 flex flex-wrap justify-end gap-2 max-w-[55%]">
              <span class="text-[10px] font-intro tracking-widest text-brand-teal uppercase px-2 py-1 rounded bg-brand-teal/10 border border-brand-teal/20">
                {church.country}
              </span>
              <span class="text-[10px] font-intro tracking-widest text-white/65 uppercase px-2 py-1 rounded bg-white/5 border border-white/10">
                {church.continent}
              </span>
            </div>

            <div class="mb-4 pr-2">
              <p class="text-sm font-intro text-white/60 mb-1">{church.city}</p>
              <h3 class="text-xl font-intro text-white group-hover:text-brand-teal transition-colors leading-tight min-h-[3.1rem]">
                {church.name}
              </h3>
            </div>

            <div class="space-y-4 border-t border-white/10 pt-4 mb-4">
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-brand-teal shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                <p class="text-sm text-white/70 font-light leading-snug">
                  {church.address && church.address !== '—' ? church.address : 'Dirección por confirmar'}
                </p>
              </div>

              {church.contact?.name && (
                <div class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-brand-teal shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
                  <div>
                    <p class="text-xs text-brand-teal uppercase tracking-wider font-intro mb-0.5">Contacto pastoral</p>
                    <p class="text-sm text-white/90 font-medium">{church.contact.name}</p>
                    {church.contact.phone && <p class="text-xs text-white/55 mt-0.5">{church.contact.phone}</p>}
                    {church.contact.email && <p class="text-xs text-white/55 mt-0.5 break-all">{church.contact.email}</p>}
                  </div>
                </div>
              )}

              {church.service && (
                <div class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-brand-teal shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10m2 10H5a2 2 0 01-2-2V7a2 2 0 012-2h14a2 2 0 012 2v12a2 2 0 01-2 2z" /></svg>
                  <div>
                    <p class="text-xs text-brand-teal uppercase tracking-wider font-intro mb-0.5">Reunión / servicio</p>
                    <p class="text-sm text-white/75">{church.service}</p>
                  </div>
                </div>
              )}

              {church.notes && (
                <div class="rounded-xl bg-white/[0.04] border border-white/10 px-3 py-2">
                  <p class="text-xs text-white/70 leading-relaxed">{church.notes}</p>
                </div>
              )}
            </div>

            <div class="grid grid-cols-2 gap-3 mt-auto relative z-10">
              {church.whatsapp && (
                <a
                  href={`https://wa.me/${church.whatsapp.replace(/[^0-9]/g, '')}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center justify-center gap-2 py-3 rounded-xl bg-brand-teal text-white text-xs font-intro tracking-wider shadow-[0_0_15px_rgba(45,212,191,0.4)] hover:brightness-110 hover:shadow-[0_0_20px_rgba(45,212,191,0.6)] hover:-translate-y-0.5 transition-all duration-300"
                >
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" /></svg>
                  WhatsApp
                </a>
              )}

              <a
                href={church.mapsHref}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center justify-center gap-2 py-3 rounded-xl bg-white/5 border border-white/10 text-white/75 text-xs font-intro tracking-wider hover:bg-white/20 hover:text-white transition-all duration-300"
              >
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                Cómo llegar
              </a>
            </div>
          </article>
        ))}
      </div>

      <div id="churches-empty" class="hidden mt-10 rounded-3xl border border-dashed border-white/20 bg-white/[0.03] p-10 text-center">
        <p class="text-white/70 font-intro text-lg">No encontramos sedes con esos filtros.</p>
        <p class="text-white/45 text-sm mt-2">Prueba limpiando país/continente o cambiando el texto de búsqueda.</p>
      </div>
    </div>
  </section>

  <script is:inline nonce={cspNonce}>
    (() => {
      const normalize = (value) =>
        String(value || '')
          .toLowerCase()
          .normalize('NFD')
          .replace(/[\u0300-\u036f]/g, '');

      const searchInput = document.getElementById('churches-search');
      const cards = Array.from(document.querySelectorAll('#churches-grid article'));
      const countEl = document.getElementById('churches-count');
      const emptyState = document.getElementById('churches-empty');

      const continentButtons = Array.from(document.querySelectorAll('#continent-chips [data-continent]'));
      const countryButtons = Array.from(document.querySelectorAll('#country-chips [data-country]'));
      const cityButtons = Array.from(document.querySelectorAll('#city-chips [data-city]'));

      let selectedContinent = '';
      let selectedCountry = '';
      let selectedCity = '';

      const setButtonState = (buttons, key, value) => {
        buttons.forEach((button) => {
          const isActive = (button.dataset[key] || '') === value;
          button.classList.toggle('filter-chip-active', isActive);
          button.setAttribute('aria-pressed', isActive ? 'true' : 'false');
        });
      };

      const syncCountryChipVisibility = () => {
        countryButtons.forEach((button) => {
          const buttonContinent = button.dataset.continent || '';
          const shouldShow = !selectedContinent || !buttonContinent || buttonContinent === selectedContinent;
          button.classList.toggle('hidden', !shouldShow);

          if (!shouldShow && (button.dataset.country || '') === selectedCountry) {
            selectedCountry = '';
          }
        });
      };

      const syncCityChipVisibility = () => {
        cityButtons.forEach((button) => {
          const buttonCity = button.dataset.city || '';
          if (!buttonCity) {
            button.classList.remove('hidden');
            return;
          }

          const buttonContinent = button.dataset.continent || '';
          const buttonCountry = button.dataset.country || '';
          const matchesContinent = !selectedContinent || buttonContinent === selectedContinent;
          const matchesCountry = !selectedCountry || buttonCountry === selectedCountry;
          const shouldShow = matchesContinent && matchesCountry;

          button.classList.toggle('hidden', !shouldShow);

          if (!shouldShow && buttonCity === selectedCity) {
            selectedCity = '';
          }
        });
      };

      const dispatchMapFocus = () => {
        window.dispatchEvent(
          new CustomEvent('mana:church-country-focus', {
            detail: { country: selectedCountry || '', city: selectedCity || '' },
          }),
        );
      };

      const filter = () => {
        const term = normalize(searchInput?.value || '');
        let visible = 0;

        cards.forEach((card) => {
          const city = normalize(card.dataset.city || '');
          const name = normalize(card.dataset.name || '');
          const address = normalize(card.dataset.address || '');
          const notes = normalize(card.dataset.notes || '');
          const service = normalize(card.dataset.service || '');
          const country = card.dataset.country || '';
          const continent = card.dataset.continent || '';

          const matchesText = !term || city.includes(term) || name.includes(term) || address.includes(term) || notes.includes(term) || service.includes(term);
          const matchesContinent = !selectedContinent || continent === selectedContinent;
          const matchesCountry = !selectedCountry || country === selectedCountry;
          const matchesCity = !selectedCity || normalize(card.dataset.city || '') === normalize(selectedCity);

          const show = matchesText && matchesContinent && matchesCountry && matchesCity;
          card.classList.toggle('hidden', !show);
          if (show) visible += 1;
        });

        if (countEl) countEl.textContent = String(visible);
        emptyState?.classList.toggle('hidden', visible > 0);
      };

      continentButtons.forEach((button) => {
        button.addEventListener('click', () => {
          selectedContinent = button.dataset.continent || '';
          setButtonState(continentButtons, 'continent', selectedContinent);
          syncCountryChipVisibility();
          syncCityChipVisibility();
          setButtonState(countryButtons, 'country', selectedCountry);
          setButtonState(cityButtons, 'city', selectedCity);
          filter();
          dispatchMapFocus();
        });
      });

      countryButtons.forEach((button) => {
        button.addEventListener('click', () => {
          selectedCountry = button.dataset.country || '';
          setButtonState(countryButtons, 'country', selectedCountry);
          syncCityChipVisibility();
          setButtonState(cityButtons, 'city', selectedCity);
          filter();
          dispatchMapFocus();
        });
      });

      cityButtons.forEach((button) => {
        button.addEventListener('click', () => {
          selectedCity = button.dataset.city || '';
          setButtonState(cityButtons, 'city', selectedCity);
          filter();
          dispatchMapFocus();
        });
      });

      if (searchInput) {
        searchInput.addEventListener('input', filter);
      }

      syncCountryChipVisibility();
      syncCityChipVisibility();
      setButtonState(continentButtons, 'continent', selectedContinent);
      setButtonState(countryButtons, 'country', selectedCountry);
      setButtonState(cityButtons, 'city', selectedCity);
      filter();
      dispatchMapFocus();
    })();
  </script>

  <style>
    .font-intro {
      font-family: 'Intro', sans-serif;
      font-weight: 900;
    }

    .font-intro-reg {
      font-family: 'Intro', sans-serif;
      font-weight: 400;
    }

    .filter-chip {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      border-radius: 999px;
      border: 1px solid rgba(255, 255, 255, 0.16);
      background: rgba(255, 255, 255, 0.04);
      color: rgba(255, 255, 255, 0.78);
      padding: 0.46rem 0.82rem;
      font-family: 'Intro', sans-serif;
      font-size: 11px;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      transition: all 140ms ease;
      cursor: pointer;
    }

    .filter-chip:hover {
      border-color: rgba(45, 212, 191, 0.6);
      color: rgba(255, 255, 255, 0.95);
      background: rgba(45, 212, 191, 0.12);
    }

    .filter-chip-active {
      background: rgba(45, 212, 191, 0.18);
      border-color: rgba(45, 212, 191, 0.75);
      color: #ccfbf1;
      box-shadow: 0 0 0 1px rgba(45, 212, 191, 0.32);
    }

    .chip-count {
      background: rgba(13, 22, 38, 0.65);
      border: 1px solid rgba(255, 255, 255, 0.12);
      color: rgba(255, 255, 255, 0.88);
      border-radius: 999px;
      font-size: 10px;
      line-height: 1;
      padding: 0.25rem 0.4rem;
