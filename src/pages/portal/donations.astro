---
import BaseLayout from '@layouts/BaseLayout.astro';
import Sidebar from '@components/portal/Sidebar.astro';
---

<BaseLayout title="Donaciones | Portal Maná" description="Todas las donaciones del ministerio." hideHeader hideFooter noindex>
  <div class="portal-shell min-h-screen bg-[#F8FAFC]">
    <div class="flex flex-col lg:flex-row min-h-screen">
      <Sidebar />

      <section class="flex-1 p-4 md:p-10 lg:p-16 relative overflow-y-auto">
        <div id="donations-gate" class="portal-panel max-w-xl mx-auto px-6 py-8 text-center text-slate-500">
          Validando permisos...
        </div>

        <div id="donations-secure-content" class="hidden max-w-7xl mx-auto space-y-8">
          <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
            <div>
              <h1 class="text-3xl font-display font-bold text-[#293C74]">Donaciones</h1>
              <p class="text-slate-600">Donaciones autorizadas para tu alcance, con concepto, destino y donante.</p>
              <p id="donations-scope-label" class="mt-4 w-fit rounded-full border border-[#293C74]/15 bg-white px-4 py-2 text-xs font-bold text-[#293C74]">
                Verificando alcance…
              </p>
            </div>
            <div class="grid w-full gap-2 sm:grid-cols-3 lg:w-auto">
              <select id="donations-status" aria-label="Filtrar donaciones por estado" class="min-h-11 w-full rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-700">
                <option value="all">Todos los estados</option>
                <option value="approved">Aprobadas</option>
                <option value="pending">Pendientes</option>
                <option value="failed">Fallidas</option>
              </select>
              <select id="donations-domain" aria-label="Filtrar donaciones por concepto" class="min-h-11 w-full rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-700">
                <option value="">Todos los conceptos</option>
                <option value="DONATION">Donaciones generales</option>
                <option value="CAMPUS">Campus</option>
                <option value="CUMBRE">Eventos</option>
                <option value="PRIMICIAS">Primicias</option>
                <option value="OTHER">Otros</option>
              </select>
              <select id="donations-page-size" aria-label="Cantidad de donaciones por carga" class="min-h-11 w-full rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-700">
                <option value="10">10 por carga</option>
                <option value="25">25 por carga</option>
                <option value="50">50 por carga</option>
              </select>
            </div>
          </div>

          <div class="portal-stat-grid grid-cols-2 sm:grid-cols-3">
            <div class="portal-stat">
              <p class="portal-stat-label">Registros filtrados</p>
              <p class="portal-stat-value" id="donations-stat-count">0</p>
            </div>
            <div class="portal-stat">
              <p class="portal-stat-label">COP aprobado visible</p>
              <p class="portal-stat-value !text-brand-teal" id="donations-stat-cop">$ 0</p>
            </div>
            <div class="portal-stat col-span-2 sm:col-span-1">
              <p class="portal-stat-label">USD aprobado visible</p>
              <p class="portal-stat-value" id="donations-stat-usd">$ 0</p>
            </div>
          </div>

          <div class="portal-panel p-4 md:p-6">
            <div class="mb-4 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
              <p id="donations-page-info" class="text-xs font-bold uppercase tracking-widest text-slate-400">
                Preparando donaciones...
              </p>
            </div>
            <div id="donations-feedback" class="hidden rounded-xl border px-4 py-4 text-sm font-semibold" role="status" aria-live="polite"></div>
            <div id="donations-loading" class="py-12 text-center text-slate-400 animate-pulse" role="status" aria-live="polite">Cargando donaciones...</div>

            <div class="portal-table-frame">
              <table id="donations-table" class="portal-responsive-table hidden w-full text-left border-collapse">
                <thead>
                  <tr class="text-xs text-slate-400 border-b border-slate-100">
                    <th class="font-bold uppercase tracking-widest py-4 pl-2">Fecha</th>
                    <th class="font-bold uppercase tracking-widest py-4">Concepto</th>
                    <th class="font-bold uppercase tracking-widest py-4">Destino</th>
                    <th class="font-bold uppercase tracking-widest py-4">Donante</th>
                    <th class="font-bold uppercase tracking-widest py-4">Contacto</th>
                    <th class="font-bold uppercase tracking-widest py-4">Estado</th>
                    <th class="font-bold uppercase tracking-widest py-4 text-right pr-2">Monto</th>
                  </tr>
                </thead>
                <tbody class="text-sm text-slate-600 divide-y divide-slate-50"></tbody>
              </table>
            </div>

            <div id="donations-empty" class="hidden text-center py-12 text-slate-400 text-sm">
              No hay donaciones para este filtro.
            </div>

            <div class="mt-6 flex justify-center">
              <button id="donations-load-more" type="button" class="hidden min-h-11 rounded-md border border-[#293C74]/20 px-4 py-2 text-xs font-bold uppercase text-[#293C74] hover:bg-[#293C74]/5 disabled:cursor-wait disabled:opacity-60">
                Cargar más
              </button>
            </div>
          </div>
        </div>
      </section>
    </div>
  </div>

  <div id="donations-sync-modal" class="fixed inset-0 z-[70] hidden items-center justify-center bg-slate-950/60 p-4" role="dialog" aria-modal="true" aria-labelledby="donations-sync-title" aria-describedby="donations-sync-description" aria-hidden="true">
    <div class="max-h-screen w-full max-w-xl overflow-y-auto rounded-2xl bg-white p-8 shadow-2xl">
      <div class="flex items-start justify-between gap-4">
        <div>
          <p class="text-xs font-bold uppercase tracking-widest text-amber-700">Operación sensible</p>
          <h2 id="donations-sync-title" class="mt-2 text-2xl font-bold text-[#293C74]">Conciliar estado en Wompi</h2>
        </div>
        <button id="donations-sync-close" type="button" class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-full border border-slate-200 text-xl text-slate-600 hover:bg-slate-50" aria-label="Cerrar conciliación de Wompi">×</button>
      </div>

      <p id="donations-sync-description" class="mt-4 text-sm leading-6 text-slate-600">
        Esta acción consulta un pago existente y actualiza su estado local. No crea un cobro ni mueve dinero.
      </p>
      <p class="mt-4 rounded-xl bg-slate-50 px-4 py-4 text-sm text-slate-700">
        Referencia: <strong id="donations-sync-reference" class="break-all text-[#293C74]"></strong>
      </p>

      <form id="donations-sync-form" class="mt-8 space-y-8" novalidate>
        <div>
          <label for="donations-sync-transaction" class="mb-2 block text-sm font-bold text-slate-700">ID de transacción de Wompi <span class="font-normal text-slate-500">(opcional)</span></label>
          <input id="donations-sync-transaction" name="transactionId" type="text" inputmode="text" autocomplete="off" spellcheck="false" class="min-h-11 w-full rounded-lg border border-slate-200 px-4 py-2 text-sm text-slate-800 focus:border-[#293C74] focus:ring-[#293C74]" aria-describedby="donations-sync-transaction-help donations-sync-feedback" />
          <p id="donations-sync-transaction-help" class="mt-2 text-xs leading-5 text-slate-500">Déjalo vacío si la referencia ya tiene una transacción asociada. No pegues llaves privadas ni credenciales.</p>
        </div>

        <div id="donations-sync-manual" class="hidden rounded-xl border border-red-200 bg-red-50 p-4">
          <p class="text-sm font-bold text-red-800">Aprobación manual excepcional</p>
          <p class="mt-2 text-sm leading-6 text-red-700">Úsala solo después de confirmar en el panel oficial de Wompi que la referencia, el monto y la moneda coinciden.</p>
          <label class="mt-4 flex min-h-11 cursor-pointer items-start gap-4 text-sm font-semibold text-red-900">
            <input id="donations-sync-manual-confirm" type="checkbox" class="mt-2 h-5 w-5 rounded border-red-300 text-red-700 focus:ring-red-600" />
            <span>Confirmo que verifiqué este pago directamente en Wompi.</span>
          </label>
          <button id="donations-sync-manual-submit" type="button" class="mt-4 hidden min-h-11 w-full rounded-lg bg-red-700 px-4 py-2 text-sm font-bold text-white hover:bg-red-800 disabled:cursor-not-allowed disabled:opacity-60" disabled>
            Aprobar manualmente
          </button>
        </div>

        <p id="donations-sync-feedback" class="min-h-6 text-sm font-semibold text-slate-600" role="status" aria-live="polite"></p>

        <div class="flex flex-col-reverse gap-4 sm:flex-row sm:justify-end">
          <button id="donations-sync-cancel" type="button" class="min-h-11 rounded-lg border border-slate-200 px-4 py-2 text-sm font-bold text-slate-700 hover:bg-slate-50">Cancelar</button>
          <button id="donations-sync-submit" type="submit" class="min-h-11 rounded-lg bg-[#293C74] px-4 py-2 text-sm font-bold text-white hover:bg-[#20315f] disabled:cursor-wait disabled:opacity-60">Consultar estado</button>
        </div>
      </form>
    </div>
  </div>
  <script>
    import '@scripts/portal-donations.js';
  </script>
</BaseLayout>
