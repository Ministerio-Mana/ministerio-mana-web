---
import BaseLayout from '@layouts/BaseLayout.astro';
import Sidebar from '@components/portal/Sidebar.astro';
---

<BaseLayout title="Donaciones | Portal Maná" description="Todas las donaciones del ministerio." hideHeader hideFooter noindex>
  <div class="portal-shell min-h-screen bg-[#F8FAFC]">
    <div class="flex flex-col lg:flex-row min-h-screen">
      <Sidebar />

      <section class="flex-1 p-4 md:p-10 lg:p-16 relative overflow-y-auto">
        <div id="donations-gate" class="portal-panel max-w-xl mx-auto px-6 py-8 text-center text-slate-500">
          Validando permisos...
        </div>

        <div id="donations-secure-content" class="hidden max-w-7xl mx-auto space-y-8">
          <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
            <div>
              <h1 class="text-3xl font-display font-bold text-[#293C74]">Donaciones</h1>
              <p class="text-slate-600">Donaciones autorizadas para tu alcance, con concepto, destino y donante.</p>
              <p id="donations-scope-label" class="mt-3 w-fit rounded-full border border-[#293C74]/15 bg-white px-4 py-2 text-xs font-bold text-[#293C74]">
                Verificando alcance…
              </p>
            </div>
            <div class="grid w-full gap-2 sm:grid-cols-3 lg:w-auto">
              <select id="donations-status" aria-label="Filtrar donaciones por estado" class="w-full rounded-lg border border-slate-200 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700">
                <option value="all">Todos los estados</option>
                <option value="approved">Aprobadas</option>
                <option value="pending">Pendientes</option>
                <option value="failed">Fallidas</option>
              </select>
              <select id="donations-domain" aria-label="Filtrar donaciones por concepto" class="w-full rounded-lg border border-slate-200 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700">
                <option value="">Todos los conceptos</option>
                <option value="DONATION">Donaciones generales</option>
                <option value="CAMPUS">Campus</option>
                <option value="CUMBRE">Eventos</option>
                <option value="PRIMICIAS">Primicias</option>
                <option value="OTHER">Otros</option>
              </select>
              <select id="donations-page-size" aria-label="Cantidad de donaciones por carga" class="w-full rounded-lg border border-slate-200 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700">
                <option value="10">10 por carga</option>
                <option value="25">25 por carga</option>
                <option value="50">50 por carga</option>
              </select>
            </div>
          </div>

          <div class="portal-stat-grid grid-cols-2 sm:grid-cols-3">
            <div class="portal-stat">
              <p class="portal-stat-label">Registros filtrados</p>
              <p class="portal-stat-value" id="donations-stat-count">0</p>
            </div>
            <div class="portal-stat">
              <p class="portal-stat-label">COP en esta carga</p>
              <p class="portal-stat-value !text-brand-teal" id="donations-stat-cop">$ 0</p>
            </div>
            <div class="portal-stat col-span-2 sm:col-span-1">
              <p class="portal-stat-label">USD en esta carga</p>
              <p class="portal-stat-value" id="donations-stat-usd">$ 0</p>
            </div>
          </div>

          <div class="portal-panel p-4 md:p-6">
            <div class="mb-4 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
              <p id="donations-page-info" class="text-xs font-bold uppercase tracking-widest text-slate-400">
                Preparando donaciones...
              </p>
            </div>
            <div id="donations-loading" class="py-12 text-center text-slate-400 animate-pulse">Cargando donaciones...</div>

            <div class="portal-table-frame">
              <table id="donations-table" class="portal-responsive-table hidden w-full text-left border-collapse">
                <thead>
                  <tr class="text-xs text-slate-400 border-b border-slate-100">
                    <th class="font-bold uppercase tracking-widest py-3 pl-2">Fecha</th>
                    <th class="font-bold uppercase tracking-widest py-3">Concepto</th>
                    <th class="font-bold uppercase tracking-widest py-3">Destino</th>
                    <th class="font-bold uppercase tracking-widest py-3">Donante</th>
                    <th class="font-bold uppercase tracking-widest py-3">Contacto</th>
                    <th class="font-bold uppercase tracking-widest py-3">Estado</th>
                    <th class="font-bold uppercase tracking-widest py-3 text-right pr-2">Monto</th>
                  </tr>
                </thead>
                <tbody class="text-sm text-slate-600 divide-y divide-slate-50"></tbody>
              </table>
            </div>

            <div id="donations-empty" class="hidden text-center py-10 text-slate-400 text-sm">
              No hay donaciones para este filtro.
            </div>

            <div class="mt-6 flex justify-center">
              <button id="donations-load-more" type="button" class="hidden min-h-10 rounded-md border border-[#293C74]/20 px-5 py-2 text-xs font-bold uppercase text-[#293C74] hover:bg-[#293C74]/5 disabled:cursor-wait disabled:opacity-60">
                Cargar más
              </button>
            </div>
          </div>
        </div>
      </section>
    </div>
  </div>
  <script>
    import '@scripts/portal-donations.js';
  </script>
</BaseLayout>
