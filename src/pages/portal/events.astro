---
import BaseLayout from '@layouts/BaseLayout.astro';
import PortalIcon from '@components/portal/PortalIcon.astro';
import Sidebar from '@components/portal/Sidebar.astro';
---

<BaseLayout title="Gestión de Eventos | Portal Maná" description="Crea y administra eventos según tu alcance pastoral." hideHeader hideFooter noindex>
  <div class="portal-shell min-h-screen bg-[#F5F7FA] text-slate-800">
    <div class="flex min-h-screen flex-col lg:flex-row">
      <Sidebar />

      <main class="min-w-0 flex-1 overflow-y-auto p-4 sm:p-6 lg:p-10">
        <div id="events-gate" class="portal-panel mx-auto max-w-xl px-6 py-8 text-center text-slate-500">
          Validando permisos...
        </div>

        <div id="events-secure-content" class="mx-auto hidden max-w-7xl space-y-6">
          <header class="flex flex-col gap-4 border-b border-slate-200 pb-5 sm:flex-row sm:items-end sm:justify-between">
            <div>
              <p class="mb-1 text-xs font-bold uppercase text-slate-500">Operación y seguimiento</p>
              <h1 class="font-display text-3xl font-bold text-[#293C74]">Eventos</h1>
              <p class="mt-1 max-w-2xl text-sm text-slate-600">Organiza el calendario de tu iglesia, región o país según tus permisos.</p>
            </div>
            <button id="btn-new-event" type="button" class="inline-flex min-h-11 items-center justify-center gap-2 rounded-md bg-[#293C74] px-4 py-2.5 text-sm font-bold text-white transition-colors hover:bg-[#20315f]">
              <PortalIcon name="plus" size={18} />
              Nuevo evento
            </button>
          </header>

          <section aria-label="Resumen de eventos" class="portal-stat-grid grid-cols-2 lg:grid-cols-4">
            <div class="portal-stat"><p class="portal-stat-label">Visibles</p><p id="event-stat-visible" class="portal-stat-value">0</p></div>
            <div class="portal-stat"><p class="portal-stat-label">Próximos</p><p id="event-stat-upcoming" class="portal-stat-value">0</p></div>
            <div class="portal-stat"><p class="portal-stat-label">Terminados</p><p id="event-stat-completed" class="portal-stat-value">0</p></div>
            <div class="portal-stat"><p class="portal-stat-label">Borradores</p><p id="event-stat-drafts" class="portal-stat-value">0</p></div>
          </section>

          <section class="portal-panel p-3 sm:p-4" aria-label="Filtros de eventos">
            <div class="flex flex-col gap-3 xl:flex-row xl:items-center xl:justify-between">
              <div id="event-filters" class="flex max-w-full gap-1 overflow-x-auto pb-1" role="tablist" aria-label="Estado del evento">
                <button type="button" class="event-filter is-active" data-event-filter="active" role="tab" aria-selected="true">Activos <span data-filter-count="active">0</span></button>
                <button type="button" class="event-filter" data-event-filter="upcoming" role="tab" aria-selected="false">Próximos <span data-filter-count="upcoming">0</span></button>
                <button type="button" class="event-filter" data-event-filter="live" role="tab" aria-selected="false">En curso <span data-filter-count="live">0</span></button>
                <button type="button" class="event-filter" data-event-filter="completed" role="tab" aria-selected="false">Terminados <span data-filter-count="completed">0</span></button>
                <button type="button" class="event-filter" data-event-filter="draft" role="tab" aria-selected="false">Borradores <span data-filter-count="draft">0</span></button>
                <button type="button" class="event-filter" data-event-filter="archived" role="tab" aria-selected="false">Archivados <span data-filter-count="archived">0</span></button>
              </div>

              <div class="grid gap-2 sm:grid-cols-[minmax(220px,1fr)_160px] xl:w-[470px]">
                <label class="relative block">
                  <span class="sr-only">Buscar evento</span>
                  <span class="pointer-events-none absolute inset-y-0 left-3 flex items-center text-slate-400"><PortalIcon name="search" size={17} /></span>
                  <input id="event-search" type="search" class="w-full border border-slate-200 bg-white py-2 pl-10 pr-3 text-sm" placeholder="Buscar evento o lugar" autocomplete="off" />
                </label>
                <label>
                  <span class="sr-only">Filtrar por alcance</span>
                  <select id="event-scope-filter" class="w-full border border-slate-200 bg-white px-3 py-2 text-sm">
                    <option value="">Todo alcance</option>
                    <option value="LOCAL">Local</option>
                    <option value="REGIONAL">Regional</option>
                    <option value="NATIONAL">Nacional</option>
                    <option value="GLOBAL">Global</option>
                  </select>
                </label>
              </div>
            </div>
          </section>

          <div id="events-loading" class="space-y-3" aria-live="polite">
            {[1, 2, 3].map(() => (
              <div class="portal-panel flex animate-pulse gap-4 p-4">
                <div class="h-20 w-20 flex-none bg-slate-100 sm:w-28"></div>
                <div class="min-w-0 flex-1 space-y-3 py-1">
                  <div class="h-4 w-2/5 bg-slate-100"></div>
                  <div class="h-3 w-3/4 bg-slate-100"></div>
                  <div class="h-3 w-1/2 bg-slate-100"></div>
                </div>
              </div>
            ))}
          </div>

          <div id="events-list" class="hidden space-y-3" aria-live="polite"></div>

          <div id="events-empty" class="portal-panel hidden px-5 py-12 text-center">
            <span class="mx-auto mb-3 flex h-11 w-11 items-center justify-center rounded-md bg-slate-100 text-slate-500"><PortalIcon name="calendar-days" size={22} /></span>
            <h2 class="text-base font-bold text-slate-800">No hay eventos en esta vista</h2>
            <p class="mt-1 text-sm text-slate-500">Cambia el filtro o crea un evento nuevo.</p>
          </div>
        </div>
      </main>
    </div>
  </div>

  <div id="event-modal" class="fixed inset-0 z-50 hidden items-start justify-center overflow-y-auto bg-slate-950/55 p-3 sm:p-6" role="dialog" aria-modal="true" aria-labelledby="event-modal-title">
    <div class="my-auto w-full max-w-6xl overflow-hidden rounded-lg border border-slate-200 bg-white shadow-2xl">
      <div class="flex items-center justify-between border-b border-slate-200 px-4 py-3 sm:px-6">
        <div>
          <p class="text-xs font-bold uppercase text-slate-500">Gestión de eventos</p>
          <h2 id="event-modal-title" class="text-xl font-bold text-[#293C74]">Nuevo evento</h2>
        </div>
        <button id="close-modal" type="button" class="inline-flex h-10 w-10 items-center justify-center rounded-md text-slate-500 hover:bg-slate-100 hover:text-slate-800" aria-label="Cerrar">
          <PortalIcon name="x" size={22} />
        </button>
      </div>

      <div class="grid lg:grid-cols-[minmax(0,1fr)_390px]">
        <form id="event-form" class="space-y-5 p-4 sm:p-6">
          <input type="hidden" name="id" id="event-id" />

          <div class="grid gap-4 sm:grid-cols-[minmax(0,1fr)_180px]">
            <label class="event-field">Título
              <input type="text" name="title" required maxlength="160" placeholder="Encuentro de familias" />
            </label>
            <label class="event-field">Publicación
              <select name="status" id="event-status">
                <option value="DRAFT">Borrador</option>
                <option value="PUBLISHED">Publicado</option>
                <option value="ARCHIVED">Archivado</option>
              </select>
            </label>
          </div>

          <label class="event-field">Descripción
            <textarea name="description" rows="3" maxlength="600" placeholder="Información principal para los asistentes"></textarea>
          </label>

          <div class="grid gap-4 sm:grid-cols-2">
            <label class="event-field">Inicio
              <input class="js-event-datetime" type="text" name="start_date" required autocomplete="off" placeholder="Selecciona fecha y hora" />
            </label>
            <label class="event-field">Fin
              <input class="js-event-datetime" type="text" name="end_date" autocomplete="off" placeholder="Selecciona fecha y hora" />
            </label>
          </div>

          <div class="grid gap-4 sm:grid-cols-2">
            <label class="event-field">Alcance
              <select name="scope" id="event-scope">
                <option value="LOCAL">Local</option>
                <option value="REGIONAL">Regional</option>
                <option value="NATIONAL">Nacional</option>
                <option value="GLOBAL">Global</option>
              </select>
            </label>
            <div id="event-scope-region-wrapper" class="hidden">
              <label class="event-field">Región
                <select name="region_id" id="event-region-select"><option value="">Selecciona una región</option></select>
              </label>
            </div>
            <div id="event-scope-church-wrapper" class="hidden">
              <label class="event-field">Iglesia
                <select name="church_id" id="event-church-select"><option value="">Selecciona una iglesia</option></select>
              </label>
            </div>
          </div>

          <div class="grid gap-4 sm:grid-cols-2">
            <label class="event-field">Lugar
              <input type="text" name="location_name" maxlength="160" placeholder="Auditorio principal" />
            </label>
            <label class="event-field">Dirección
              <input type="text" name="location_address" maxlength="160" placeholder="Dirección del encuentro" />
            </label>
          </div>

          <div class="grid gap-4 sm:grid-cols-2">
            <label class="event-field">Ciudad
              <input type="text" name="city" maxlength="160" placeholder="Ciudad" />
            </label>
            <label class="event-field">País
              <input type="text" name="country" maxlength="160" placeholder="País" />
            </label>
          </div>

          <label class="event-field">Imagen de invitación
            <input type="url" name="banner_url" maxlength="500" placeholder="https://..." />
          </label>

          <div id="event-platform-pending" class="rounded-md border border-slate-200 bg-slate-50 px-4 py-3">
            <p class="text-sm font-bold text-slate-700">Configuración pública avanzada pendiente de activar</p>
            <p class="mt-1 text-xs leading-relaxed text-slate-500">El evento puede seguir guardándose y publicándose con la configuración actual.</p>
          </div>

          <section id="event-platform-settings" class="hidden space-y-4 border-t border-slate-200 pt-5" aria-labelledby="event-platform-title">
            <div>
              <h3 id="event-platform-title" class="text-sm font-bold text-[#293C74]">Invitación pública</h3>
              <p class="mt-1 text-xs text-slate-500">Controla dónde aparece el evento y cómo se registran los asistentes.</p>
            </div>

            <div class="grid gap-4 sm:grid-cols-2">
              <label class="event-field">Visibilidad
                <select name="visibility" data-platform-field disabled>
                  <option value="UNLISTED">Solo por enlace</option>
                  <option value="PUBLIC">Público en la agenda</option>
                  <option value="PRIVATE">Privado</option>
                </select>
              </label>
              <label class="event-field">Categoría
                <input type="text" name="category" data-platform-field disabled maxlength="80" placeholder="Familias, jóvenes, formación..." />
              </label>
            </div>

            <label class="event-field">Enlace público
              <div class="mt-1 flex min-w-0 items-center rounded-md border border-slate-200 bg-white focus-within:border-[#293C74]">
                <span class="hidden flex-none border-r border-slate-200 px-3 text-sm text-slate-500 sm:inline">/eventos/</span>
                <input id="event-slug" class="min-w-0 flex-1 border-0 !mt-0 focus:ring-0" type="text" name="slug" data-platform-field disabled maxlength="180" placeholder="encuentro-de-familias" autocapitalize="none" autocomplete="off" spellcheck="false" />
              </div>
              <span id="event-slug-hint" class="mt-1.5 block text-xs font-medium text-slate-500">Los espacios se convierten automáticamente en guiones.</span>
            </label>

            <div class="grid gap-4 sm:grid-cols-2">
              <label class="event-field">Inscripción
                <select name="registration_mode" id="event-registration-mode" data-platform-field disabled>
                  <option value="NONE">Sin inscripción</option>
                  <option value="INTERNAL">Inscripción en Maná</option>
                  <option value="EXTERNAL">Enlace externo</option>
                </select>
              </label>
              <label id="event-capacity-wrapper" class="event-field">Cupo
                <input type="number" name="capacity" data-platform-field disabled min="0" max="1000000" step="1" placeholder="Sin límite" />
              </label>
            </div>

            <div id="event-registration-url-wrapper" class="hidden">
              <label class="event-field">Enlace de inscripción
                <input type="text" name="registration_url" data-platform-field disabled maxlength="500" placeholder="https://..." />
              </label>
            </div>

            <div id="event-registration-window" class="grid gap-4 sm:grid-cols-2">
              <label class="event-field">Abre inscripciones
                <input class="js-event-datetime" type="text" name="registration_opens_at" data-platform-field disabled autocomplete="off" placeholder="Opcional" />
              </label>
              <label class="event-field">Cierra inscripciones
                <input class="js-event-datetime" type="text" name="registration_closes_at" data-platform-field disabled autocomplete="off" placeholder="Opcional" />
              </label>
            </div>

            <label class="event-field">Zona horaria
              <select name="timezone" data-platform-field disabled>
                <option value="America/Bogota">Colombia · Bogotá</option>
                <option value="America/Guayaquil">Ecuador · Guayaquil</option>
                <option value="America/Mexico_City">México · Ciudad de México</option>
                <option value="America/Panama">Centroamérica · Panamá</option>
                <option value="America/New_York">Estados Unidos · Este</option>
                <option value="America/Chicago">Estados Unidos · Centro</option>
                <option value="America/Denver">Estados Unidos · Montaña</option>
                <option value="America/Los_Angeles">Estados Unidos · Pacífico</option>
                <option value="Europe/Madrid">Europa · Madrid</option>
                <option value="Europe/Paris">Europa · París</option>
                <option value="Australia/Sydney">Australia · Sídney</option>
                <option value="UTC">UTC</option>
              </select>
            </label>

            <label class="event-field">Correo de contacto
              <input type="email" name="contact_email" data-platform-field disabled maxlength="254" placeholder="eventos@ministeriomana.org" />
            </label>
          </section>

          <div id="event-finance-pending" class="hidden rounded-md border border-slate-200 bg-slate-50 px-4 py-3">
            <p class="text-sm font-bold text-slate-700">Operación financiera pendiente de activar</p>
          </div>

          <section id="event-finance-settings" class="hidden space-y-4 border-t border-slate-200 pt-5" aria-labelledby="event-finance-title">
            <div>
              <h3 id="event-finance-title" class="text-sm font-bold text-[#293C74]">Modalidad y cobro</h3>
              <p id="event-finance-registration-hint" class="mt-1 text-xs text-slate-500">Selecciona “Inscripción en Maná” para configurar cobros y aprobación.</p>
            </div>
            <div class="grid gap-4 sm:grid-cols-2">
              <label class="event-field">Modalidad
                <select name="attendance_mode" data-finance-field disabled>
                  <option value="IN_PERSON">Presencial</option>
                  <option value="ONLINE">Virtual</option>
                  <option value="HYBRID">Híbrido</option>
                </select>
              </label>
              <label class="event-field">Tipo de precio
                <select id="event-pricing-model" name="pricing_model" data-finance-field disabled>
                  <option value="FREE">Gratuito</option>
                  <option value="PAID">Precio fijo</option>
                  <option value="DONATION">Aporte voluntario</option>
                </select>
              </label>
            </div>
            <div class="grid gap-4 sm:grid-cols-2">
              <label class="event-field">Precio por persona
                <input id="event-price" type="text" name="price" data-finance-field disabled inputmode="decimal" autocomplete="off" maxlength="24" placeholder="0" />
              </label>
              <label class="event-field">Moneda
                <select id="event-currency" name="currency" data-finance-field disabled>
                  <option value="COP">COP · Peso colombiano</option>
                  <option value="USD">USD · Dólar estadounidense</option>
                  <option value="EUR">EUR · Euro</option>
                </select>
              </label>
            </div>
            <label id="event-online-provider-wrapper" class="event-field" hidden style="display: none;">Cobro automático
              <select id="event-online-provider" data-finance-field disabled>
                <option value="NONE">Sin cobro en línea</option>
                <option value="WOMPI">Wompi</option>
                <option value="STRIPE">Stripe</option>
              </select>
            </label>
            <div id="event-manual-payment-panel" class="space-y-2 rounded-md border border-slate-200 bg-slate-50 p-3">
              <label class="flex min-h-9 items-center gap-2 text-sm font-semibold text-slate-700">
                <input id="event-manual-payment-enabled" type="checkbox" data-finance-field disabled class="h-4 w-4 rounded border-slate-300 text-[#293C74] focus:ring-[#293C74]" />
                Aceptar pago verificado manualmente
              </label>
              <p id="event-manual-payment-hint" class="text-xs leading-relaxed text-slate-500">Disponible para eventos con inscripción en Maná y precio fijo o aporte voluntario.</p>
              <div id="event-manual-payment-settings" class="hidden space-y-3 border-t border-slate-200 pt-3">
                <div class="grid gap-4 sm:grid-cols-2">
                  <label class="event-field">Tipo de pago
                    <select id="event-manual-payment-kind" data-finance-field disabled>
                      <option value="QR_TRANSFER">Código QR</option>
                      <option value="BANK_TRANSFER">Transferencia bancaria</option>
                      <option value="EXTERNAL">Enlace de pago externo</option>
                      <option value="CASH">Efectivo</option>
                    </select>
                  </label>
                  <label class="event-field">Nombre visible
                    <input id="event-manual-payment-label" type="text" data-finance-field disabled maxlength="80" placeholder="Transferencia a la iglesia" />
                  </label>
                </div>
                <label class="event-field">Instrucciones
                  <textarea id="event-manual-payment-instructions" data-finance-field disabled rows="3" maxlength="700" placeholder="Indica el titular, banco o pasos de pago sin publicar claves privadas."></textarea>
                </label>
                <label id="event-manual-payment-url-wrapper" class="event-field hidden">Enlace HTTPS de pago
                  <input id="event-manual-payment-url" type="url" data-finance-field disabled maxlength="500" placeholder="https://..." />
                </label>
                <div id="event-manual-payment-qr-wrapper" class="hidden space-y-3">
                  <label class="event-field">Imagen del código QR
                    <input id="event-manual-payment-qr" type="file" data-finance-field disabled accept="image/png,image/jpeg,image/webp" />
                  </label>
                  <input id="event-manual-payment-qr-path" type="hidden" />
                  <img id="event-manual-payment-qr-preview" class="hidden aspect-square w-full max-w-48 rounded-md border border-slate-200 bg-white object-contain p-2" alt="Vista previa del código QR" />
                </div>
              </div>
            </div>
            <label class="flex min-h-10 items-center gap-2 rounded-md border border-slate-200 bg-white px-3 py-1.5 text-sm font-semibold text-slate-700">
              <input type="checkbox" name="registration_requires_approval" data-finance-field disabled class="h-4 w-4 rounded border-slate-300 text-[#293C74] focus:ring-[#293C74]" />
              Aprobar inscripciones antes de confirmarlas
            </label>
          </section>

          <div id="event-form-error" class="hidden rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700" role="alert"></div>

          <div class="flex flex-col-reverse gap-2 border-t border-slate-200 pt-4 sm:flex-row sm:justify-end">
            <button id="event-cancel" type="button" class="min-h-10 rounded-md border border-slate-300 px-3 py-1.5 text-sm font-bold text-slate-700 hover:bg-slate-50">Cancelar</button>
            <button type="submit" class="min-h-10 rounded-md bg-[#293C74] px-4 py-1.5 text-sm font-bold text-white hover:bg-[#20315f]">Guardar evento</button>
          </div>
        </form>

        <aside class="border-t border-slate-200 bg-slate-50 p-4 sm:p-6 lg:border-l lg:border-t-0">
          <p class="mb-3 text-xs font-bold uppercase text-slate-500">Vista previa de la invitación</p>
          <article class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
            <div id="event-preview-media" class="relative aspect-[16/9] bg-[#293C74]">
              <img id="event-preview-image" class="hidden h-full w-full object-cover" alt="" />
              <div id="event-preview-date" class="absolute bottom-3 left-3 rounded-md bg-white px-3 py-2 text-center shadow-sm">
                <span class="block text-xs font-bold uppercase text-slate-500">Fecha</span>
                <strong class="block text-lg text-[#293C74]">Por definir</strong>
              </div>
            </div>
            <div class="space-y-3 p-5">
              <div class="flex flex-wrap items-center gap-2">
                <span id="event-preview-scope" class="portal-chip bg-[#293C74]/10 text-[#293C74]">Local</span>
                <span id="event-preview-status" class="portal-chip bg-amber-50 text-amber-700">Borrador</span>
              </div>
              <h3 id="event-preview-title" class="text-xl font-bold leading-tight text-[#293C74]">Título del evento</h3>
              <p id="event-preview-description" class="text-sm leading-relaxed text-slate-600">La descripción aparecerá aquí.</p>
              <p id="event-preview-location" class="border-t border-slate-100 pt-3 text-sm font-medium text-slate-700">Lugar por definir</p>
              <p id="event-preview-price" class="text-sm font-bold text-[#293C74]">Evento gratuito</p>
              <span id="event-preview-cta" class="hidden min-h-10 items-center justify-center rounded-md bg-[#293C74] px-4 py-2 text-sm font-bold text-white">Inscribirme</span>
            </div>
          </article>
        </aside>
      </div>
    </div>
  </div>

  <style>
    .event-filter {
      display: inline-flex;
      min-height: 40px;
      flex: none;
      align-items: center;
      gap: 0.4rem;
      border-radius: 5px;
      padding: 0.45rem 0.7rem;
      color: #5d687a;
      font-size: 0.78rem;
      font-weight: 700;
      white-space: nowrap;
    }

    .event-filter span {
      min-width: 1.25rem;
      border-radius: 4px;
      background: #eef1f5;
      padding: 0.12rem 0.3rem;
      color: #4b5563;
      font-size: 0.7rem;
      text-align: center;
    }

    .event-filter:hover,
    .event-filter.is-active {
      background: #293c74;
      color: #fff;
    }

    .event-filter.is-active span {
      background: rgb(255 255 255 / 16%);
      color: #fff;
    }

    .event-field {
      display: block;
      color: #475569;
      font-size: 0.75rem;
      font-weight: 700;
    }

    .event-field :is(input, select, textarea) {
      display: block;
      width: 100%;
      margin-top: 0.35rem;
      border: 1px solid #dce2ea;
      background: #fff;
      padding: 0.5rem 0.65rem;
      color: #172033;
      font-size: 0.875rem;
      font-weight: 400;
    }

    .event-field :is(input, select) {
      min-height: 2.5rem;
    }

    .event-field textarea {
      resize: vertical;
    }

    .event-field :is(input, select, textarea):disabled {
      cursor: not-allowed;
      background: #f1f5f9;
      color: #7b8798;
    }

    :global(.flatpickr-calendar.event-calendar) {
      width: min(330px, calc(100vw - 24px));
      border: 1px solid #dce2ea;
      border-radius: 6px;
      background: #fff;
      padding: 8px;
