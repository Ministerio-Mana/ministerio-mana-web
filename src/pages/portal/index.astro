      </div>
    </div>

    <div id="portal-alert-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40 backdrop-blur-sm p-4" role="dialog" aria-modal="true" aria-labelledby="portal-alert-title" aria-describedby="portal-alert-message" aria-hidden="true">
      <div class="w-full max-w-md bg-white rounded-[2rem] shadow-2xl border border-slate-100 p-6 md:p-8" tabindex="-1">
        <div class="flex items-start justify-between gap-4">
          <div>
            <p class="text-[10px] font-bold text-[#293C74] uppercase tracking-[0.3em]">Portal Maná</p>
            <h3 id="portal-alert-title" class="text-lg font-display font-bold text-[#293C74]">Atención</h3>
          </div>
          <button id="portal-alert-close" type="button" aria-label="Cerrar aviso" class="w-11 h-11 rounded-full bg-slate-50 text-[#293C74] hover:bg-[#293C74] hover:text-white flex items-center justify-center transition-colors font-bold">
            <span aria-hidden="true">×</span>
          </button>
        </div>
        <p id="portal-alert-message" class="text-sm text-slate-600 mt-3"></p>
        <div class="mt-6 flex justify-end">
          <button id="portal-alert-ok" type="button" class="min-h-11 px-4 py-2 rounded-xl bg-[#293C74] text-white text-xs font-bold hover:bg-[#293C74]/90">Entendido</button>
        </div>
      </div>
    </div>

    <div id="portal-confirm-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40 backdrop-blur-sm p-4" role="dialog" aria-modal="true" aria-labelledby="portal-confirm-title" aria-describedby="portal-confirm-message" aria-hidden="true">
      <div class="w-full max-w-md bg-white rounded-[2rem] shadow-2xl border border-slate-100 p-6 md:p-8" tabindex="-1">
        <div class="flex items-start justify-between gap-4">
          <div>
            <p class="text-[10px] font-bold text-[#293C74] uppercase tracking-[0.3em]">Portal Maná</p>
            <h3 id="portal-confirm-title" class="text-lg font-display font-bold text-[#293C74]">Confirmar</h3>
          </div>
          <button id="portal-confirm-close" type="button" aria-label="Cerrar confirmación" class="w-11 h-11 rounded-full bg-slate-50 text-[#293C74] hover:bg-[#293C74] hover:text-white flex items-center justify-center transition-colors font-bold">
            <span aria-hidden="true">×</span>
          </button>
        </div>
        <p id="portal-confirm-message" class="text-sm text-slate-600 mt-3"></p>
        <div class="mt-6 flex flex-wrap justify-end gap-2">
          <button id="portal-confirm-cancel" type="button" class="min-h-11 px-4 py-2 rounded-xl border border-slate-200 text-xs font-bold text-slate-600 hover:bg-slate-50">Cancelar</button>
          <button id="portal-confirm-ok" type="button" class="min-h-11 px-4 py-2 rounded-xl bg-[#E15554] text-white text-xs font-bold hover:bg-[#D94B4A]">Confirmar</button>
        </div>
      </div>
    </div>

    <div id="booking-inspector-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40 backdrop-blur-sm p-4" role="dialog" aria-modal="true" aria-labelledby="booking-inspector-title" aria-describedby="booking-inspector-subtitle" aria-hidden="true">
      <div class="w-full max-w-6xl max-h-[calc(100vh-2rem)] overflow-hidden bg-white rounded-[2rem] shadow-2xl border border-slate-100 flex flex-col" tabindex="-1">
        <div class="px-6 md:px-8 py-5 border-b border-slate-100 flex items-start justify-between gap-4">
          <div class="min-w-0">
            <p class="text-[10px] font-bold text-[#293C74] uppercase tracking-[0.3em]">Reserva Cumbre</p>
            <h3 id="booking-inspector-title" class="text-xl md:text-2xl font-display font-bold text-[#293C74] truncate">Detalle de reserva</h3>
            <p id="booking-inspector-subtitle" class="text-xs text-slate-500 mt-1">Cargando...</p>
          </div>
          <button id="booking-inspector-close" type="button" aria-label="Cerrar detalle de reserva" class="w-11 h-11 rounded-full bg-slate-50 text-[#293C74] hover:bg-[#293C74] hover:text-white flex items-center justify-center transition-colors font-bold shrink-0">
            <span aria-hidden="true">×</span>
          </button>
        </div>

        <div class="px-6 md:px-8 py-4 border-b border-slate-100 bg-slate-50/60">
          <div class="relative max-w-xl">
            <label for="booking-inspector-search" class="sr-only">Buscar en esta reserva</label>
            <input id="booking-inspector-search" type="search" class="w-full min-h-11 bg-white border border-slate-200 rounded-xl pl-9 pr-4 py-2 text-sm text-[#293C74] placeholder-slate-400 focus:outline-none focus:ring-1 focus:ring-[#293C74] focus:border-[#293C74]" placeholder="Buscar en esta reserva: participante, correo, documento o referencia..." />
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-slate-400 absolute left-3 top-2.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </div>
        </div>

        <div id="booking-inspector-body" class="flex-1 overflow-auto p-6 md:p-8">
          <p class="text-sm text-slate-500">Cargando detalle...</p>
        </div>
      </div>
    </div>

    <!-- Church Selector Modal -->
    <ChurchSelector />

    <!-- Advanced Registration Modal -->
    <RegistrationModal />
  </div>

  <style>
    .nav-link.active {
      @apply bg-brand-teal text-white;
    }
    .nav-link.active span {
      @apply text-white;
    }
    .nav-link.active svg {
      @apply text-white;
    }

    @keyframes border-flow {
      0%, 100% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
    }
    .animate-border-flow {
      background-size: 200% 200%;
      animation: border-flow 6s ease infinite;
    }
  </style>

  <script>
    import '@scripts/portal-dashboard.js';
    import '@scripts/portal-user-event-view.js';
  </script>
</BaseLayout>

</body>
</html>
