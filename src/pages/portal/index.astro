---
import BaseLayout from '@layouts/BaseLayout.astro';
import ChurchSelector from '@components/portal/ChurchSelector.astro';
import PortalIcon from '@components/portal/PortalIcon.astro';
import RegistrationModal from '@components/portal/RegistrationModal.astro';
import Sidebar from '@components/portal/Sidebar.astro';
---

<BaseLayout title="Portal Maná | Ministerio Maná" description="Gestiona tus aportes y eventos en el Portal Maná." hideHeader hideFooter noindex>
  <div class="portal-shell min-h-screen bg-[#F8FAFC] text-slate-800 selection:bg-[#293C74]/20">
    <div class="flex flex-col lg:flex-row min-h-screen">
      
      <!-- Sidebar / Navigation -->
      <Sidebar />

      <!-- Main Content Area -->
      <section class="flex-1 p-4 md:p-10 lg:p-16 relative overflow-y-auto">
        <div class="max-w-6xl mx-auto">
          
          <!-- Loading State (Skeleton) -->
          <div id="account-loading" class="space-y-10 animate-pulse" role="status" aria-live="polite" aria-label="Cargando la información del panel">
            <div class="h-10 w-48 bg-slate-200 rounded-xl"></div>
            <div class="grid md:grid-cols-3 gap-6">
              <div class="h-40 bg-slate-200 rounded-[2rem]"></div>
              <div class="h-40 bg-slate-200 rounded-[2rem]"></div>
              <div class="h-40 bg-slate-200 rounded-[2rem]"></div>
            </div>
          </div>

          <div id="account-error" class="hidden text-center py-20" role="alert">
            <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-red-400/10 text-red-400 mb-6">
               <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
            </div>
            <h2 class="text-2xl font-bold mb-2">Algo salió mal</h2>
            <p class="text-slate-600">No pudimos cargar la información de tu cuenta.</p>
            <button id="account-error-retry" type="button" class="mt-6 min-h-11 px-6 py-2 bg-[#293C74] text-white rounded-xl hover:bg-[#293C74]/90 transition-all">Reintentar</button>
          </div>

          <div id="account-content" class="hidden space-y-12" aria-busy="true">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
              <div>
                <p class="text-[10px] font-bold text-slate-600 uppercase tracking-[0.3em]">Portal Maná</p>
                <h1 class="text-2xl font-display font-bold text-[#293C74]">Panel General</h1>
              </div>
              <div class="flex flex-wrap items-center gap-3">
                <a href="/" class="inline-flex min-h-11 items-center gap-2 rounded-md bg-brand-teal px-4 py-2 text-xs font-bold uppercase text-white shadow-sm transition hover:bg-brand-teal/90">
                  Ir al Inicio
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10l9-7 9 7M4 10v10a1 1 0 001 1h5m4 0h5a1 1 0 001-1V10" />
                  </svg>
                </a>
                <a href="/eventos" class="inline-flex min-h-11 items-center gap-2 rounded-md border border-[#293C74]/20 px-4 py-2 text-xs font-bold uppercase text-[#293C74] transition hover:border-[#293C74]/60 hover:bg-[#293C74]/5">
                  <PortalIcon name="calendar-days" size={16} />
                  Agenda pública
                </a>
              </div>
            </div>

            <div id="account-data-warning" class="hidden rounded-lg border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-900" role="alert">
              No se pudo cargar toda la información actualizada.
              <button id="account-data-retry" type="button" class="ml-2 min-h-11 rounded-md border border-amber-300 bg-white px-4 py-2 text-xs font-bold text-amber-900 hover:bg-amber-100">
                Reintentar
              </button>
            </div>
            
            <!-- Tab: Resumen -->
            <div id="tab-resumen" class="tab-content space-y-10" role="region" aria-labelledby="tab-resumen-title" aria-hidden="false">
              <header>
                <h2 id="tab-resumen-title" tabindex="-1" class="text-3xl lg:text-4xl font-display font-bold text-[#293C74] mb-2 outline-none">¡Hola <span id="welcome-name" class="text-brand-teal">...</span>!</h2>
                <p class="text-slate-600">Este es el resumen de tu participación en los eventos Maná.</p>
              </header>

              <div class="grid grid-cols-1 gap-3 md:grid-cols-2 lg:grid-cols-3">
                <!-- Status Card 1 -->
                <div class="portal-panel p-5">
                  <p class="mb-2 text-[10px] font-bold uppercase text-slate-600">Total aportado</p>
                  <h3 id="stat-total-paid" class="text-2xl font-display font-bold text-[#293C74] leading-tight">$0</h3>
                  <p class="text-xs text-brand-teal mt-2 font-bold">En todos tus eventos</p>
                </div>

                <!-- Status Card 2 -->
                <div class="portal-panel p-5">
                  <p class="mb-2 text-[10px] font-bold uppercase text-slate-600">Próximo abono</p>
                  <h3 id="stat-next-due" class="text-2xl font-display font-bold text-[#293C74] leading-tight">-</h3>
                  <p id="stat-next-note" class="text-xs text-[#F2C94C] mt-2 font-bold">Plan de cuotas activo</p>
                </div>

                <!-- Support Card -->
                <div class="portal-panel p-5">
                  <h3 class="mb-2 text-lg font-black text-[#293C74]">¿Necesitas ayuda?</h3>
                  <p class="mb-4 text-xs font-bold leading-relaxed text-slate-700">Si tienes dudas con tus aportes, nuestro equipo de soporte está listo para asistirte.</p>
                  <a href="https://wa.me/573148297534" class="inline-flex min-h-11 items-center gap-2 rounded-md bg-[#293C74] px-4 py-2 text-sm font-bold text-white transition-colors hover:bg-[#293C74]/90">
                    Soporte WhatsApp
                  </a>
                </div>
              </div>

              <!-- Important Alerts / Next Step -->
              <div id="plan-highlight" class="portal-panel hidden overflow-hidden border-l-4 !border-l-brand-teal p-5 md:p-6">
                <div class="flex flex-col items-center gap-5 md:flex-row">
                   <div class="w-16 h-16 rounded-2xl bg-[#F2C94C]/10 flex items-center justify-center text-[#F2C94C] shrink-0">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 16h-1.5m.5 0v-4.5m0 0V11m0 5h1m2-1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1" /></svg>
                   </div>
                   <div class="text-center md:text-left">
                      <h4 id="highlight-header" class="font-bold text-[#293C74]">Recordatorio de abono automático</h4>
                      <p class="text-slate-600 text-sm">Tu próxima cuota de <span id="highlight-amount" class="text-[#293C74] font-bold">...</span> para <span id="highlight-context" class="text-[#293C74] font-bold">Cumbre Mundial 2026</span> será procesada el <span id="highlight-date" class="text-[#293C74] font-bold">...</span>.</p>
                   </div>
                   <div class="md:ml-auto">
                      <button type="button" data-tab-trigger="reservas" class="min-h-11 text-sm font-bold text-brand-teal hover:underline px-4 py-2">Ver mis inscripciones →</button>
                   </div>
                </div>
              </div>

              <div class="space-y-6">
                <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-2">
                  <div>
                    <h3 class="text-lg font-bold text-[#293C74]">Eventos inscritos</h3>
                    <p class="text-xs text-slate-500">Resumen por evento con cuenta regresiva y próximos abonos.</p>
                  </div>
                </div>
                <div id="summary-events-list" class="grid grid-cols-1 lg:grid-cols-2 gap-6"></div>
                <div id="summary-events-empty" class="hidden p-10 text-center bg-white border border-slate-100 rounded-[2rem] shadow-sm">
                  <p class="text-slate-500">Aún no tienes eventos inscritos.</p>
                </div>
              </div>

              <div class="space-y-6">
                <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-3">
                  <div>
                    <h3 class="text-lg font-bold text-[#293C74]">Ofrendas y Diezmos</h3>
                    <p class="text-xs text-slate-500">Tus aportes y recordatorios activos.</p>
                  </div>
                  <a id="giving-cta" href="/primicias?type=diezmos&recurring=1" hidden class="inline-flex min-h-11 items-center gap-2 rounded-full bg-brand-teal text-white px-5 py-2 text-xs font-bold uppercase tracking-widest shadow-sm hover:bg-brand-teal/90 transition">
                    Programar diezmo
                  </a>
                </div>
                <div id="giving-list" class="grid grid-cols-1 md:grid-cols-2 gap-4"></div>
                <div id="giving-empty" class="hidden p-10 text-center bg-white border border-slate-100 rounded-[2rem] shadow-sm">
                  <p class="text-slate-500">Aún no tienes ofrendas ni diezmos registrados.</p>
                </div>
              </div>

              <div class="space-y-6">
                <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-3">
                  <div>
                    <h3 class="text-lg font-bold text-[#293C74]">Mis siembras Campus</h3>
                    <p class="text-xs text-slate-500">Pausa, reactiva o cancela tus apoyos mensuales a misioneros Campus.</p>
                  </div>
                  <a id="campus-cta" href="/campus" hidden class="inline-flex min-h-11 items-center gap-2 rounded-full border border-brand-teal/40 text-brand-teal px-5 py-2 text-xs font-bold uppercase tracking-widest hover:bg-brand-teal/10 transition">
                    Apoyar campus
                  </a>
                </div>
                <div id="campus-list" class="grid grid-cols-1 md:grid-cols-2 gap-4"></div>
                <div id="campus-empty" class="hidden p-10 text-center bg-white border border-slate-100 rounded-[2rem] shadow-sm">
                  <p class="text-slate-500">Aún no tienes siembras Campus registradas.</p>
                </div>
              </div>

              <div class="space-y-6">
                <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-2">
                  <div>
                    <h3 class="text-lg font-bold text-[#293C74]">Eventos cerca de ti</h3>
                    <p class="text-xs text-slate-500">Próximos encuentros en tu ciudad o país.</p>
                  </div>
                </div>
                <div id="local-events-list" class="grid grid-cols-1 md:grid-cols-2 gap-4"></div>
                <div id="local-events-empty" class="hidden p-10 text-center bg-white border border-slate-100 rounded-[2rem] shadow-sm">
                  <p class="text-slate-500">No hay eventos cercanos por ahora.</p>
                </div>
              </div>
            </div>

            <!-- Tab: Reservas -->
            <div id="tab-reservas" class="tab-content hidden space-y-10" role="region" aria-labelledby="tab-reservas-title" aria-hidden="true">
              <header>
                <h2 id="tab-reservas-title" tabindex="-1" class="text-3xl lg:text-4xl font-display font-bold text-[#293C74] mb-2 outline-none">Mis Eventos</h2>
                <p class="text-slate-600">Gestiona tus inscripciones a eventos y planes de abono.</p>
              </header>

              <div class="space-y-10">
                <div class="space-y-6">
                   <h3 class="text-xs font-bold text-slate-600 uppercase tracking-[0.3em]">Eventos Inscritos</h3>
                   <div id="bookings-list" class="grid grid-cols-1 md:grid-cols-2 gap-6"></div>
                   <div id="bookings-empty" class="hidden p-12 text-center bg-white border border-slate-100 rounded-[2rem] shadow-sm">
                    <p class="text-slate-500">Aún no tienes inscripciones para la Cumbre 2026.</p>
                   </div>
                </div>

                <div class="space-y-6">
                   <h3 class="text-xs font-bold text-slate-600 uppercase tracking-[0.3em]">Planes de Abono</h3>
                   <div id="plans-list" class="grid grid-cols-1 md:grid-cols-2 gap-6"></div>
                   <div id="plans-empty" class="hidden p-12 text-center bg-white border border-slate-100 rounded-[2rem] shadow-sm">
                    <p class="text-slate-500">No tienes planes de abono activos.</p>
                   </div>
                </div>

                <div class="space-y-6">
                   <h3 class="text-xs font-bold text-slate-600 uppercase tracking-[0.3em]">Cuotas Pendientes</h3>
                   <div id="installments-list" class="space-y-4"></div>
                   <div id="installments-empty" class="hidden p-10 text-center bg-white border border-slate-100 rounded-[2rem] shadow-sm">
                    <p class="text-slate-500">No tienes cuotas pendientes en este momento.</p>
                   </div>
                </div>
              </div>
            </div>

            <!-- Tab: Pagos -->
            <div id="tab-pagos" class="tab-content hidden space-y-10" role="region" aria-labelledby="tab-pagos-title" aria-hidden="true">
              <header>
                <h2 id="tab-pagos-title" tabindex="-1" class="text-3xl lg:text-4xl font-display font-bold text-[#293C74] mb-2 outline-none">Mis Aportes</h2>
                <p class="text-slate-600">Registro detallado de aportes y abonos realizados.</p>
              </header>

              <div class="bg-white border border-slate-100 rounded-[2.5rem] overflow-hidden shadow-lg shadow-slate-200/50">
                <div class="overflow-x-auto">
                  <table class="min-w-full text-sm">
                    <thead>
                      <tr class="text-[10px] font-bold text-[#293C74] uppercase tracking-widest border-b border-slate-100 bg-slate-50/50">
                        <th class="text-left py-6 px-8">Fecha</th>
                        <th class="text-left py-6 px-8">Referencia</th>
                        <th class="text-left py-6 px-8">Detalle</th>
                        <th class="text-right py-6 px-8">Monto</th>
                        <th class="text-center py-6 px-8">Estado</th>
                      </tr>
                    </thead>
                    <tbody id="payments-table" class="divide-y divide-slate-50"></tbody>
                  </table>
                  <div id="payments-empty" class="hidden p-20 text-center">
                    <p class="text-slate-500">No hay aportes registrados en tu historial.</p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Tab: Perfil -->
            <div id="tab-perfil" class="tab-content hidden space-y-10" role="region" aria-labelledby="tab-perfil-title" aria-hidden="true">
               <header>
                 <h2 id="tab-perfil-title" tabindex="-1" class="text-3xl lg:text-4xl font-display font-bold text-[#293C74] mb-2 outline-none">Mi Perfil</h2>
                 <p class="text-slate-600">Mantén tu información personal actualizada.</p>
               </header>

               <div class="max-w-3xl bg-white border border-slate-100 rounded-[2.5rem] p-8 md:p-10 space-y-8 shadow-lg shadow-slate-200/50">
                  <div class="grid gap-6">
                    <div class="space-y-2">
                       <label for="profile-name" class="block text-[10px] font-bold text-[#293C74] uppercase tracking-widest ml-1">Nombre Completo</label>
                       <input type="text" id="profile-name" class="w-full bg-slate-50 border border-slate-200 rounded-2xl px-5 py-4 text-[#293C74] focus:border-[#293C74] focus:ring-1 focus:ring-[#293C74] outline-none transition-all font-medium placeholder-slate-500">
                    </div>
                    <div class="space-y-2">
                       <label for="profile-email" class="block text-[10px] font-bold text-[#293C74] uppercase tracking-widest ml-1">Correo Electrónico</label>
                       <input type="email" id="profile-email" disabled class="w-full bg-slate-50 border border-slate-200 rounded-2xl px-5 py-4 text-slate-500 cursor-not-allowed">
                    </div>
                    <div class="space-y-2">
                       <label for="profile-role" class="block text-[10px] font-bold text-[#293C74] uppercase tracking-widest ml-1">Rol</label>
                       <input type="text" id="profile-role" disabled class="w-full bg-slate-50 border border-slate-200 rounded-2xl px-5 py-4 text-slate-500 cursor-not-allowed">
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                      <div class="space-y-2">
                        <label for="profile-phone" class="block text-[10px] font-bold text-[#293C74] uppercase tracking-widest ml-1">Teléfono / WhatsApp</label>
                        <input type="text" id="profile-phone" class="w-full bg-slate-50 border border-slate-200 rounded-2xl px-5 py-4 text-[#293C74] focus:border-[#293C74] focus:ring-1 focus:ring-[#293C74] outline-none transition-all font-medium placeholder-slate-500">
                      </div>
                      <div class="space-y-2">
                        <label for="profile-city" class="block text-[10px] font-bold text-[#293C74] uppercase tracking-widest ml-1">Ciudad</label>
                        <input type="text" id="profile-city" class="w-full bg-slate-50 border border-slate-200 rounded-2xl px-5 py-4 text-[#293C74] focus:border-[#293C74] focus:ring-1 focus:ring-[#293C74] outline-none transition-all font-medium placeholder-slate-500">
                      </div>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                      <div class="space-y-2">
                        <label for="profile-document-type" class="block text-[10px] font-bold text-[#293C74] uppercase tracking-widest ml-1">Tipo de documento</label>
                        <select id="profile-document-type" class="w-full bg-slate-50 border border-slate-200 rounded-2xl px-5 py-4 text-[#293C74] focus:border-[#293C74] focus:ring-1 focus:ring-[#293C74] outline-none transition-all font-medium">
                          <option value="">Selecciona una opción</option>
                          <option value="CC">CC</option>
                          <option value="CE">CE</option>
                          <option value="NIT">NIT</option>
                          <option value="TI">TI</option>
                          <option value="PAS">Pasaporte</option>
                        </select>
                      </div>
                      <div class="space-y-2">
                        <label for="profile-document-number" class="block text-[10px] font-bold text-[#293C74] uppercase tracking-widest ml-1">Número de documento</label>
                        <input type="text" id="profile-document-number" class="w-full bg-slate-50 border border-slate-200 rounded-2xl px-5 py-4 text-[#293C74] focus:border-[#293C74] focus:ring-1 focus:ring-[#293C74] outline-none transition-all font-medium placeholder-slate-500">
                      </div>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                      <div class="space-y-2">
                        <label for="profile-country" class="block text-[10px] font-bold text-[#293C74] uppercase tracking-widest ml-1">País</label>
                        <input type="text" id="profile-country" class="w-full bg-slate-50 border border-slate-200 rounded-2xl px-5 py-4 text-[#293C74] focus:border-[#293C74] focus:ring-1 focus:ring-[#293C74] outline-none transition-all font-medium placeholder-slate-500">
                      </div>
                      <div class="space-y-2">
                        <label for="profile-affiliation" class="block text-[10px] font-bold text-[#293C74] uppercase tracking-widest ml-1">Mi relación con Maná</label>
                        <select id="profile-affiliation" class="w-full bg-slate-50 border border-slate-200 rounded-2xl px-5 py-4 text-[#293C74] focus:border-[#293C74] focus:ring-1 focus:ring-[#293C74] outline-none transition-all font-medium">
                          <option value="">Selecciona una opción</option>
                          <option value="local">Asisto a una sede</option>
                          <option value="online">Soy Maná Online</option>
                          <option value="none">Prefiero no seleccionar</option>
                        </select>
                      </div>
                    </div>
                    <div id="profile-church-wrapper" class="space-y-2 hidden">
                      <label for="profile-church-name" class="block text-[10px] font-bold text-[#293C74] uppercase tracking-widest ml-1">Nombre de la sede / iglesia</label>
                      <input type="text" id="profile-church-name" class="w-full bg-slate-50 border border-slate-200 rounded-2xl px-5 py-4 text-[#293C74] focus:border-[#293C74] focus:ring-1 focus:ring-[#293C74] outline-none transition-all font-medium placeholder-slate-500" placeholder="Ej: Maná Medellín">
                    </div>
                  </div>


                  <div class="pt-4 flex items-center justify-between gap-4">
                     <p id="profile-status" class="text-sm font-medium"></p>
                     <button id="btn-save-profile" type="button" class="min-h-11 bg-[#293C74] text-white px-8 py-3 rounded-2xl font-bold hover:shadow-lg hover:shadow-[#293C74]/20 hover:-translate-y-0.5 transition-all text-sm">
                        Guardar Personales
                     </button>
                  </div>
               </div>

               <!-- Security Section -->
               <div class="max-w-3xl bg-white border border-slate-100 rounded-[2.5rem] p-8 md:p-10 space-y-6 shadow-lg shadow-slate-200/50">
                  <div>
                    <h3 class="text-lg font-bold text-[#293C74]">Seguridad</h3>
                    <p class="text-sm text-slate-600">Actualiza tu contraseña para ingresar sin enlace mágico.</p>
                  </div>
                  
                  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="space-y-2">
                      <label for="security-new-password" class="block text-[10px] font-bold text-[#293C74] uppercase tracking-widest ml-1">Nueva Contraseña</label>
                      <input type="password" id="security-new-password" minlength="10" aria-describedby="security-password-help" class="w-full bg-slate-50 border border-slate-200 rounded-2xl px-5 py-4 text-[#293C74] focus:border-[#293C74] focus:ring-1 focus:ring-[#293C74] outline-none transition-all placeholder-slate-400" placeholder="Mínimo 10 caracteres">
                      <p id="security-password-help" class="text-xs leading-relaxed text-slate-600">Usa mínimo 10 caracteres, con mayúscula, minúscula, número y símbolo.</p>
                    </div>
                    <div class="space-y-2">
                       <button id="btn-update-password" type="button" class="w-full min-h-11 h-full mt-6 md:mt-0 bg-white border border-[#293C74]/20 text-[#293C74] px-6 py-4 rounded-2xl font-bold hover:bg-[#293C74] hover:text-white transition-all text-sm">
                          Actualizar Contraseña
                       </button>
                    </div>
                  </div>
                  <p id="security-status" class="text-sm font-medium text-slate-500 min-h-[1.25rem]"></p>
                  
                  <!-- Passkeys Section (Hidden for now) -->
                  <div class="hidden pt-6 border-t border-slate-100 mt-2">
                     <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
                        <div>
                           <div class="flex items-center gap-2 mb-1">
                              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-[#293C74]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 11c0 3.517-1.009 6.799-2.753 9.571m-3.44-2.04l.054-.09A13.916 13.916 0 008 11a4 4 0 118 0c0 1.017-.07 2.019-.203 3m-2.118 6.844A21.88 21.88 0 0015.171 17m3.839 1.132c.645-2.266.99-4.659.99-7.131A8 8 0 008 8m8.363 12.18c.201-.06.401-.123.6-.192" /></svg>
