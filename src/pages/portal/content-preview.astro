---
import BaseLayout from '@layouts/BaseLayout.astro';
import PortalIcon from '@components/portal/PortalIcon.astro';
---

<BaseLayout title="Vista previa de contenido | Portal Maná" description="Vista previa privada del contenido editorial." hideHeader hideFooter noindex>
  <main class="min-h-screen bg-[#F5F7FA] text-slate-800">
    <header class="sticky top-0 z-20 border-b border-slate-200 bg-white/95 px-4 py-3 backdrop-blur sm:px-6">
      <div class="mx-auto flex max-w-6xl items-center justify-between gap-4">
        <a href="/portal/content" class="inline-flex min-h-10 items-center gap-2 rounded-md px-3 py-2 text-sm font-bold text-[#293C74] hover:bg-slate-100">
          <PortalIcon name="arrow-left" size={18} />
          Volver a Contenido
        </a>
        <span id="cms-preview-status" class="portal-chip bg-amber-50 text-amber-700">Vista previa privada</span>
      </div>
    </header>

    <div class="mx-auto max-w-6xl px-4 py-6 sm:px-6 sm:py-10">
      <div id="cms-preview-loading" class="portal-panel px-6 py-12 text-center text-slate-500">Cargando vista previa...</div>
      <div id="cms-preview-error" class="portal-panel hidden border-red-200 bg-red-50 px-6 py-8 text-center text-red-700" role="alert"></div>
      <article id="cms-preview-root" class="hidden space-y-5"></article>
    </div>
  </main>

  <script src="../../scripts/portal-content-preview.js"></script>
</BaseLayout>
