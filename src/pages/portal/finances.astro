---
import BaseLayout from '@layouts/BaseLayout.astro';
import Sidebar from '@components/portal/Sidebar.astro';
---

<BaseLayout title="Finanzas | Portal Maná" description="Reportes financieros y control de diezmos." hideHeader hideFooter noindex>
  <div class="portal-shell min-h-screen bg-[#F8FAFC]">
    <div class="flex flex-col lg:flex-row min-h-screen">
      <Sidebar />
      
      <section class="flex-1 p-4 md:p-10 lg:p-16 relative overflow-y-auto">
         <div id="finances-gate" class="portal-panel max-w-xl mx-auto px-6 py-8 text-center text-slate-500">
            <div id="finances-loading" class="py-12 text-center text-slate-400 animate-pulse">Cargando datos...</div>
         </div>

         <div id="finances-secure-content" class="hidden max-w-6xl mx-auto space-y-8">
            <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
               <div>
                  <h1 class="text-3xl font-display font-bold text-[#293C74]">Finanzas</h1>
                  <p class="text-slate-600">Resumen de los movimientos autorizados para tu alcance.</p>
               </div>
               <p id="finances-scope-label" class="w-fit rounded-full border border-[#293C74]/15 bg-white px-4 py-2 text-xs font-bold text-[#293C74]">
                  Verificando alcance…
               </p>
            </div>

            <form id="finances-filters" class="portal-panel p-4 md:p-6" aria-labelledby="finances-filters-title">
               <div class="flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
                  <div>
                     <h2 id="finances-filters-title" class="text-lg font-bold text-[#293C74]">Filtrar movimientos</h2>
                     <p id="finances-filter-summary" class="mt-1 text-xs text-slate-500">Todo el historial · Todas las cuentas · COP y USD separados</p>
                  </div>
                  <div class="flex flex-wrap gap-2">
                     <button id="finances-export-cop" type="button" class="min-h-10 rounded-md border border-[#293C74]/20 bg-white px-4 py-2 text-xs font-bold text-[#293C74] hover:bg-[#293C74]/5 disabled:cursor-wait disabled:opacity-50">
                        Descargar CSV · COP
                     </button>
                     <button id="finances-export-usd" type="button" class="min-h-10 rounded-md border border-cyan-200 bg-cyan-50 px-4 py-2 text-xs font-bold text-cyan-800 hover:bg-cyan-100 disabled:cursor-wait disabled:opacity-50">
                        Descargar CSV · USD
                     </button>
                  </div>
               </div>

               <div class="mt-5 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
                  <div>
                     <label for="finances-period-filter" class="mb-1 block text-xs font-bold uppercase tracking-widest text-slate-500">Período</label>
                     <select id="finances-period-filter" class="min-h-11 w-full rounded-md border-slate-200 bg-white text-sm text-[#293C74]">
                        <option value="all">Todo el historial</option>
                        <option value="month">Este mes</option>
                        <option value="30d">Últimos 30 días</option>
                        <option value="year">Este año</option>
                        <option value="custom">Fechas personalizadas</option>
                     </select>
                  </div>
                  <div>
                     <label for="finances-account-filter" class="mb-1 block text-xs font-bold uppercase tracking-widest text-slate-500">Cuenta o proveedor</label>
                     <select id="finances-account-filter" class="min-h-11 w-full rounded-md border-slate-200 bg-white text-sm text-[#293C74]">
                        <option value="">Todas las cuentas autorizadas</option>
                        <option value="WOMPI">Wompi · Nacional Colombia</option>
                        <option value="STRIPE">Stripe · Global</option>
                        <option value="LOCAL">Cuentas locales</option>
                        <option value="REGIONAL">Cuentas regionales</option>
                        <option value="NATIONAL">Todas las cuentas nacionales</option>
                        <option value="GLOBAL">Todas las cuentas globales</option>
                     </select>
                  </div>
                  <div>
                     <label for="finances-currency-filter" class="mb-1 block text-xs font-bold uppercase tracking-widest text-slate-500">Moneda en pantalla</label>
                     <select id="finances-currency-filter" class="min-h-11 w-full rounded-md border-slate-200 bg-white text-sm text-[#293C74]">
                        <option value="">COP y USD, sin sumarlos</option>
                        <option value="COP">Solo COP</option>
                        <option value="USD">Solo USD</option>
                     </select>
                  </div>
               </div>

               <div id="finances-custom-dates" class="mt-4 hidden grid gap-4 sm:grid-cols-2" aria-hidden="true">
                  <div>
                     <label for="finances-date-from" class="mb-1 block text-xs font-bold uppercase tracking-widest text-slate-500">Desde</label>
                     <input id="finances-date-from" type="date" class="min-h-11 w-full rounded-md border-slate-200 bg-white text-sm text-[#293C74]">
                  </div>
                  <div>
                     <label for="finances-date-to" class="mb-1 block text-xs font-bold uppercase tracking-widest text-slate-500">Hasta</label>
                     <input id="finances-date-to" type="date" class="min-h-11 w-full rounded-md border-slate-200 bg-white text-sm text-[#293C74]">
                  </div>
               </div>

               <p id="finances-filter-feedback" class="mt-4 hidden rounded-md px-4 py-3 text-sm" role="status"></p>
               <div class="mt-5 flex flex-wrap justify-end gap-2">
                  <button id="finances-clear-filters" type="button" class="min-h-11 rounded-md border border-slate-200 bg-white px-5 py-2.5 text-sm font-bold text-slate-700 hover:bg-slate-50">Limpiar</button>
                  <button id="finances-apply-filters" type="submit" class="min-h-11 rounded-md bg-[#293C74] px-5 py-2.5 text-sm font-bold text-white hover:bg-[#20315f] disabled:cursor-wait disabled:opacity-60">Aplicar filtros</button>
               </div>
            </form>

            <!-- Stats Grid -->
            <div class="portal-stat-grid grid-cols-1 sm:grid-cols-2">
                <div class="portal-stat">
		                     <p class="portal-stat-label">Recaudo cargado</p>
                     <div class="grid grid-cols-2 gap-3">
                        <div>
                           <span class="text-xs font-bold uppercase text-slate-500">COP</span>
                           <h3 id="stat-total-cop" class="portal-stat-value mt-1">$ 0</h3>
                        </div>
                        <div>
                           <span class="text-xs font-bold uppercase text-slate-500">USD</span>
                           <h3 id="stat-total-usd" class="portal-stat-value mt-1">$ 0</h3>
                        </div>
                     </div>
		                     <p class="mt-2 text-xs text-slate-500">Transacciones visibles</p>
                </div>

                 <div class="portal-stat">
                     <p class="portal-stat-label">Movimientos visibles</p>
                     <h3 id="stat-transaction-count" class="portal-stat-value">0</h3>
                     <p class="mt-2 text-xs text-slate-500">Pagos aprobados cargados con los filtros actuales</p>
                </div>
            </div>

            <!-- Category Summary -->
            <div class="portal-panel p-4 md:p-6">
                <div class="flex flex-col gap-2 md:flex-row md:items-center md:justify-between mb-6">
                    <div>
                        <h3 class="text-lg font-bold text-[#293C74]">Resumen por categoría</h3>
                        <p class="text-xs text-slate-400">Cada moneda conserva su propio subtotal; nunca se suman COP y USD.</p>
                    </div>
	                    <p class="text-[10px] uppercase tracking-widest text-slate-400">Vista paginada</p>
                </div>
                <div id="finances-categories" class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
                    <!-- Cards injected by JS -->
                </div>
            </div>

            <!-- Transactions List -->
		            <div class="portal-panel p-4 md:p-6">
	                <div class="mb-6 flex flex-col gap-2 md:flex-row md:items-center md:justify-between">
	                    <h3 class="text-lg font-bold text-[#293C74]">Últimas Transacciones</h3>
	                    <p id="finances-page-info" class="text-xs font-semibold text-slate-400">Cargando...</p>
	                </div>
                
                <div id="finances-transactions-loading" class="hidden py-12 text-center text-slate-400 animate-pulse">Cargando datos...</div>
                
                <div class="portal-table-frame">
                    <table id="finances-table" class="portal-responsive-table hidden w-full text-left border-collapse">
                        <thead>
                            <tr class="text-xs text-slate-400 border-b border-slate-100">
                                <th class="font-bold uppercase tracking-widest py-3 pl-2">Fecha</th>
                                <th class="font-bold uppercase tracking-widest py-3">Concepto</th>
                                <th class="font-bold uppercase tracking-widest py-3">Donante</th>
                                <th class="font-bold uppercase tracking-widest py-3">Cuenta</th>
                                <th class="font-bold uppercase tracking-widest py-3">Estado</th>
                                <th class="font-bold uppercase tracking-widest py-3 text-right pr-2">Monto</th>
                            </tr>
                        </thead>
                        <tbody class="text-sm text-slate-600 divide-y divide-slate-50">
                            <!-- Rows injected by JS -->
                        </tbody>
                    </table>
                </div>
	                <div id="finances-empty" class="hidden text-center py-10 text-slate-400 text-sm">No hay registros financieros recientes.</div>
	                <div class="mt-6 flex justify-center">
		                    <button id="finances-load-more" type="button" class="hidden min-h-10 rounded-md border border-[#293C74]/20 px-5 py-2 text-xs font-bold uppercase text-[#293C74] hover:border-[#293C74]/50 hover:bg-[#293C74]/5 disabled:cursor-wait disabled:opacity-60">
	                        Cargar más
	                    </button>
	                </div>
	            </div>

            <!-- Payment Alerts -->
            <div class="portal-panel p-4 md:p-6">
                <div class="flex flex-col gap-2 md:flex-row md:items-center md:justify-between mb-6">
                    <div>
                        <h3 class="text-lg font-bold text-[#293C74]">Alertas de pago</h3>
                        <p class="text-xs text-slate-400">Pendientes o fallidos. No se cuentan como ingresos.</p>
                    </div>
	                    <p id="finances-issues-page-info" class="text-[10px] uppercase tracking-widest text-slate-400">Cargando...</p>
                </div>
	                <div id="finances-issues-list" class="space-y-4">
	                    <!-- Cards injected by JS -->
	                </div>
	                <div id="finances-issues-empty" class="hidden text-center py-6 text-slate-400 text-sm">No hay alertas de pago por ahora.</div>
	                <div class="mt-6 flex justify-center">
		                    <button id="finances-issues-load-more" type="button" class="hidden min-h-10 rounded-md border border-amber-200 bg-amber-50 px-5 py-2 text-xs font-bold uppercase text-amber-800 hover:bg-amber-100 disabled:cursor-wait disabled:opacity-60">
	                        Cargar más alertas
	                    </button>
	                </div>
	            </div>

         </div>
      </section>
    </div>
  </div>
  <script src="../../scripts/portal-finances.js"></script>
</BaseLayout>
