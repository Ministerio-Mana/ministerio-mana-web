---
import BaseLayout from '@layouts/BaseLayout.astro';
import Sidebar from '@components/portal/Sidebar.astro';
---

<BaseLayout title="Finanzas | Portal Maná" description="Reportes financieros y control de diezmos." hideHeader hideFooter noindex>
  <div class="portal-shell min-h-screen bg-[#F8FAFC]">
    <div class="flex flex-col lg:flex-row min-h-screen">
      <Sidebar />
      
      <section class="flex-1 p-4 md:p-10 lg:p-16 relative overflow-y-auto">
         <div id="finances-gate" class="portal-panel max-w-xl mx-auto px-6 py-8 text-center text-slate-500">
            <div id="finances-loading" class="animate-pulse py-12 text-center text-slate-400" role="status" aria-live="polite">Cargando datos...</div>
         </div>

         <div id="finances-secure-content" class="hidden max-w-6xl mx-auto space-y-8">
            <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
               <div>
                  <h1 class="text-3xl font-display font-bold text-[#293C74]">Finanzas</h1>
                  <p class="text-slate-600">Resumen de los movimientos autorizados para tu alcance.</p>
               </div>
               <p id="finances-scope-label" class="w-fit rounded-full border border-[#293C74]/15 bg-white px-4 py-2 text-xs font-bold text-[#293C74]">
                  Verificando alcance…
               </p>
            </div>

            <section id="finance-reconciliation" class="portal-panel hidden p-4 md:p-6" aria-labelledby="finance-reconciliation-title">
               <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
                  <div class="max-w-2xl">
                     <p class="text-xs font-bold uppercase tracking-widest text-cyan-700">Conciliación de proveedores</p>
                     <h2 id="finance-reconciliation-title" class="mt-2 text-xl font-bold text-[#293C74]">Importar reporte oficial</h2>
                     <p class="mt-2 text-sm leading-6 text-slate-600">
                        Revisa el resumen antes de guardar. El portal ignora datos personales y nunca calcula una comisión que el proveedor no haya informado.
                     </p>
                  </div>
                  <p class="w-fit rounded-full border border-emerald-200 bg-emerald-50 px-4 py-2 text-xs font-bold text-emerald-800">
                     Carga privada y auditable
                  </p>
               </div>

               <form id="finance-reconciliation-form" class="mt-6 grid gap-4 lg:grid-cols-[minmax(0,14rem)_minmax(0,1fr)_auto] lg:items-end">
                  <div>
                     <label for="finance-reconciliation-provider" class="mb-2 block text-xs font-bold uppercase tracking-widest text-slate-500">Proveedor</label>
                     <select id="finance-reconciliation-provider" name="provider" class="min-h-11 w-full rounded-md border-slate-200 bg-white text-sm text-[#293C74]">
                        <option value="AUTO">Detectar automáticamente</option>
                        <option value="WOMPI">Wompi · Colombia</option>
                        <option value="STRIPE">Stripe · Global</option>
                     </select>
                  </div>
                  <div>
                     <label for="finance-reconciliation-file" class="mb-2 block text-xs font-bold uppercase tracking-widest text-slate-500">Reporte CSV</label>
                     <input id="finance-reconciliation-file" name="report" type="file" accept=".csv,text/csv" required class="block min-h-11 w-full rounded-md border border-slate-200 bg-white px-4 py-2 text-sm text-slate-700 file:mr-4 file:rounded-md file:border-0 file:bg-slate-100 file:px-4 file:py-2 file:text-xs file:font-bold file:text-[#293C74]">
                     <p class="mt-2 text-xs text-slate-500">CSV oficial, UTF-8, máximo 4 MB y 10.000 movimientos.</p>
                  </div>
                  <button id="finance-reconciliation-preview-button" type="submit" class="min-h-11 rounded-md bg-[#293C74] px-6 py-2 text-sm font-bold text-white hover:bg-[#20315f] disabled:cursor-wait disabled:opacity-60">
                     Revisar archivo
                  </button>
               </form>

               <p id="finance-reconciliation-feedback" class="mt-4 hidden rounded-md border px-4 py-4 text-sm" role="status" aria-live="polite"></p>

               <div id="finance-reconciliation-preview" class="mt-6 hidden rounded-md border border-slate-200 bg-slate-50/70 p-4 md:p-6">
                  <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
                     <div>
                        <p class="text-xs font-bold uppercase tracking-widest text-slate-500">Vista previa verificada</p>
                        <h3 id="finance-reconciliation-preview-title" class="mt-2 text-lg font-bold text-[#293C74]">Reporte</h3>
                        <p id="finance-reconciliation-preview-meta" class="mt-2 text-sm text-slate-600"></p>
                     </div>
                     <span id="finance-reconciliation-exactness" class="w-fit rounded-full px-4 py-2 text-xs font-bold"></span>
                  </div>
                  <div id="finance-reconciliation-totals" class="mt-6 grid gap-4 sm:grid-cols-2 xl:grid-cols-3"></div>
                  <div id="finance-reconciliation-warnings" class="mt-4 space-y-2"></div>
                  <div class="mt-6 flex flex-col-reverse gap-4 border-t border-slate-200 pt-6 sm:flex-row sm:items-center sm:justify-end">
                     <button id="finance-reconciliation-cancel" type="button" class="min-h-11 rounded-md border border-slate-200 bg-white px-6 py-2 text-sm font-bold text-slate-700 hover:bg-slate-50">Cambiar archivo</button>
                     <button id="finance-reconciliation-commit" type="button" class="min-h-11 rounded-md bg-emerald-700 px-6 py-2 text-sm font-bold text-white hover:bg-emerald-800 disabled:cursor-not-allowed disabled:opacity-50">Importar reporte</button>
                  </div>
               </div>
            </section>

            <form id="finances-filters" class="portal-panel p-4 md:p-6" aria-labelledby="finances-filters-title">
               <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
                  <div>
                     <h2 id="finances-filters-title" class="text-lg font-bold text-[#293C74]">Filtrar movimientos</h2>
                     <p id="finances-filter-summary" class="mt-2 text-xs text-slate-500">Todo el historial · Todas las cuentas · COP y USD separados</p>
                  </div>
                  <div class="flex flex-wrap gap-2">
                     <button id="finances-export-cop" type="button" class="min-h-11 rounded-md border border-[#293C74]/20 bg-white px-4 py-2 text-xs font-bold text-[#293C74] hover:bg-[#293C74]/5 disabled:cursor-wait disabled:opacity-50">
                        Descargar CSV · COP
                     </button>
                     <button id="finances-export-usd" type="button" class="min-h-11 rounded-md border border-cyan-200 bg-cyan-50 px-4 py-2 text-xs font-bold text-cyan-800 hover:bg-cyan-100 disabled:cursor-wait disabled:opacity-50">
                        Descargar CSV · USD
                     </button>
                  </div>
               </div>

               <div class="mt-6 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
                  <div>
                     <label for="finances-period-filter" class="mb-2 block text-xs font-bold uppercase tracking-widest text-slate-500">Período</label>
                     <select id="finances-period-filter" class="min-h-11 w-full rounded-md border-slate-200 bg-white text-sm text-[#293C74]">
                        <option value="all">Todo el historial</option>
                        <option value="month">Este mes</option>
                        <option value="30d">Últimos 30 días</option>
                        <option value="year">Este año</option>
                        <option value="custom">Fechas personalizadas</option>
                     </select>
                  </div>
                  <div>
                     <label for="finances-account-filter" class="mb-2 block text-xs font-bold uppercase tracking-widest text-slate-500">Cuenta o proveedor</label>
                     <select id="finances-account-filter" class="min-h-11 w-full rounded-md border-slate-200 bg-white text-sm text-[#293C74]">
                        <option value="">Todas las cuentas autorizadas</option>
                        <option value="WOMPI">Wompi · Nacional Colombia</option>
                        <option value="STRIPE">Stripe · Global</option>
                        <option value="LOCAL">Cuentas locales</option>
                        <option value="REGIONAL">Cuentas regionales</option>
                        <option value="NATIONAL">Todas las cuentas nacionales</option>
                        <option value="GLOBAL">Todas las cuentas globales</option>
                     </select>
                  </div>
                  <div>
                     <label for="finances-currency-filter" class="mb-2 block text-xs font-bold uppercase tracking-widest text-slate-500">Moneda en pantalla</label>
                     <select id="finances-currency-filter" class="min-h-11 w-full rounded-md border-slate-200 bg-white text-sm text-[#293C74]">
                        <option value="">COP y USD, sin sumarlos</option>
                        <option value="COP">Solo COP</option>
                        <option value="USD">Solo USD</option>
                     </select>
                  </div>
               </div>

               <div id="finances-custom-dates" class="mt-4 hidden grid gap-4 sm:grid-cols-2" aria-hidden="true">
                  <div>
                     <label for="finances-date-from" class="mb-2 block text-xs font-bold uppercase tracking-widest text-slate-500">Desde</label>
                     <input id="finances-date-from" type="date" class="min-h-11 w-full rounded-md border-slate-200 bg-white text-sm text-[#293C74]">
                  </div>
                  <div>
                     <label for="finances-date-to" class="mb-2 block text-xs font-bold uppercase tracking-widest text-slate-500">Hasta</label>
                     <input id="finances-date-to" type="date" class="min-h-11 w-full rounded-md border-slate-200 bg-white text-sm text-[#293C74]">
                  </div>
               </div>

               <p id="finances-filter-feedback" class="mt-4 hidden rounded-md px-4 py-4 text-sm" role="status"></p>
               <div class="mt-6 flex flex-wrap justify-end gap-2">
                  <button id="finances-clear-filters" type="button" class="min-h-11 rounded-md border border-slate-200 bg-white px-6 py-2 text-sm font-bold text-slate-700 hover:bg-slate-50">Limpiar</button>
                  <button id="finances-apply-filters" type="submit" class="min-h-11 rounded-md bg-[#293C74] px-6 py-2 text-sm font-bold text-white hover:bg-[#20315f] disabled:cursor-wait disabled:opacity-60">Aplicar filtros</button>
               </div>
            </form>

            <!-- Stats Grid -->
            <div class="portal-stat-grid grid-cols-1 sm:grid-cols-2">
                <div class="portal-stat">
		                     <p class="portal-stat-label">Recaudo cargado</p>
                     <div class="grid grid-cols-2 gap-4">
                        <div>
                           <span class="text-xs font-bold uppercase text-slate-500">COP</span>
                           <p id="stat-total-cop" class="portal-stat-value mt-2">$ 0</p>
                        </div>
                        <div>
                           <span class="text-xs font-bold uppercase text-slate-500">USD</span>
                           <p id="stat-total-usd" class="portal-stat-value mt-2">$ 0</p>
                        </div>
                     </div>
		                     <p class="mt-2 text-xs text-slate-500">Transacciones visibles</p>
                </div>

                 <div class="portal-stat">
                     <p class="portal-stat-label">Movimientos visibles</p>
                     <p id="stat-transaction-count" class="portal-stat-value">0</p>
                     <p class="mt-2 text-xs text-slate-500">Pagos aprobados cargados con los filtros actuales</p>
                </div>
            </div>

            <!-- Category Summary -->
            <section class="portal-panel p-4 md:p-6" aria-labelledby="finances-categories-title">
                <div class="flex flex-col gap-2 md:flex-row md:items-center md:justify-between mb-6">
                    <div>
                        <h2 id="finances-categories-title" class="text-lg font-bold text-[#293C74]">Resumen por categoría</h2>
                        <p class="text-xs text-slate-400">Cada moneda conserva su propio subtotal; nunca se suman COP y USD.</p>
                    </div>
	                    <p class="text-[10px] uppercase tracking-widest text-slate-400">Vista paginada</p>
                </div>
                <div id="finances-categories" class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
                    <!-- Cards injected by JS -->
                </div>
            </section>

            <!-- Transactions List -->
		            <section class="portal-panel p-4 md:p-6" aria-labelledby="finances-transactions-title">
	                <div class="mb-6 flex flex-col gap-2 md:flex-row md:items-center md:justify-between">
	                    <h2 id="finances-transactions-title" class="text-lg font-bold text-[#293C74]">Últimas transacciones</h2>
	                    <p id="finances-page-info" class="text-xs font-semibold text-slate-400" role="status" aria-live="polite">Cargando...</p>
	                </div>
                
                <div id="finances-transactions-loading" class="hidden animate-pulse py-12 text-center text-slate-400" role="status" aria-live="polite">Cargando datos...</div>
                
                <div class="portal-table-frame">
                    <table id="finances-table" class="portal-responsive-table hidden w-full text-left border-collapse">
                        <thead>
                            <tr class="text-xs text-slate-400 border-b border-slate-100">
                                <th class="font-bold uppercase tracking-widest py-4 pl-2">Fecha</th>
                                <th class="font-bold uppercase tracking-widest py-4">Concepto</th>
                                <th class="font-bold uppercase tracking-widest py-4">Donante</th>
                                <th class="font-bold uppercase tracking-widest py-4">Cuenta</th>
                                <th class="font-bold uppercase tracking-widest py-4">Estado</th>
                                <th class="font-bold uppercase tracking-widest py-4 text-right pr-2">Monto</th>
                            </tr>
                        </thead>
                        <tbody class="text-sm text-slate-600 divide-y divide-slate-50">
                            <!-- Rows injected by JS -->
                        </tbody>
                    </table>
                </div>
	                <div id="finances-empty" class="hidden text-center py-10 text-slate-400 text-sm" role="status">No hay registros financieros recientes.</div>
	                <div class="mt-6 flex justify-center">
		                    <button id="finances-load-more" type="button" class="hidden min-h-11 rounded-md border border-[#293C74]/20 px-6 py-2 text-xs font-bold uppercase text-[#293C74] hover:border-[#293C74]/50 hover:bg-[#293C74]/5 disabled:cursor-wait disabled:opacity-60">
	                        Cargar más
	                    </button>
	                </div>
	            </section>

            <!-- Payment Alerts -->
            <section class="portal-panel p-4 md:p-6" aria-labelledby="finances-issues-title">
                <div class="flex flex-col gap-2 md:flex-row md:items-center md:justify-between mb-6">
                    <div>
                        <h2 id="finances-issues-title" class="text-lg font-bold text-[#293C74]">Alertas de pago</h2>
                        <p class="text-xs text-slate-400">Pendientes o fallidos. No se cuentan como ingresos.</p>
                    </div>
	                    <p id="finances-issues-page-info" class="text-[10px] uppercase tracking-widest text-slate-400" role="status" aria-live="polite">Cargando...</p>
                </div>
	                <div id="finances-issues-list" class="space-y-4">
	                    <!-- Cards injected by JS -->
	                </div>
	                <div id="finances-issues-empty" class="hidden text-center py-6 text-slate-400 text-sm" role="status">No hay alertas de pago por ahora.</div>
	                <div class="mt-6 flex justify-center">
		                    <button id="finances-issues-load-more" type="button" class="hidden min-h-11 rounded-md border border-amber-200 bg-amber-50 px-6 py-2 text-xs font-bold uppercase text-amber-800 hover:bg-amber-100 disabled:cursor-wait disabled:opacity-60">
	                        Cargar más alertas
	                    </button>
	                </div>
	            </section>

         </div>
      </section>
    </div>
  </div>
  <script src="../../scripts/portal-finances.js"></script>
</BaseLayout>
