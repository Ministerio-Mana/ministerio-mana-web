---
import BaseLayout from '@layouts/BaseLayout.astro';
import Sidebar from '@components/portal/Sidebar.astro';
---

<BaseLayout title="Peticiones | Portal Maná" description="Revisión e intercesión de peticiones de oración." hideHeader hideFooter>
  <main class="min-h-screen bg-[#F8FAFC]">
    <div class="flex min-h-screen flex-col lg:flex-row">
      <Sidebar />

      <section class="relative flex-1 overflow-y-auto p-4 md:p-10 lg:p-16">
        <div class="mx-auto max-w-7xl space-y-8">
          <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
            <div>
              <p class="mb-2 text-xs font-black uppercase tracking-[0.24em] text-brand-teal">Intercesión</p>
              <h1 class="font-display text-3xl font-black text-[#293C74] md:text-4xl">Peticiones de oración</h1>
              <p class="mt-2 max-w-2xl text-sm leading-6 text-slate-600">
                Las privadas se reciben para oración. Las públicas quedan pendientes hasta que un administrador las apruebe.
              </p>
            </div>

            <div class="flex flex-wrap gap-3">
              <select id="prayers-status" class="rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-600 shadow-sm">
                <option value="all">Todos los estados</option>
                <option value="private">Privadas</option>
                <option value="pending">Pendientes</option>
                <option value="flagged">Marcadas</option>
                <option value="approved">Aprobadas</option>
                <option value="rejected">Rechazadas</option>
              </select>
              <select id="prayers-visibility" class="rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-600 shadow-sm">
                <option value="all">Todas</option>
                <option value="private">Solo privadas</option>
                <option value="public">Solo públicas</option>
              </select>
            </div>
          </div>

          <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
            <div class="rounded-[2rem] border border-slate-100 bg-white p-6 shadow-sm">
              <p class="mb-2 text-xs font-bold uppercase tracking-widest text-slate-400">Recibidas</p>
              <p id="prayers-stat-total" class="text-3xl font-black text-[#293C74]">0</p>
            </div>
            <div class="rounded-[2rem] border border-slate-100 bg-white p-6 shadow-sm">
              <p class="mb-2 text-xs font-bold uppercase tracking-widest text-slate-400">Privadas</p>
              <p id="prayers-stat-private" class="text-3xl font-black text-brand-teal">0</p>
            </div>
            <div class="rounded-[2rem] border border-slate-100 bg-white p-6 shadow-sm">
              <p class="mb-2 text-xs font-bold uppercase tracking-widest text-slate-400">Por revisar</p>
              <p id="prayers-stat-review" class="text-3xl font-black text-[#293C74]">0</p>
            </div>
          </div>

          <div class="rounded-[2.5rem] border border-slate-100 bg-white p-6 shadow-sm md:p-8">
            <div class="mb-5 flex flex-col gap-2 md:flex-row md:items-center md:justify-between">
              <div>
                <h2 class="font-display text-xl font-black text-[#293C74]">Bandeja de peticiones</h2>
                <p id="prayers-role-note" class="text-sm text-slate-500">Cargando permisos...</p>
              </div>
              <button id="prayers-refresh" type="button" class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-xs font-black uppercase tracking-widest text-[#293C74] hover:bg-slate-100">
                Actualizar
              </button>
            </div>

            <div id="prayers-loading" class="py-12 text-center text-slate-400">Cargando peticiones...</div>
            <div id="prayers-list" class="grid grid-cols-1 gap-4 hidden"></div>
            <div id="prayers-empty" class="hidden py-12 text-center text-sm text-slate-400">No hay peticiones para este filtro.</div>
          </div>
        </div>
      </section>
    </div>
  </main>

  <script>
    import '@scripts/portal-prayers.js';
  </script>
</BaseLayout>
