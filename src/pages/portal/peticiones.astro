---
import BaseLayout from '@layouts/BaseLayout.astro';
import Sidebar from '@components/portal/Sidebar.astro';
---

<BaseLayout title="Peticiones | Portal Maná" description="Revisión e intercesión de peticiones de oración." hideHeader hideFooter noindex>
  <div class="portal-shell min-h-screen bg-[#F8FAFC]">
    <div class="flex min-h-screen flex-col lg:flex-row">
      <Sidebar />

      <section class="relative flex-1 overflow-y-auto p-4 md:p-10 lg:p-16">
        <div id="prayers-gate" class="portal-panel mx-auto max-w-xl px-6 py-8 text-center text-slate-500">
          Validando permisos...
        </div>

        <div id="prayers-secure-content" class="hidden mx-auto max-w-7xl space-y-8">
          <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
            <div>
              <p class="mb-2 text-xs font-black uppercase tracking-[0.24em] text-brand-teal">Intercesión</p>
              <h1 class="font-display text-3xl font-black text-[#293C74] md:text-4xl">Peticiones de oración</h1>
              <p class="mt-2 max-w-2xl text-sm leading-6 text-slate-600">
                Las privadas se reciben para oración. Las públicas quedan pendientes hasta que un administrador las apruebe.
              </p>
            </div>

            <div class="grid w-full grid-cols-1 gap-4 sm:grid-cols-2 lg:w-auto">
              <div class="space-y-2">
                <label for="prayers-status" class="block text-xs font-black uppercase tracking-wider text-slate-600">Estado</label>
                <select id="prayers-status" class="min-h-11 w-full rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-700">
                  <option value="all">Todos los estados</option>
                  <option value="private">Privadas</option>
                  <option value="pending">Pendientes</option>
                  <option value="flagged">Marcadas</option>
                  <option value="approved">Aprobadas</option>
                  <option value="rejected">Rechazadas</option>
                </select>
              </div>
              <div class="space-y-2">
                <label for="prayers-visibility" class="block text-xs font-black uppercase tracking-wider text-slate-600">Visibilidad</label>
                <select id="prayers-visibility" class="min-h-11 w-full rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-700">
                  <option value="all">Todas</option>
                  <option value="private">Solo privadas</option>
                  <option value="public">Solo públicas</option>
                </select>
              </div>
            </div>
          </div>

          <div class="portal-stat-grid grid-cols-3">
            <div class="portal-stat">
              <p class="portal-stat-label">Total recibidas</p>
              <p id="prayers-stat-total" class="portal-stat-value">0</p>
            </div>
            <div class="portal-stat">
              <p class="portal-stat-label">Privadas</p>
              <p id="prayers-stat-private" class="portal-stat-value !text-brand-teal">0</p>
            </div>
            <div class="portal-stat">
              <p class="portal-stat-label">Por revisar</p>
              <p id="prayers-stat-review" class="portal-stat-value">0</p>
            </div>
          </div>

          <div class="portal-panel p-4 md:p-6">
            <div class="mb-4 flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
              <div>
                <h2 class="font-display text-xl font-black text-[#293C74]">Bandeja de peticiones</h2>
                <p id="prayers-role-note" class="text-sm text-slate-500">Cargando permisos...</p>
              </div>
              <button id="prayers-refresh" type="button" class="min-h-11 rounded-md border border-slate-200 bg-slate-50 px-4 py-2 text-xs font-black uppercase text-[#293C74] hover:bg-slate-100">
                Actualizar
              </button>
            </div>

            <div id="prayers-feedback" class="hidden rounded-xl border px-4 py-4 text-sm font-semibold" role="status" aria-live="polite"></div>
            <p id="prayers-coverage" class="mb-4 text-sm text-slate-500" role="status" aria-live="polite"></p>
            <div id="prayers-loading" class="py-12 text-center text-slate-400" role="status" aria-live="polite">Cargando peticiones...</div>
            <div id="prayers-list" class="grid grid-cols-1 gap-4 hidden"></div>
            <div id="prayers-empty" class="hidden py-12 text-center text-sm text-slate-400">No hay peticiones para este filtro.</div>
            <div class="mt-4 flex justify-center">
              <button id="prayers-load-more" type="button" class="hidden min-h-11 rounded-md border border-slate-200 bg-white px-4 py-2 text-sm font-black text-[#293C74] hover:bg-slate-50 disabled:cursor-wait disabled:opacity-60">
                Cargar más
              </button>
            </div>
          </div>
        </div>
      </section>
    </div>
  </div>

  <div id="prayer-review-modal" class="fixed inset-0 z-[90] hidden items-center justify-center p-4" role="dialog" aria-modal="true" aria-labelledby="prayer-review-title" aria-describedby="prayer-review-description" aria-hidden="true">
    <div class="absolute inset-0 bg-slate-950/60 backdrop-blur-sm" data-prayer-review-backdrop></div>
    <div class="relative z-10 max-h-[calc(100vh-2rem)] w-full max-w-xl overflow-y-auto rounded-2xl border border-slate-200 bg-white p-6 shadow-2xl md:p-8">
      <div class="flex items-start justify-between gap-4">
        <div class="min-w-0">
          <p class="mb-2 text-xs font-black uppercase tracking-[0.24em] text-brand-teal">Decisión pastoral</p>
          <h2 id="prayer-review-title" class="font-display text-2xl font-black text-[#293C74]">Revisar petición</h2>
        </div>
        <button id="prayer-review-close" type="button" class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-full border border-slate-200 text-xl text-slate-600 hover:bg-slate-50" aria-label="Cerrar revisión de petición">×</button>
      </div>

      <p id="prayer-review-description" class="mt-4 text-sm leading-6 text-slate-600"></p>
      <div id="prayer-review-summary" class="mt-4 rounded-xl border border-slate-200 bg-slate-50 p-4 text-sm text-slate-700"></div>

      <form id="prayer-review-form" class="mt-6 space-y-4" novalidate>
        <input id="prayer-review-id" type="hidden" />
        <input id="prayer-review-decision" type="hidden" />
        <div id="prayer-review-note-wrap" class="hidden space-y-2">
          <label for="prayer-review-note" class="block text-sm font-black text-slate-700">Motivo interno <span class="font-semibold text-slate-500">(opcional)</span></label>
          <textarea id="prayer-review-note" rows="4" maxlength="320" class="min-h-24 w-full rounded-lg border border-slate-200 bg-white p-4 text-sm text-slate-800 focus:border-brand-teal focus:outline-none focus:ring-2 focus:ring-brand-teal/20" aria-describedby="prayer-review-note-help"></textarea>
          <p id="prayer-review-note-help" class="text-xs leading-5 text-slate-500">Solo lo verá el equipo autorizado; no se envía a la persona.</p>
        </div>
        <div id="prayer-review-feedback" class="hidden rounded-xl border px-4 py-4 text-sm font-semibold" role="status" aria-live="polite"></div>
        <div class="flex flex-col-reverse gap-4 sm:flex-row sm:justify-end">
          <button id="prayer-review-cancel" type="button" class="min-h-11 rounded-md border border-slate-200 bg-white px-4 py-2 text-sm font-black text-slate-700 hover:bg-slate-50">Cancelar</button>
          <button id="prayer-review-submit" type="submit" class="min-h-11 rounded-md bg-brand-teal px-4 py-2 text-sm font-black text-white hover:brightness-105 disabled:cursor-wait disabled:opacity-60">Confirmar decisión</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    import '@scripts/portal-prayers.js';
  </script>
</BaseLayout>
