---
import BaseLayout from '@layouts/BaseLayout.astro';
import Sidebar from '@components/portal/Sidebar.astro';
import PortalIcon from '@components/portal/PortalIcon.astro';
---

<BaseLayout title="Página de mi iglesia | Portal Maná" description="Editor visual de la página pública de cada iglesia." hideHeader hideFooter noindex>
  <div class="min-h-screen bg-slate-50 text-slate-800">
    <div class="flex min-h-screen flex-col lg:flex-row">
      <Sidebar />
      <main class="min-w-0 flex-1 p-4 md:p-8 lg:p-12">
        <div id="church-page-gate" class="mx-auto max-w-xl rounded-2xl border border-slate-200 bg-white p-8 text-center text-sm text-slate-500 shadow-sm" role="status" aria-live="polite">Validando permisos...</div>

        <div id="church-page-app" class="mx-auto hidden max-w-7xl space-y-6">
          <header class="border-b border-slate-200 pb-4">
            <div class="flex flex-col gap-4 xl:flex-row xl:items-end xl:justify-between">
              <div>
                <p class="text-xs font-black uppercase tracking-[.16em] text-slate-500">Presencia local</p>
                <h1 class="mt-2 font-display text-3xl font-black text-[#293C74] md:text-4xl">Página de mi iglesia</h1>
                <p class="mt-2 max-w-2xl text-sm leading-relaxed text-slate-600">Completa la información, elige una plantilla y agrega imágenes. El diseño y el movimiento se aplican automáticamente.</p>
              </div>
              <div class="flex flex-col gap-2 sm:flex-row sm:items-end">
                <label class="text-xs font-bold text-slate-600">Iglesia
                  <select id="church-page-church" class="mt-2 min-h-11 w-full min-w-64 rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm font-bold text-[#293C74]"></select>
                </label>
                <a id="church-page-public-link" class="hidden min-h-11 items-center justify-center gap-2 rounded-xl border border-slate-300 bg-white px-4 py-2 text-sm font-bold text-slate-700" target="_blank" rel="noopener noreferrer"><PortalIcon name="external-link" size={17} /> Ver página</a>
              </div>
            </div>
          </header>

          <section id="church-page-setup" class="hidden rounded-2xl border border-amber-200 bg-amber-50 p-6">
            <p class="text-xs font-black uppercase tracking-[.16em] text-amber-700">Configuración pendiente</p>
            <h2 class="mt-2 text-xl font-black text-[#293C74]">Activa las páginas locales</h2>
            <p class="mt-2 max-w-2xl text-sm leading-relaxed text-slate-700">Ejecuta este archivo una sola vez en Supabase. No modifica eventos, pagos, roles ni las iglesias existentes.</p>
            <code class="mt-4 block overflow-x-auto rounded-xl bg-white px-4 py-4 text-sm font-bold text-[#293C74]">docs/sql/church_public_pages.sql</code>
          </section>

          <div id="church-page-alert" class="hidden rounded-xl border px-4 py-4 text-sm font-semibold" role="status" aria-live="polite"></div>

          <form id="church-page-form" class="hidden space-y-6">
            <div class="grid gap-6 xl:grid-cols-[minmax(0,1fr)_minmax(22rem,.72fr)] xl:items-start">
              <div class="space-y-6">
                <section class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm md:p-6">
                  <div class="mb-4">
                    <p class="text-xs font-black uppercase tracking-[.14em] text-brand-teal">1. Estilo</p>
                    <h2 class="mt-2 text-xl font-black text-[#293C74]">Elige cómo se contará la historia</h2>
                  </div>
                  <fieldset id="church-page-templates" class="grid gap-4 md:grid-cols-3">
                    <legend class="sr-only">Plantilla visual</legend>
                    <label class="church-template-card">
                      <input type="radio" name="template" value="ESSENTIAL" class="sr-only" />
                      <span class="church-template-thumb church-template-thumb--essential"><i></i><i></i><i></i></span>
                      <strong>Esencial</strong><small>Clara, rápida y con secciones tradicionales.</small>
                    </label>
                    <label class="church-template-card">
                      <input type="radio" name="template" value="STORY" class="sr-only" />
                      <span class="church-template-thumb church-template-thumb--story"><i></i><i></i><i></i></span>
                      <strong>Historia</strong><small>Escenas de pantalla completa que avanzan con el scroll.</small>
                    </label>
                    <label class="church-template-card">
                      <input type="radio" name="template" value="MOSAIC" class="sr-only" />
                      <span class="church-template-thumb church-template-thumb--mosaic"><i></i><i></i><i></i></span>
                      <strong>Mosaico</strong><small>Editorial, visual y con tarjetas que aparecen al recorrer.</small>
                    </label>
                  </fieldset>
                  <div class="mt-6 border-t border-slate-100 pt-4">
                    <h3 class="text-sm font-black text-[#293C74]">Paleta protegida</h3>
                    <p class="mt-2 text-xs leading-relaxed text-slate-500">El sistema elige el color del texto y la capa sobre las fotos para conservar la lectura. No necesitas combinar colores.</p>
                    <fieldset id="church-page-themes" class="mt-4 grid gap-2 sm:grid-cols-3">
                      <legend class="sr-only">Paleta de color</legend>
                      <label class="church-theme-card"><input type="radio" name="story_theme" value="navy" class="sr-only" /><span class="church-theme-swatch church-theme-swatch--navy"></span><strong>Azul Maná</strong></label>
                      <label class="church-theme-card"><input type="radio" name="story_theme" value="light" class="sr-only" /><span class="church-theme-swatch church-theme-swatch--light"></span><strong>Claro editorial</strong></label>
                      <label class="church-theme-card"><input type="radio" name="story_theme" value="warm" class="sr-only" /><span class="church-theme-swatch church-theme-swatch--warm"></span><strong>Cálido</strong></label>
                    </fieldset>
                  </div>
                </section>

                <details open class="rounded-2xl border border-slate-200 bg-white shadow-sm">
                  <summary class="cursor-pointer list-none px-4 py-4 font-black text-[#293C74] md:px-6">2. Bienvenida e información</summary>
                  <div class="grid gap-4 border-t border-slate-100 p-4 md:grid-cols-2 md:p-6">
                    <label class="church-field md:col-span-2">Nombre público<input id="church-page-name" maxlength="120" required /></label>
                    <label class="church-field md:col-span-2">Frase de bienvenida<input id="church-page-tagline" maxlength="180" required placeholder="Una familia para crecer en la fe" /></label>
                    <label class="church-field md:col-span-2">Descripción<textarea id="church-page-description" rows="5" maxlength="1600" required></textarea></label>
                    <label class="church-field">Enlace público<div class="church-slug"><span>/iglesias/</span><input id="church-page-slug" maxlength="160" required /></div></label>
                    <label class="church-field">Horarios<textarea id="church-page-schedule" rows="3" maxlength="600" required placeholder="Domingos · 10:00 a. m."></textarea></label>
                  </div>
                </details>

                <details open class="rounded-2xl border border-slate-200 bg-white shadow-sm">
                  <summary class="cursor-pointer list-none px-4 py-4 font-black text-[#293C74] md:px-6">3. Imágenes principales</summary>
                  <div class="grid gap-4 border-t border-slate-100 p-4 md:grid-cols-2 md:p-6">
                    <div class="church-image-guide md:col-span-2">
                      <strong>Guía rápida de imágenes</strong>
                      <ul>
                        <li><b>Fondo o portada:</b> horizontal, ideal 1600 × 900 px.</li>
                        <li><b>Retrato o arte:</b> cuadrada 1080 × 1080 o vertical 1080 × 1350 px.</li>
                        <li><b>Sin deformaciones:</b> “Imagen de fondo” recorta con punto importante; “Arte protagonista” muestra la pieza completa.</li>
                      </ul>
                      <p>JPG, PNG o WebP · máximo 5 MB. Arrastra la foto directamente al recuadro o abre la biblioteca.</p>
                    </div>
                    <div class="church-image-field md:col-span-2">
                      <span>Portada o fondo principal</span>
                      <div id="church-page-hero-preview" class="church-image-preview church-image-preview--wide" data-image-target="hero" data-image-drop-target="hero" role="button" tabindex="0" aria-label="Elegir o arrastrar la portada"></div>
                      <button type="button" data-image-target="hero" class="church-secondary-button"><PortalIcon name="image" size={17} /> Elegir o subir imagen</button>
                      <label class="church-field">Descripción accesible<input id="church-page-hero-alt" maxlength="160" placeholder="Personas reunidas en la iglesia..." /></label>
                    </div>
                    <div class="church-image-field">
                      <span>Pastor, equipo o arte cuadrado</span>
                      <div id="church-page-pastor-preview" class="church-image-preview" data-image-target="pastor" data-image-drop-target="pastor" role="button" tabindex="0" aria-label="Elegir o arrastrar el retrato"></div>
                      <button type="button" data-image-target="pastor" class="church-secondary-button"><PortalIcon name="image" size={17} /> Elegir o subir imagen</button>
                      <label class="church-field">Descripción accesible<input id="church-page-pastor-alt" maxlength="160" /></label>
                    </div>
                    <div class="grid content-start gap-4">
                      <label class="church-field">Nombre del pastor o equipo<input id="church-page-pastor-name" maxlength="120" /></label>
                      <label class="church-field">Rol o presentación<input id="church-page-pastor-title" maxlength="80" placeholder="Pastores locales" /></label>
                    </div>
                  </div>
                </details>

                <details id="church-page-story-section" class="rounded-2xl border border-slate-200 bg-white shadow-sm">
                  <summary class="cursor-pointer list-none px-4 py-4 font-black text-[#293C74] md:px-6">4. Escenas de la historia</summary>
                  <div class="space-y-4 border-t border-slate-100 p-4 md:p-6">
                    <p class="text-sm leading-relaxed text-slate-600">Para Historia y Mosaico agrega entre 2 y 6 escenas. Solo completas texto e imágenes; el movimiento queda protegido.</p>
                    <div id="church-page-scenes" class="space-y-4"></div>
                    <button id="church-page-add-scene" type="button" class="church-secondary-button"><PortalIcon name="plus" size={17} /> Agregar escena</button>
                  </div>
                </details>

                <details class="rounded-2xl border border-slate-200 bg-white shadow-sm">
                  <summary class="cursor-pointer list-none px-4 py-4 font-black text-[#293C74] md:px-6">5. Galería y contacto</summary>
                  <div class="space-y-6 border-t border-slate-100 p-4 md:p-6">
                    <div>
                      <div class="flex flex-wrap items-center justify-between gap-4">
                        <div><h3 class="font-black text-[#293C74]">Galería</h3><p class="mt-2 text-xs text-slate-500">Hasta 8 fotos de la comunidad.</p></div>
                        <button type="button" data-image-target="gallery" class="church-secondary-button"><PortalIcon name="plus" size={17} /> Agregar foto</button>
                      </div>
                      <div id="church-page-gallery" class="mt-4 grid gap-4 sm:grid-cols-2"></div>
                    </div>
                    <div class="grid gap-4 md:grid-cols-2">
                      <label class="church-field">WhatsApp<input id="church-page-whatsapp" inputmode="tel" maxlength="24" placeholder="+57 300 000 0000" /></label>
                      <label class="church-field">Correo<input id="church-page-email" type="email" maxlength="254" /></label>
                      <label class="church-field md:col-span-2">Mensaje inicial de WhatsApp<input id="church-page-whatsapp-message" maxlength="280" placeholder="Hola, quiero recibir información..." /></label>
                    </div>
                  </div>
                </details>
              </div>

              <aside class="space-y-4 xl:sticky xl:top-6">
                <section class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
                  <div class="flex items-center justify-between border-b border-slate-100 px-4 py-4">
                    <div><p class="text-xs font-black uppercase tracking-[.14em] text-brand-teal">Vista previa</p><p id="church-page-preview-label" class="mt-2 text-xs text-slate-500">Esencial</p></div>
                    <span id="church-page-status" class="rounded-full bg-slate-100 px-4 py-2 text-xs font-black text-slate-600">Borrador</span>
                  </div>
                  <div id="church-page-preview" class="church-live-preview"></div>
                </section>
                <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
                  <p id="church-page-save-status" class="min-h-5 text-xs text-slate-500" role="status" aria-live="polite">Los cambios se conservan en este dispositivo hasta guardarlos.</p>
                  <div class="mt-4 grid gap-2 sm:grid-cols-2 xl:grid-cols-1">
                    <button id="church-page-save" type="submit" class="inline-flex min-h-11 items-center justify-center gap-2 rounded-xl bg-[#293C74] px-4 py-2 text-sm font-black text-white"><PortalIcon name="save" size={17} /> Guardar borrador</button>
                    <button id="church-page-publish" type="button" class="inline-flex min-h-11 items-center justify-center gap-2 rounded-xl border border-[#293C74]/30 bg-white px-4 py-2 text-sm font-black text-[#293C74]"><PortalIcon name="send" size={17} /><span id="church-page-publish-label">Publicar</span></button>
                  </div>
                </div>
              </aside>
            </div>
          </form>
        </div>
      </main>
    </div>
  </div>

  <div id="church-media-modal" class="fixed inset-0 z-50 hidden overflow-y-auto bg-slate-950/60 p-4 backdrop-blur-sm" role="dialog" aria-modal="true" aria-labelledby="church-media-title" aria-hidden="true">
    <div class="mx-auto my-8 max-w-5xl rounded-2xl border border-slate-200 bg-white shadow-2xl">
      <div class="flex items-start justify-between gap-4 border-b border-slate-100 p-4 md:p-6">
        <div><h2 id="church-media-title" class="text-xl font-black text-[#293C74]">Imágenes de esta iglesia</h2><p class="mt-2 text-sm text-slate-500">Elige una imagen existente o sube una nueva. JPG, PNG o WebP, máximo 5 MB.</p></div>
        <button id="church-media-close" type="button" class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl border border-slate-200 text-slate-500" aria-label="Cerrar biblioteca"><PortalIcon name="x" size={19} /></button>
      </div>
      <div class="grid gap-6 p-4 md:grid-cols-[17rem_1fr] md:p-6">
        <form id="church-media-upload" class="space-y-4">
          <label id="church-media-dropzone" for="church-media-file" tabindex="0" role="button" class="flex min-h-44 cursor-pointer flex-col items-center justify-center gap-2 rounded-2xl border-2 border-dashed border-slate-300 bg-slate-50 p-4 text-center focus:outline-none focus:ring-2 focus:ring-[#293C74]/30">
            <PortalIcon name="upload" size={28} class="text-[#293C74]" />
            <strong class="text-sm text-[#293C74]">Arrastra una imagen</strong><span class="text-xs text-slate-500">o toca para seleccionarla</span>
            <input id="church-media-file" type="file" accept="image/jpeg,image/png,image/webp" class="sr-only" />
          </label>
          <p id="church-media-upload-status" class="min-h-5 text-xs text-slate-500" role="status" aria-live="polite"></p>
          <button type="submit" class="min-h-11 w-full rounded-xl bg-[#293C74] px-4 py-2 text-sm font-black text-white">Subir imagen</button>
        </form>
        <div>
          <label class="church-field">Buscar<input id="church-media-search" type="search" placeholder="Nombre de archivo" /></label>
          <div id="church-media-list" class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3"></div>
          <p id="church-media-empty" class="mt-4 hidden rounded-xl border border-dashed border-slate-200 p-6 text-center text-sm text-slate-500">Todavía no hay imágenes en la carpeta de esta iglesia.</p>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  import '@scripts/portal-church-page.js';
</script>

<style>
  :global(.church-field) { color: #475569; display: block; font-size: .75rem; font-weight: 800; }
  :global(.church-field input), :global(.church-field textarea), :global(.church-field select) { background: #f8fafc; border: 1px solid #dce4ec; border-radius: 12px; color: #172151; display: block; font-size: .875rem; font-weight: 500; margin-top: var(--space-1); min-height: var(--control-min-size); padding: var(--space-2); width: 100%; }
  :global(.church-field input:focus), :global(.church-field textarea:focus), :global(.church-field select:focus) { border-color: #293c74; outline: 3px solid rgba(41,60,116,.14); }
  .church-slug { align-items: center; display: flex; margin-top: var(--space-1); }
  .church-slug span { background: #eef2f7; border: 1px solid #dce4ec; border-radius: 12px 0 0 12px; color: #64748b; min-height: 44px; padding: var(--space-2); }
  .church-slug input { border-left: 0; border-radius: 0 12px 12px 0; margin: 0; }
  .church-template-card { border: 2px solid #e2e8f0; border-radius: 16px; cursor: pointer; display: flex; min-height: 176px; padding: var(--space-2); flex-direction: column; }
  .church-template-card:has(input:checked) { border-color: #293c74; box-shadow: 0 0 0 3px rgba(41,60,116,.12); }
  .church-template-card:focus-within { outline: 3px solid rgba(40,166,189,.35); outline-offset: 2px; }
  .church-template-card strong { color: #293c74; font-size: .95rem; margin-top: var(--space-2); }
  .church-template-card small { color: #64748b; line-height: 1.45; margin-top: var(--space-1); }
  .church-template-thumb { background: #111936; border-radius: 10px; display: grid; gap: var(--space-1); height: 72px; overflow: hidden; padding: var(--space-1); }
  .church-template-thumb i { background: #28a6bd; border-radius: 4px; display: block; }
  .church-template-thumb--essential { grid-template-rows: 1.5fr .45fr .45fr; }
  .church-template-thumb--story { grid-template-columns: 1fr 1fr 1fr; padding: 0; }
  .church-template-thumb--story i:nth-child(2) { background: #f2c94c; }
  .church-template-thumb--mosaic { grid-template-columns: 1.5fr 1fr; grid-template-rows: 1fr 1fr; }
  .church-template-thumb--mosaic i:first-child { grid-row: 1 / -1; }
  .church-theme-card { align-items: center; border: 1px solid #dce4ec; border-radius: 12px; cursor: pointer; display: flex; gap: var(--space-1); min-height: 52px; padding: var(--space-1); }
  .church-theme-card:has(input:checked) { border-color: #293c74; box-shadow: 0 0 0 3px rgba(41,60,116,.12); }
  .church-theme-card:focus-within { outline: 3px solid rgba(40,166,189,.35); outline-offset: 2px; }
  .church-theme-card strong { color: #293c74; font-size: .75rem; line-height: 1.25; }
  .church-theme-swatch { border: 1px solid rgba(23,33,81,.14); border-radius: 8px; display: block; flex: 0 0 auto; height: 34px; width: 42px; }
  .church-theme-swatch--navy { background: linear-gradient(135deg,#111936 0 55%,#28a6bd 55%); }
  .church-theme-swatch--light { background: linear-gradient(135deg,#edf6f4 0 55%,#246a84 55%); }
  .church-theme-swatch--warm { background: linear-gradient(135deg,#f7f2e7 0 55%,#9a5c28 55%); }
  :global(.church-secondary-button) { align-items: center; border: 1px solid #cbd5e1; border-radius: 12px; color: #293c74; display: inline-flex; font-size: .8rem; font-weight: 900; gap: var(--space-1); justify-content: center; min-height: var(--control-min-size); padding: var(--space-1) var(--space-2); }
  .church-image-guide { background: #f7f9ff; border: 1px solid rgba(41,60,116,.16); border-radius: 16px; color: #475569; padding: var(--space-2); }
  .church-image-guide > strong { color: #293c74; font-size: .85rem; }
  .church-image-guide ul { display: grid; gap: var(--space-1); list-style: disc; margin: var(--space-2) 0 0 var(--space-3); }
  .church-image-guide li, .church-image-guide p { font-size: .75rem; line-height: 1.5; }
  .church-image-guide p { border-top: 1px solid rgba(41,60,116,.1); margin-top: var(--space-2); padding-top: var(--space-2); }
  .church-image-field { display: grid; gap: var(--space-2); }
  .church-image-field > span { color: #475569; font-size: .75rem; font-weight: 900; }
  .church-image-preview { align-items: center; aspect-ratio: 4 / 3; background: #eef2f7; background-position: center; background-size: cover; border: 1px dashed #94a3b8; border-radius: 16px; cursor: pointer; display: flex; justify-content: center; overflow: hidden; position: relative; transition: border-color 160ms ease, box-shadow 160ms ease; }
  .church-image-preview--wide { aspect-ratio: 16 / 7; }
  .church-image-preview:focus-visible, .church-image-preview.is-dragging { border-color: #293c74; box-shadow: 0 0 0 4px rgba(40,166,189,.18); outline: none; }
  .church-image-preview::after, :global(.church-scene-image::after) { background: rgba(7,17,28,.76); border-radius: 999px; bottom: var(--space-1); color: #fff; content: 'Arrastra o toca'; font-size: .68rem; font-weight: 900; left: 50%; opacity: 0; padding: var(--space-1) var(--space-2); pointer-events: none; position: absolute; transform: translateX(-50%); transition: opacity 160ms ease; white-space: nowrap; }
  .church-image-preview:hover::after, .church-image-preview:focus-visible::after, .church-image-preview.is-dragging::after, :global(.church-scene-image:hover::after), :global(.church-scene-image:focus-visible::after), :global(.church-scene-image.is-dragging::after) { opacity: 1; }
  .church-live-preview { background: #111936; min-height: 34rem; overflow: hidden; }
  :global(.preview-shell--navy) { --preview-bg: #111936; --preview-copy: #fff; --preview-surface: #fff; --preview-surface-copy: #172151; --preview-muted: #64748b; }
  :global(.preview-shell--light) { --preview-bg: #edf6f4; --preview-copy: #101827; --preview-surface: #fff; --preview-surface-copy: #101827; --preview-muted: #526174; }
  :global(.preview-shell--warm) { --preview-bg: #f7f2e7; --preview-copy: #101827; --preview-surface: #fffaf0; --preview-surface-copy: #101827; --preview-muted: #6b6258; }
  :global(.preview-essential header) { align-items: end; background: linear-gradient(145deg,#20315f,#28a6bd); background-position: center; background-size: cover; color: #fff; display: flex; flex-direction: column; justify-content: end; min-height: 22rem; padding: var(--space-4); }
  :global(.preview-essential header :is(small, strong, span)) { color: #fff !important; text-shadow: 0 2px 16px rgba(7,17,28,.34); }
  :global(.preview-essential header small) { align-self: flex-start; font-size: .65rem; font-weight: 900; letter-spacing: .14em; text-transform: uppercase; }
  :global(.preview-essential header strong) { align-self: flex-start; font-size: clamp(2rem,5vw,3.4rem); font-weight: 900; line-height: .95; margin-top: var(--space-2); }
  :global(.preview-essential header span) { align-self: flex-start; line-height: 1.45; margin-top: var(--space-2); }
  :global(.preview-essential section) { background: var(--preview-surface); color: var(--preview-surface-copy); padding: var(--space-4); }
  :global(.preview-essential section strong) { color: var(--preview-surface-copy) !important; display: block; font-size: 1.45rem; font-weight: 900; }
  :global(.preview-essential section p) { color: var(--preview-muted); line-height: 1.55; margin-top: var(--space-2); }
  :global(.preview-story) { background: var(--preview-bg); color: var(--preview-copy); display: grid; min-height: 34rem; }
  :global(.preview-story-card) { align-items: end; background: linear-gradient(145deg,#20315f,#28a6bd) center/cover; color: #fff; display: flex; min-height: 17rem; padding: var(--space-3); position: relative; }
