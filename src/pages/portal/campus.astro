---
import BaseLayout from '@layouts/BaseLayout.astro';
import Sidebar from '@components/portal/Sidebar.astro';
---
<BaseLayout title="Campus | Portal Maná" description="Gestión de donantes Campus" hideHeader hideFooter noindex>
  <div class="portal-shell min-h-screen bg-[#F8FAFC]">
    <div class="flex flex-col lg:flex-row min-h-screen">
      <Sidebar />
      
      <section class="flex-1 p-4 md:p-10 lg:p-16 relative overflow-y-auto">
         <div id="campus-gate" class="max-w-xl mx-auto rounded-2xl border border-slate-200 bg-white px-6 py-8 text-center text-slate-500 shadow-sm">
            Validando permisos...
         </div>

         <div id="campus-secure-content" class="hidden max-w-7xl mx-auto space-y-8">
            <!-- Header -->
            <div class="flex items-center justify-between">
               <div>
                   <h1 class="text-3xl font-display font-bold text-[#293C74]">Campus</h1>
                   <p class="text-slate-600" id="campus-subtitle">Gestión de donantes y relaciones</p>
               </div>
            </div>

            <div id="donor-stats" class="portal-stat-grid hidden grid-cols-2 sm:grid-cols-3 lg:grid-cols-5">
                <div class="portal-stat">
                    <p class="portal-stat-label">Total donantes</p>
                    <p class="portal-stat-value" id="stat-total-donors">0</p>
                </div>
                <div class="portal-stat">
                    <p class="portal-stat-label">Recurrentes</p>
                    <p class="portal-stat-value !text-emerald-700" id="stat-recurring-donors">0</p>
                </div>
                <div class="portal-stat">
                    <p class="portal-stat-label">Donación única</p>
                    <p class="portal-stat-value !text-sky-700" id="stat-one-time-donors">0</p>
                </div>
                <div class="admin-campus-stat portal-stat hidden">
                    <p class="portal-stat-label">Total Campus</p>
                    <div class="text-sm font-bold text-brand-teal" id="stat-campus-totals">—</div>
                </div>
                <div class="admin-campus-stat portal-stat hidden">
                    <p class="portal-stat-label">Misioneros activos</p>
                    <p class="portal-stat-value" id="stat-active-missionaries">0</p>
                </div>
            </div>

            <!-- Donors List -->
            <div class="portal-panel p-4 md:p-6">
                <div class="mb-6 flex flex-col gap-4 border-b border-slate-100 pb-5 xl:flex-row xl:items-center xl:justify-between">
                    <div class="inline-flex w-full rounded-lg bg-slate-100 p-1 sm:w-auto" role="group" aria-label="Filtrar donantes">
                        <button type="button" class="donor-filter flex-1 rounded-md bg-white px-3 py-2 text-xs font-bold text-[#293C74] shadow-sm sm:flex-none" data-donor-filter="all" aria-pressed="true">
                            Todos <span id="filter-count-all" class="ml-1 text-slate-400">0</span>
                        </button>
                        <button type="button" class="donor-filter flex-1 rounded-md px-3 py-2 text-xs font-bold text-slate-500 sm:flex-none" data-donor-filter="recurring" aria-pressed="false">
                            Recurrentes <span id="filter-count-recurring" class="ml-1 text-slate-400">0</span>
                        </button>
                        <button type="button" class="donor-filter flex-1 rounded-md px-3 py-2 text-xs font-bold text-slate-500 sm:flex-none" data-donor-filter="one_time" aria-pressed="false">
                            Una vez <span id="filter-count-one-time" class="ml-1 text-slate-400">0</span>
                        </button>
                    </div>
                    <div class="flex w-full flex-col gap-3 sm:flex-row xl:max-w-2xl xl:justify-end">
                        <label id="donor-missionary-filter-container" class="hidden w-full sm:max-w-64">
                            <span class="sr-only">Filtrar por misionero</span>
                            <select id="donor-missionary-filter" class="w-full rounded-lg border-slate-200 bg-slate-50 px-4 py-2.5 text-sm text-slate-700 focus:border-[#293C74] focus:ring-[#293C74]">
                                <option value="all">Todos los misioneros</option>
                            </select>
                        </label>
                        <label class="block w-full sm:max-w-sm">
                            <span class="sr-only">Buscar donante</span>
                            <input id="donor-search" type="search" autocomplete="off" placeholder="Buscar por nombre, correo o teléfono" class="w-full rounded-lg border-slate-200 bg-slate-50 px-4 py-2.5 text-sm text-slate-700 focus:border-[#293C74] focus:ring-[#293C74]" />
                        </label>
                    </div>
                </div>

                <p id="donors-result-count" class="mb-4 hidden text-xs font-semibold text-slate-400"></p>
                <div id="donors-loading" class="py-12 text-center text-slate-400 animate-pulse">Cargando donantes...</div>
                
                <div id="donors-content" class="hidden space-y-3">
                    <!-- Donor cards will be injected here by JS -->
                </div>
                
                <div id="donors-empty" class="hidden text-center py-10 text-slate-400 text-sm">
                    No se encontraron donantes todavía.
                </div>

                <div class="mt-6 flex justify-center">
                    <button id="donors-load-more" type="button" class="hidden rounded-lg border border-slate-200 bg-white px-5 py-2.5 text-sm font-bold text-[#293C74] hover:border-[#293C74]/30 hover:bg-slate-50">
                        Mostrar 20 más
                    </button>
                </div>
            </div>

         </div>
      </section>
    </div>
  </div>
  <script>
      import '@scripts/portal-campus.js';
  </script>
</BaseLayout>
