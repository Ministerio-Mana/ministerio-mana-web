---
import BaseLayout from '@layouts/BaseLayout.astro';
import Sidebar from '@components/portal/Sidebar.astro';
---
<BaseLayout title="Campus | Portal Maná" description="Gestión de donantes Campus" hideHeader hideFooter noindex>
  <div class="portal-shell min-h-screen bg-[#F8FAFC]">
    <div class="flex flex-col lg:flex-row min-h-screen">
      <Sidebar />
      
      <section class="flex-1 p-4 md:p-10 lg:p-16 relative overflow-y-auto">
         <div id="campus-gate" class="max-w-xl mx-auto rounded-2xl border border-slate-200 bg-white px-6 py-8 text-center text-slate-500 shadow-sm">
            Validando permisos...
         </div>

         <div id="campus-secure-content" class="hidden mx-auto max-w-7xl space-y-8">
            <div class="flex flex-col gap-6 border-b border-slate-200 pb-8 lg:flex-row lg:items-end lg:justify-between">
               <div>
                   <p class="mb-2 text-xs font-bold uppercase tracking-widest text-[#28A6BD]">Relaciones y sostenimiento</p>
                   <h1 class="text-3xl font-display font-bold text-[#293C74] md:text-4xl">Campus</h1>
                   <p class="mt-2 max-w-2xl text-slate-600" id="campus-subtitle">Gestión de donantes y relaciones</p>
                   <p id="campus-scope-label" class="mt-4 w-fit rounded-full border border-[#293C74]/15 bg-white px-4 py-2 text-xs font-bold text-[#293C74]">
                       Verificando alcance…
                   </p>
               </div>
               <div id="campus-report-actions" class="hidden w-full flex-col gap-2 sm:w-auto sm:flex-row">
                   <button id="campus-export-general" type="button" class="min-h-11 rounded-lg bg-[#293C74] px-6 py-2 text-sm font-bold text-white hover:bg-[#20315f] disabled:cursor-wait disabled:opacity-60">
                       Descargar informe general
                   </button>
                   <button id="campus-export-missionary" type="button" class="min-h-11 rounded-lg border border-slate-200 bg-white px-6 py-2 text-sm font-bold text-[#293C74] hover:border-[#293C74]/30 hover:bg-slate-50 disabled:cursor-not-allowed disabled:opacity-50" disabled>
                       Informe por misionero
                   </button>
               </div>
            </div>
            <p id="campus-export-feedback" class="hidden rounded-xl border px-4 py-4 text-sm font-semibold" role="status" aria-live="polite"></p>

            <div id="donor-stats" class="portal-stat-grid hidden grid-cols-2 lg:grid-cols-3 xl:grid-cols-6">
                <div class="portal-stat">
                    <p class="portal-stat-label">Donantes visibles</p>
                    <p class="portal-stat-value" id="stat-total-donors">0</p>
                </div>
                <div class="portal-stat">
                    <p class="portal-stat-label">Recurrentes</p>
                    <p class="portal-stat-value !text-emerald-700" id="stat-recurring-donors">0</p>
                </div>
                <div class="portal-stat">
                    <p class="portal-stat-label">Donación única</p>
                    <p class="portal-stat-value !text-sky-700" id="stat-one-time-donors">0</p>
                </div>
                <div class="admin-campus-stat portal-stat hidden">
                    <p class="portal-stat-label">Aprobado en COP</p>
                    <p class="portal-stat-value !text-[#13869A]" id="stat-campus-cop">$ 0</p>
                </div>
                <div class="admin-campus-stat portal-stat hidden">
                    <p class="portal-stat-label">Aprobado en USD</p>
                    <p class="portal-stat-value !text-[#13869A]" id="stat-campus-usd">US$ 0.00</p>
                </div>
                <div class="admin-campus-stat portal-stat hidden">
                    <p class="portal-stat-label">Misioneros activos</p>
                    <p class="portal-stat-value" id="stat-active-missionaries">0</p>
                </div>
            </div>

            <div class="portal-panel p-4 md:p-8">
                <div class="mb-6">
                    <h2 class="text-xl font-bold text-[#293C74]">Donantes y aportes</h2>
                    <p class="mt-2 text-sm text-slate-500">Filtra por relación o misionero y abre el detalle solo cuando lo necesites.</p>
                </div>
                <div class="mb-6 flex flex-col gap-4 rounded-2xl border border-slate-200 bg-slate-50 p-4 xl:flex-row xl:items-end xl:justify-between">
                    <div class="grid w-full grid-cols-3 rounded-lg bg-white p-2 shadow-sm sm:w-auto" role="group" aria-label="Filtrar donantes">
                        <button type="button" class="donor-filter min-h-11 flex-1 rounded-md bg-white px-4 py-2 text-xs font-bold text-[#293C74] shadow-sm sm:flex-none" data-donor-filter="all" aria-pressed="true">
                            Todos <span id="filter-count-all" class="ml-2 text-slate-400">0</span>
                        </button>
                        <button type="button" class="donor-filter min-h-11 rounded-md px-4 py-2 text-xs font-bold text-slate-500" data-donor-filter="recurring" aria-pressed="false">
                            Recurrentes <span id="filter-count-recurring" class="ml-2 text-slate-400">0</span>
                        </button>
                        <button type="button" class="donor-filter min-h-11 rounded-md px-4 py-2 text-xs font-bold text-slate-500" data-donor-filter="one_time" aria-pressed="false">
                            Una vez <span id="filter-count-one-time" class="ml-2 text-slate-400">0</span>
                        </button>
                    </div>
                    <div class="flex w-full flex-col gap-4 sm:flex-row xl:max-w-2xl xl:justify-end">
                        <div id="donor-missionary-filter-container" class="hidden w-full sm:max-w-64">
                            <label for="donor-missionary-filter" class="mb-2 block text-xs font-bold text-slate-600">Misionero</label>
                            <select id="donor-missionary-filter" class="min-h-11 w-full rounded-lg border-slate-200 bg-slate-50 px-4 py-2 text-sm text-slate-700 focus:border-[#293C74] focus:ring-[#293C74]">
                                <option value="all">Todos los misioneros</option>
                            </select>
                        </div>
                        <div class="block w-full sm:max-w-sm">
                            <label for="donor-search" class="mb-2 block text-xs font-bold text-slate-600">Buscar donante</label>
                            <input id="donor-search" type="search" autocomplete="off" placeholder="Nombre, correo o teléfono" class="min-h-11 w-full rounded-lg border-slate-200 bg-slate-50 px-4 py-2 text-sm text-slate-700 focus:border-[#293C74] focus:ring-[#293C74]" />
                        </div>
                    </div>
                </div>

                <p id="campus-coverage-note" class="mb-4 hidden rounded-xl border border-amber-200 bg-amber-50 px-4 py-4 text-sm font-semibold text-amber-800" role="status" aria-live="polite"></p>
                <p id="donors-result-count" class="mb-4 hidden text-xs font-semibold text-slate-500" role="status" aria-live="polite"></p>
                <div id="donors-loading" class="py-12 text-center text-slate-400 animate-pulse" role="status" aria-live="polite">Cargando donantes...</div>
                
                <div id="donors-content" class="hidden space-y-4"></div>
                
                <div id="donors-empty" class="hidden text-center py-12 text-slate-400 text-sm" role="status">
                    No se encontraron donantes todavía.
                </div>

                <div class="mt-6 flex justify-center">
                    <button id="donors-load-more" type="button" class="hidden min-h-11 rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-bold text-[#293C74] hover:border-[#293C74]/30 hover:bg-slate-50">
                        Mostrar 20 más
                    </button>
                </div>
            </div>

         </div>
      </section>
    </div>
  </div>
  <script>
      import '@scripts/portal-campus.js';
  </script>
</BaseLayout>
