---
import BaseLayout from '@layouts/BaseLayout.astro';
import Sidebar from '@components/portal/Sidebar.astro';
import { MISIONEROS } from '@data/misioneros';
import { PORTAL_ROLE_DEFINITIONS } from '@lib/portalRbac';
---

<BaseLayout title="Usuarios | Portal Maná" description="Gestión de usuarios." hideHeader hideFooter noindex>
  <div class="portal-shell min-h-screen bg-[#F8FAFC]">
    <div class="flex flex-col lg:flex-row min-h-screen">
      <Sidebar />
      
      <section class="relative flex-1 overflow-y-auto p-4 sm:p-6 lg:p-8 xl:p-12">
         <div id="users-gate" class="portal-panel max-w-xl mx-auto px-6 py-8 text-center text-slate-500">
            Validando permisos...
         </div>

         <div id="users-secure-content" class="hidden mx-auto max-w-7xl space-y-8">
            <div class="flex flex-col gap-6 border-b border-slate-200 pb-8 sm:flex-row sm:items-end sm:justify-between">
               <div>
                   <p class="mb-2 text-xs font-bold uppercase tracking-widest text-[#28A6BD]">Accesos y responsabilidades</p>
                   <h1 class="text-3xl font-display font-bold text-[#293C74] md:text-4xl">Usuarios</h1>
                   <p class="mt-2 max-w-2xl text-slate-600">Administra quién entra al Portal y limita cada permiso al país, región, iglesia o responsabilidad que le corresponde.</p>
               </div>
               <button id="btn-open-create-user" type="button" class="flex min-h-11 w-full items-center justify-center gap-2 rounded-md bg-[#293C74] px-4 py-2 text-sm font-bold text-white transition-colors hover:bg-[#20315f] sm:w-auto">
                   <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5V19M5 12H19" /></svg>
                   Nuevo Usuario
               </button>
            </div>

            <!-- Users List -->
            <div class="portal-panel p-4 sm:p-6 lg:p-8">
                <div class="mb-6 flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
                    <div>
                        <h2 class="text-xl font-bold text-[#293C74]">Directorio del Portal</h2>
                        <p class="mt-2 text-sm text-slate-500">Busca, filtra y administra una cuenta sin perder de vista su alcance.</p>
                    </div>
                    <div id="users-count" class="text-xs font-bold uppercase tracking-widest text-slate-500">0 usuarios</div>
                </div>
                <div class="mb-4">
                    <div id="users-summary" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-2"></div>
                </div>

                <div class="mb-6 space-y-2">
                    <div class="grid grid-cols-1 gap-2 sm:grid-cols-2 xl:grid-cols-4">
                            <div class="relative sm:col-span-2">
                                <input id="users-search" type="search" autocomplete="off" aria-label="Buscar usuarios" class="min-h-11 w-full rounded-xl border border-slate-200 bg-slate-50 py-2 pl-10 pr-4 text-sm text-[#293C74] placeholder-slate-400 focus:ring-1 focus:ring-[#293C74]/20" placeholder="Buscar nombre, email, iglesia o ciudad">
                                <span class="pointer-events-none absolute inset-y-0 left-4 flex items-center" aria-hidden="true">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21L15 15M17 10A7 7 0 1 1 3 10A7 7 0 0 1 17 10Z" /></svg>
                                </span>
                            </div>
                            <select id="users-role-filter" aria-label="Filtrar usuarios por rol" class="min-h-11 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-2 text-sm text-[#293C74] focus:ring-1 focus:ring-[#293C74]/20">
                                <option value="">Todos los roles</option>
                                {PORTAL_ROLE_DEFINITIONS.map(({ role, label }) => (
                                    <option value={role}>{label}</option>
                                ))}
                            </select>
                            <select id="users-status-filter" aria-label="Filtrar usuarios por estado" class="min-h-11 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-2 text-sm text-[#293C74] focus:ring-1 focus:ring-[#293C74]/20">
                                <option value="">Todos los estados</option>
                                <option value="active">Activo</option>
                                <option value="invited">Invitado</option>
                                <option value="confirmed">Confirmado sin ingreso</option>
                                <option value="pending">Pendiente</option>
                                <option value="blocked">Bloqueado</option>
                                <option value="deleted">Eliminado</option>
                                <option value="unknown">Sin diagnóstico</option>
                            </select>
                    </div>

                    <div class="grid grid-cols-1 gap-2 sm:grid-cols-2 xl:grid-cols-4">
                        <select id="users-country-filter" aria-label="Filtrar usuarios por país" class="min-h-11 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-2 text-sm text-[#293C74] focus:ring-1 focus:ring-[#293C74]/20">
                            <option value="">Todos los países</option>
                        </select>
                        <select id="users-city-filter" aria-label="Filtrar usuarios por ciudad" class="min-h-11 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-2 text-sm text-[#293C74] focus:ring-1 focus:ring-[#293C74]/20">
                            <option value="">Todas las ciudades</option>
                        </select>
                        <select id="users-scope-filter" aria-label="Filtrar usuarios por alcance" class="min-h-11 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-2 text-sm text-[#293C74] focus:ring-1 focus:ring-[#293C74]/20">
                            <option value="">Todas las categorías</option>
                            <option value="global">Global (Administración/Finanzas)</option>
                            <option value="national">Nacional</option>
                            <option value="regional">Regional</option>
                            <option value="church">Iglesia local</option>
                            <option value="campus">Campus</option>
                            <option value="assistant">Asistente/usuario base</option>
                        </select>
                        <button id="users-clear-filters" type="button" class="min-h-11 w-full rounded-md border border-slate-200 px-4 py-2 text-sm font-bold text-slate-700 hover:bg-slate-50">
                            Limpiar filtros
                        </button>
                    </div>
                </div>
                <div id="users-loading" class="py-12 text-center text-slate-400 animate-pulse">Cargando usuarios...</div>
                
                <div class="portal-table-frame">
                    <table id="users-table" class="portal-responsive-table hidden w-full text-left border-collapse">
                        <thead>
                            <tr class="text-xs text-slate-400 border-b border-slate-100">
                                <th class="py-4 pl-2 font-bold uppercase tracking-widest">Nombre</th>
                                <th class="py-4 font-bold uppercase tracking-widest">Email</th>
                                <th class="py-4 font-bold uppercase tracking-widest">Rol</th>
                                <th class="py-4 font-bold uppercase tracking-widest">Alcance</th>
                                <th class="py-4 font-bold uppercase tracking-widest">Estado acceso</th>
                                <th class="py-4 font-bold uppercase tracking-widest">Último ingreso</th>
                                <th class="py-4 pr-2 text-right font-bold uppercase tracking-widest">Acciones</th>
                            </tr>
                        </thead>
                        <tbody class="text-sm text-slate-600 divide-y divide-slate-50">
                            <!-- Rows injected by JS -->
                        </tbody>
                    </table>
                </div>
                <div id="users-empty" class="hidden text-center py-10 text-slate-400 text-sm">No se encontraron usuarios.</div>
                <div id="users-pagination" class="mt-4 hidden flex-col gap-4 border-t border-slate-100 pt-4 sm:flex-row sm:items-center sm:justify-between">
                    <div class="flex items-center gap-4">
                        <span id="users-page-info" class="text-xs font-semibold text-slate-500">Mostrando 0 usuarios</span>
                        <select id="users-page-size" aria-label="Usuarios por página" class="min-h-11 rounded-md border border-slate-200 bg-white px-4 py-2 text-xs font-semibold text-slate-700">
                            <option value="10">10 por página</option>
                            <option value="20">20 por página</option>
                            <option value="50">50 por página</option>
                        </select>
                    </div>
                    <div class="grid grid-cols-2 gap-2 sm:flex">
                        <button id="users-page-prev" type="button" class="min-h-11 rounded-md border border-slate-200 px-4 py-2 text-xs font-bold text-slate-700 hover:bg-slate-50 disabled:cursor-not-allowed disabled:opacity-40">Anterior</button>
                        <button id="users-page-next" type="button" class="min-h-11 rounded-md border border-slate-200 px-4 py-2 text-xs font-bold text-slate-700 hover:bg-slate-50 disabled:cursor-not-allowed disabled:opacity-40">Siguiente</button>
                    </div>
                </div>
            </div>

         </div>
      </section>
    </div>

    <!-- Create User Modal -->
    <div id="create-user-modal" class="fixed inset-0 z-50 hidden items-start justify-center overflow-y-auto bg-black/40 p-4" role="dialog" aria-modal="true" aria-labelledby="create-user-title" aria-describedby="create-user-description" aria-hidden="true">
        <div class="my-auto max-h-[calc(100vh-2rem)] w-full max-w-2xl overflow-y-auto rounded-2xl bg-white shadow-2xl">
            <div class="flex items-start justify-between gap-4 border-b border-slate-100 p-6 sm:p-8">
                <div>
                    <p class="mb-2 text-xs font-bold uppercase tracking-widest text-[#28A6BD]">Nuevo acceso</p>
                    <h3 id="create-user-title" class="text-2xl font-bold text-[#293C74]">Crear nuevo usuario</h3>
                    <p id="create-user-description" class="mt-2 text-sm text-slate-500">Asigna únicamente el rol y alcance que esta persona necesita.</p>
                </div>
                <button id="create-user-close" type="button" class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full border border-slate-200 text-xl text-slate-500 hover:bg-slate-50" aria-label="Cerrar creación de usuario">×</button>
            </div>
            
            <form id="create-user-form" class="space-y-6 p-6 sm:p-8">
                <fieldset class="space-y-4">
                    <legend class="mb-4 text-sm font-bold text-[#293C74]">1. Datos de la persona</legend>
                <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                    <div>
                        <label for="create-user-first-name" class="mb-2 block text-xs font-bold uppercase tracking-widest text-slate-500">Nombre</label>
                        <input id="create-user-first-name" type="text" name="firstName" required autocomplete="given-name" class="min-h-11 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-4 text-sm">
                    </div>
                    <div>
                        <label for="create-user-last-name" class="mb-2 block text-xs font-bold uppercase tracking-widest text-slate-500">Apellido</label>
                        <input id="create-user-last-name" type="text" name="lastName" required autocomplete="family-name" class="min-h-11 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-4 text-sm">
                    </div>
                </div>
                <div>
                    <label for="create-user-email" class="mb-2 block text-xs font-bold uppercase tracking-widest text-slate-500">Email</label>
                    <input id="create-user-email" type="email" name="email" required autocomplete="email" class="min-h-11 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-4 text-sm">
                </div>
                <div>
                    <label for="create-user-password" class="mb-2 block text-xs font-bold uppercase tracking-widest text-slate-500">Contraseña temporal (opcional)</label>
                    <input id="create-user-password" type="password" name="password" autocomplete="new-password" minlength="10" aria-describedby="create-user-password-help" class="min-h-11 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-4 text-sm">
                    <p id="create-user-password-help" class="mt-2 text-[11px] leading-snug text-slate-500">Déjala vacía para enviar correo de activación. Si escribes una contraseña, la cuenta se crea con esa clave y se intenta enviar un enlace de acceso.</p>
                </div>
                </fieldset>

                <fieldset class="space-y-4 border-t border-slate-100 pt-6">
                    <legend class="mb-4 text-sm font-bold text-[#293C74]">2. Responsabilidad y alcance</legend>
                 <div>
                     <label for="user-role-select" class="mb-2 block text-xs font-bold uppercase tracking-widest text-slate-500">Rol</label>
                     <select name="role" id="user-role-select" required class="min-h-11 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-4 text-sm">
                         <option value="">Cargando roles disponibles…</option>
                     </select>
                </div>

                <div id="user-campus-missionary" class="hidden">
                    <label for="user-campus-missionary-select" class="mb-2 block text-xs font-bold uppercase tracking-widest text-slate-500">Misionero asociado</label>
                    <select id="user-campus-missionary-select" name="campusMissionarySlug" class="min-h-11 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-4 text-sm">
                        <option value="">Selecciona un misionero Campus</option>
                        {MISIONEROS.map((missionary) => (
                            <option value={missionary.slug}>{missionary.nombre}</option>
                        ))}
                    </select>
                </div>

                <div id="user-finance-scope" class="hidden rounded-2xl border border-amber-200 bg-amber-50/60 p-4 sm:p-6">
                    <div class="mb-4">
                        <p class="text-sm font-bold text-amber-950">Alcance financiero obligatorio</p>
                        <p class="mt-2 text-xs leading-5 text-amber-900">Esta persona verá únicamente la información financiera del nivel seleccionado. El acceso queda registrado para auditoría.</p>
                    </div>
                    <div>
                        <label for="user-finance-scope-type" class="mb-2 block text-xs font-bold uppercase tracking-widest text-amber-900">Nivel financiero</label>
                        <select id="user-finance-scope-type" name="financeScopeType" class="min-h-11 w-full rounded-xl border border-amber-200 bg-white px-4 py-4 text-sm text-[#293C74]">
                            <option value="country">Nacional · un país</option>
                            <option value="region">Regional · una región</option>
                            <option value="church">Local · una iglesia</option>
                            <option value="global">Global · todos los países</option>
                        </select>
                    </div>
                    <div id="user-finance-country-wrapper" class="mt-4">
                        <label for="user-finance-country" class="mb-2 block text-xs font-bold uppercase tracking-widest text-amber-900">País</label>
                        <select id="user-finance-country" name="financeScopeKey" autocomplete="country-name" class="min-h-11 w-full rounded-xl border border-amber-200 bg-white px-4 py-4 text-sm">
                            <option value="">Selecciona un país</option>
                        </select>
                    </div>
                    <div id="user-finance-region-wrapper" class="mt-4 hidden">
                        <label for="user-finance-region" class="mb-2 block text-xs font-bold uppercase tracking-widest text-amber-900">Región</label>
                        <select id="user-finance-region" name="financeScopeId" class="min-h-11 w-full rounded-xl border border-amber-200 bg-white px-4 py-4 text-sm">
                            <option value="">Selecciona una región</option>
                        </select>
                    </div>
                    <div id="user-finance-church-wrapper" class="mt-4 hidden">
                        <label for="user-finance-church" class="mb-2 block text-xs font-bold uppercase tracking-widest text-amber-900">Iglesia</label>
                        <select id="user-finance-church" name="financeScopeId" class="min-h-11 w-full rounded-xl border border-amber-200 bg-white px-4 py-4 text-sm">
                            <option value="">Selecciona una iglesia</option>
                        </select>
                    </div>
                </div>

                <div id="user-scope-country" class="hidden">
                    <label id="user-country-label" for="user-country-input" class="mb-2 block text-xs font-bold uppercase tracking-widest text-slate-500">País</label>
                    <select id="user-country-input" name="country" autocomplete="country-name" class="min-h-11 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-4 text-sm">
                        <option value="">Selecciona un país</option>
                    </select>
                    <p id="user-country-help" class="mt-2 text-xs text-slate-500">Primero elige el país; después verás únicamente sus regiones e iglesias.</p>
                </div>

                <div id="user-scope-region" class="hidden">
                    <label id="user-region-label" for="user-region-select" class="mb-2 block text-xs font-bold uppercase tracking-widest text-slate-500">Región</label>
                    <select id="user-region-select" name="regionId" class="min-h-11 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-4 text-sm">
                        <option value="">Selecciona una región</option>
                    </select>
                </div>

                <div id="user-scope-church" class="hidden">
                    <label for="user-church-select" class="mb-2 block text-xs font-bold uppercase tracking-widest text-slate-500">Iglesia / Ciudad (Pastor Local)</label>
                    <select id="user-church-select" name="churchId" class="min-h-11 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-4 text-sm">
                        <option value="">Selecciona una iglesia</option>
                    </select>
                </div>

                </fieldset>

                <p id="create-user-feedback" class="hidden rounded-xl px-4 py-4 text-sm" role="status" aria-live="polite"></p>

                <div class="flex flex-col-reverse gap-4 border-t border-slate-100 pt-6 sm:flex-row sm:justify-end">
                    <button type="button" id="btn-cancel-create" class="min-h-11 flex-1 rounded-xl bg-slate-100 py-4 text-sm font-bold text-slate-600 transition-colors hover:bg-slate-200">Cancelar</button>
                    <button type="submit" id="btn-submit-create" class="min-h-11 flex-1 rounded-xl bg-[#293C74] py-4 text-sm font-bold text-white shadow-lg transition-colors hover:brightness-110">Crear usuario</button>
                </div>
            </form>
        </div>
    </div>

    <div id="role-scope-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/45 p-4" role="dialog" aria-modal="true" aria-labelledby="role-scope-title" aria-describedby="role-scope-user" aria-hidden="true">
        <div class="max-h-[calc(100vh-2rem)] w-full max-w-2xl overflow-y-auto rounded-2xl bg-white shadow-2xl">
            <div class="flex items-start justify-between gap-4 border-b border-slate-100 p-4 sm:p-6">
                <div>
                    <p class="text-xs font-bold text-[#28A6BD]">Responsabilidad principal</p>
                    <h3 id="role-scope-title" class="mt-2 text-xl font-bold text-[#293C74] sm:text-2xl">Editar rol y alcance</h3>
                    <p id="role-scope-user" class="mt-2 text-sm text-slate-500">Selecciona un usuario.</p>
                </div>
                <button id="role-scope-close" type="button" class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full border border-slate-200 text-xl text-slate-500 hover:bg-slate-50" aria-label="Cerrar edición de rol">×</button>
            </div>

            <form id="role-scope-form" class="space-y-6 p-4 sm:p-6">
                <div class="rounded-xl border border-sky-100 bg-sky-50 p-4 text-sm leading-6 text-sky-900">
                    El rol define qué puede hacer la persona. El alcance limita dónde puede hacerlo. El acceso financiero se administra aparte para no reemplazar el rol pastoral.
                </div>

                <div>
                    <label for="role-scope-role" class="mb-2 block text-xs font-bold uppercase tracking-widest text-slate-500">Rol principal</label>
                    <select id="role-scope-role" name="role" class="min-h-11 w-full rounded-xl border border-slate-200 bg-white px-4 py-4 text-sm text-[#293C74]">
                        {PORTAL_ROLE_DEFINITIONS.filter(({ role, legacy }) => role !== 'finance' && !legacy).map(({ role, label }) => (
                            <option value={role}>{label}</option>
                        ))}
                    </select>
                </div>

                <div id="role-scope-country-wrapper" class="hidden">
                    <label for="role-scope-country" class="mb-2 block text-xs font-bold uppercase tracking-widest text-slate-500">País</label>
                    <select id="role-scope-country" name="country" class="min-h-11 w-full rounded-xl border border-slate-200 bg-white px-4 py-4 text-sm">
                        <option value="">Selecciona un país</option>
                    </select>
                    <p class="mt-2 text-xs text-slate-500">La lista proviene de las iglesias y regiones activas del Portal.</p>
                </div>

                <div id="role-scope-region-wrapper" class="hidden">
                    <label for="role-scope-region" class="mb-2 block text-xs font-bold uppercase tracking-widest text-slate-500">Región</label>
                    <select id="role-scope-region" name="regionId" class="min-h-11 w-full rounded-xl border border-slate-200 bg-white px-4 py-4 text-sm">
                        <option value="">Selecciona una región</option>
                    </select>
                </div>

                <div id="role-scope-church-wrapper" class="hidden">
                    <label for="role-scope-church" class="mb-2 block text-xs font-bold uppercase tracking-widest text-slate-500">Iglesia</label>
                    <select id="role-scope-church" name="churchId" class="min-h-11 w-full rounded-xl border border-slate-200 bg-white px-4 py-4 text-sm">
                        <option value="">Selecciona una iglesia</option>
                    </select>
                </div>

                <div id="role-scope-campus-wrapper" class="hidden">
                    <label for="role-scope-campus" class="mb-2 block text-xs font-bold uppercase tracking-widest text-slate-500">Misionero Campus</label>
                    <select id="role-scope-campus" name="campusMissionarySlug" class="min-h-11 w-full rounded-xl border border-slate-200 bg-white px-4 py-4 text-sm">
                        <option value="">Selecciona un misionero Campus</option>
                        {MISIONEROS.map((missionary) => (
                            <option value={missionary.slug}>{missionary.nombre}</option>
                        ))}
                    </select>
                </div>

                <p id="role-scope-feedback" class="hidden rounded-xl px-4 py-4 text-sm" role="status" aria-live="polite"></p>

                <div class="flex flex-col-reverse gap-4 border-t border-slate-100 pt-6 sm:flex-row sm:justify-end">
                    <button id="role-scope-cancel" type="button" class="min-h-11 w-full rounded-xl border border-slate-200 bg-white px-4 py-4 text-sm font-bold text-slate-700 hover:bg-slate-50 sm:w-auto">Cancelar</button>
                    <button id="role-scope-save" type="submit" class="min-h-11 w-full rounded-xl bg-[#293C74] px-4 py-4 text-sm font-bold text-white hover:bg-[#20315f] disabled:cursor-not-allowed disabled:opacity-50 sm:w-auto">Guardar rol y alcance</button>
                </div>
            </form>
        </div>
    </div>

    <div id="finance-assignment-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/45 p-4" role="dialog" aria-modal="true" aria-labelledby="finance-assignment-title" aria-describedby="finance-assignment-user" aria-hidden="true">
        <div class="max-h-[calc(100vh-2rem)] w-full max-w-2xl overflow-y-auto rounded-2xl bg-white shadow-2xl">
            <div class="flex items-start justify-between gap-4 border-b border-slate-100 p-4 sm:p-6">
                <div>
                    <p class="text-xs font-bold text-[#28A6BD]">Permiso adicional</p>
                    <h3 id="finance-assignment-title" class="mt-2 text-xl font-bold text-[#293C74] sm:text-2xl">Acceso financiero</h3>
                    <p id="finance-assignment-user" class="mt-2 text-sm text-slate-500">Selecciona un usuario.</p>
                </div>
                <button id="finance-assignment-close" type="button" class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full border border-slate-200 text-xl text-slate-500 hover:bg-slate-50" aria-label="Cerrar alcances financieros">×</button>
            </div>

            <div class="space-y-6 p-4 sm:p-6">
                <div class="rounded-xl border border-sky-100 bg-sky-50 p-4 text-sm leading-6 text-sky-900">
                    <strong>La cuenta y su rol principal no cambian.</strong> Aquí agregas o retiras el acceso a información financiera y decides exactamente qué país, región o iglesia puede consultar.
                </div>

                <div id="finance-assignment-migration" class="hidden rounded-xl border border-amber-200 bg-amber-50 px-4 py-4 text-sm text-amber-900">
                    <p class="font-bold">Activación pendiente en Supabase</p>
                    <p class="mt-2">Ejecuta <code>docs/sql/finance_scopes_hierarchy.sql</code>. Después podrás usar esta pantalla sin escribir asignaciones SQL.</p>
                </div>

                <section aria-labelledby="finance-current-title">
                    <div class="flex items-center justify-between gap-4">
                        <h4 id="finance-current-title" class="text-sm font-bold text-[#293C74]">Alcances activos</h4>
                        <span id="finance-assignment-count" class="rounded-full bg-slate-100 px-4 py-2 text-[10px] font-bold uppercase tracking-wider text-slate-600">0 asignaciones</span>
                    </div>
                    <div id="finance-assignment-list" class="mt-4 space-y-2">
                        <p class="rounded-xl border border-dashed border-slate-200 px-4 py-4 text-center text-sm text-slate-400">Cargando asignaciones…</p>
                    </div>
                </section>

                <form id="finance-assignment-form" class="space-y-4 rounded-2xl border border-slate-200 bg-slate-50/70 p-4 sm:p-6">
                    <div>
                        <h4 class="text-sm font-bold text-[#293C74]">Asignar acceso financiero</h4>
                        <p class="mt-2 text-xs text-slate-500">Puede tener más de uno. Nunca se mezclan movimientos fuera de los alcances asignados.</p>
                    </div>

                    <div>
                        <label for="finance-assignment-scope" class="mb-2 block text-xs font-bold uppercase tracking-widest text-slate-500">Nivel financiero</label>
                        <select id="finance-assignment-scope" name="scopeType" class="min-h-11 w-full rounded-xl border border-slate-200 bg-white px-4 py-4 text-sm text-[#293C74]">
                            <option value="church">Local · una iglesia</option>
                            <option value="region">Regional · una región</option>
                            <option value="country">Nacional · un país</option>
                            <option value="global">Global · todas las cuentas autorizadas</option>
                        </select>
                    </div>

                    <div id="finance-assignment-country-wrapper" class="hidden">
                        <label for="finance-assignment-country" class="mb-2 block text-xs font-bold uppercase tracking-widest text-slate-500">País</label>
                        <select id="finance-assignment-country" name="scopeKey" autocomplete="country-name" class="min-h-11 w-full rounded-xl border border-slate-200 bg-white px-4 py-4 text-sm">
                            <option value="">Selecciona un país</option>
                        </select>
                    </div>

                    <div id="finance-assignment-region-wrapper" class="hidden">
                        <label for="finance-assignment-region" class="mb-2 block text-xs font-bold uppercase tracking-widest text-slate-500">Región</label>
                        <select id="finance-assignment-region" name="scopeId" class="min-h-11 w-full rounded-xl border border-slate-200 bg-white px-4 py-4 text-sm">
                            <option value="">Selecciona una región</option>
                        </select>
                    </div>

                    <div id="finance-assignment-church-wrapper">
                        <label for="finance-assignment-church" class="mb-2 block text-xs font-bold uppercase tracking-widest text-slate-500">Iglesia</label>
                        <select id="finance-assignment-church" name="scopeId" class="min-h-11 w-full rounded-xl border border-slate-200 bg-white px-4 py-4 text-sm">
                            <option value="">Selecciona una iglesia</option>
                        </select>
                    </div>

                    <p id="finance-assignment-feedback" class="hidden rounded-xl px-4 py-4 text-sm" role="status"></p>

                    <div class="flex flex-col-reverse gap-4 pt-2 sm:flex-row sm:justify-end">
                        <button id="finance-assignment-cancel" type="button" class="min-h-11 w-full rounded-md border border-slate-200 bg-white px-4 py-2 text-sm font-bold text-slate-700 hover:bg-slate-50 sm:w-auto">Cerrar</button>
                        <button id="finance-assignment-save" type="submit" class="min-h-11 w-full rounded-md bg-[#293C74] px-4 py-2 text-sm font-bold text-white hover:bg-[#20315f] disabled:cursor-not-allowed disabled:opacity-50 sm:w-auto">Asignar acceso</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

  </div>
  <script>
      import '@scripts/portal-users.js';
  </script>
</BaseLayout>
