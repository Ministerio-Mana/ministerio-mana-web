---
import BaseLayout from '@layouts/BaseLayout.astro';
import PortalIcon from '@components/portal/PortalIcon.astro';
import Sidebar from '@components/portal/Sidebar.astro';
---

<BaseLayout title="Gestión de Contenido | Portal Maná" description="CMS para administrar contenido público del sitio." hideHeader hideFooter noindex>
  <div class="portal-shell min-h-screen bg-[#F8FAFC] text-slate-800 selection:bg-[#293C74]/20">
    <div class="flex flex-col lg:flex-row min-h-screen">
      <Sidebar />

      <section class="flex-1 p-4 md:p-8 lg:p-12 xl:p-14 relative overflow-y-auto">
        <div id="cms-gate" class="max-w-xl mx-auto rounded-2xl border border-slate-200 bg-white px-6 py-8 text-center text-slate-500 shadow-sm">
          Validando permisos...
        </div>

        <div id="cms-secure-content" class="hidden max-w-7xl mx-auto space-y-6 md:space-y-8">
          <header class="border-b border-slate-200 pb-5">
            <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-4">
              <div>
                <p class="text-xs font-bold text-slate-500 uppercase">Edición del sitio</p>
                <h1 class="text-2xl md:text-4xl font-display font-bold text-[#293C74]">Contenido</h1>
                <p class="text-slate-600 mt-1 text-sm md:text-base">Páginas, bloques, imágenes y publicación.</p>
              </div>
              <div class="flex flex-wrap items-center gap-2">
                <button id="cms-new-page" data-cms-action class="inline-flex min-h-11 items-center gap-2 px-4 py-2.5 rounded-md bg-[#293C74] text-white text-sm font-bold hover:bg-[#1f2f63] transition">
                  <PortalIcon name="plus" size={18} />
                  Nueva página
                </button>
              </div>
            </div>
          </header>

          <div id="cms-alert" class="hidden rounded-xl border px-4 py-3 text-sm"></div>

          <div id="cms-busy" class="hidden rounded-xl border border-[#293C74]/20 bg-[#293C74]/5 px-4 py-2 text-xs font-bold text-[#293C74] animate-pulse"></div>

          <section id="cms-setup" class="portal-panel hidden overflow-hidden">
            <div class="grid md:grid-cols-[190px_1fr]">
              <div class="flex min-h-40 items-center justify-center bg-[#293C74] text-white">
                <PortalIcon name="file-pen-line" size={46} />
              </div>
              <div class="p-6 md:p-8">
                <p class="text-xs font-bold uppercase text-amber-700">Configuración pendiente</p>
                <h2 class="mt-1 text-xl font-bold text-[#293C74]">Activa la base editorial</h2>
                <p class="mt-2 max-w-2xl text-sm leading-relaxed text-slate-600">Las tablas de contenido todavía no existen en Supabase. Ejecuta el archivo indicado una sola vez; no modifica eventos, usuarios, donaciones ni pagos.</p>
                <code class="mt-4 block overflow-x-auto rounded-md border border-slate-200 bg-slate-50 px-4 py-3 text-xs text-slate-700">docs/sql/cms_schema.sql</code>
              </div>
            </div>
          </section>

          <div id="cms-workbench" class="grid grid-cols-1 xl:grid-cols-[340px_1fr] gap-5 md:gap-6">
            <aside class="bg-white border border-slate-200 rounded-[1.75rem] p-4 md:p-5 shadow-sm space-y-4 xl:sticky xl:top-6 xl:h-[calc(100vh-8rem)] xl:overflow-hidden">
              <div class="space-y-2">
                <label for="cms-filter" class="text-[10px] font-bold uppercase tracking-[0.2em] text-slate-500">Buscar página</label>
                <input id="cms-filter" class="w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-2.5 text-sm" placeholder="home, eventos, noticias..." />
              </div>
              <div id="cms-pages" class="space-y-2 xl:max-h-[calc(100vh-14.5rem)] xl:overflow-auto pr-1"></div>
              <div id="cms-pages-empty" class="hidden rounded-xl border border-dashed border-slate-200 p-4 text-sm text-slate-500">No hay páginas CMS todavía.</div>
            </aside>

            <section class="space-y-5 md:space-y-6">
              <div class="bg-white border border-slate-200 rounded-[1.75rem] p-4 md:p-6 shadow-sm space-y-4">
                <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-3">
                  <h2 class="text-lg md:text-xl font-display font-bold text-[#293C74]">Configuración de Página</h2>
                  <div class="flex flex-wrap items-center gap-2">
                    <button id="cms-page-save" data-cms-action class="min-h-10 px-4 py-2 rounded-xl bg-brand-teal text-white text-sm font-bold hover:bg-brand-teal/90 transition">Guardar</button>
                    <button id="cms-page-publish" data-cms-action class="min-h-10 px-4 py-2 rounded-xl border border-[#293C74]/30 text-[#293C74] text-sm font-bold hover:bg-[#293C74]/5 transition">Publicar</button>
                    <button id="cms-page-unpublish" data-cms-action class="min-h-10 px-4 py-2 rounded-xl border border-slate-300 text-slate-700 text-sm font-bold hover:bg-slate-100 transition">Borrador</button>
                    <button id="cms-page-preview" data-cms-action class="min-h-10 px-4 py-2 rounded-xl border border-brand-teal/40 text-brand-teal text-sm font-bold hover:bg-brand-teal/10 transition">Vista previa</button>
                  </div>
                </div>

                <div id="cms-page-form" class="grid grid-cols-1 md:grid-cols-2 gap-4">
                  <label class="text-xs font-bold text-slate-600">Nombre interno
                    <input id="cms-page-key" class="mt-1 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-2.5 text-sm" />
                  </label>
                  <label class="text-xs font-bold text-slate-600">Ruta pública
                    <input id="cms-page-path" class="mt-1 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-2.5 text-sm" placeholder="/" />
                  </label>
                  <label class="text-xs font-bold text-slate-600">Título
                    <input id="cms-page-title" class="mt-1 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-2.5 text-sm" />
                  </label>
                  <label class="text-xs font-bold text-slate-600">Idioma
                    <input id="cms-page-locale" class="mt-1 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-2.5 text-sm" value="es" />
                  </label>
                  <label class="text-xs font-bold text-slate-600 md:col-span-2">Descripción
                    <textarea id="cms-page-description" rows="2" class="mt-1 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-2.5 text-sm"></textarea>
                  </label>
                  <label class="text-xs font-bold text-slate-600">Título para buscadores
                    <input id="cms-page-seo-title" class="mt-1 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-2.5 text-sm" />
                  </label>
                  <label class="text-xs font-bold text-slate-600">Descripción para buscadores
                    <input id="cms-page-seo-description" class="mt-1 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-2.5 text-sm" />
                  </label>
                  <label class="text-xs font-bold text-slate-600 md:col-span-2">Imagen al compartir
                    <input id="cms-page-seo-image" class="mt-1 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-2.5 text-sm" placeholder="https://..." />
                  </label>
                </div>

                <div id="cms-page-meta" class="text-xs text-slate-500"></div>
              </div>

              <div class="bg-white border border-slate-200 rounded-[1.75rem] p-4 md:p-6 shadow-sm space-y-5">
                <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-3">
                  <h2 class="text-lg md:text-xl font-display font-bold text-[#293C74]">Secciones</h2>
                  <button id="cms-section-new" data-cms-action class="inline-flex min-h-10 items-center gap-2 px-4 py-2 rounded-xl bg-[#293C74] text-white text-sm font-bold hover:bg-[#1f2f63] transition"><PortalIcon name="plus" size={17} /> Agregar sección</button>
                </div>

                <div id="cms-sections" class="space-y-3"></div>
                <div id="cms-sections-empty" class="hidden rounded-xl border border-dashed border-slate-200 p-4 text-sm text-slate-500">Esta página aún no tiene secciones.</div>
              </div>

              <div class="bg-white border border-slate-200 rounded-[1.75rem] p-4 md:p-6 shadow-sm space-y-4">
                <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-3">
                  <h2 class="text-lg md:text-xl font-display font-bold text-[#293C74]">Biblioteca Multimedia</h2>
                  <button id="cms-media-refresh" data-cms-action class="min-h-10 px-4 py-2 rounded-xl border border-slate-300 text-slate-700 text-sm font-bold hover:bg-slate-100 transition">Actualizar</button>
                </div>
                <form id="cms-media-upload-form" class="space-y-3">
                  <label id="cms-media-dropzone" for="cms-media-file" class="group flex min-h-36 cursor-pointer flex-col items-center justify-center gap-2 rounded-xl border-2 border-dashed border-slate-300 bg-slate-50 px-5 py-6 text-center transition hover:border-[#293C74] hover:bg-[#293C74]/5 focus-within:border-[#293C74] focus-within:ring-2 focus-within:ring-[#293C74]/20">
                    <span class="flex h-11 w-11 items-center justify-center rounded-full bg-white text-[#293C74] shadow-sm"><PortalIcon name="upload" size={21} /></span>
                    <span class="text-sm font-bold text-[#293C74]">Arrastra imágenes aquí</span>
                    <span class="text-xs text-slate-500">o haz clic para seleccionar imágenes</span>
                    <span id="cms-media-file-name" class="hidden max-w-full truncate rounded-md bg-white px-3 py-1 text-xs font-bold text-slate-700"></span>
                    <input id="cms-media-file" type="file" accept="image/jpeg,image/png,image/webp" multiple class="sr-only" />
                  </label>
                  <div class="grid grid-cols-1 gap-3 md:grid-cols-[1fr_auto]">
                    <input id="cms-media-folder" type="text" class="w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-2.5 text-sm" placeholder="Carpeta (ej: inicio)" />
                    <div class="flex flex-col gap-2 sm:flex-row">
                      <button id="cms-media-directory-trigger" type="button" data-cms-action class="inline-flex min-h-11 items-center justify-center gap-2 rounded-md border border-[#293C74]/30 bg-white px-4 py-2.5 text-sm font-bold text-[#293C74] transition hover:bg-[#293C74]/5"><PortalIcon name="archive" size={17} /> Carpeta completa</button>
                      <button type="submit" data-cms-action class="inline-flex min-h-11 items-center justify-center gap-2 rounded-md bg-[#293C74] px-5 py-2.5 text-sm font-bold text-white transition hover:bg-[#1f2f63]"><PortalIcon name="upload" size={17} /> Subir</button>
                    </div>
                  </div>
                  <input id="cms-media-directory" type="file" accept="image/jpeg,image/png,image/webp" multiple webkitdirectory class="sr-only" />
                </form>
                <div id="cms-media-upload-progress" class="hidden space-y-2" aria-live="polite">
                  <div class="flex items-center justify-between gap-3 text-xs font-bold text-slate-600">
                    <span id="cms-media-upload-progress-label">Preparando carga...</span>
                    <span id="cms-media-upload-progress-count">0%</span>
                  </div>
                  <div class="h-2 overflow-hidden rounded-full bg-slate-100">
                    <div id="cms-media-upload-progress-bar" class="h-full w-0 rounded-full bg-brand-teal transition-[width] duration-300"></div>
                  </div>
                </div>
                <p class="text-xs text-slate-500">Imágenes JPG, PNG o WebP. El sistema valida tipo, peso y dimensiones antes de publicarlas.</p>
                <div id="cms-media-status" class="text-xs text-slate-500"></div>
                <div id="cms-media-list" class="grid grid-cols-1 md:grid-cols-2 gap-3"></div>
                <div id="cms-media-empty" class="hidden rounded-xl border border-dashed border-slate-200 p-4 text-sm text-slate-500">No hay archivos cargados aún.</div>
              </div>

              <div class="bg-white border border-slate-200 rounded-[1.75rem] p-4 md:p-6 shadow-sm space-y-4">
                <h2 class="text-lg md:text-xl font-display font-bold text-[#293C74]">Actividad Reciente</h2>
                <div id="cms-history" class="space-y-2"></div>
                <div id="cms-history-empty" class="hidden rounded-xl border border-dashed border-slate-200 p-4 text-sm text-slate-500">Sin movimientos para esta página.</div>
              </div>
            </section>
          </div>
        </div>
      </section>
    </div>
  </div>

  <div id="cms-page-modal" class="hidden fixed inset-0 z-50 bg-slate-900/50 backdrop-blur-sm p-4 md:p-6">
    <div class="mx-auto mt-10 max-w-lg rounded-[1.75rem] bg-white border border-slate-200 p-5 md:p-6 shadow-2xl">
      <div class="flex items-center justify-between gap-3">
        <h3 class="text-lg font-bold text-[#293C74]">Nueva Página</h3>
        <button id="cms-page-modal-close" class="inline-flex h-9 w-9 items-center justify-center rounded-md border border-slate-200 text-slate-500 hover:text-slate-800 hover:border-slate-300" aria-label="Cerrar"><PortalIcon name="x" size={19} /></button>
      </div>
      <form id="cms-page-modal-form" class="mt-4 space-y-3">
        <label class="block text-xs font-bold text-slate-600">Nombre interno
          <input id="cms-modal-page-key" required class="mt-1 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-2.5 text-sm" placeholder="home" />
        </label>
        <label class="block text-xs font-bold text-slate-600">Título
          <input id="cms-modal-page-title" required class="mt-1 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-2.5 text-sm" placeholder="Inicio" />
        </label>
        <label class="block text-xs font-bold text-slate-600">Ruta
          <input id="cms-modal-page-path" required class="mt-1 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-2.5 text-sm" placeholder="/" />
        </label>
        <div class="pt-2 flex items-center justify-end gap-2">
          <button type="button" id="cms-page-modal-cancel" class="px-4 py-2 rounded-xl border border-slate-300 text-slate-700 text-sm font-bold">Cancelar</button>
          <button type="submit" data-cms-action class="px-4 py-2 rounded-xl bg-[#293C74] text-white text-sm font-bold">Crear página</button>
        </div>
      </form>
    </div>
  </div>

  <div id="cms-section-modal" class="hidden fixed inset-0 z-50 bg-slate-900/50 backdrop-blur-sm p-4 md:p-6">
    <div class="mx-auto mt-10 max-w-lg rounded-[1.75rem] bg-white border border-slate-200 p-5 md:p-6 shadow-2xl">
      <div class="flex items-center justify-between gap-3">
        <h3 class="text-lg font-bold text-[#293C74]">Nueva Sección</h3>
        <button id="cms-section-modal-close" class="inline-flex h-9 w-9 items-center justify-center rounded-md border border-slate-200 text-slate-500 hover:text-slate-800 hover:border-slate-300" aria-label="Cerrar"><PortalIcon name="x" size={19} /></button>
      </div>
      <form id="cms-section-modal-form" class="mt-4 space-y-3">
        <label class="block text-xs font-bold text-slate-600">Nombre interno de la sección
          <input id="cms-modal-section-key" required class="mt-1 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-2.5 text-sm" placeholder="hero-principal" />
        </label>
        <label class="block text-xs font-bold text-slate-600">Tipo
          <select id="cms-modal-section-kind" class="mt-1 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-2.5 text-sm">
            <option value="hero">Portada</option>
            <option value="rich_text" selected>Texto</option>
            <option value="gallery">Galería</option>
            <option value="cta">Llamado a la acción</option>
            <option value="video">Video</option>
            <option value="cards">Tarjetas</option>
            <option value="custom">Avanzado</option>
          </select>
        </label>
        <label class="block text-xs font-bold text-slate-600">Título
          <input id="cms-modal-section-title" class="mt-1 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-2.5 text-sm" placeholder="Hero principal" />
        </label>
        <div class="pt-2 flex items-center justify-end gap-2">
          <button type="button" id="cms-section-modal-cancel" class="px-4 py-2 rounded-xl border border-slate-300 text-slate-700 text-sm font-bold">Cancelar</button>
          <button type="submit" data-cms-action class="px-4 py-2 rounded-xl bg-[#293C74] text-white text-sm font-bold">Crear sección</button>
        </div>
      </form>
    </div>
  </div>

  <script src="../../scripts/portal-content.js"></script>
</BaseLayout>
