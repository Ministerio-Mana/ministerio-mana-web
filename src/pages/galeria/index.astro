---
import BaseLayout from '@layouts/BaseLayout.astro';
import PortalIcon from '@components/portal/PortalIcon.astro';
import { CUMBRE_GALLERY_FOLDER } from '@lib/cumbreGallery';
import { optimizedPublicImageUrl } from '@lib/publicMedia';
import { supabaseAdmin } from '@lib/supabaseAdmin';

export const prerender = false;

let photoCount = 0;
let cover: string | null = null;
if (supabaseAdmin) {
  const result = await supabaseAdmin
    .from('cms_media')
    .select('public_url', { count: 'exact' })
    .eq('provider', 'imagekit')
    .like('folder', `${CUMBRE_GALLERY_FOLDER}/%`)
    .order('path', { ascending: true })
    .range(0, 0);
  photoCount = Number(result.count || 0);
  cover = result.data?.[0]?.public_url || null;
}
---

<BaseLayout title="Galería — Ministerio Maná" description="Memoria fotográfica de encuentros y eventos del Ministerio Maná.">
  <main class="bg-slate-50 text-slate-900">
    <header class="border-b border-slate-200 bg-white">
      <div class="container-tight py-10 sm:py-14">
        <p class="text-xs font-bold uppercase text-slate-500">Memoria Maná</p>
        <h1 class="mt-2 text-3xl font-bold text-[#293C74] sm:text-4xl">Galería</h1>
        <p class="mt-3 max-w-2xl text-base leading-relaxed text-slate-600">Encuentros, celebraciones y personas que hacen parte de nuestra historia como iglesia.</p>
      </div>
    </header>

    <section class="container-tight py-8 sm:py-12" aria-labelledby="gallery-events-title">
      <div class="mb-6 flex items-end justify-between gap-4 border-b border-slate-200 pb-5">
        <div>
          <h2 id="gallery-events-title" class="text-xl font-bold text-[#293C74]">Eventos</h2>
          <p class="mt-1 text-sm text-slate-500">Selecciona un encuentro para explorar sus álbumes.</p>
        </div>
      </div>

      <a href="/galeria/cumbre-mundial-2026" class="group grid overflow-hidden border border-slate-200 bg-white transition hover:border-[#293C74]/40 md:grid-cols-[minmax(0,1.4fr)_minmax(280px,0.6fr)]">
        <div class="aspect-[16/10] overflow-hidden bg-slate-200 md:aspect-auto md:min-h-80">
          {cover ? (
            <img src={optimizedPublicImageUrl(cover, 1280, 82)} alt="Cumbre Mundial Maná 2026" class="h-full w-full object-cover transition duration-500 group-hover:scale-[1.02]" loading="eager" decoding="async" />
          ) : (
            <div class="flex h-full min-h-64 items-center justify-center text-slate-400"><PortalIcon name="image" size={44} /></div>
          )}
        </div>
        <div class="flex flex-col justify-between p-6 sm:p-8">
          <div>
            <p class="text-xs font-bold uppercase text-slate-500">Junio de 2026</p>
            <h3 class="mt-2 text-2xl font-bold text-[#293C74]">Cumbre Mundial Maná 2026</h3>
            <p class="mt-3 text-sm leading-relaxed text-slate-600">La memoria fotográfica de plenarias, celebraciones y espacios de comunidad.</p>
          </div>
          <div class="mt-8 flex items-center justify-between gap-4 border-t border-slate-200 pt-4 text-sm font-bold text-[#293C74]">
            <span>{photoCount} fotografías</span>
            <span class="inline-flex items-center gap-2">Ver álbumes <span class="rotate-180"><PortalIcon name="arrow-left" size={18} /></span></span>
          </div>
        </div>
      </a>
    </section>
  </main>
</BaseLayout>
