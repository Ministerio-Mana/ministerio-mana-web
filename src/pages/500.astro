---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  title="Error del Servidor · Ministerio Maná"
  description="Ocurrió un error inesperado. Estamos trabajando para resolverlo."
  noindex={true}
>
  <section class="relative min-h-[85vh] flex items-center justify-center overflow-hidden bg-brand-void">
    
    <!-- Stormy background -->
    <div class="absolute inset-0">
      <!-- Animated gradient clouds -->
      <div class="absolute inset-0 opacity-30" style="background: radial-gradient(ellipse at 30% 20%, rgba(41,60,116,0.5) 0%, transparent 50%), radial-gradient(ellipse at 70% 60%, rgba(246,81,155,0.2) 0%, transparent 40%), radial-gradient(ellipse at 50% 80%, rgba(40,166,189,0.15) 0%, transparent 50%);"></div>
      <!-- Noise texture -->
      <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml;base64,');"></div>
    </div>

    <!-- Content -->
    <div class="relative z-10 text-center px-4 max-w-2xl mx-auto">
      
      <!-- Error icon with pulse -->
      <div class="mb-8 relative inline-block">
        <div class="w-20 h-20 rounded-2xl bg-gradient-to-br from-brand/30 to-accent/20 border border-white/10 flex items-center justify-center mx-auto backdrop-blur-sm">
          <svg class="w-10 h-10 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
          </svg>
        </div>
        <!-- Pulse ring -->
        <div class="absolute -inset-3 rounded-3xl border border-accent/20 animate-ping opacity-30"></div>
      </div>

      <!-- 500 Number -->
      <div class="mb-4">
        <span class="text-6xl md:text-7xl font-display font-black text-transparent bg-clip-text bg-gradient-to-r from-slate-500 to-slate-700 select-none">
          500
        </span>
      </div>

      <!-- Message -->
      <h1 class="text-2xl md:text-3xl font-display font-black text-white mb-3 tracking-tight">
        Algo salió mal
      </h1>
      <p class="text-slate-400 text-base md:text-lg leading-relaxed mb-6 max-w-lg mx-auto">
        Nuestro servidor tuvo un problema inesperado. Estamos trabajando para resolverlo. 
        Intenta de nuevo en unos minutos.
      </p>

      <!-- Status pill -->
      <div class="inline-flex items-center gap-2 rounded-full bg-white/5 border border-white/10 px-4 py-2 mb-8">
        <span class="w-2 h-2 rounded-full bg-amber-400 animate-pulse"></span>
        <span class="text-xs font-display text-slate-400 uppercase tracking-widest">Investigando el problema</span>
      </div>

      <!-- Bible verse -->
      <div class="mb-10 max-w-md mx-auto">
        <blockquote class="text-sm text-slate-500 italic">
          "No temas, porque yo estoy contigo; no desmayes, porque yo soy tu Dios."
        </blockquote>
        <cite class="text-xs text-slate-600 not-italic font-display uppercase tracking-widest">
          — Isaías 41:10
        </cite>
      </div>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <button onclick="window.location.reload()" class="group relative inline-flex items-center gap-2 rounded-full px-7 py-3 text-sm font-display font-bold text-white bg-mana-gradient shadow-brand hover:shadow-brandHover transition-all duration-300 hover:-translate-y-0.5">
          <svg class="w-4 h-4 transition-transform group-hover:rotate-180 duration-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>
          Reintentar
        </button>
        <a href="/" class="inline-flex items-center gap-2 rounded-full px-7 py-3 text-sm font-display font-bold text-white/60 hover:text-white border border-white/10 hover:border-white/25 transition-all duration-300">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>
          Volver al Inicio
        </a>
      </div>

      <!-- Contact -->
      <p class="mt-8 text-xs text-slate-600">
        Si el problema persiste, escríbenos a 
        <a href="mailto:info@ministeriomana.org" class="text-brand-teal hover:underline font-bold">info@ministeriomana.org</a>
      </p>
    </div>
  </section>
</BaseLayout>
