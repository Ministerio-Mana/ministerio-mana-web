---
import VenAyudanosExperience from '@components/ven-ayudanos/VenAyudanosExperience.astro';
import MujeresVenAyudanosExperience from '@components/ven-ayudanos/MujeresVenAyudanosExperience.astro';
import KidsVenAyudanosExperience from '@components/ven-ayudanos/KidsVenAyudanosExperience.astro';
import { routedMinistryKeys, type RoutedMinistryKey } from '@data/venAyudanos';

export const prerender = false;

const slug = Astro.params.ministerio?.toLowerCase();

if (slug === 'campus') {
  return Astro.redirect(`/campus/${Astro.url.search}`);
}

if (!slug || !routedMinistryKeys.includes(slug as RoutedMinistryKey)) {
  return Astro.redirect('/ven-ayudanos');
}
---

{slug === 'mujeres' ? (
  <MujeresVenAyudanosExperience />
) : slug === 'ninos' ? (
  <KidsVenAyudanosExperience />
) : (
  <VenAyudanosExperience selected={slug as RoutedMinistryKey} />
)}
