---
import BaseLayout from '@layouts/BaseLayout.astro';

const cspNonce = Astro.locals?.cspNonce;
const installmentDeadline = (import.meta.env?.CUMBRE_INSTALLMENT_DEADLINE ?? '2026-05-15') as string;
---

<BaseLayout title="Cumbre 2026 Manual | Ministerio Maná" description="Operación privada para reservas y pagos físicos." hideHeader hideFooter noindex>
  <div class="min-h-screen bg-[#F8FAFC] text-slate-800 selection:bg-[#293C74]/20">
    <section class="px-4 py-12 md:px-8 md:py-16" aria-labelledby="cumbre-manual-title">
      <div class="mx-auto max-w-5xl space-y-8">
        <div class="relative overflow-hidden rounded-2xl border border-slate-100 bg-white p-8 shadow-lg shadow-slate-200/60">
          <div class="absolute -right-8 -top-12 h-40 w-40 rounded-full bg-[#293C74]/10"></div>
          <div class="relative">
            <p class="text-xs font-bold uppercase tracking-widest text-slate-500">Portal Maná</p>
            <h1 id="cumbre-manual-title" class="mt-2 text-3xl font-display font-bold text-[#293C74] md:text-4xl">Registro manual Cumbre 2026</h1>
            <p class="mt-2 max-w-2xl text-slate-600">Usa este formulario únicamente cuando la reserva o el pago físico ya fueron verificados por el equipo autorizado.</p>
          </div>
        </div>

        <div id="cumbre-manual-gate" class="mx-auto max-w-xl rounded-xl border border-slate-200 bg-white px-6 py-8 text-center text-slate-500 shadow-sm" role="status" aria-live="polite">
          <p id="cumbre-manual-gate-message">Validando cuenta individual...</p>
          <a id="cumbre-manual-gate-link" href="/portal" class="mt-4 hidden min-h-11 items-center justify-center rounded-xl border border-slate-300 bg-white px-4 py-2 text-sm font-bold text-[#293C74] hover:bg-slate-50">Volver al Portal</a>
        </div>

        <div id="cumbre-manual-content" class="hidden space-y-8">
        <aside class="rounded-xl border border-amber-200 bg-amber-50 p-4 text-sm leading-6 text-amber-900" aria-labelledby="cumbre-manual-security-title">
          <h2 id="cumbre-manual-security-title" class="font-bold">Operación financiera sensible</h2>
          <p class="mt-2">No uses esta pantalla para simular pagos. Verifica soporte, reserva, moneda y monto antes de confirmar. Los cambios quedan asociados a tu cuenta individual.</p>
          <p id="cumbre-manual-actor" class="mt-2 font-bold">Sesión en validación</p>
        </aside>

        <div class="rounded-2xl border border-slate-100 bg-white p-8 shadow-lg shadow-slate-200/50">
          <div class="mb-8 flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
            <div>
              <h2 class="text-xl md:text-2xl font-display font-bold text-[#293C74]">Crear reserva manual</h2>
              <p class="text-sm text-slate-500">Datos del responsable + participantes y forma de pago.</p>
            </div>
            <span class="inline-flex items-center gap-2 rounded-full bg-[#293C74]/10 px-4 py-2 text-xs font-bold uppercase tracking-widest text-[#293C74]">Formulario interno</span>
          </div>

          <form id="manual-booking-form" method="POST" action="/api/cumbre2026/manual/submit" class="space-y-8" data-installment-deadline={installmentDeadline}>
            <input type="hidden" name="participants" id="participants-json" value="[]" />
            <input type="hidden" name="idempotencyKey" id="manual-idempotency-key" />

            <div class="grid gap-4 md:grid-cols-2">
              <div>
                <label for="manual-contact-name" class="mb-2 block text-xs font-bold uppercase tracking-widest text-[#293C74]">Nombre responsable</label>
                <input id="manual-contact-name" name="contactName" autocomplete="name" required class="min-h-11 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-4 font-medium text-[#293C74] outline-none transition-all placeholder-slate-400 focus:border-[#293C74] focus:ring-1 focus:ring-[#293C74]" placeholder="Nombre completo" />
              </div>
              <div>
                <label for="manual-contact-email" class="mb-2 block text-xs font-bold uppercase tracking-widest text-[#293C74]">Email</label>
                <input id="manual-contact-email" type="email" name="email" autocomplete="email" required class="min-h-11 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-4 font-medium text-[#293C74] outline-none transition-all placeholder-slate-400 focus:border-[#293C74] focus:ring-1 focus:ring-[#293C74]" placeholder="correo@email.com" />
              </div>
              <div>
                <label for="manual-contact-phone" class="mb-2 block text-xs font-bold uppercase tracking-widest text-[#293C74]">Teléfono</label>
                <input id="manual-contact-phone" name="phone" type="tel" autocomplete="tel" required class="min-h-11 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-4 font-medium text-[#293C74] outline-none transition-all placeholder-slate-400 focus:border-[#293C74] focus:ring-1 focus:ring-[#293C74]" placeholder="300 000 0000" />
              </div>
              <div>
                <label for="manual-document-type" class="mb-2 block text-xs font-bold uppercase tracking-widest text-[#293C74]">Tipo documento</label>
                <select id="manual-document-type" name="documentType" class="min-h-11 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-4 font-medium text-[#293C74] outline-none transition-all focus:border-[#293C74] focus:ring-1 focus:ring-[#293C74]">
                  <option value="">Selecciona</option>
                  <option value="CC">CC</option>
                  <option value="CE">CE</option>
                  <option value="NIT">NIT</option>
                  <option value="TI">TI</option>
                  <option value="PAS">Pasaporte</option>
                </select>
              </div>
              <div>
                <label for="manual-document-number" class="mb-2 block text-xs font-bold uppercase tracking-widest text-[#293C74]">Número documento</label>
                <input id="manual-document-number" name="documentNumber" autocomplete="off" class="min-h-11 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-4 font-medium text-[#293C74] outline-none transition-all placeholder-slate-400 focus:border-[#293C74] focus:ring-1 focus:ring-[#293C74]" placeholder="Documento" />
              </div>
              <div>
                <label for="manual-country" class="mb-2 block text-xs font-bold uppercase tracking-widest text-[#293C74]">País</label>
                <input id="manual-country" name="country" autocomplete="country-name" required class="min-h-11 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-4 font-medium text-[#293C74] outline-none transition-all placeholder-slate-400 focus:border-[#293C74] focus:ring-1 focus:ring-[#293C74]" placeholder="Colombia" />
              </div>
              <div>
                <label for="manual-city" class="mb-2 block text-xs font-bold uppercase tracking-widest text-[#293C74]">Ciudad</label>
                <input id="manual-city" name="city" autocomplete="address-level2" required class="min-h-11 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-4 font-medium text-[#293C74] outline-none transition-all placeholder-slate-400 focus:border-[#293C74] focus:ring-1 focus:ring-[#293C74]" placeholder="Ciudad" />
              </div>
              <div>
                <label for="manual-church" class="mb-2 block text-xs font-bold uppercase tracking-widest text-[#293C74]">Iglesia / Sede</label>
                <input id="manual-church" name="church" required class="min-h-11 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-4 font-medium text-[#293C74] outline-none transition-all placeholder-slate-400 focus:border-[#293C74] focus:ring-1 focus:ring-[#293C74]" placeholder="Iglesia / Sede" />
              </div>
              <div>
                <label for="manual-country-group" class="mb-2 block text-xs font-bold uppercase tracking-widest text-[#293C74]">Grupo país</label>
                <select id="manual-country-group" name="countryGroup" class="min-h-11 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-4 font-medium text-[#293C74] outline-none transition-all focus:border-[#293C74] focus:ring-1 focus:ring-[#293C74]">
                  <option value="CO" selected>Colombia</option>
                  <option value="INT">Internacional</option>
                </select>
              </div>
            </div>

            <div class="rounded-2xl border border-slate-100 bg-slate-50/70 p-6">
              <div class="mb-4 flex flex-wrap items-center justify-between gap-4">
                <div>
                  <h3 class="text-sm font-bold text-[#293C74]">Participantes</h3>
                  <p class="mt-2 text-xs text-slate-500">Los cupos con hospedaje ya están agotados; registra nuevos participantes sin alojamiento.</p>
                </div>
                <button type="button" id="add-participant" class="min-h-11 rounded-xl bg-[#293C74] px-4 py-2 text-xs font-bold text-white transition hover:bg-[#293C74]/90">Agregar participante</button>
              </div>
              <div class="grid gap-4 md:grid-cols-4">
                <div>
                  <label for="participant-name" class="mb-2 block text-xs font-bold text-[#293C74]">Nombre</label>
                  <input id="participant-name" autocomplete="off" class="min-h-11 w-full rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm text-[#293C74] outline-none placeholder-slate-400 focus:border-[#293C74] focus:ring-1 focus:ring-[#293C74]" placeholder="Nombre completo" />
                </div>
                <div>
                  <label for="participant-age" class="mb-2 block text-xs font-bold text-[#293C74]">Edad</label>
                  <input id="participant-age" type="number" min="0" max="120" step="1" inputmode="numeric" class="min-h-11 w-full rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm text-[#293C74] outline-none placeholder-slate-400 focus:border-[#293C74] focus:ring-1 focus:ring-[#293C74]" placeholder="Edad" />
                </div>
                <div>
                  <label for="participant-lodging" class="mb-2 block text-xs font-bold text-[#293C74]">Alojamiento</label>
                  <select id="participant-lodging" class="min-h-11 w-full rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm text-[#293C74] outline-none focus:border-[#293C74] focus:ring-1 focus:ring-[#293C74]">
                    <option value="no">Sin alojamiento</option>
                  </select>
                </div>
                <div>
                  <label for="participant-relationship" class="mb-2 block text-xs font-bold text-[#293C74]">Relación <span class="font-normal text-slate-500">(opcional)</span></label>
                  <input id="participant-relationship" autocomplete="off" class="min-h-11 w-full rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm text-[#293C74] outline-none placeholder-slate-400 focus:border-[#293C74] focus:ring-1 focus:ring-[#293C74]" placeholder="Ej. hijo" />
                </div>
              </div>
              <p id="participant-status" class="mt-4 text-xs text-slate-500" role="status" aria-live="polite">Aún no hay participantes.</p>
              <ul id="participants-list" class="mt-2 space-y-2 text-sm text-slate-600"></ul>
            </div>

            <div class="rounded-2xl border border-slate-100 bg-white p-6">
              <h3 class="mb-4 text-sm font-bold text-[#293C74]">Pago</h3>
              <div class="grid gap-4 md:grid-cols-2">
                <div>
                  <label for="payment-option" class="mb-2 block text-xs font-bold uppercase tracking-widest text-[#293C74]">Opción de pago</label>
                  <select name="paymentOption" id="payment-option" class="min-h-11 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-2 font-medium text-[#293C74] outline-none transition-all focus:border-[#293C74] focus:ring-1 focus:ring-[#293C74]">
                    <option value="FULL">Pago completo</option>
                    <option value="DEPOSIT">Reserva 50%</option>
                    <option value="INSTALLMENTS">Cuotas</option>
                  </select>
                </div>
                <div id="frequency-wrapper" class="hidden">
                  <label for="frequency-select" class="mb-2 block text-xs font-bold uppercase tracking-widest text-[#293C74]">Frecuencia cuotas</label>
                  <select id="frequency-select" name="frequency" class="min-h-11 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-2 font-medium text-[#293C74] outline-none transition-all focus:border-[#293C74] focus:ring-1 focus:ring-[#293C74]">
                    <option value="MONTHLY">Mensual</option>
                    <option value="BIWEEKLY">Quincenal</option>
                  </select>
                </div>
                <div id="deposit-wrapper" class="hidden md:col-span-2">
                  <label for="deposit-due-date" class="mb-2 block text-xs font-bold uppercase tracking-widest text-[#293C74]">Fecha de segundo pago</label>
                  <input id="deposit-due-date" name="deposit_due_date" type="date" max={installmentDeadline} class="min-h-11 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-2 font-medium text-[#293C74] outline-none transition-all focus:border-[#293C74] focus:ring-1 focus:ring-[#293C74]" />
                  <p class="mt-2 text-xs text-slate-500">Disponible hasta <span id="deposit-deadline-label" class="font-semibold text-[#293C74]">15 de mayo de 2026</span> (incluido).</p>
                </div>
                <div>
                  <label for="manual-currency" class="mb-2 block text-xs font-bold uppercase tracking-widest text-[#293C74]">Moneda de pago</label>
                  <select id="manual-currency" name="currency" class="min-h-11 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-2 font-medium text-[#293C74] outline-none transition-all focus:border-[#293C74] focus:ring-1 focus:ring-[#293C74]">
                    <option value="COP">Pesos colombianos (COP)</option>
                    <option value="USD">Dólares (USD)</option>
                  </select>
                </div>
                <div>
                  <label for="manual-payment-amount" class="mb-2 block text-xs font-bold uppercase tracking-widest text-[#293C74]">Valor pagado hoy</label>
                  <input id="manual-payment-amount" name="paymentAmount" type="text" inputmode="decimal" autocomplete="off" class="min-h-11 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-2 font-medium text-[#293C74] outline-none placeholder-slate-400 transition-all focus:border-[#293C74] focus:ring-1 focus:ring-[#293C74]" placeholder="0" />
                  <div class="mt-2 flex flex-wrap items-center justify-between gap-2 text-xs text-slate-500">
                    <span id="manual-payment-hint">Automático: $0</span>
                    <label class="inline-flex min-h-11 cursor-pointer items-center gap-2 font-semibold text-slate-600">
                      <input id="manual-payment-custom-toggle" type="checkbox" class="h-4 w-4 rounded border-slate-300 text-brand-teal focus:ring-brand-teal">
                      Aporte libre
                    </label>
                  </div>
                </div>
                <div>
                  <label for="manual-payment-method" class="mb-2 block text-xs font-bold uppercase tracking-widest text-[#293C74]">Método de pago</label>
                  <input id="manual-payment-method" name="paymentMethod" autocomplete="off" class="min-h-11 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-2 font-medium text-[#293C74] outline-none placeholder-slate-400 transition-all focus:border-[#293C74] focus:ring-1 focus:ring-[#293C74]" placeholder="Efectivo / Transferencia" />
                </div>
              </div>
            </div>

            <label class="flex min-h-11 cursor-pointer items-start gap-4 rounded-xl border border-slate-200 bg-slate-50 p-4 text-sm leading-6 text-slate-700">
              <input name="manualConfirmed" value="yes" type="checkbox" required class="mt-2 h-4 w-4 shrink-0 rounded border-slate-300 text-[#293C74] focus:ring-[#293C74]" />
              <span><strong class="text-[#293C74]">Confirmo la operación.</strong> Verifiqué los datos, participantes, moneda, monto y soporte físico antes de guardar.</span>
            </label>

            <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
              <div class="flex flex-wrap gap-2">
                <button id="manual-booking-submit" type="submit" class="min-h-11 rounded-xl bg-[#293C74] px-8 py-2 font-bold text-white transition-all hover:shadow-lg hover:shadow-[#293C74]/20">Crear reserva</button>
                <button id="manual-booking-reset" type="button" disabled class="hidden min-h-11 rounded-xl border border-slate-300 bg-white px-4 py-2 font-bold text-[#293C74] hover:bg-slate-50 disabled:cursor-not-allowed disabled:opacity-60">Limpiar para otra reserva</button>
              </div>
              <p id="manual-status" class="text-sm text-slate-500" role="status" aria-live="polite"></p>
            </div>
          </form>
        </div>

        <div class="rounded-2xl border border-slate-100 bg-white p-8 shadow-lg shadow-slate-200/50">
          <div class="mb-6 flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
            <div>
              <h2 class="text-xl md:text-2xl font-display font-bold text-[#293C74]">Registrar abono manual</h2>
              <p class="text-sm text-slate-500">Usa el Booking ID y el monto recibido.</p>
            </div>
            <span class="inline-flex items-center gap-2 rounded-full bg-brand-teal/10 px-4 py-2 text-xs font-bold uppercase tracking-widest text-brand-teal">Abonos</span>
          </div>
          <form id="manual-payment-form" method="POST" action="/api/cumbre2026/manual/payment" class="space-y-6">
            <input type="hidden" name="idempotencyKey" id="manual-payment-idempotency-key" />
            <div class="grid gap-4 md:grid-cols-3">
              <div>
                <label for="manual-payment-booking-id" class="mb-2 block text-xs font-bold uppercase tracking-widest text-[#293C74]">Booking ID</label>
                <input id="manual-payment-booking-id" name="bookingId" autocomplete="off" required class="min-h-11 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-2 font-medium text-[#293C74] outline-none placeholder-slate-400 transition-all focus:border-[#293C74] focus:ring-1 focus:ring-[#293C74]" placeholder="UUID de la reserva" />
              </div>
              <div>
                <label for="manual-payment-value" class="mb-2 block text-xs font-bold uppercase tracking-widest text-[#293C74]">Monto recibido</label>
                <input id="manual-payment-value" name="amount" type="text" inputmode="decimal" autocomplete="off" required class="min-h-11 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-2 font-medium text-[#293C74] outline-none placeholder-slate-400 transition-all focus:border-[#293C74] focus:ring-1 focus:ring-[#293C74]" placeholder="Monto en moneda de la reserva" />
              </div>
              <div>
                <label for="manual-abono-method" class="mb-2 block text-xs font-bold uppercase tracking-widest text-[#293C74]">Método verificado</label>
                <input id="manual-abono-method" name="paymentMethod" autocomplete="off" required class="min-h-11 w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-2 font-medium text-[#293C74] outline-none placeholder-slate-400 transition-all focus:border-[#293C74] focus:ring-1 focus:ring-[#293C74]" placeholder="Efectivo / Transferencia" />
              </div>
            </div>
            <label class="flex min-h-11 cursor-pointer items-start gap-4 rounded-xl border border-slate-200 bg-slate-50 p-4 text-sm leading-6 text-slate-700">
              <input name="paymentConfirmed" value="yes" type="checkbox" required class="mt-2 h-4 w-4 shrink-0 rounded border-slate-300 text-brand-teal focus:ring-brand-teal" />
              <span><strong class="text-[#293C74]">Confirmo el abono.</strong> Comparé reserva, moneda, saldo, monto y soporte. Entiendo que esta acción afecta la contabilidad.</span>
            </label>
            <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
              <div class="flex flex-wrap gap-2">
                <button id="manual-payment-submit" type="submit" class="min-h-11 rounded-xl bg-brand-teal px-8 py-2 font-bold text-white transition-all hover:shadow-lg hover:shadow-brand-teal/20">Registrar abono</button>
                <button id="manual-payment-reset" type="button" disabled class="hidden min-h-11 rounded-xl border border-slate-300 bg-white px-4 py-2 font-bold text-[#293C74] hover:bg-slate-50 disabled:cursor-not-allowed disabled:opacity-60">Limpiar para otro abono</button>
              </div>
              <p id="payment-status" class="text-sm text-slate-500" role="status" aria-live="polite"></p>
            </div>
          </form>
        </div>
        </div>
      </div>
    </section>
  </div>

  <script src="../../../scripts/cumbre-manual-auth.js"></script>

  <script type="module" nonce={cspNonce}>
    const participants = [];
    const list = document.getElementById('participants-list');
    const participantsInput = document.getElementById('participants-json');
    const participantStatus = document.getElementById('participant-status');
    const participantName = document.getElementById('participant-name');
    const participantAge = document.getElementById('participant-age');
    const participantLodging = document.getElementById('participant-lodging');
    const participantRelationship = document.getElementById('participant-relationship');
    const bookingForm = document.getElementById('manual-booking-form');
    const bookingSubmit = document.getElementById('manual-booking-submit');
    const bookingReset = document.getElementById('manual-booking-reset');
    const bookingStatus = document.getElementById('manual-status');
    const idempotencyInput = document.getElementById('manual-idempotency-key');
    const paymentForm = document.getElementById('manual-payment-form');
    const paymentSubmit = document.getElementById('manual-payment-submit');
    const paymentReset = document.getElementById('manual-payment-reset');
    const paymentStatus = document.getElementById('payment-status');
    const paymentIdempotencyInput = document.getElementById('manual-payment-idempotency-key');
    const paymentOption = document.getElementById('payment-option');
    const frequencyWrapper = document.getElementById('frequency-wrapper');
    const frequencySelect = document.getElementById('frequency-select');
    const currencySelect = document.getElementById('manual-currency');
    const countryGroupSelect = document.getElementById('manual-country-group');
    const paymentAmountInput = document.getElementById('manual-payment-amount');
    const paymentHint = document.getElementById('manual-payment-hint');
    const paymentCustomToggle = document.getElementById('manual-payment-custom-toggle');
    const depositWrapper = document.getElementById('deposit-wrapper');
    const depositInput = document.getElementById('deposit-due-date');
    const depositDeadlineLabel = document.getElementById('deposit-deadline-label');
    const installmentDeadline = bookingForm?.dataset?.installmentDeadline || '2026-05-15';
    let paymentAmountTouched = false;
    let bookingIdempotencyKey = null;
    let bookingSignature = null;
    let paymentIdempotencyKey = null;
    let paymentSignature = null;
    let bookingDirty = false;
    let paymentDirty = false;
    let bookingCompleted = false;
    let paymentCompleted = false;

    const generateIdempotencyKey = () => window.crypto?.randomUUID?.()
      || `${Date.now()}-${Math.random().toString(16).slice(2)}`;

    const prices = {
      COP: { lodging: 850000, no_lodging: 660000, child_0_7: 300000, child_7_13: 550000 },
      USD: { lodging: 220, no_lodging: 170, child_0_7: 80, child_7_13: 140 },
    };

    const normalizeCurrency = (value) => (value === 'USD' ? 'USD' : 'COP');
    const roundCurrency = (amount, currency) => currency === 'COP'
      ? Math.round(amount)
      : Math.round(amount * 100) / 100;

    const formatCurrency = (amount, currency) => new Intl.NumberFormat(
      currency === 'USD' ? 'en-US' : 'es-CO',
      {
        style: 'currency',
        currency,
        maximumFractionDigits: currency === 'USD' ? 2 : 0,
      },
    ).format(amount);

    const formatInputAmount = (amount, currency) => {
      if (!Number.isFinite(amount)) return '';
      return new Intl.NumberFormat(currency === 'USD' ? 'en-US' : 'es-CO', {
        maximumFractionDigits: currency === 'USD' ? 2 : 0,
      }).format(amount);
    };

    const parseInputAmount = (raw, currency) => {
      const value = String(raw || '').trim();
      if (!value) return null;
      if (currency === 'COP') {
        const digits = value.replace(/[^\d]/g, '');
        const amount = digits ? Number(digits) : Number.NaN;
        return Number.isFinite(amount) ? amount : null;
      }
      const normalized = value.replace(/[^0-9.,]/g, '').replace(/,/g, '');
      const amount = normalized ? Number(normalized) : Number.NaN;
      return Number.isFinite(amount) ? amount : null;
    };

    const getPackageType = (age, lodging) => {
      if (age <= 4) return 'child_0_7';
      if (age <= 10) return 'child_7_13';
      return lodging === 'yes' ? 'lodging' : 'no_lodging';
    };

    const getSelectedCurrency = () => normalizeCurrency(currencySelect?.value);
    const getTotalAmount = () => {
      const currency = getSelectedCurrency();
      return participants.reduce((sum, participant) => {
        const packageType = getPackageType(participant.age, participant.lodging);
        return sum + (prices[currency]?.[packageType] || 0);
      }, 0);
    };

    const getInstallmentPreview = (total, frequency) => {
      const [year, month, day] = installmentDeadline.split('-').map(Number);
      const end = new Date(Date.UTC(year, (month || 1) - 1, day || 1));
      const now = new Date();
      const current = new Date(Date.UTC(now.getUTCFullYear(), now.getUTCMonth(), now.getUTCDate()));
      if (end < current) return { count: 1, amount: total };
      const dueDates = [];
      let tempDate = new Date(current);
      while (tempDate <= end) {
        dueDates.push(new Date(tempDate));
        if (frequency === 'BIWEEKLY') tempDate.setUTCDate(tempDate.getUTCDate() + 14);
        else tempDate.setUTCMonth(tempDate.getUTCMonth() + 1);
      }
      const count = Math.max(1, dueDates.length);
      return { count, amount: total / count };
    };

    const getDefaultPaymentAmount = () => {
      const total = getTotalAmount();
      const currency = getSelectedCurrency();
      const option = paymentOption?.value || 'FULL';
      if (option === 'DEPOSIT') return roundCurrency(total * 0.5, currency);
      if (option === 'INSTALLMENTS') {
        return roundCurrency(getInstallmentPreview(total, frequencySelect?.value || 'MONTHLY').amount, currency);
      }
      return roundCurrency(total, currency);
    };

    const updatePaymentHint = () => {
      if (!paymentHint) return;
      const label = paymentCustomToggle?.checked ? 'Sugerido' : 'Automático';
      paymentHint.textContent = `${label}: ${formatCurrency(getDefaultPaymentAmount(), getSelectedCurrency())}`;
    };

    const syncPaymentAmount = (force = false) => {
      if (!paymentAmountInput) return;
      const customEnabled = Boolean(paymentCustomToggle?.checked);
      paymentAmountInput.readOnly = !customEnabled;
      paymentAmountInput.classList.toggle('bg-white', customEnabled);
      paymentAmountInput.classList.toggle('bg-slate-50', !customEnabled);
      const shouldSync = !customEnabled && (force || !paymentAmountTouched || !paymentAmountInput.value);
      if (shouldSync || (customEnabled && force && !paymentAmountInput.value)) {
        const amount = getDefaultPaymentAmount();
        paymentAmountInput.value = amount ? formatInputAmount(amount, getSelectedCurrency()) : '';
        if (force) paymentAmountTouched = false;
      }
      updatePaymentHint();
    };

    const formatLongDateWithYear = (value) => {
      const [year, month, day] = value.split('-').map(Number);
      const date = new Date(year, (month || 1) - 1, day || 1);
      return Number.isNaN(date.getTime())
        ? value
        : date.toLocaleDateString('es-CO', { day: 'numeric', month: 'long', year: 'numeric' });
    };

    const getTodayValue = (daysToAdd = 0) => {
      const date = new Date();
      date.setDate(date.getDate() + daysToAdd);
      return `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, '0')}-${String(date.getDate()).padStart(2, '0')}`;
    };

    const syncDepositSchedule = () => {
      if (!depositInput) return;
      const minDate = getTodayValue(1);
      depositInput.min = minDate;
      depositInput.max = installmentDeadline;
      if (depositDeadlineLabel) depositDeadlineLabel.textContent = formatLongDateWithYear(installmentDeadline);
      if (installmentDeadline >= minDate && (!depositInput.value || depositInput.value < minDate || depositInput.value > installmentDeadline)) {
        depositInput.value = installmentDeadline;
      }
    };

    const closeExpiredPaymentOptions = () => {
      if (!paymentOption || getTodayValue() <= installmentDeadline) return;
      for (const value of ['DEPOSIT', 'INSTALLMENTS']) {
        const option = paymentOption.querySelector(`option[value="${value}"]`);
        if (option) {
          option.disabled = true;
          option.textContent = `${option.textContent} · plazo cerrado`;
        }
      }
      paymentOption.value = 'FULL';
    };

    const renderParticipants = () => {
      participantsInput.value = JSON.stringify(participants);
      list.replaceChildren();
      participants.forEach((participant, index) => {
        const item = document.createElement('li');
        item.className = 'flex flex-wrap items-center justify-between gap-2 rounded-xl border border-slate-200 bg-white px-4 py-2';
        const description = document.createElement('span');
        description.textContent = `${participant.fullName} · ${participant.age} años · Sin alojamiento`;
        const removeButton = document.createElement('button');
        removeButton.type = 'button';
        removeButton.className = 'min-h-11 rounded-xl px-4 py-2 font-bold text-red-700 hover:bg-red-50';
        removeButton.textContent = 'Quitar';
        removeButton.setAttribute('aria-label', `Quitar a ${participant.fullName}`);
        removeButton.addEventListener('click', () => {
          participants.splice(index, 1);
          bookingDirty = true;
          paymentAmountTouched = false;
          renderParticipants();
          syncPaymentAmount(true);
          participantName?.focus();
        });
        item.append(description, removeButton);
        list.append(item);
      });
      participantStatus.textContent = participants.length
        ? `${participants.length} de 20 participante${participants.length === 1 ? '' : 's'} registrado${participants.length === 1 ? '' : 's'}.`
        : 'Aún no hay participantes.';
    };

    document.getElementById('add-participant')?.addEventListener('click', () => {
      const name = participantName?.value.trim() || '';
      const ageValue = participantAge?.value.trim() || '';
      const age = Number(ageValue);
      if (!name) {
        participantStatus.textContent = 'Escribe el nombre del participante.';
        participantName?.focus();
        return;
      }
      if (!ageValue || !Number.isInteger(age) || age < 0 || age > 120) {
        participantStatus.textContent = 'Escribe una edad válida entre 0 y 120 años.';
        participantAge?.focus();
        return;
      }
      if (participants.length >= 20) {
        participantStatus.textContent = 'La reserva admite máximo 20 participantes.';
        return;
      }
      participants.push({
        fullName: name,
        age,
        lodging: participantLodging?.value || 'no',
        relationship: participantRelationship?.value.trim() || '',
      });
      if (participantName) participantName.value = '';
      if (participantAge) participantAge.value = '';
      if (participantLodging) participantLodging.value = 'no';
      if (participantRelationship) participantRelationship.value = '';
      bookingDirty = true;
      paymentAmountTouched = false;
      renderParticipants();
      syncPaymentAmount(true);
      participantName?.focus();
    });

    const updatePaymentSections = () => {
      const value = paymentOption?.value || 'FULL';
      frequencyWrapper?.classList.toggle('hidden', value !== 'INSTALLMENTS');
      depositWrapper?.classList.toggle('hidden', value !== 'DEPOSIT');
      if (depositInput) depositInput.required = value === 'DEPOSIT';
      if (value === 'DEPOSIT') syncDepositSchedule();
      paymentAmountTouched = false;
      syncPaymentAmount(true);
    };

    const syncCurrencyFromCountryGroup = () => {
      if (countryGroupSelect && currencySelect) currencySelect.value = countryGroupSelect.value === 'INT' ? 'USD' : 'COP';
    };
    const syncCountryGroupFromCurrency = () => {
      if (countryGroupSelect && currencySelect) countryGroupSelect.value = normalizeCurrency(currencySelect.value) === 'USD' ? 'INT' : 'CO';
    };

    paymentOption?.addEventListener('change', updatePaymentSections);
    frequencySelect?.addEventListener('change', () => {
      paymentAmountTouched = false;
      syncPaymentAmount(true);
    });
    currencySelect?.addEventListener('change', () => {
      syncCountryGroupFromCurrency();
      paymentAmountTouched = false;
      syncPaymentAmount(true);
    });
    countryGroupSelect?.addEventListener('change', () => {
      syncCurrencyFromCountryGroup();
      paymentAmountTouched = false;
      syncPaymentAmount(true);
    });
    paymentAmountInput?.addEventListener('input', () => {
      paymentAmountTouched = true;
      const amount = parseInputAmount(paymentAmountInput.value, getSelectedCurrency());
      if (amount !== null) paymentAmountInput.value = formatInputAmount(amount, getSelectedCurrency());
      updatePaymentHint();
    });
    paymentCustomToggle?.addEventListener('change', () => {
      paymentAmountTouched = Boolean(paymentCustomToggle.checked);
      syncPaymentAmount(true);
    });
    depositInput?.addEventListener('change', syncDepositSchedule);
    depositInput?.addEventListener('blur', syncDepositSchedule);

    const authHeaders = () => {
      const value = window['cumbreManualAuthHeaders'];
      if (!value || typeof value !== 'object') throw new Error('La sesión individual no está disponible. Recarga la página.');
      return value;
    };

    const requestJson = async (action, formData) => {
      const controller = new AbortController();
      const timeout = window.setTimeout(() => controller.abort(), 15000);
      try {
        const response = await fetch(action, {
          method: 'POST',
          body: formData,
          headers: authHeaders(),
          credentials: 'include',
          signal: controller.signal,
        });
        const payload = await response.json().catch(() => ({}));
        return { response, payload };
      } finally {
        window.clearTimeout(timeout);
      }
    };

    const setBusy = (button, busy, label, completed) => {
      if (!button) return;
      button.dataset.defaultLabel ||= button.textContent || '';
      button.textContent = busy ? label : button.dataset.defaultLabel;
      button.disabled = busy || completed;
      button.setAttribute('aria-busy', busy ? 'true' : 'false');
    };

    bookingForm?.addEventListener('input', () => {
      if (!bookingCompleted) bookingDirty = true;
    });
    bookingForm?.addEventListener('change', () => {
      if (!bookingCompleted) bookingDirty = true;
    });
    paymentForm?.addEventListener('input', () => {
      if (!paymentCompleted) paymentDirty = true;
    });
    paymentForm?.addEventListener('change', () => {
      if (!paymentCompleted) paymentDirty = true;
    });

    bookingForm?.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (bookingCompleted) return;
      if (!participants.length) {
        bookingStatus.textContent = 'Agrega al menos un participante antes de crear la reserva.';
        participantName?.focus();
        return;
      }
      const option = paymentOption?.value || 'FULL';
      if (option === 'DEPOSIT' && !depositInput?.value) {
        bookingStatus.textContent = 'Selecciona la fecha del segundo pago.';
        depositInput?.focus();
        return;
      }
      const parsedPayment = parseInputAmount(paymentAmountInput?.value, getSelectedCurrency());
      if (paymentCustomToggle?.checked && (!paymentAmountInput?.value || parsedPayment === null || parsedPayment <= 0)) {
        bookingStatus.textContent = 'Ingresa el valor pagado hoy para el aporte libre.';
        paymentAmountInput?.focus();
        return;
      }

      const formData = new FormData(bookingForm);
      if (parsedPayment !== null) formData.set('paymentAmount', String(parsedPayment));
      const signature = JSON.stringify(Array.from(formData.entries()).filter(([key]) => key !== 'idempotencyKey'));
      if (!bookingIdempotencyKey || bookingSignature !== signature) {
        bookingIdempotencyKey = generateIdempotencyKey();
        bookingSignature = signature;
      }
      idempotencyInput.value = bookingIdempotencyKey;
      formData.set('idempotencyKey', bookingIdempotencyKey);
      bookingStatus.textContent = 'Creando reserva de forma segura...';
      setBusy(bookingSubmit, true, 'Creando...', bookingCompleted);

      try {
        const { payload } = await requestJson(bookingForm.action, formData);
        if (payload?.ok) {
          bookingCompleted = true;
          bookingDirty = false;
          bookingStatus.textContent = payload.idempotent
            ? `La reserva ${payload.bookingId} ya estaba creada; no se duplicó.`
            : `Reserva creada: ${payload.bookingId}.`;
          bookingReset.disabled = false;
          bookingReset.classList.remove('hidden');
        } else {
          bookingStatus.textContent = payload?.error || 'No se pudo crear la reserva.';
        }
      } catch (error) {
        bookingStatus.textContent = error?.name === 'AbortError'
          ? 'La operación tardó demasiado. Conservamos los datos; revisa la reserva antes de reenviar.'
          : error instanceof Error ? error.message : 'No se pudo conectar. Conservamos los datos.';
      } finally {
        setBusy(bookingSubmit, false, 'Creando...', bookingCompleted);
      }
    });

    bookingReset?.addEventListener('click', () => {
      bookingForm.reset();
      participants.splice(0, participants.length);
      bookingIdempotencyKey = null;
      bookingSignature = null;
      bookingCompleted = false;
      bookingDirty = false;
      paymentAmountTouched = false;
      idempotencyInput.value = '';
      bookingStatus.textContent = '';
      bookingReset.disabled = true;
      bookingReset.classList.add('hidden');
      renderParticipants();
      syncCurrencyFromCountryGroup();
      closeExpiredPaymentOptions();
      updatePaymentSections();
      bookingSubmit.disabled = false;
      document.getElementById('manual-contact-name')?.focus();
    });

    paymentForm?.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (paymentCompleted) return;
      const formData = new FormData(paymentForm);
      const signature = JSON.stringify({
        bookingId: String(formData.get('bookingId') || '').trim(),
        amount: String(formData.get('amount') || '').trim(),
        paymentMethod: String(formData.get('paymentMethod') || '').trim(),
      });
      if (!paymentIdempotencyKey || paymentSignature !== signature) {
        paymentIdempotencyKey = generateIdempotencyKey();
        paymentSignature = signature;
      }
      paymentIdempotencyInput.value = paymentIdempotencyKey;
      formData.set('idempotencyKey', paymentIdempotencyKey);
      paymentStatus.textContent = 'Registrando el abono de forma segura...';
      setBusy(paymentSubmit, true, 'Registrando...', paymentCompleted);

      try {
        const { payload } = await requestJson(paymentForm.action, formData);
        if (payload?.ok || payload?.recorded) {
          paymentCompleted = true;
          paymentDirty = false;
          paymentStatus.textContent = payload?.recorded && !payload?.ok
            ? `${payload.error} Referencia: ${payload.reference || 'pendiente'}.`
            : payload.idempotent
              ? `El abono ${payload.reference} ya estaba registrado; no se duplicó.`
              : `Abono registrado: ${payload.reference}.`;
          paymentReset.disabled = false;
          paymentReset.classList.remove('hidden');
        } else {
          paymentStatus.textContent = payload?.error || 'No se pudo registrar el abono.';
        }
      } catch (error) {
        paymentStatus.textContent = error?.name === 'AbortError'
          ? 'La operación tardó demasiado. No la reenvíes sin revisar primero la reserva.'
          : error instanceof Error ? error.message : 'No se pudo conectar. Conservamos los datos.';
      } finally {
        setBusy(paymentSubmit, false, 'Registrando...', paymentCompleted);
      }
    });

    paymentReset?.addEventListener('click', () => {
      paymentForm.reset();
      paymentIdempotencyKey = null;
      paymentSignature = null;
      paymentCompleted = false;
      paymentDirty = false;
      paymentIdempotencyInput.value = '';
      paymentStatus.textContent = '';
      paymentReset.disabled = true;
      paymentReset.classList.add('hidden');
      paymentSubmit.disabled = false;
      document.getElementById('manual-payment-booking-id')?.focus();
    });

    window.addEventListener('beforeunload', (event) => {
      if ((!bookingDirty || bookingCompleted) && (!paymentDirty || paymentCompleted)) return;
      event.preventDefault();
      event.returnValue = '';
    });

    renderParticipants();
    syncCurrencyFromCountryGroup();
    closeExpiredPaymentOptions();
    updatePaymentSections();
    syncPaymentAmount(true);
  </script>
</BaseLayout>
