---

<section
  class:list={['prayer-wall-experience', compact && 'prayer-wall-experience--compact']}
  data-prayer-wall
  data-prayer-compact={compact ? 'true' : 'false'}
  data-prayer-samples={JSON.stringify(samplePrayers)}
  data-prayer-i18n={i18n}
>
  {compact ? (
    <div class="prayer-compact">
      <div class="prayer-compact__header">
        <div>
          <p class="prayer-kicker">{c.compactKicker}</p>
          <h3>{c.compactTitle}</h3>
        </div>
        <div class="prayer-count-pill">
          <span data-prayer-total>0</span>
          <small>{c.requests}</small>
        </div>
      </div>

      <div class="prayer-wall-stage prayer-wall-stage--compact" data-wall-stage>
        <div class="prayer-stone-layer" aria-hidden="true">
          <svg class="prayer-wall-sketch" viewBox="0 0 960 620" preserveAspectRatio="none" focusable="false">
            <rect class="prayer-wall-sketch__wash" x="0" y="0" width="960" height="620" rx="28"></rect>
            <g class="prayer-wall-sketch__stones">
              {wallStones.map(([x, y, width, height, radius], index) => (
                <rect x={x} y={y} width={width} height={height} rx={radius} style={`--tone:${index % 5};`} />
              ))}
            </g>
            <g class="prayer-wall-sketch__shade">
              {wallStones.filter((_, index) => index % 3 === 0).map(([x, y, width, height]) => (
                <path d={`M${x + 16} ${y + height - 18} C${x + width * 0.38} ${y + height - 3} ${x + width * 0.72} ${y + height - 28} ${x + width - 18} ${y + height - 12}`} />
              ))}
            </g>
            <g class="prayer-wall-sketch__scars">
              {wallScars.map((d) => <path d={d} />)}
            </g>
            <g class="prayer-wall-sketch__crevices">
              {wallCrevices.map((d) => <path d={d} />)}
            </g>
            <g class="prayer-wall-sketch__paper-slips">
              {wallPaperSlips.map(([x, y, width, height, rotate, tone]) => (
                <g class={`prayer-wall-sketch__paper-slip prayer-wall-sketch__paper-slip--${tone}`} transform={`translate(${x} ${y}) rotate(${rotate})`}>
