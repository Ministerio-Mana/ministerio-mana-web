  .prayer-wall-detail {
    background:
      radial-gradient(circle at 18% 14%, rgba(255, 255, 255, 0.72), transparent 8rem),
      linear-gradient(100deg, rgba(125, 94, 35, 0.16), transparent 18%, transparent 84%, rgba(125, 94, 35, 0.12)),
      linear-gradient(180deg, #fff9e8, #f3e8c8);
    border: 1px solid rgba(125, 94, 35, 0.2);
    border-radius: 0.8rem 0.8rem 1.2rem 1.2rem;
    box-shadow:
      0 22px 46px rgba(7, 17, 28, 0.28),
