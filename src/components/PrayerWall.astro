const wallPaperSlips: WallPaperSlip[] = [
  ...horizontalPaperRuns.flatMap(([startX, endX, seamY, count, seed]) => {
    const step = (endX - startX) / Math.max(1, count - 1);
    return Array.from({ length: count }, (_, index): WallPaperSlip => {
      const width = 24 + ((index + seed) % 5) * 5;
      const height = 10 + ((index + seed * 2) % 3) * 3;
      const x = Math.round(startX + step * index - width / 2);
      const y = Math.round(seamY - height / 2 + (((index + seed) % 3) - 1) * 3);
      const rotate = ((index * 5 + seed * 3) % 13) - 6;
      return [x, y, width, height, rotate, (index + seed) % 4];
    });
  }),
  ...verticalPaperRuns.flatMap(([seamX, startY, endY, count, seed]) => {
    const step = (endY - startY) / Math.max(1, count - 1);
    return Array.from({ length: count }, (_, index): WallPaperSlip => {
      const width = 10 + ((index + seed) % 3) * 3;
      const height = 27 + ((index + seed * 2) % 4) * 5;
      const x = Math.round(seamX - width / 2 + (((index + seed) % 3) - 1) * 2);
      const y = Math.round(startY + step * index - height / 2);
      const rotate = ((index * 4 + seed * 5) % 11) - 5;
      return [x, y, width, height, rotate, (index + seed) % 4];
    });
  }),
];
