  #muro,
  #peticion {
    --layout-prayer-anchor-offset: calc(var(--space-4) + var(--space-4) + var(--space-4) + var(--space-2));
    scroll-margin-top: var(--layout-prayer-anchor-offset);
  }

  [data-prayer-reveal] {
    opacity: 0;
    transform: translateY(1.35rem);
    transition: opacity 680ms ease, transform 680ms ease;
  }

  [data-prayer-reveal].is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @keyframes prayer-note-land {
    0% {
      opacity: 0;
      transform: translate(-50%, -50%) translateY(-2rem) scale(1.08) rotate(var(--r));
    }
    72% {
      opacity: 1;
      transform: translate(-50%, -50%) translateY(0.25rem) scale(0.98) rotate(var(--r));
    }
    100% {
      opacity: 1;
      transform: translate(-50%, -50%) translateY(0) scale(1) rotate(var(--r));
    }
  }

  @keyframes prayer-detail-unfold {
    0% {
      opacity: 0;
      transform: rotate(-7deg) scale(0.18, 0.12);
    }
    72% {
      opacity: 1;
      transform: rotate(0.8deg) scale(1.03, 0.97);
    }
    100% {
      opacity: 1;
      transform: rotate(-0.7deg) scale(1);
    }
  }

  @keyframes prayer-marker-breathe {
    0%, 100% {
      box-shadow: 0 0 0 3px rgba(63, 167, 187, 0.18);
      transform: scale(1);
    }
    50% {
      box-shadow: 0 0 0 7px rgba(63, 167, 187, 0.04);
      transform: scale(1.08);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    [data-prayer-reveal],
    .prayer-note.is-new,
    .prayer-note::after,
    .prayer-wall-guide__paper i,
    .prayer-wall-detail.is-unfolding {
      animation: none;
      opacity: 1;
      transition: none;
    }

    .prayer-note {
      transition: none;
    }
  }

  @media (max-width: 1023px) {
    .prayer-hero__inner,
    .prayer-main__grid {
      grid-template-columns: 1fr;
