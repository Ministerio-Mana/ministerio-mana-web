  .prayer-main__intro {
    margin-bottom: 2rem;
  }

  .prayer-main__copy {
    border-left: 2px solid rgba(63, 167, 187, 0.82);
    color: rgba(255, 255, 255, 0.76);
    font-size: 1rem;
    line-height: 1.65;
    margin-top: 1.25rem;
    max-width: 43rem;
    padding-left: 1rem;
  }

  .prayer-main__grid {
    align-items: start;
    display: grid;
    gap: 1.25rem;
    grid-template-columns: minmax(0, 1.35fr) minmax(20rem, 0.65fr);
  }

  .prayer-wall-panel,
  .prayer-form,
  .prayer-compact {
    border: 1px solid rgba(255, 255, 255, 0.14);
    background: rgba(255, 255, 255, 0.08);
