---
import TurnstileWidget from '@components/TurnstileWidget.astro';

interface Props {
  compact?: boolean;
  locale?: string;
}

const { compact = false, locale: localeProp } = Astro.props as Props;
const normalizePrayerLocale = (value?: string | null) => (value === 'en' ? 'en' : 'es');
const locale = normalizePrayerLocale(localeProp ?? (Astro.locals as { lang?: string }).lang);
const showTurnstile = !import.meta.env.DEV;
const stones = Array.from({ length: compact ? 30 : 58 }, (_, index) => index);
