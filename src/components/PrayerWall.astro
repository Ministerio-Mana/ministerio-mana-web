    min-height: 32rem;
    overflow: hidden;
    perspective: 1000px;
    position: relative;
    touch-action: pan-y;
  }

  .prayer-wall-stage::before,
  .prayer-wall-stage::after {
    content: "";
    inset: 0;
    pointer-events: none;
    position: absolute;
  }

  .prayer-wall-stage::before {
    background:
      radial-gradient(circle at 12% 18%, rgba(26, 37, 92, 0.12) 0 0.08rem, transparent 0.1rem),
      radial-gradient(circle at 76% 32%, rgba(26, 37, 92, 0.11) 0 0.07rem, transparent 0.09rem),
      radial-gradient(circle at 44% 74%, rgba(77, 59, 18, 0.12) 0 0.08rem, transparent 0.1rem),
      linear-gradient(115deg, rgba(255, 255, 255, 0.28), transparent 34%);
    background-size: 4.2rem 4.2rem, 5.1rem 5.1rem, 3.7rem 3.7rem, auto;
    mix-blend-mode: multiply;
    z-index: 1;
  }

  .prayer-wall-stage::after {
    background:
      linear-gradient(90deg, rgba(7, 17, 28, 0.12), transparent 22%, transparent 78%, rgba(7, 17, 28, 0.1)),
      linear-gradient(180deg, rgba(255, 248, 229, 0.24), transparent 35%, rgba(7, 17, 28, 0.08));
    z-index: 2;
  }

  .prayer-wall-stage--compact {
    height: 27rem;
    min-height: 25rem;
  }

  .prayer-stone-layer {
    inset: 0;
    overflow: hidden;
    position: absolute;
    z-index: 0;
  }

  .prayer-wall-sketch {
    display: block;
    height: 100%;
    width: 100%;
  }

  .prayer-wall-sketch__wash {
    fill: rgba(234, 227, 208, 0.54);
  }

  .prayer-wall-sketch__stones rect {
    fill: #d9d5c4;
    stroke: rgba(89, 68, 32, 0.24);
    stroke-width: 1.65;
    vector-effect: non-scaling-stroke;
  }

  .prayer-wall-sketch__stones rect:nth-child(4n + 2) {
    fill: #cfd9d1;
  }

  .prayer-wall-sketch__stones rect:nth-child(5n + 1) {
    fill: #e3dbc4;
  }

  .prayer-wall-sketch__shade path,
  .prayer-wall-sketch__hatch path {
    fill: none;
    stroke: rgba(26, 37, 92, 0.14);
    stroke-linecap: round;
    stroke-width: 1.8;
    vector-effect: non-scaling-stroke;
  }

  .prayer-wall-sketch__scars path {
    fill: none;
    stroke: rgba(74, 55, 29, 0.22);
    stroke-linecap: round;
    stroke-width: 1.4;
    vector-effect: non-scaling-stroke;
  }

  .prayer-wall-sketch__crevices path {
    fill: none;
    stroke: rgba(56, 39, 22, 0.54);
    stroke-linecap: round;
    stroke-width: 8.8;
    filter: drop-shadow(0 3px 0 rgba(255, 248, 229, 0.2));
    vector-effect: non-scaling-stroke;
  }

  .prayer-wall-sketch__paper-slip {
    opacity: 0.86;
  }

  .prayer-wall-sketch__paper-slip .paper-slip__shadow {
    fill: rgba(38, 31, 24, 0.24);
  }

  .prayer-wall-sketch__paper-slip .paper-slip__sheet {
    fill: rgba(255, 250, 238, 0.9);
    stroke: rgba(72, 54, 30, 0.32);
    stroke-linejoin: round;
    stroke-width: 1;
    vector-effect: non-scaling-stroke;
  }

  .prayer-wall-sketch__paper-slip--1 .paper-slip__sheet {
    fill: rgba(233, 238, 244, 0.86);
  }

  .prayer-wall-sketch__paper-slip--2 .paper-slip__sheet {
    fill: rgba(245, 232, 218, 0.9);
  }

  .prayer-wall-sketch__paper-slip .paper-slip__fold,
  .prayer-wall-sketch__paper-slip .paper-slip__crease {
    fill: none;
    stroke: rgba(32, 45, 99, 0.22);
    stroke-linecap: round;
    stroke-width: 0.9;
    vector-effect: non-scaling-stroke;
  }

  .prayer-wall-sketch__cracks path {
    fill: none;
    stroke: rgba(7, 17, 28, 0.28);
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2.4;
    vector-effect: non-scaling-stroke;
  }

  .prayer-wall-sketch__holes circle {
    fill: rgba(7, 17, 28, 0.26);
  }

  .prayer-wall-sketch__caper-bush .bush-mass {
    fill: rgba(31, 83, 66, 0.2);
    stroke: rgba(31, 83, 66, 0.2);
    stroke-width: 1;
    vector-effect: non-scaling-stroke;
  }

  .prayer-wall-sketch__caper-bush .branch {
    fill: none;
    stroke: rgba(25, 73, 58, 0.52);
    stroke-linecap: round;
    stroke-width: 1.6;
    vector-effect: non-scaling-stroke;
  }

  .prayer-wall-sketch__caper-bush .leaf {
    fill: rgba(37, 101, 78, 0.64);
    stroke: rgba(26, 61, 52, 0.28);
    stroke-width: 0.9;
    vector-effect: non-scaling-stroke;
  }

  .prayer-wall-sketch__plants path {
    fill: rgba(45, 113, 88, 0.34);
    stroke: rgba(26, 37, 92, 0.34);
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.8;
    vector-effect: non-scaling-stroke;
  }

  .prayer-wall-sketch__flowers .petal {
    fill: rgba(255, 248, 229, 0.68);
    stroke: rgba(125, 94, 35, 0.24);
    stroke-linejoin: round;
    stroke-width: 1.35;
    vector-effect: non-scaling-stroke;
  }

  .prayer-wall-sketch__flowers .stamen {
    fill: none;
    stroke: rgba(111, 67, 111, 0.52);
    stroke-linecap: round;
    stroke-width: 1.45;
    vector-effect: non-scaling-stroke;
  }

  .prayer-wall-sketch__flowers .anther {
    fill: rgba(111, 67, 111, 0.58);
  }

  .prayer-wall-light {
    background:
      radial-gradient(circle at 22% 18%, rgba(242, 201, 76, 0.2), transparent 14rem),
      radial-gradient(circle at 78% 70%, rgba(40, 166, 189, 0.14), transparent 15rem);
    inset: 0;
    pointer-events: none;
    position: absolute;
    z-index: 3;
  }

  .prayer-note-layer {
    inset: 0;
    position: absolute;
    transform: translate3d(var(--wall-pan-x, 0), var(--wall-pan-y, 0), 0);
    transition: transform 280ms ease;
    z-index: 4;
  }

  .prayer-note {
    --note-width: 8.4rem;
    --paper-left: 1.15rem;
    --paper-top: 1.72rem;
    background: transparent;
    border: 0;
    border-radius: 0;
    box-shadow: none;
    cursor: pointer;
    left: clamp(calc(var(--note-width) / 2 + 0.65rem), var(--x), calc(100% - (var(--note-width) / 2 + 0.65rem)));
    height: 4.65rem;
    max-width: calc(100% - 2rem);
    min-height: 4.65rem;
    isolation: isolate;
    overflow: visible;
    padding: 0;
    position: absolute;
    top: var(--y);
    transform:
      translate(-50%, -50%)
      rotate(var(--r))
      rotateX(var(--tilt-y, 0deg))
      rotateY(var(--tilt-x, 0deg));
    transform-style: preserve-3d;
    transition:
      transform 180ms ease,
      opacity 180ms ease;
    width: var(--note-width);
  }

  .prayer-note::before {
    content: "";
    display: none;
    height: 0;
    left: 0;
    position: absolute;
    top: 0;
    width: 0;
    z-index: 0;
  }

  .prayer-note::after {
    content: "";
    display: none;
    height: 0;
    left: 0;
    position: absolute;
    top: 0;
    width: 0;
    z-index: 1;
  }

  .prayer-note:hover,
  .prayer-note:focus,
  .prayer-note:focus-within,
  .prayer-note.is-open {
    transform:
      translate(-50%, -50%)
      rotate(var(--r))
      rotateX(var(--tilt-y, 0deg))
      rotateY(var(--tilt-x, 0deg))
      scale(1.06);
    z-index: 4;
  }

  .prayer-note:hover header,
  .prayer-note:focus header,
  .prayer-note:focus-within header,
  .prayer-note.is-open header {
    border-color: rgba(242, 201, 76, 0.86);
    box-shadow: 0 0 0 2px rgba(242, 201, 76, 0.26);
  }

  .prayer-note.is-new {
    animation: prayer-note-land 620ms cubic-bezier(.2, .8, .2, 1) both;
  }

  .prayer-note__pin {
    background: rgba(32, 45, 99, 0.56);
    border-radius: 999px;
    height: 1px;
    left: 4.66rem;
    position: absolute;
    top: 1.44rem;
    transform: rotate(-16deg);
    transform-origin: left center;
    width: 2.1rem;
    z-index: 2;
  }

  .prayer-note__pin::after {
    background: var(--prayer-teal);
    border: 2px solid rgba(255, 248, 229, 0.9);
    border-radius: 999px;
    box-shadow: 0 4px 10px rgba(7, 17, 28, 0.22);
    content: "";
    height: 0.48rem;
    position: absolute;
    right: -0.18rem;
    top: 50%;
    transform: translateY(-50%);
    width: 0.48rem;
  }

  .prayer-note[data-label-side="left"] .prayer-note__pin {
    left: auto;
    right: 4.66rem;
    transform: rotate(16deg);
    transform-origin: right center;
  }

  .prayer-note[data-label-side="left"] .prayer-note__pin::after {
    left: -0.18rem;
    right: auto;
  }

  .prayer-note__paper {
    display: block;
    height: 3.35rem;
    left: calc(var(--paper-left) - 0.86rem);
    pointer-events: none;
    position: absolute;
    top: calc(var(--paper-top) - 0.56rem);
    transform: rotate(var(--r));
    width: 5.95rem;
    z-index: 3;
  }

  .prayer-note__paper svg {
    display: block;
    height: 100%;
    overflow: visible;
    width: 100%;
  }

  .prayer-note__paper-body {
    fill: #fff8e5;
    stroke: rgba(32, 45, 99, 0.34);
    stroke-linejoin: round;
    stroke-width: 1.35;
  }

  .prayer-note__paper-body--back {
    fill: #f2e7c9;
  }

  .prayer-note__paper-body--front {
    fill: #fffaf0;
  }

  .prayer-note__paper-body--blue {
    fill: #e8eef7;
  }

  .prayer-note__paper-body--pink {
    fill: #f5dfdf;
  }

  .prayer-note__paper-shadow {
    fill: rgba(7, 17, 28, 0.22);
  }

  .prayer-note__paper-fold,
  .prayer-note__paper-line {
    fill: none;
    stroke: rgba(125, 94, 35, 0.34);
    stroke-linecap: round;
    stroke-width: 1.25;
  }

  .prayer-note__paper-line {
    stroke: rgba(32, 45, 99, 0.2);
  }

  .prayer-note header {
    background:
      linear-gradient(90deg, rgba(125, 94, 35, 0.12), transparent 44%),
      rgba(255, 248, 229, 0.94);
    border: 1px solid rgba(32, 45, 99, 0.28);
    border-radius: 8px;
    box-shadow: 0 12px 24px rgba(7, 17, 28, 0.16);
    left: 5.86rem;
    margin: 0;
    min-width: 0;
    padding: 0.42rem 0.54rem 0.38rem;
    position: absolute;
    top: 0.05rem;
    width: max-content;
