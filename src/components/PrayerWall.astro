const samplePrayers = c.samples.map(([id, firstName, city, country, requestText, prayersCount, createdAt]) => ({
  id,
  first_name: firstName,
  city,
  country,
  request_text: requestText,
  prayers_count: prayersCount,
  created_at: createdAt,
}));
const i18n = JSON.stringify(c.js);
---

<section
  class:list={['prayer-wall-experience', compact && 'prayer-wall-experience--compact']}
  data-prayer-wall
  data-prayer-compact={compact ? 'true' : 'false'}
  data-prayer-samples={JSON.stringify(samplePrayers)}
  data-prayer-i18n={i18n}
>
  {compact ? (
    <div class="prayer-compact">
      <div class="prayer-compact__header">
        <div>
          <p class="prayer-kicker">{c.compactKicker}</p>
          <h3>{c.compactTitle}</h3>
        </div>
        <div class="prayer-count-pill">
          <span data-prayer-total>0</span>
          <small>{c.requests}</small>
        </div>
      </div>

      <div class="prayer-wall-guide" role="note">
        <span class="prayer-wall-guide__paper" aria-hidden="true"><i></i></span>
        <p><strong>{c.wallGuideTitle}</strong><span>{c.wallGuideBody}</span></p>
      </div>

      <div class="prayer-wall-stage prayer-wall-stage--compact" data-wall-stage>
        <div class="prayer-stone-layer" aria-hidden="true">
          <svg class="prayer-wall-sketch" viewBox="0 0 960 620" preserveAspectRatio="none" focusable="false">
            <rect class="prayer-wall-sketch__wash" x="0" y="0" width="960" height="620" rx="28"></rect>
            <g class="prayer-wall-sketch__stones">
              {wallStones.map(([x, y, width, height, radius], index) => (
                <rect x={x} y={y} width={width} height={height} rx={radius} style={`--tone:${index % 5};`} />
              ))}
            </g>
            <g class="prayer-wall-sketch__shade">
              {wallStones.filter((_, index) => index % 3 === 0).map(([x, y, width, height]) => (
                <path d={`M${x + 16} ${y + height - 18} C${x + width * 0.38} ${y + height - 3} ${x + width * 0.72} ${y + height - 28} ${x + width - 18} ${y + height - 12}`} />
              ))}
            </g>
            <g class="prayer-wall-sketch__scars">
              {wallScars.map((d) => <path d={d} />)}
            </g>
            <g class="prayer-wall-sketch__crevices">
              {wallCrevices.map((d) => <path d={d} />)}
            </g>
            <g class="prayer-wall-sketch__paper-slips">
              {wallPaperSlips.map(([x, y, width, height, rotate, tone]) => (
                <g class={`prayer-wall-sketch__paper-slip prayer-wall-sketch__paper-slip--${tone}`} transform={`translate(${x} ${y}) rotate(${rotate})`}>
                  <path class="paper-slip__shadow" d={`M2 3 L${width + 1} 1 L${width - 1} ${height + 3} L0 ${height + 2} Z`} />
                  <path class="paper-slip__back" d={`M${width * -0.06} ${height * 0.18} L${width * 0.72} ${height * -0.06} L${width * 0.78} ${height * 0.76} L${width * 0.02} ${height * 0.92} Z`} />
                  <path class="paper-slip__sheet" d={`M0 2 C${width * 0.28} -1 ${width * 0.68} 4 ${width} 1 L${width - 2} ${height} C${width * 0.62} ${height - 2} ${width * 0.3} ${height + 3} 1 ${height} Z`} />
                  <path class="paper-slip__fold" d={`M${width * 0.24} 2 C${width * 0.34} ${height * 0.46} ${width * 0.22} ${height * 0.72} ${width * 0.08} ${height}`} />
                  <path class="paper-slip__crease" d={`M${width * 0.48} ${height * 0.38} C${width * 0.62} ${height * 0.25} ${width * 0.72} ${height * 0.45} ${width * 0.86} ${height * 0.3}`} />
                </g>
              ))}
            </g>
            <g class="prayer-wall-sketch__cracks">
              {wallCracks.map((d) => <path d={d} />)}
            </g>
            <g class="prayer-wall-sketch__holes">
              {wallHoles.map(([cx, cy, radius]) => <circle cx={cx} cy={cy} r={radius} />)}
            </g>
            <g class="prayer-wall-sketch__caper-bush" transform="translate(822 124) scale(0.54) translate(-631 -148)">
              <path class="bush-mass" d="M462 124 C478 72 542 44 612 58 C678 36 760 56 800 110 C820 156 770 201 704 206 C640 238 548 220 506 184 C454 178 430 154 462 124 Z" />
              {wallCaperBranches.map((d) => <path class="branch" d={d} />)}
              {wallCaperLeaves.map(([cx, cy, rx, ry, rotate, opacity]) => (
                <ellipse class="leaf" cx={cx} cy={cy} rx={rx} ry={ry} opacity={opacity} transform={`rotate(${rotate} ${cx} ${cy})`} />
              ))}
            </g>
            <g class="prayer-wall-sketch__plants">
              {wallPlants.map((d) => <path d={d} />)}
            </g>
            <g class="prayer-wall-sketch__flowers">
              {wallCaperFlowers.map(([x, y, scale]) => (
                <g transform={`translate(${x} ${y}) scale(${scale})`}>
                  <path class="petal" d="M0 0 C-14 -18 -1 -29 9 -12 C20 -27 35 -12 15 1 C33 10 20 27 5 11 C-9 28 -24 12 0 0 Z" />
                  <path class="stamen" d="M5 3 C-2 -13 -3 -23 -2 -32" />
                  <path class="stamen" d="M7 3 C9 -12 15 -24 19 -33" />
                  <path class="stamen" d="M4 4 C-8 -7 -15 -17 -19 -26" />
                  <circle class="anther" cx="-2" cy="-32" r="2" />
                  <circle class="anther" cx="19" cy="-33" r="2" />
                  <circle class="anther" cx="-19" cy="-26" r="2" />
                </g>
              ))}
            </g>
            <g class="prayer-wall-sketch__hatch">
              <path d="M52 44 C158 30 260 38 360 30" />
              <path d="M520 52 C626 35 746 42 890 30" />
              <path d="M70 584 C208 560 338 584 468 558" />
              <path d="M612 586 C720 558 822 578 920 548" />
            </g>
          </svg>
        </div>
        <div class="prayer-note-layer" data-prayer-list></div>
        <button type="button" class="prayer-wall-detail-backdrop" data-prayer-detail-backdrop hidden aria-label={c.js.close}></button>
        <aside class="prayer-wall-detail" data-prayer-detail hidden aria-live="polite" role="dialog" aria-modal="false" aria-label={c.js.selectedRequest}>
          <button type="button" class="prayer-wall-detail__close" data-prayer-detail-close aria-label={c.js.close}>×</button>
          <span>{c.js.selectedRequest}</span>
          <h4 data-prayer-detail-name></h4>
          <small data-prayer-detail-meta></small>
          <p data-prayer-detail-text></p>
          <footer>
            <strong data-prayer-detail-count></strong>
            <button type="button" data-prayer-detail-pray></button>
          </footer>
        </aside>
        <p class="prayer-empty" data-prayer-empty>{c.loading}</p>
      </div>
      <div class="prayer-wall-pager" data-prayer-pager hidden>
        <button type="button" data-prayer-prev>{c.pagerPrev}</button>
        <span data-prayer-page aria-live="polite"></span>
        <button type="button" data-prayer-next>{c.pagerNext}</button>
      </div>
    </div>
  ) : (
    <>
      <section class="prayer-hero" data-prayer-reveal>
        <div class="prayer-hero__image" aria-hidden="true">
          <img src="/images/cumbre/fishermen-bg-highres.jpg" alt="" />
        </div>
        <div class="prayer-hero__veil" aria-hidden="true"></div>

        <div class="prayer-hero__inner container-tight">
          <div class="prayer-hero__copy">
            <div class="prayer-display-title prayer-display-title--hero">
              <span class="prayer-display-title__script">{c.heroScript}</span>
              <h1 aria-label={c.heroTitle}>
                <span class="prayer-display-title__outline">{c.heroOutline}</span>
                <span class="prayer-display-title__solid">{c.heroSolid}</span>
              </h1>
            </div>
            <p class="prayer-hero__body">
              {c.heroBody}
            </p>
            <div class="prayer-hero__actions">
              <a href="#peticion" class="prayer-action prayer-action--primary">{c.writeRequest}</a>
              <a href="#muro" class="prayer-action prayer-action--ghost">{c.seeWall}</a>
            </div>
          </div>

          <aside class="prayer-verse" aria-label={c.verseLabel}>
            <span>{c.verseRef}</span>
            <blockquote>{c.verse}</blockquote>
            <p>{c.verseBody}</p>
          </aside>
        </div>
      </section>

      <section id="muro" class="prayer-main">
        <div class="prayer-main__intro container-tight" data-prayer-reveal>
          <div class="prayer-display-title prayer-display-title--section">
            <span class="prayer-display-title__script">{c.liveScript}</span>
            <h2 aria-label={c.liveTitle}>
              <span class="prayer-display-title__outline">{c.liveOutline}</span>
              <span class="prayer-display-title__solid">{c.liveSolid}</span>
            </h2>
          </div>
          <p class="prayer-main__copy">{c.liveBody}</p>
        </div>

        <div class="prayer-main__grid container-tight">
          <div class="prayer-wall-panel" data-prayer-reveal>
            <div class="prayer-wall-panel__bar">
              <div>
                <span data-prayer-total>0</span>
                <small>{c.activeRequests}</small>
              </div>
              <div>
                <span data-prayer-count>0</span>
                <small>{c.registeredPrayers}</small>
              </div>
              <button type="button" data-refresh-prayers aria-label={c.refreshLabel}>
                <svg aria-hidden="true" viewBox="0 0 24 24">
                  <path d="M20 6v5h-5M4 18v-5h5" />
                  <path d="M18.2 9A7 7 0 0 0 6.3 6.7L4 9m1.8 6A7 7 0 0 0 17.7 17.3L20 15" />
                </svg>
              </button>
            </div>

            <div class="prayer-wall-guide" role="note">
              <span class="prayer-wall-guide__paper" aria-hidden="true"><i></i></span>
              <p><strong>{c.wallGuideTitle}</strong><span>{c.wallGuideBody}</span></p>
            </div>

            <div class="prayer-wall-stage" data-wall-stage>
              <div class="prayer-stone-layer" aria-hidden="true">
                <svg class="prayer-wall-sketch" viewBox="0 0 960 620" preserveAspectRatio="none" focusable="false">
                  <rect class="prayer-wall-sketch__wash" x="0" y="0" width="960" height="620" rx="28"></rect>
                  <g class="prayer-wall-sketch__stones">
                    {wallStones.map(([x, y, width, height, radius], index) => (
                      <rect x={x} y={y} width={width} height={height} rx={radius} style={`--tone:${index % 5};`} />
                    ))}
                  </g>
                  <g class="prayer-wall-sketch__shade">
                    {wallStones.filter((_, index) => index % 3 === 0).map(([x, y, width, height]) => (
                      <path d={`M${x + 16} ${y + height - 18} C${x + width * 0.38} ${y + height - 3} ${x + width * 0.72} ${y + height - 28} ${x + width - 18} ${y + height - 12}`} />
                    ))}
                  </g>
                  <g class="prayer-wall-sketch__scars">
                    {wallScars.map((d) => <path d={d} />)}
                  </g>
                  <g class="prayer-wall-sketch__crevices">
                    {wallCrevices.map((d) => <path d={d} />)}
                  </g>
                  <g class="prayer-wall-sketch__paper-slips">
                    {wallPaperSlips.map(([x, y, width, height, rotate, tone]) => (
                      <g class={`prayer-wall-sketch__paper-slip prayer-wall-sketch__paper-slip--${tone}`} transform={`translate(${x} ${y}) rotate(${rotate})`}>
                        <path class="paper-slip__shadow" d={`M2 3 L${width + 1} 1 L${width - 1} ${height + 3} L0 ${height + 2} Z`} />
                        <path class="paper-slip__back" d={`M${width * -0.06} ${height * 0.18} L${width * 0.72} ${height * -0.06} L${width * 0.78} ${height * 0.76} L${width * 0.02} ${height * 0.92} Z`} />
                        <path class="paper-slip__sheet" d={`M0 2 C${width * 0.28} -1 ${width * 0.68} 4 ${width} 1 L${width - 2} ${height} C${width * 0.62} ${height - 2} ${width * 0.3} ${height + 3} 1 ${height} Z`} />
                        <path class="paper-slip__fold" d={`M${width * 0.24} 2 C${width * 0.34} ${height * 0.46} ${width * 0.22} ${height * 0.72} ${width * 0.08} ${height}`} />
                        <path class="paper-slip__crease" d={`M${width * 0.48} ${height * 0.38} C${width * 0.62} ${height * 0.25} ${width * 0.72} ${height * 0.45} ${width * 0.86} ${height * 0.3}`} />
                      </g>
                    ))}
                  </g>
                  <g class="prayer-wall-sketch__cracks">
                    {wallCracks.map((d) => <path d={d} />)}
                  </g>
                  <g class="prayer-wall-sketch__holes">
                    {wallHoles.map(([cx, cy, radius]) => <circle cx={cx} cy={cy} r={radius} />)}
                  </g>
                  <g class="prayer-wall-sketch__caper-bush" transform="translate(822 124) scale(0.54) translate(-631 -148)">
                    <path class="bush-mass" d="M462 124 C478 72 542 44 612 58 C678 36 760 56 800 110 C820 156 770 201 704 206 C640 238 548 220 506 184 C454 178 430 154 462 124 Z" />
                    {wallCaperBranches.map((d) => <path class="branch" d={d} />)}
                    {wallCaperLeaves.map(([cx, cy, rx, ry, rotate, opacity]) => (
                      <ellipse class="leaf" cx={cx} cy={cy} rx={rx} ry={ry} opacity={opacity} transform={`rotate(${rotate} ${cx} ${cy})`} />
                    ))}
                  </g>
                  <g class="prayer-wall-sketch__plants">
                    {wallPlants.map((d) => <path d={d} />)}
                  </g>
                  <g class="prayer-wall-sketch__flowers">
                    {wallCaperFlowers.map(([x, y, scale]) => (
                      <g transform={`translate(${x} ${y}) scale(${scale})`}>
                        <path class="petal" d="M0 0 C-14 -18 -1 -29 9 -12 C20 -27 35 -12 15 1 C33 10 20 27 5 11 C-9 28 -24 12 0 0 Z" />
                        <path class="stamen" d="M5 3 C-2 -13 -3 -23 -2 -32" />
                        <path class="stamen" d="M7 3 C9 -12 15 -24 19 -33" />
                        <path class="stamen" d="M4 4 C-8 -7 -15 -17 -19 -26" />
                        <circle class="anther" cx="-2" cy="-32" r="2" />
                        <circle class="anther" cx="19" cy="-33" r="2" />
                        <circle class="anther" cx="-19" cy="-26" r="2" />
                      </g>
                    ))}
                  </g>
                  <g class="prayer-wall-sketch__hatch">
                    <path d="M52 44 C158 30 260 38 360 30" />
                    <path d="M520 52 C626 35 746 42 890 30" />
                    <path d="M70 584 C208 560 338 584 468 558" />
                    <path d="M612 586 C720 558 822 578 920 548" />
                  </g>
                </svg>
              </div>
              <div class="prayer-wall-light" aria-hidden="true"></div>
              <div class="prayer-note-layer" data-prayer-list></div>
              <button type="button" class="prayer-wall-detail-backdrop" data-prayer-detail-backdrop hidden aria-label={c.js.close}></button>
              <aside class="prayer-wall-detail" data-prayer-detail hidden aria-live="polite" role="dialog" aria-modal="false" aria-label={c.js.selectedRequest}>
                <button type="button" class="prayer-wall-detail__close" data-prayer-detail-close aria-label={c.js.close}>×</button>
                <span>{c.js.selectedRequest}</span>
                <h3 data-prayer-detail-name></h3>
                <small data-prayer-detail-meta></small>
                <p data-prayer-detail-text></p>
                <footer>
                  <strong data-prayer-detail-count></strong>
                  <button type="button" data-prayer-detail-pray></button>
                </footer>
              </aside>
              <p class="prayer-empty" data-prayer-empty>{c.loading}</p>
            </div>
            <div class="prayer-wall-pager" data-prayer-pager hidden>
              <button type="button" data-prayer-prev>{c.pagerPrev}</button>
              <span data-prayer-page aria-live="polite"></span>
              <button type="button" data-prayer-next>{c.pagerNext}</button>
            </div>
          </div>

          <form id="peticion" class="prayer-form" method="post" action="/api/prayer/submit" data-prayer-form data-prayer-reveal>
            <div class="prayer-form__heading">
              <div class="prayer-display-title prayer-display-title--form">
                <span class="prayer-display-title__script">{c.formScript}</span>
                <h2 aria-label={c.formTitle}>
                  <span class="prayer-display-title__outline">{c.formOutline}</span>
                  <span class="prayer-display-title__solid">{c.formSolid}</span>
                </h2>
              </div>
              <p>
                {c.formHelp}
              </p>
            </div>

            <div class="prayer-field">
              <label for="prayer-name">{c.firstName}</label>
              <input id="prayer-name" name="firstName" type="text" maxlength="60" autocomplete="given-name" required placeholder={c.firstNamePlaceholder} />
            </div>

            <div class="prayer-field">
              <label for="prayer-request">{c.request}</label>
              <textarea id="prayer-request" name="requestText" maxlength="280" required placeholder={c.requestPlaceholder}></textarea>
            </div>

            <fieldset class="prayer-visibility">
              <legend>{c.visibilityLegend}</legend>
              <label>
                <input type="radio" name="visibility" value="private" checked />
                <span>
                  <strong>{c.privateLabel}</strong>
                  <small>{c.privateHelp}</small>
                </span>
              </label>
              <label>
                <input type="radio" name="visibility" value="public" />
                <span>
                  <strong>{c.publicLabel}</strong>
                  <small>{c.publicHelp}</small>
                </span>
              </label>
            </fieldset>

            <div class="prayer-form__row">
              <div class="prayer-field">
                <label for="prayer-city">{c.city}</label>
                <input id="prayer-city" name="city" type="text" maxlength="80" autocomplete="address-level2" placeholder={c.cityPlaceholder} />
              </div>

              <div class="prayer-field">
                <label for="prayer-country">{c.country}</label>
                <select id="prayer-country" name="country" autocomplete="country">
                  <option value="">{c.country}</option>
                  <option value="CO">Colombia</option>
                  <option value="US">Estados Unidos</option>
                  <option value="VE">Venezuela</option>
                  <option value="EC">Ecuador</option>
                  <option value="PE">Perú</option>
                  <option value="MX">México</option>
                  <option value="AR">Argentina</option>
                  <option value="CL">Chile</option>
                  <option value="ES">España</option>
                </select>
              </div>
            </div>

            {showTurnstile && <TurnstileWidget appearance="always" theme="dark" />}

            <button class="prayer-submit" type="submit" data-prayer-submit>
              {c.submit}
            </button>
            <p class="prayer-status" data-prayer-status aria-live="polite"></p>
          </form>

          <div class="prayer-confirm" data-prayer-confirm hidden>
            <div class="prayer-confirm__panel" role="dialog" aria-modal="true" aria-labelledby="prayer-confirm-title">
              <button type="button" class="prayer-confirm__close" data-prayer-confirm-cancel aria-label={c.js.close}>×</button>
              <span data-prayer-confirm-eyebrow>{c.visibilityLegend}</span>
              <h3 id="prayer-confirm-title" data-prayer-confirm-title></h3>
              <p data-prayer-confirm-body></p>
              <div class="prayer-confirm__actions">
                <button type="button" class="prayer-confirm__switch" data-prayer-confirm-switch></button>
                <button type="button" class="prayer-confirm__send" data-prayer-confirm-send>{c.js.confirmSend}</button>
              </div>
              <button type="button" class="prayer-confirm__back" data-prayer-confirm-cancel>{c.js.confirmCancel}</button>
            </div>
          </div>
        </div>
      </section>

      <section class="prayer-rhythm">
        <div class="container-tight prayer-rhythm__inner">
          <div data-prayer-reveal>
            <p class="prayer-kicker">{c.rhythmKicker}</p>
            <h2>{c.rhythmTitle}</h2>
          </div>

          <div class="prayer-rhythm__steps" data-prayer-reveal>
            {c.steps.map(([number, title, body]) => (
              <article>
                <span>{number}</span>
                <h3>{title}</h3>
                <p>{body}</p>
              </article>
            ))}
          </div>
        </div>
      </section>
    </>
  )}
</section>

<script src="../scripts/prayer-wall.js"></script>

<style is:global>
  @font-face {
    font-family: "Summer Loving";
    src: url("/fonts/SUMMER FONT/Summer Loving Regular.otf") format("opentype");
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  .prayer-wall-experience {
    --prayer-navy: #202d63;
    --prayer-night: #111936;
    --prayer-ink: #0f1838;
    --prayer-teal: #3fa7bb;
    --prayer-gold: #F2C94C;
    --prayer-paper: #fff8e5;
    --prayer-stone: #d8dfdf;
    --prayer-warm: #f5efeb;
    background: var(--prayer-night);
    color: var(--prayer-navy);
    isolation: isolate;
    font-family: "Intro", system-ui, sans-serif;
  }

  .prayer-wall-experience h1,
  .prayer-wall-experience h2,
  .prayer-wall-experience h3,
  .prayer-wall-experience p {
    letter-spacing: 0;
  }

  .prayer-kicker {
    color: var(--prayer-gold);
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.22em !important;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .prayer-display-title {
    --display-script-size: 4.6rem;
    --display-outline-size: 5.55rem;
    --display-solid-size: 5.15rem;
    --display-outline-color: rgba(255, 255, 255, 0.88);
    --display-script-color: var(--prayer-gold);
    --display-stroke: 1.6px;
    max-width: 56rem;
    position: relative;
  }

  .prayer-display-title__script {
    color: var(--display-script-color);
    display: block;
    font-family: "Summer Loving", cursive;
    font-size: var(--display-script-size);
    line-height: 0.82;
    margin: 0 0 -0.1em;
    position: relative;
    text-shadow: 0 12px 28px rgba(0, 0, 0, 0.24);
    transform: rotate(-3deg);
    transform-origin: left bottom;
    z-index: 1;
  }

  .prayer-display-title h1,
  .prayer-display-title h2 {
    color: white;
    display: grid;
    font-family: "Intro", system-ui, sans-serif;
    font-weight: 900;
    gap: 0.02em;
    letter-spacing: 0;
    line-height: 0.87;
    margin: 0;
    text-transform: uppercase;
    text-wrap: balance;
  }

  .prayer-display-title__outline,
  .prayer-display-title__solid {
    display: block;
  }

  .prayer-display-title__outline {
    color: transparent;
    font-size: var(--display-outline-size);
    -webkit-text-stroke: var(--display-stroke) var(--display-outline-color);
    text-stroke: var(--display-stroke) var(--display-outline-color);
  }

  .prayer-display-title__solid {
    color: white;
    font-size: var(--display-solid-size);
  }

  .prayer-display-title--hero {
    margin-top: 0.25rem;
  }

  .prayer-display-title--section {
