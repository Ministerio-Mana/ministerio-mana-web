  .prayer-verse blockquote {
    color: white;
    font-size: 2rem;
    font-weight: 900;
    line-height: 1.12;
    margin-top: 1rem;
  }

  .prayer-verse p {
    border-left: 2px solid rgba(40, 166, 189, 0.8);
    color: rgba(255, 255, 255, 0.74);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-top: 1.25rem;
    padding-left: 1rem;
  }

  .prayer-main {
    background:
      linear-gradient(90deg, rgba(216, 232, 240, 0.11) 0 1px, transparent 1px) 0 0 / clamp(72px, 9vw, 130px) 100%,
      radial-gradient(circle at 90% 8%, rgba(63, 167, 187, 0.16), transparent 18rem),
      linear-gradient(135deg, #19244f 0%, #24396f 52%, #111936 100%);
