    gap: 0.8rem;
    grid-template-columns: 1fr 1fr auto;
    padding: 1rem;
  }

  .prayer-wall-panel__bar div {
    min-width: 0;
  }

  .prayer-wall-panel__bar span,
  .prayer-count-pill span {
    color: white;
    display: block;
    font-size: 1.6rem;
    font-weight: 900;
    line-height: 1;
  }

  .prayer-wall-panel__bar small,
  .prayer-count-pill small {
    color: rgba(255, 255, 255, 0.74);
    display: block;
    font-size: 0.68rem;
    font-weight: 800;
    line-height: 1.2;
    margin-top: 0.3rem;
    text-transform: uppercase;
  }

  .prayer-wall-panel__bar button {
    align-items: center;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 999px;
    color: white;
    display: inline-flex;
    height: 2.75rem;
    justify-content: center;
    width: 2.75rem;
  }

  .prayer-wall-panel__bar svg {
    height: 1.15rem;
    width: 1.15rem;
  }

  .prayer-wall-panel__bar path {
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2;
  }

  .prayer-wall-guide {
    align-items: center;
    background: rgba(17, 25, 54, 0.94);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    color: white;
    display: flex;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
  }

  .prayer-wall-guide p {
    display: grid;
    gap: var(--space-1);
    min-width: 0;
  }

  .prayer-wall-guide strong {
    color: white;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.04em;
    line-height: 1.1;
    text-transform: uppercase;
  }

  .prayer-wall-guide p span {
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.72rem;
    line-height: 1.35;
  }

  .prayer-wall-guide__paper {
    background:
      linear-gradient(96deg, transparent 0 34%, rgba(125, 94, 35, 0.2) 35% 37%, transparent 38%),
      linear-gradient(180deg, #fffaf0, #e9dfc5);
    box-shadow: 0 5px 10px rgba(7, 17, 28, 0.28);
    clip-path: polygon(2% 14%, 94% 4%, 100% 82%, 8% 100%);
    flex: 0 0 auto;
    height: 1.8rem;
    position: relative;
    transform: rotate(-4deg);
    width: 3rem;
  }

  .prayer-wall-guide__paper i {
    animation: prayer-marker-breathe 2.8s ease-in-out infinite;
    background: var(--prayer-teal);
    border: 2px solid white;
    border-radius: 999px;
    box-shadow: 0 0 0 3px rgba(63, 167, 187, 0.18);
    height: 0.7rem;
    position: absolute;
    right: 0.18rem;
    top: 0.12rem;
    width: 0.7rem;
  }

  .prayer-wall-stage {
    background:
      radial-gradient(circle at 18% 10%, rgba(255, 244, 214, 0.68), transparent 25rem),
      radial-gradient(circle at 88% 86%, rgba(92, 66, 35, 0.18), transparent 18rem),
      linear-gradient(180deg, #dfcfb2, #c9b895 58%, #a99472);
    height: 42rem;
    max-height: 72svh;
    min-height: 32rem;
    overflow: hidden;
    perspective: 1000px;
    position: relative;
    touch-action: pan-y;
  }

  .prayer-wall-stage::before,
  .prayer-wall-stage::after {
    content: "";
    inset: 0;
    pointer-events: none;
    position: absolute;
  }

  .prayer-wall-stage::before {
    background:
      radial-gradient(circle at 12% 18%, rgba(26, 37, 92, 0.12) 0 0.08rem, transparent 0.1rem),
      radial-gradient(circle at 76% 32%, rgba(26, 37, 92, 0.11) 0 0.07rem, transparent 0.09rem),
      radial-gradient(circle at 44% 74%, rgba(77, 59, 18, 0.12) 0 0.08rem, transparent 0.1rem),
      linear-gradient(115deg, rgba(255, 255, 255, 0.28), transparent 34%);
    background-size: 4.2rem 4.2rem, 5.1rem 5.1rem, 3.7rem 3.7rem, auto;
    mix-blend-mode: multiply;
    z-index: 1;
  }

  .prayer-wall-stage::after {
    background:
      linear-gradient(90deg, rgba(7, 17, 28, 0.12), transparent 22%, transparent 78%, rgba(7, 17, 28, 0.1)),
      linear-gradient(180deg, rgba(255, 248, 229, 0.24), transparent 35%, rgba(7, 17, 28, 0.08));
    z-index: 2;
  }

  .prayer-wall-stage--compact {
    height: 27rem;
    min-height: 25rem;
  }

  .prayer-stone-layer {
    inset: 0;
    overflow: hidden;
    position: absolute;
    z-index: 0;
  }

  .prayer-wall-sketch {
    display: block;
    height: 100%;
    width: 100%;
  }

  .prayer-wall-sketch__wash {
    fill: rgba(222, 205, 174, 0.42);
  }

  .prayer-wall-sketch__stones rect {
    fill: #cfbd9e;
    stroke: rgba(65, 45, 25, 0.46);
    stroke-width: 2.15;
    vector-effect: non-scaling-stroke;
  }

  .prayer-wall-sketch__stones rect:nth-child(4n + 2) {
    fill: #ddcdae;
  }

  .prayer-wall-sketch__stones rect:nth-child(5n + 1) {
    fill: #bca787;
  }

  .prayer-wall-sketch__shade path,
  .prayer-wall-sketch__hatch path {
    fill: none;
    stroke: rgba(77, 52, 27, 0.24);
    stroke-linecap: round;
    stroke-width: 1.8;
    vector-effect: non-scaling-stroke;
  }

  .prayer-wall-sketch__scars path {
    fill: none;
    stroke: rgba(74, 51, 28, 0.32);
    stroke-linecap: round;
    stroke-width: 1.4;
    vector-effect: non-scaling-stroke;
  }

  .prayer-wall-sketch__crevices path {
    fill: none;
    stroke: rgba(45, 30, 18, 0.78);
    stroke-linecap: round;
    stroke-width: 10.5;
    filter: drop-shadow(0 3px 0 rgba(255, 239, 203, 0.28));
    vector-effect: non-scaling-stroke;
  }

  .prayer-wall-sketch__paper-slip {
    filter: drop-shadow(0 2px 2px rgba(38, 27, 17, 0.34));
    opacity: 0.98;
  }

  .prayer-wall-sketch__paper-slip .paper-slip__shadow {
    fill: rgba(38, 27, 17, 0.4);
  }

  .prayer-wall-sketch__paper-slip .paper-slip__back {
    fill: #d8d0c1;
    stroke: rgba(72, 49, 27, 0.38);
    stroke-linejoin: round;
    stroke-width: 0.9;
    vector-effect: non-scaling-stroke;
  }

  .prayer-wall-sketch__paper-slip .paper-slip__sheet {
    fill: #fffaf0;
    stroke: rgba(72, 49, 27, 0.46);
    stroke-linejoin: round;
    stroke-width: 1;
    vector-effect: non-scaling-stroke;
  }

  .prayer-wall-sketch__paper-slip--1 .paper-slip__sheet {
    fill: #e7e3d9;
  }

  .prayer-wall-sketch__paper-slip--2 .paper-slip__sheet {
    fill: #e7edf2;
  }

  .prayer-wall-sketch__paper-slip--3 .paper-slip__sheet {
    fill: #e8d97f;
  }

  .prayer-wall-sketch__paper-slip .paper-slip__fold,
  .prayer-wall-sketch__paper-slip .paper-slip__crease {
    fill: none;
    stroke: rgba(72, 49, 27, 0.34);
    stroke-linecap: round;
    stroke-width: 0.9;
    vector-effect: non-scaling-stroke;
  }

  .prayer-wall-sketch__cracks path {
    fill: none;
    stroke: rgba(45, 30, 18, 0.46);
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2.4;
    vector-effect: non-scaling-stroke;
  }

  .prayer-wall-sketch__holes circle {
    fill: rgba(45, 30, 18, 0.46);
  }

  .prayer-wall-sketch__caper-bush .bush-mass {
    fill: rgba(31, 83, 66, 0.2);
    stroke: rgba(31, 83, 66, 0.2);
    stroke-width: 1;
    vector-effect: non-scaling-stroke;
  }

  .prayer-wall-sketch__caper-bush .branch {
    fill: none;
    stroke: rgba(25, 73, 58, 0.52);
    stroke-linecap: round;
    stroke-width: 1.6;
    vector-effect: non-scaling-stroke;
  }

  .prayer-wall-sketch__caper-bush .leaf {
    fill: rgba(37, 101, 78, 0.64);
    stroke: rgba(26, 61, 52, 0.28);
    stroke-width: 0.9;
    vector-effect: non-scaling-stroke;
  }

  .prayer-wall-sketch__plants path {
    fill: rgba(45, 113, 88, 0.34);
    stroke: rgba(26, 37, 92, 0.34);
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.8;
    vector-effect: non-scaling-stroke;
  }

  .prayer-wall-sketch__flowers .petal {
    fill: rgba(255, 248, 229, 0.68);
    stroke: rgba(125, 94, 35, 0.24);
    stroke-linejoin: round;
    stroke-width: 1.35;
    vector-effect: non-scaling-stroke;
  }

  .prayer-wall-sketch__flowers .stamen {
    fill: none;
    stroke: rgba(111, 67, 111, 0.52);
    stroke-linecap: round;
    stroke-width: 1.45;
    vector-effect: non-scaling-stroke;
  }

  .prayer-wall-sketch__flowers .anther {
    fill: rgba(111, 67, 111, 0.58);
  }

  .prayer-wall-light {
    background:
      radial-gradient(circle at 22% 18%, rgba(242, 201, 76, 0.2), transparent 14rem),
      radial-gradient(circle at 78% 70%, rgba(40, 166, 189, 0.14), transparent 15rem);
    inset: 0;
    pointer-events: none;
    position: absolute;
    z-index: 3;
  }

  .prayer-note-layer {
    inset: 0;
    position: absolute;
    transform: translate3d(var(--wall-pan-x, 0), var(--wall-pan-y, 0), 0);
    transition: transform 280ms ease;
    z-index: 4;
  }

  .prayer-note {
    --note-height: 2.75rem;
    --note-paper-height: 1.3rem;
    --note-paper-width: 3.8rem;
    --note-width: 4.4rem;
    background: transparent;
    border: 0;
    border-radius: 0;
    box-shadow: none;
    cursor: pointer;
    height: var(--note-height);
    left: var(--x);
    max-width: calc(100% - 2rem);
    min-height: 2.75rem;
    isolation: isolate;
    outline: 0;
    overflow: visible;
    padding: 0;
    position: absolute;
    top: var(--y);
    transform:
      translate(-50%, -50%)
      rotate(var(--r))
      rotateX(var(--tilt-y, 0deg))
      rotateY(var(--tilt-x, 0deg));
    transform-style: preserve-3d;
    transition:
      transform 180ms ease,
      opacity 180ms ease;
    width: var(--note-width);
  }

  .prayer-note[data-paper-orientation="vertical"] {
    --note-height: 5.25rem;
    --note-paper-height: 4.6rem;
    --note-paper-width: 1.45rem;
    --note-width: 2.75rem;
  }

  .prayer-note::before {
    background: linear-gradient(180deg, rgba(31, 20, 12, 0.88), rgba(73, 50, 27, 0.76));
    border-radius: 999px;
    box-shadow:
      0 3px 3px rgba(255, 237, 199, 0.18),
      inset 0 2px 2px rgba(13, 8, 5, 0.34);
    content: "";
    display: block;
    height: 0.38rem;
    left: 50%;
    position: absolute;
    top: 50%;
    transform: translateX(-50%);
    width: calc(var(--note-paper-width) + 0.7rem);
    z-index: 0;
  }

  .prayer-note::after {
    animation: prayer-marker-breathe 2.8s ease-in-out infinite;
    background: var(--prayer-teal);
    border: 2px solid white;
    border-radius: 999px;
    box-shadow: 0 0 0 3px rgba(63, 167, 187, 0.18);
    content: "";
    display: block;
    height: 0.7rem;
    left: calc(50% + 1.1rem);
    position: absolute;
    top: calc(50% + 0.52rem);
    width: 0.7rem;
    z-index: 7;
  }

  .prayer-note:hover,
  .prayer-note:focus,
  .prayer-note:focus-within,
  .prayer-note.is-open {
    transform:
      translate(-50%, calc(-50% - 0.12rem))
      rotate(var(--r))
      rotateX(var(--tilt-y, 0deg))
      rotateY(var(--tilt-x, 0deg))
      scale(1.08);
    z-index: 4;
  }

  .prayer-note:hover .prayer-note__paper,
  .prayer-note:focus-within .prayer-note__paper,
  .prayer-note.is-open .prayer-note__paper {
    filter: drop-shadow(0 8px 9px rgba(7, 17, 28, 0.28));
    transform: translate(-50%, -38%);
  }

  .prayer-note:focus-visible {
    border-radius: 4px;
    outline: 3px solid var(--prayer-teal);
    outline-offset: 4px;
  }

  .prayer-note.is-new {
    animation: prayer-note-land 620ms cubic-bezier(.2, .8, .2, 1) both;
  }

  .prayer-note__pin {
    background: linear-gradient(90deg, transparent, rgba(31, 20, 12, 0.72) 14% 86%, transparent);
    border-radius: 999px;
    box-shadow: 0 2px 1px rgba(255, 235, 198, 0.2);
    height: 0.16rem;
    left: 50%;
    position: absolute;
    top: calc(50% - 0.02rem);
    transform: translateX(-50%);
    width: calc(var(--note-paper-width) + 0.34rem);
    z-index: 5;
  }

  .prayer-note__pin::after {
    display: none;
  }

  .prayer-note__paper {
    display: block;
    filter: drop-shadow(0 4px 4px rgba(38, 27, 17, 0.3));
    height: var(--note-paper-height);
    left: 50%;
    pointer-events: none;
    position: absolute;
    top: 50%;
    transform: translate(-50%, -20%);
    transition: filter 180ms ease, transform 180ms ease;
    width: var(--note-paper-width);
    z-index: 3;
  }

  .prayer-note__paper svg {
    display: block;
    height: 100%;
    overflow: visible;
    width: 100%;
  }

  .prayer-note__paper-body {
    fill: #fff8e5;
    stroke: rgba(82, 56, 28, 0.48);
    stroke-linejoin: round;
    stroke-width: 1.1;
  }

  .prayer-note__paper-body--back {
    fill: #f2e7c9;
  }

  .prayer-note__paper-body--front {
    fill: #fffaf0;
  }

  .prayer-note__paper-body--blue {
    fill: #e8eef7;
  }

  .prayer-note__paper-body--pink {
    fill: #f5dfdf;
  }

  .prayer-note__paper-shadow {
    fill: rgba(38, 27, 17, 0.34);
  }

  .prayer-note__paper-fold,
  .prayer-note__paper-line {
    fill: none;
    stroke: rgba(82, 56, 28, 0.42);
    stroke-linecap: round;
    stroke-width: 1.25;
  }

  .prayer-note__paper-line {
    stroke: rgba(32, 45, 99, 0.2);
  }

  .prayer-note header {
    align-items: flex-start;
    background: rgba(17, 25, 54, 0.94);
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 999px;
    box-shadow: 0 7px 18px rgba(7, 17, 28, 0.22);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    justify-content: flex-start;
    left: 50%;
    margin: 0;
    max-width: 13rem;
    min-width: 0;
    opacity: 0;
    padding: var(--space-1) var(--space-2);
    pointer-events: none;
    position: absolute;
    text-align: left;
    top: calc(50% + 1.55rem);
    transform: translate(-50%, -0.2rem);
    transition: opacity 160ms ease, transform 160ms ease;
    width: min(13rem, 65vw);
    z-index: 6;
  }

  .prayer-note:hover header,
  .prayer-note:focus-visible header,
  .prayer-note:focus-within header,
  .prayer-note.is-open header {
    opacity: 1;
    transform: translate(-50%, 0);
  }

  .prayer-note.is-open header {
    opacity: 0;
    transform: translate(-50%, -0.2rem);
  }

  .prayer-note[data-paper-orientation="vertical"] header {
    top: calc(50% + 2.8rem);
    transform: translate(-50%, -0.2rem);
    width: min(13rem, 65vw);
  }

  .prayer-note h3 {
    color: white;
    display: block;
    font-family: inherit;
    font-size: 0.64rem;
    font-weight: 800;
    letter-spacing: 0.02em;
    line-height: 1;
    margin: 0;
    max-width: 100%;
    overflow: hidden;
    overflow-wrap: anywhere;
    text-overflow: ellipsis;
    text-transform: none;
