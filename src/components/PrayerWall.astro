      prayed: 'Prayed',
      prayButton: 'I prayed',
      empty: 'There are no published requests yet.',
      pageStatus: 'Group {current} of {total}',
      submitting: 'We are receiving your request.',
      submitError: 'We could not register the request.',
      success: 'We received your request. We will pray with you.',
      successPrivate: 'We received your private request. The Intercession Ministry will keep it in prayer.',
      successPublicPending: 'We received your request. An administrator will review it before it appears on the wall.',
