};
const c = copy[locale as keyof typeof copy];
const samplePrayers = c.samples.map(([id, firstName, city, country, requestText, prayersCount, createdAt]) => ({
  id,
  first_name: firstName,
  city,
  country,
  request_text: requestText,
  prayers_count: prayersCount,
  created_at: createdAt,
}));
const i18n = JSON.stringify(c.js);
---

<section
  class:list={['prayer-wall-experience', compact && 'prayer-wall-experience--compact']}
  data-prayer-wall
  data-prayer-compact={compact ? 'true' : 'false'}
  data-prayer-samples={JSON.stringify(samplePrayers)}
  data-prayer-i18n={i18n}
>
  {compact ? (
    <div class="prayer-compact">
      <div class="prayer-compact__header">
        <div>
          <p class="prayer-kicker">{c.compactKicker}</p>
          <h3>{c.compactTitle}</h3>
        </div>
        <div class="prayer-count-pill">
          <span data-prayer-total>0</span>
          <small>{c.requests}</small>
        </div>
      </div>

      <div class="prayer-wall-stage prayer-wall-stage--compact" data-wall-stage>
        <div class="prayer-stone-layer" aria-hidden="true">
          {stones.map((stone) => <span style={`--stone:${stone};`} />)}
        </div>
        <div class="prayer-note-layer" data-prayer-list></div>
        <p class="prayer-empty" data-prayer-empty>{c.loading}</p>
      </div>
      <div class="prayer-wall-pager" data-prayer-pager hidden>
        <button type="button" data-prayer-prev>{c.pagerPrev}</button>
        <span data-prayer-page aria-live="polite"></span>
        <button type="button" data-prayer-next>{c.pagerNext}</button>
      </div>
    </div>
  ) : (
    <>
      <section class="prayer-hero" data-prayer-reveal>
        <div class="prayer-hero__image" aria-hidden="true">
          <img src="/images/cumbre/fishermen-bg-highres.jpg" alt="" />
        </div>
        <div class="prayer-hero__veil" aria-hidden="true"></div>

        <div class="prayer-hero__inner container-tight">
          <div class="prayer-hero__copy">
            <p class="prayer-kicker">{c.heroKicker}</p>
            <h1>{c.heroTitle}</h1>
            <p>
              {c.heroBody}
            </p>
            <div class="prayer-hero__actions">
              <a href="#peticion" class="prayer-action prayer-action--primary">{c.writeRequest}</a>
              <a href="#muro" class="prayer-action prayer-action--ghost">{c.seeWall}</a>
            </div>
          </div>

          <aside class="prayer-verse" aria-label={c.verseLabel}>
            <span>{c.verseRef}</span>
            <blockquote>{c.verse}</blockquote>
            <p>{c.verseBody}</p>
          </aside>
        </div>
      </section>

      <section id="muro" class="prayer-main">
        <div class="prayer-main__intro container-tight" data-prayer-reveal>
          <p class="prayer-kicker">{c.liveKicker}</p>
          <h2>{c.liveTitle}</h2>
        </div>

        <div class="prayer-main__grid container-tight">
          <div class="prayer-wall-panel" data-prayer-reveal>
            <div class="prayer-wall-panel__bar">
              <div>
                <span data-prayer-total>0</span>
                <small>{c.activeRequests}</small>
              </div>
              <div>
                <span data-prayer-count>0</span>
                <small>{c.registeredPrayers}</small>
              </div>
              <button type="button" data-refresh-prayers aria-label={c.refreshLabel}>
                <svg aria-hidden="true" viewBox="0 0 24 24">
                  <path d="M20 6v5h-5M4 18v-5h5" />
                  <path d="M18.2 9A7 7 0 0 0 6.3 6.7L4 9m1.8 6A7 7 0 0 0 17.7 17.3L20 15" />
                </svg>
              </button>
            </div>

            <div class="prayer-wall-stage" data-wall-stage>
              <div class="prayer-stone-layer" aria-hidden="true">
                {stones.map((stone) => <span style={`--stone:${stone};`} />)}
              </div>
              <div class="prayer-wall-light" aria-hidden="true"></div>
              <div class="prayer-note-layer" data-prayer-list></div>
              <p class="prayer-empty" data-prayer-empty>{c.loading}</p>
            </div>
            <div class="prayer-wall-pager" data-prayer-pager hidden>
              <button type="button" data-prayer-prev>{c.pagerPrev}</button>
              <span data-prayer-page aria-live="polite"></span>
              <button type="button" data-prayer-next>{c.pagerNext}</button>
            </div>
          </div>

          <form id="peticion" class="prayer-form" method="post" action="/api/prayer/submit" data-prayer-form data-prayer-reveal>
            <div>
              <p class="prayer-kicker">{c.newKicker}</p>
              <h2>{c.formTitle}</h2>
              <p>
                {c.formHelp}
              </p>
            </div>

            <div class="prayer-field">
              <label for="prayer-name">{c.firstName}</label>
              <input id="prayer-name" name="firstName" type="text" maxlength="60" autocomplete="given-name" required placeholder={c.firstNamePlaceholder} />
            </div>

            <div class="prayer-field">
              <label for="prayer-request">{c.request}</label>
              <textarea id="prayer-request" name="requestText" maxlength="280" required placeholder={c.requestPlaceholder}></textarea>
            </div>

            <fieldset class="prayer-visibility">
              <legend>{c.visibilityLegend}</legend>
              <label>
                <input type="radio" name="visibility" value="private" checked />
                <span>
                  <strong>{c.privateLabel}</strong>
                  <small>{c.privateHelp}</small>
                </span>
              </label>
              <label>
                <input type="radio" name="visibility" value="public" />
                <span>
                  <strong>{c.publicLabel}</strong>
                  <small>{c.publicHelp}</small>
                </span>
              </label>
            </fieldset>

            <div class="prayer-form__row">
              <div class="prayer-field">
                <label for="prayer-city">{c.city}</label>
                <input id="prayer-city" name="city" type="text" maxlength="80" autocomplete="address-level2" placeholder={c.cityPlaceholder} />
              </div>

              <div class="prayer-field">
                <label for="prayer-country">{c.country}</label>
                <select id="prayer-country" name="country" autocomplete="country">
                  <option value="">{c.country}</option>
                  <option value="CO">Colombia</option>
                  <option value="US">Estados Unidos</option>
                  <option value="VE">Venezuela</option>
                  <option value="EC">Ecuador</option>
                  <option value="PE">Perú</option>
                  <option value="MX">México</option>
                  <option value="AR">Argentina</option>
                  <option value="CL">Chile</option>
                  <option value="ES">España</option>
                </select>
              </div>
            </div>

            {showTurnstile && <TurnstileWidget appearance="always" theme="dark" />}

            <button class="prayer-submit" type="submit" data-prayer-submit>
              {c.submit}
            </button>
            <p class="prayer-status" data-prayer-status aria-live="polite"></p>
          </form>
        </div>
      </section>

      <section class="prayer-rhythm">
        <div class="container-tight prayer-rhythm__inner">
          <div data-prayer-reveal>
            <p class="prayer-kicker">{c.rhythmKicker}</p>
            <h2>{c.rhythmTitle}</h2>
          </div>

          <div class="prayer-rhythm__steps" data-prayer-reveal>
            {c.steps.map(([number, title, body]) => (
              <article>
                <span>{number}</span>
                <h3>{title}</h3>
                <p>{body}</p>
              </article>
            ))}
          </div>
        </div>
      </section>
    </>
  )}
</section>

<script>
  import '@scripts/prayer-wall.js';
</script>

<style is:global>
  .prayer-wall-experience {
    --prayer-navy: #1A255C;
    --prayer-night: #07111c;
    --prayer-ink: #0B1120;
    --prayer-teal: #28A6BD;
    --prayer-gold: #F2C94C;
    --prayer-paper: #fff8e5;
    --prayer-stone: #d8dfdf;
    background: #f5efeb;
    color: var(--prayer-navy);
    isolation: isolate;
  }

  .prayer-wall-experience h1,
  .prayer-wall-experience h2,
  .prayer-wall-experience h3,
  .prayer-wall-experience p {
    letter-spacing: 0;
  }

  .prayer-kicker {
    color: var(--prayer-gold);
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.22em !important;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .prayer-hero {
    min-height: 100svh;
    overflow: hidden;
    position: relative;
    background: var(--prayer-night);
    color: white;
  }

  .prayer-hero__image,
  .prayer-hero__veil {
    position: absolute;
    inset: 0;
  }

  .prayer-hero__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.58;
    transform: scale(1.03);
  }

  .prayer-hero__veil {
    background:
      linear-gradient(105deg, rgba(7, 17, 28, 0.98) 0%, rgba(7, 17, 28, 0.88) 48%, rgba(26, 37, 92, 0.55) 100%),
      linear-gradient(180deg, rgba(7, 17, 28, 0.04), rgba(7, 17, 28, 0.78));
  }

  .prayer-hero__inner {
    display: grid;
    grid-template-columns: minmax(0, 1.12fr) minmax(18rem, 0.7fr);
    gap: 3rem;
    min-height: 100svh;
    align-items: center;
    padding-top: 7.5rem;
    padding-bottom: 5rem;
    position: relative;
    z-index: 1;
  }

  .prayer-hero__copy {
    max-width: 48rem;
  }

  .prayer-hero h1 {
    color: white;
    font-size: 4.55rem;
    font-weight: 900;
    line-height: 0.95;
    margin-top: 1rem;
    max-width: 48rem;
    text-wrap: balance;
  }

  .prayer-hero__copy > p:not(.prayer-kicker) {
    color: rgba(255, 255, 255, 0.84);
    font-size: 1.15rem;
    font-weight: 300;
    line-height: 1.75;
    margin-top: 1.25rem;
    max-width: 40rem;
  }

  .prayer-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 2rem;
  }

  .prayer-action {
    align-items: center;
    border-radius: 999px;
    display: inline-flex;
    font-size: 0.92rem;
    font-weight: 900;
    justify-content: center;
    min-height: 3.25rem;
    padding: 0.95rem 1.35rem;
    text-transform: uppercase;
  }

  .prayer-action--primary {
    background: linear-gradient(135deg, var(--prayer-teal), #3f58a1);
    box-shadow: 0 26px 70px rgba(40, 166, 189, 0.28);
    color: white;
  }

  .prayer-action--ghost {
    border: 1px solid rgba(255, 255, 255, 0.28);
    background: rgba(255, 255, 255, 0.09);
    color: white;
  }

  .prayer-verse {
    border: 1px solid rgba(255, 255, 255, 0.16);
    background: rgba(0, 0, 0, 0.32);
    border-radius: 1.25rem;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.28);
    padding: 2rem;
    backdrop-filter: blur(16px);
  }

  .prayer-verse span {
    color: var(--prayer-gold);
    display: block;
    font-size: 0.74rem;
    font-weight: 900;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .prayer-verse blockquote {
    color: white;
    font-size: 2rem;
    font-weight: 900;
    line-height: 1.12;
    margin-top: 1rem;
  }

  .prayer-verse p {
    border-left: 2px solid rgba(40, 166, 189, 0.8);
    color: rgba(255, 255, 255, 0.74);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-top: 1.25rem;
    padding-left: 1rem;
  }

  .prayer-main {
    background:
      linear-gradient(180deg, #f5efeb 0%, #edf6f4 50%, #f5efeb 100%);
    padding: 6rem 0;
    position: relative;
  }

  .prayer-main__intro {
    margin-bottom: 2rem;
  }

  .prayer-main__intro h2 {
    color: var(--prayer-navy);
    font-size: 3.4rem;
    font-weight: 900;
    line-height: 1.02;
    margin-top: 0.65rem;
    max-width: 48rem;
  }

  .prayer-main__grid {
    align-items: start;
    display: grid;
    gap: 1.25rem;
    grid-template-columns: minmax(0, 1.35fr) minmax(20rem, 0.65fr);
  }

  .prayer-wall-panel,
  .prayer-form,
  .prayer-compact {
    border: 1px solid rgba(26, 37, 92, 0.12);
    background: rgba(255, 255, 255, 0.82);
    border-radius: 1.35rem;
    box-shadow: 0 24px 80px rgba(26, 37, 92, 0.14);
    overflow: hidden;
  }

  .prayer-wall-panel__bar {
    align-items: center;
    background: linear-gradient(135deg, rgba(26, 37, 92, 0.98), rgba(40, 166, 189, 0.86));
    color: white;
    display: grid;
    gap: 0.8rem;
    grid-template-columns: 1fr 1fr auto;
    padding: 1rem;
  }

  .prayer-wall-panel__bar div {
    min-width: 0;
  }

  .prayer-wall-panel__bar span,
  .prayer-count-pill span {
    color: white;
    display: block;
    font-size: 1.6rem;
    font-weight: 900;
    line-height: 1;
  }

  .prayer-wall-panel__bar small,
  .prayer-count-pill small {
    color: rgba(255, 255, 255, 0.74);
    display: block;
    font-size: 0.68rem;
    font-weight: 800;
    line-height: 1.2;
    margin-top: 0.3rem;
    text-transform: uppercase;
  }

  .prayer-wall-panel__bar button {
    align-items: center;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 999px;
    color: white;
    display: inline-flex;
    height: 2.7rem;
    justify-content: center;
    width: 2.7rem;
  }

  .prayer-wall-panel__bar svg {
    height: 1.15rem;
    width: 1.15rem;
  }

  .prayer-wall-panel__bar path {
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2;
  }

  .prayer-wall-stage {
    background:
      radial-gradient(circle at 18% 10%, rgba(255, 248, 229, 0.42), transparent 25rem),
      linear-gradient(115deg, rgba(255, 255, 255, 0.24), transparent 36%),
      linear-gradient(180deg, #d1d2c8, #aeb8b3 55%, #8f9d99);
    height: 42rem;
    max-height: 72svh;
    min-height: 32rem;
    overflow: hidden;
    perspective: 1000px;
    position: relative;
    touch-action: pan-y;
  }

  .prayer-wall-stage::before,
  .prayer-wall-stage::after {
    content: "";
    inset: 0;
    pointer-events: none;
    position: absolute;
  }

  .prayer-wall-stage::before {
    background:
      linear-gradient(90deg, transparent 0 15%, rgba(33, 43, 54, 0.18) 15.2% 15.8%, transparent 16% 38%, rgba(33, 43, 54, 0.15) 38.2% 38.8%, transparent 39% 61%, rgba(33, 43, 54, 0.16) 61.2% 61.8%, transparent 62% 84%, rgba(33, 43, 54, 0.14) 84.2% 84.8%, transparent 85%),
      linear-gradient(180deg, transparent 0 14%, rgba(33, 43, 54, 0.24) 14.1% 15%, transparent 15.2% 30%, rgba(33, 43, 54, 0.2) 30.1% 31%, transparent 31.2% 46%, rgba(33, 43, 54, 0.22) 46.1% 47%, transparent 47.2% 62%, rgba(33, 43, 54, 0.2) 62.1% 63%, transparent 63.2% 78%, rgba(33, 43, 54, 0.24) 78.1% 79%, transparent 79.2%);
    mix-blend-mode: multiply;
    z-index: 1;
  }

  .prayer-wall-stage::after {
    background:
      linear-gradient(90deg, rgba(7, 17, 28, 0.26), transparent 22%, transparent 78%, rgba(7, 17, 28, 0.22)),
      linear-gradient(180deg, rgba(255, 248, 229, 0.2), transparent 35%, rgba(7, 17, 28, 0.2));
    z-index: 2;
  }

  .prayer-wall-stage--compact {
    height: 27rem;
    min-height: 25rem;
  }

  .prayer-stone-layer {
    display: grid;
    gap: 0.38rem;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    inset: 0;
    padding: 0.55rem;
    position: absolute;
  }

  .prayer-stone-layer span {
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.34), rgba(255, 255, 255, 0) 42%),
      linear-gradient(180deg, rgba(242, 201, 76, 0.08), rgba(26, 37, 92, 0.15));
    border: 1px solid rgba(26, 37, 92, 0.16);
    border-radius: 0.35rem;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.44),
      inset 0 -18px 30px rgba(26, 37, 92, 0.1),
      0 1px 0 rgba(255, 255, 255, 0.24);
    min-height: 5.8rem;
    opacity: calc(0.72 + (var(--stone) % 4) * 0.06);
    transform: translateY(calc((var(--stone) % 3) * 0.18rem));
  }

  .prayer-stone-layer span:nth-child(6n + 1),
  .prayer-stone-layer span:nth-child(6n + 4) {
    transform: translateX(-1.3rem);
  }

  .prayer-stone-layer span:nth-child(6n + 3),
  .prayer-stone-layer span:nth-child(6n + 6) {
    transform: translateX(1.1rem);
  }

  .prayer-wall-light {
    background:
      radial-gradient(circle at 22% 18%, rgba(242, 201, 76, 0.2), transparent 14rem),
      radial-gradient(circle at 78% 70%, rgba(40, 166, 189, 0.14), transparent 15rem);
    inset: 0;
    pointer-events: none;
    position: absolute;
    z-index: 3;
  }

  .prayer-note-layer {
    inset: 0;
    position: absolute;
    transform: translate3d(var(--wall-pan-x, 0), var(--wall-pan-y, 0), 0);
    transition: transform 280ms ease;
    z-index: 4;
  }

  .prayer-note {
    --note-width: 12.2rem;
    background:
      linear-gradient(90deg, rgba(125, 94, 35, 0.22), transparent 10%, transparent 88%, rgba(125, 94, 35, 0.12)),
      linear-gradient(180deg, rgba(255, 255, 255, 0.78), rgba(255, 255, 255, 0)),
      var(--prayer-paper);
    border: 1px solid rgba(77, 59, 18, 0.16);
    border-radius: 999px 0.75rem 0.75rem 999px;
    box-shadow:
      0 14px 26px rgba(26, 37, 92, 0.18),
      -10px 10px 18px rgba(33, 43, 54, 0.18),
      inset 0 1px 0 rgba(255, 255, 255, 0.7);
    cursor: pointer;
    left: clamp(calc(var(--note-width) / 2 + 0.65rem), var(--x), calc(100% - (var(--note-width) / 2 + 0.65rem)));
    max-width: calc(100% - 2rem);
    min-height: 4.9rem;
    overflow: hidden;
    padding: 0.78rem 0.82rem 0.72rem 1.68rem;
    position: absolute;
    top: var(--y);
    transform:
      translate(-50%, -50%)
      rotate(var(--r))
      rotateX(var(--tilt-y, 0deg))
      rotateY(var(--tilt-x, 0deg));
    transform-style: preserve-3d;
    transition:
      border-radius 180ms ease,
      box-shadow 180ms ease,
      min-height 180ms ease,
      transform 180ms ease,
      width 180ms ease;
    width: var(--note-width);
  }

  .prayer-note::before {
    background:
      linear-gradient(90deg, rgba(255, 255, 255, 0.58), rgba(125, 94, 35, 0.18)),
      var(--prayer-paper);
    border: 1px solid rgba(77, 59, 18, 0.16);
    border-radius: 999px;
    bottom: 0.42rem;
    box-shadow:
      inset -4px 0 8px rgba(77, 59, 18, 0.14),
      2px 0 6px rgba(77, 59, 18, 0.12);
    content: "";
    left: 0.42rem;
    position: absolute;
    top: 0.42rem;
    width: 0.72rem;
  }

  .prayer-note::after {
    background: rgba(7, 17, 28, 0.32);
    border-radius: 999px;
    content: "";
    height: 0.28rem;
    left: 0.2rem;
    position: absolute;
    top: 50%;
    transform: translate(-100%, -50%);
    width: 1.3rem;
  }

  .prayer-note:hover,
  .prayer-note:focus,
  .prayer-note:focus-within,
  .prayer-note.is-open {
    border-radius: 1rem;
    box-shadow:
      0 30px 62px rgba(26, 37, 92, 0.3),
      0 0 0 1px rgba(242, 201, 76, 0.24),
      inset 0 1px 0 rgba(255, 255, 255, 0.78);
    min-height: 12.25rem;
    width: min(18rem, calc(100% - 2rem));
    z-index: 4;
  }

  .prayer-note.is-new {
    animation: prayer-note-land 620ms cubic-bezier(.2, .8, .2, 1) both;
  }

  .prayer-note__pin {
    background: rgba(242, 201, 76, 0.88);
    border: 1px solid rgba(255, 255, 255, 0.72);
    border-radius: 999px;
    box-shadow: 0 8px 18px rgba(77, 59, 18, 0.2);
    height: 0.46rem;
    right: 0.75rem;
    position: absolute;
    top: 0.62rem;
    width: 1.6rem;
  }

  .prayer-note header {
    margin: 0;
    min-width: 0;
  }

  .prayer-note h3 {
    color: var(--prayer-navy);
    font-size: 0.94rem;
    font-weight: 900;
    line-height: 1.15;
    margin: 0;
    max-width: calc(100% - 2rem);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .prayer-note small {
    color: rgba(26, 37, 92, 0.58);
    display: block;
    font-size: 0.62rem;
    font-weight: 800;
    line-height: 1.2;
    margin-top: 0.18rem;
    overflow: hidden;
    text-overflow: ellipsis;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .prayer-note p {
    color: rgba(11, 17, 32, 0.76);
    display: -webkit-box;
    font-size: 0.78rem;
    line-height: 1.36;
    margin-top: 0.45rem;
    max-height: 2.2rem;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .prayer-note.is-open p,
  .prayer-note:focus-within p {
    display: block;
    font-size: 0.86rem;
    line-height: 1.48;
    max-height: 5.8rem;
    overflow: auto;
  }

  .prayer-note footer {
    align-items: center;
    display: flex;
    gap: 0.5rem;
    justify-content: space-between;
    margin-top: 0.8rem;
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    transition: max-height 180ms ease, opacity 180ms ease;
  }

  .prayer-note.is-open footer,
  .prayer-note:focus-within footer {
    max-height: 3rem;
    opacity: 1;
  }

  .prayer-note__count {
    color: rgba(26, 37, 92, 0.62);
    font-size: 0.72rem;
    font-weight: 900;
    white-space: nowrap;
  }

  .prayer-note button {
    background: var(--prayer-navy);
    border-radius: 999px;
    color: white;
    font-size: 0.72rem;
    font-weight: 900;
    min-height: 2rem;
    padding: 0.45rem 0.75rem;
    text-transform: uppercase;
  }

  .prayer-note button[disabled] {
    background: rgba(26, 37, 92, 0.4);
    cursor: default;
  }

  .prayer-empty {
    background: rgba(255, 255, 255, 0.74);
    border: 1px solid rgba(26, 37, 92, 0.1);
    border-radius: 999px;
    color: rgba(26, 37, 92, 0.62);
    font-size: 0.88rem;
    font-weight: 800;
    left: 50%;
    padding: 0.7rem 1rem;
    position: absolute;
    top: 50%;
    transform: translate(-50%, -50%);
    z-index: 3;
  }

  .prayer-empty[hidden] {
    display: none;
  }

  .prayer-wall-pager {
    align-items: center;
    background: rgba(255, 255, 255, 0.84);
    border-top: 1px solid rgba(26, 37, 92, 0.1);
    display: flex;
    gap: 0.8rem;
    justify-content: space-between;
    padding: 0.85rem 1rem;
  }

  .prayer-wall-pager[hidden] {
    display: none;
  }

  .prayer-wall-pager button {
    border: 1px solid rgba(26, 37, 92, 0.14);
    border-radius: 999px;
    color: var(--prayer-navy);
    font-size: 0.74rem;
    font-weight: 900;
    min-height: 2.35rem;
    padding: 0.55rem 0.9rem;
    text-transform: uppercase;
  }

  .prayer-wall-pager button:disabled {
    cursor: default;
    opacity: 0.45;
  }

  .prayer-wall-pager span {
    color: rgba(26, 37, 92, 0.64);
    font-size: 0.78rem;
    font-weight: 900;
    text-align: center;
    text-transform: uppercase;
  }

  .prayer-form {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0)),
      var(--prayer-ink);
    color: white;
    display: grid;
    gap: 1rem;
    padding: 1.25rem;
    position: sticky;
    top: 6rem;
  }

  .prayer-form h2 {
    color: white;
    font-size: 2rem;
    font-weight: 900;
    line-height: 1.05;
    margin-top: 0.45rem;
  }

  .prayer-form p:not(.prayer-kicker):not(.prayer-status) {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.9rem;
    line-height: 1.58;
    margin-top: 0.55rem;
  }

  .prayer-form__row {
    display: grid;
    gap: 0.8rem;
    grid-template-columns: minmax(0, 1fr) 9.5rem;
  }

  .prayer-field {
    display: grid;
    gap: 0.42rem;
  }

  .prayer-field label {
    color: rgba(255, 255, 255, 0.76);
    font-size: 0.78rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .prayer-field input,
  .prayer-field textarea,
  .prayer-field select {
    appearance: none;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 0.72rem;
    color: white;
    font: inherit;
    min-height: 3rem;
    outline: none;
    padding: 0.85rem 0.95rem;
    width: 100%;
  }

  .prayer-field textarea {
    min-height: 8.75rem;
    resize: vertical;
  }

  .prayer-field input::placeholder,
  .prayer-field textarea::placeholder {
    color: rgba(255, 255, 255, 0.38);
  }

  .prayer-field select {
    color-scheme: dark;
  }

  .prayer-field input:focus,
  .prayer-field textarea:focus,
  .prayer-field select:focus {
    border-color: rgba(242, 201, 76, 0.82);
    box-shadow: 0 0 0 3px rgba(242, 201, 76, 0.18);
  }

  .prayer-visibility {
    border: 0;
    display: grid;
    gap: 0.65rem;
    margin: 0;
    padding: 0;
  }

  .prayer-visibility legend {
    color: rgba(255, 255, 255, 0.76);
    font-size: 0.78rem;
    font-weight: 900;
    margin-bottom: 0.42rem;
    text-transform: uppercase;
  }

  .prayer-visibility label {
    align-items: flex-start;
    background: rgba(255, 255, 255, 0.07);
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 0.82rem;
    cursor: pointer;
    display: grid;
    gap: 0.65rem;
    grid-template-columns: auto minmax(0, 1fr);
    padding: 0.78rem;
  }

  .prayer-visibility input {
    accent-color: var(--prayer-gold);
    margin-top: 0.16rem;
  }

  .prayer-visibility strong,
  .prayer-visibility small {
    display: block;
    line-height: 1.3;
  }

  .prayer-visibility strong {
    color: white;
    font-size: 0.86rem;
    font-weight: 900;
  }

  .prayer-visibility small {
    color: rgba(255, 255, 255, 0.62);
    font-size: 0.76rem;
    margin-top: 0.18rem;
  }

  .prayer-submit {
    align-items: center;
    background: linear-gradient(135deg, var(--prayer-teal), #3f58a1);
    border-radius: 999px;
    color: white;
    display: inline-flex;
    font-size: 0.88rem;
    font-weight: 900;
    justify-content: center;
    min-height: 3.15rem;
    padding: 0.9rem 1.2rem;
    text-transform: uppercase;
  }

  .prayer-submit:disabled {
    opacity: 0.58;
  }

  .prayer-status {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.85rem;
    line-height: 1.4;
    min-height: 1.2rem;
  }

  .prayer-status.is-error {
    color: #fecaca;
    font-weight: 800;
  }

  .prayer-status.is-success {
    color: #bbf7d0;
    font-weight: 800;
  }

  .prayer-rhythm {
    background: var(--prayer-night);
    color: white;
    padding: 5.5rem 0;
  }

  .prayer-rhythm__inner {
    display: grid;
    gap: 2rem;
  }

  .prayer-rhythm h2 {
    color: white;
    font-size: 3rem;
    font-weight: 900;
    line-height: 1.04;
    margin-top: 0.55rem;
    max-width: 38rem;
  }

  .prayer-rhythm__steps {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .prayer-rhythm__steps article {
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.06);
    border-radius: 0.85rem;
    padding: 1.25rem;
  }

  .prayer-rhythm__steps span {
    color: var(--prayer-gold);
    display: block;
    font-size: 0.78rem;
    font-weight: 900;
  }

  .prayer-rhythm__steps h3 {
    color: white;
    font-size: 1.2rem;
    font-weight: 900;
    margin-top: 0.75rem;
  }

  .prayer-rhythm__steps p {
    color: rgba(255, 255, 255, 0.68);
    font-size: 0.9rem;
    line-height: 1.55;
    margin-top: 0.45rem;
  }

  .prayer-compact {
    padding: 1rem;
  }

  .prayer-compact__header {
    align-items: center;
    display: flex;
    gap: 1rem;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .prayer-compact h3 {
    color: var(--prayer-navy);
    font-size: 1.35rem;
    font-weight: 900;
    margin-top: 0.25rem;
  }

  .prayer-count-pill {
    background: var(--prayer-navy);
    border-radius: 0.85rem;
    min-width: 6.6rem;
    padding: 0.85rem;
    text-align: center;
  }

  .prayer-wall-experience--compact .prayer-note {
    --note-width: 10.8rem;
    min-height: 4.65rem;
  }

  [data-prayer-reveal] {
    opacity: 0;
    transform: translateY(1.35rem);
    transition: opacity 680ms ease, transform 680ms ease;
  }

  [data-prayer-reveal].is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @keyframes prayer-note-land {
    0% {
      opacity: 0;
      transform: translate(-50%, -50%) translateY(-2rem) scale(1.08) rotate(var(--r));
    }
    72% {
      opacity: 1;
      transform: translate(-50%, -50%) translateY(0.25rem) scale(0.98) rotate(var(--r));
    }
    100% {
      opacity: 1;
      transform: translate(-50%, -50%) translateY(0) scale(1) rotate(var(--r));
    }
  }

  @media (prefers-reduced-motion: reduce) {
    [data-prayer-reveal],
    .prayer-note.is-new {
      animation: none;
      opacity: 1;
      transition: none;
    }

    .prayer-note {
      transition: none;
    }
  }

  @media (max-width: 1023px) {
    .prayer-hero__inner,
    .prayer-main__grid {
      grid-template-columns: 1fr;
    }

    .prayer-hero__inner {
      gap: 1.6rem;
      padding-top: 6.5rem;
    }

    .prayer-hero h1 {
      font-size: 3.35rem;
    }

    .prayer-verse {
      max-width: 34rem;
    }

    .prayer-form {
      position: relative;
      top: auto;
    }
  }

  @media (max-width: 767px) {
    .prayer-hero {
      min-height: 94svh;
    }

    .prayer-hero__inner {
      min-height: 94svh;
      padding-bottom: 3rem;
      padding-top: 5.8rem;
    }

    .prayer-hero h1 {
      font-size: 2.42rem;
      line-height: 1;
    }

    .prayer-hero__copy > p:not(.prayer-kicker) {
      font-size: 0.98rem;
      line-height: 1.58;
    }

    .prayer-action {
      min-height: 3rem;
      width: 100%;
    }

    .prayer-verse {
      padding: 1.1rem;
    }

    .prayer-verse blockquote {
      font-size: 1.35rem;
    }

    .prayer-main {
      padding: 4rem 0;
    }

    .prayer-main__intro h2,
    .prayer-rhythm h2 {
      font-size: 2rem;
      line-height: 1.08;
    }

    .prayer-wall-panel__bar {
      grid-template-columns: 1fr auto;
    }

    .prayer-wall-panel__bar div:nth-child(2) {
      display: none;
    }

    .prayer-wall-stage {
      height: 33rem;
      max-height: none;
      min-height: 33rem;
    }

    .prayer-stone-layer {
      gap: 0.28rem;
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .prayer-stone-layer span {
      min-height: 4.9rem;
    }

    .prayer-note {
      --note-width: 8.55rem;
      min-height: 4.6rem;
      padding: 0.68rem 0.68rem 0.64rem 1.42rem;
    }

    .prayer-note p {
      font-size: 0.72rem;
      line-height: 1.32;
    }

    .prayer-note:hover,
    .prayer-note:focus,
    .prayer-note:focus-within,
    .prayer-note.is-open {
      min-height: 11.4rem;
      width: min(16.5rem, calc(100% - 1rem));
