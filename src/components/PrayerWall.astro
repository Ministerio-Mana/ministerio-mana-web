  .prayer-hero {
    min-height: 100svh;
    overflow: hidden;
    position: relative;
    background:
      linear-gradient(90deg, rgba(216, 232, 240, 0.12) 0 1px, transparent 1px) 0 0 / clamp(72px, 9vw, 130px) 100%,
      radial-gradient(circle at 78% 16%, rgba(63, 167, 187, 0.24), transparent 18rem),
