      --display-outline-size: 1.85rem;
      --display-solid-size: 1.65rem;
    }

    .prayer-hero__body {
      font-size: 0.98rem;
      line-height: 1.58;
      margin-top: 1.15rem;
    }

    .prayer-action {
      min-height: 3rem;
      width: 100%;
    }

    .prayer-verse {
      padding: 1.1rem;
    }

    .prayer-verse blockquote {
      font-size: 1.35rem;
    }

    .prayer-main {
      padding: 4rem 0;
    }

    .prayer-rhythm h2 {
      font-size: 2rem;
      line-height: 1.08;
    }

    .prayer-main__copy {
      font-size: 0.94rem;
      line-height: 1.58;
    }

    .prayer-wall-panel__bar {
      grid-template-columns: 1fr auto;
    }

    .prayer-wall-panel__bar div:nth-child(2) {
      display: none;
    }

    .prayer-wall-stage {
      height: 33rem;
      max-height: none;
      min-height: 33rem;
    }

    .prayer-note {
      --note-height: 2.75rem;
      --note-paper-height: 1.2rem;
      --note-paper-width: 3.35rem;
      --note-width: 4rem;
      height: var(--note-height);
      min-height: 2.75rem;
    }

    .prayer-note[data-paper-orientation="vertical"] {
      --note-height: 4.75rem;
      --note-paper-height: 4.1rem;
      --note-paper-width: 1.25rem;
      --note-width: 2.75rem;
    }

    .prayer-note p {
      display: none;
    }

    .prayer-note:hover,
    .prayer-note:focus,
    .prayer-note:focus-within,
    .prayer-note.is-open {
      width: var(--note-width);
    }

    .prayer-note header {
      top: calc(50% + 1.45rem);
      width: min(12rem, 76vw);
    }

    .prayer-note[data-paper-orientation="vertical"] header {
      top: calc(50% + 2.55rem);
      width: min(12rem, 76vw);
    }

    .prayer-note__pin {
      top: calc(50% - 0.02rem);
      width: calc(var(--note-paper-width) + 0.3rem);
    }

    .prayer-note h3 {
      font-size: 0.62rem;
      max-width: 100%;
    }

    .prayer-note small {
      display: -webkit-box;
    }

    .prayer-wall-detail {
      max-width: calc(100% - 1.5rem);
      width: calc(100% - 1.5rem);
    }

    .prayer-wall-detail h3,
    .prayer-wall-detail h4 {
      font-size: 1.05rem;
    }

    .prayer-wall-detail p {
      font-size: 0.82rem;
