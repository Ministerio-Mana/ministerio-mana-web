---
interface Props {
  class?: string;
}

const className = Astro.props.class ?? '';
---

<svg
  class={`sowing-icon ${className}`}
  viewBox="0 0 24 24"
  fill="none"
  aria-hidden="true"
  focusable="false"
>
  <path
    class="sowing-hand"
    d="M3 18.8c2.7 2 6.4 2.5 9.9 1.5 1.7-.5 3.3-1.3 5.1-1.2 1.2.1 2 .6 2 1.4 0 .6-.5 1.1-1.2 1.3-4.2 1.3-8.6 2.2-12.8.8a11 11 0 0 1-3.5-1.9"
    stroke="currentColor"
    stroke-width="1.8"
    stroke-linecap="round"
    stroke-linejoin="round"
    opacity="0.92"
  />
  <path
    class="seed-drop"
    d="M12 13.2s-5-2.9-5-6.2c0-1.8 1.3-3.2 3-3.2.9 0 1.6.4 2 1.1.5-.7 1.2-1.1 2.1-1.1 1.7 0 3 1.4 3 3.2 0 3.3-5.1 6.2-5.1 6.2Z"
    fill="currentColor"
    opacity="0.95"
  />
</svg>

<style>
  .sowing-icon {
    display: inline-flex;
    width: 1.65rem;
    height: 1.65rem;
    flex: 0 0 auto;
    overflow: visible;
  }

  .seed-drop {
    transform-origin: 12px 9px;
    animation: heart-give 2.3s ease-in-out infinite;
  }

  @keyframes heart-give {
    0%, 100% { transform: translateY(0) scale(0.95); opacity: 0.88; }
    45% { transform: translateY(-1px) scale(1.08); opacity: 1; }
    68% { transform: translateY(0) scale(1); opacity: 0.96; }
  }

  @media (prefers-reduced-motion: reduce) {
    .seed-drop {
      animation: none;
    }
  }
</style>
