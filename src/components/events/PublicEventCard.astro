---
type Props = {
  title: string;
  summary?: string | null;
  startDate: string;
  endDate?: string | null;
  location?: string | null;
  image?: string | null;
  imageLayout?: string | null;
  href: string;
  category?: string | null;
};

const { title, summary, startDate, endDate, location, image, imageLayout, href, category } = Astro.props;
const mediaLayout = imageLayout === 'SQUARE' || imageLayout === 'VERTICAL' ? imageLayout.toLowerCase() : 'horizontal';
const start = new Date(startDate);
const end = new Date(endDate || startDate);
const isPast = Number.isFinite(end.getTime()) && end.getTime() < Date.now();
const dateLabel = Number.isFinite(start.getTime())
  ? new Intl.DateTimeFormat('es-CO', { day: 'numeric', month: 'long', year: 'numeric' }).format(start)
  : 'Fecha por confirmar';
const monthLabel = Number.isFinite(start.getTime())
  ? new Intl.DateTimeFormat('es-CO', { month: 'short' }).format(start).replace('.', '').toUpperCase()
  : 'EVENTO';
const dayLabel = Number.isFinite(start.getTime()) ? String(start.getDate()) : '—';
---

<article class:list={["event-public-card group grid min-w-0 overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm transition hover:border-slate-300 hover:shadow-md", `event-public-card--${mediaLayout}`]}>
  <a href={href} class:list={["event-public-card-media relative block overflow-hidden bg-[#293C74]", `event-public-card-media--${mediaLayout}`]} aria-label={`Ver ${title}`}>
    {image ? (
      <img src={image} alt="" loading="lazy" decoding="async" class:list={["absolute inset-0 h-full w-full transition duration-300 group-hover:scale-[1.02]", mediaLayout === 'horizontal' ? 'object-cover' : 'object-contain']} />
    ) : (
      <span class="absolute inset-0 flex flex-col items-center justify-center text-white">
        <span class="text-xs font-bold text-white/80">{monthLabel}</span>
        <strong class="text-4xl leading-none text-white">{dayLabel}</strong>
      </span>
    )}
  </a>
  <div class="flex min-w-0 flex-col justify-between gap-4 p-5">
    <div>
      <div class="mb-2 flex flex-wrap items-center gap-2 text-xs font-bold uppercase text-slate-500">
        <span>{isPast ? 'Finalizado' : 'Próximo'}</span>
        {category && <><span aria-hidden="true">·</span><span>{category}</span></>}
      </div>
      <h2 class="text-xl font-bold leading-tight text-[#293C74]"><a href={href} class="inline-flex min-h-11 items-center hover:underline">{title}</a></h2>
      {summary && <p class="mt-2 line-clamp-2 text-sm leading-relaxed text-slate-600">{summary}</p>}
    </div>
    <div class="flex flex-col gap-1 border-t border-slate-100 pt-3 text-sm text-slate-600">
      <span class="font-semibold text-slate-800">{dateLabel}</span>
      {location && <span>{location}</span>}
    </div>
  </div>
</article>

<style>
  .event-public-card {
    grid-template-columns: 180px minmax(0, 1fr);
  }

  .event-public-card-media { min-height: 10rem; }
  .event-public-card-media--square { aspect-ratio: 1; min-height: 0; }
  .event-public-card-media--vertical { aspect-ratio: 4 / 5; min-height: 0; }

  @media (max-width: 639px) {
    .event-public-card { grid-template-columns: 1fr; }
    .event-public-card-media--horizontal { min-height: 10rem; }
    .event-public-card-media--square { width: min(100%, 300px); margin-inline: auto; }
    .event-public-card-media--vertical { width: min(100%, 240px); margin-inline: auto; }
  }
</style>
