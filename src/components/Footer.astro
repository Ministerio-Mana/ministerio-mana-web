              {visiblePlaylist.length ? (
                visiblePlaylist.map((video, index) => (
                  <button
                    type="button"
                    class="mana-playlist-track"
                    aria-current={index === 0 ? 'true' : undefined}
                    data-devotional-command="loadVideoById"
                    data-devotional-video={video.videoId}
                    data-devotional-track-title={video.title}
                    data-devotional-track-description={video.description}
                    data-devotional-track-image={video.image}
                    data-devotional-track-url={video.url}
                  >
                    <img src={video.image} alt="" loading="lazy" decoding="async" />
                    <span>
                      <strong>{video.title}</strong>
                      <small>{video.description}</small>
                    </span>
