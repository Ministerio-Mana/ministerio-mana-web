          <a href={latestDevotional.url} target="_blank" rel="noopener noreferrer" class="mana-devotional-thumb" aria-label={latestDevotional.title} data-devotional-link>
            <img src={latestDevotional.image} alt="" loading="lazy" decoding="async" data-devotional-image />
          </a>

          <div class="min-w-0">
            <div class="flex flex-wrap items-center gap-2">
              <span class="rounded-md bg-white/10 px-2.5 py-1 text-[10px] font-bold uppercase text-[#9ee7f4]">{t(locale, 'footer_player_source')}</span>
            </div>
            <h3 class="mt-2 line-clamp-2 text-sm font-display font-black leading-tight text-white md:line-clamp-1 md:text-base" data-devotional-title>{latestDevotional.title}</h3>
            <p class="mt-1 line-clamp-2 text-xs leading-relaxed text-slate-300 md:text-sm" data-devotional-description>{latestDevotional.description}</p>

            <div class="mt-2.5 flex flex-wrap items-center gap-2">
              <button type="button" class="mana-player-icon" aria-label={t(locale, 'footer_player_previous')} data-devotional-step="-1">
                <svg viewBox="0 0 24 24" class="h-4 w-4" aria-hidden="true"><path fill="currentColor" d="M7 6h2v12H7V6Zm3.5 6 8.5 6V6l-8.5 6Z" /></svg>
              </button>
              <button type="button" class="mana-player-play" aria-label={t(locale, 'footer_player_play')} data-devotional-toggle>
                <svg viewBox="0 0 24 24" class="h-5 w-5 mana-player-play-icon" aria-hidden="true"><path fill="currentColor" d="M8 5v14l11-7L8 5Z" /></svg>
                <svg viewBox="0 0 24 24" class="hidden h-5 w-5 mana-player-pause-icon" aria-hidden="true"><path fill="currentColor" d="M7 5h4v14H7V5Zm6 0h4v14h-4V5Z" /></svg>
                <span data-devotional-toggle-label>{t(locale, 'footer_player_play')}</span>
              </button>
              <button type="button" class="mana-player-icon" aria-label={t(locale, 'footer_player_next')} data-devotional-step="1">
                <svg viewBox="0 0 24 24" class="h-4 w-4" aria-hidden="true"><path fill="currentColor" d="M15 6h2v12h-2V6ZM5 18l8.5-6L5 6v12Z" /></svg>
              </button>

              <div class="mana-wave ml-1" aria-hidden="true">
                <span></span>
                <span></span>
                <span></span>
                <span></span>
                <span></span>
              </div>
            </div>

            <div class="mt-2 h-1 overflow-hidden rounded-full bg-white/10">
              <div class="mana-progress h-full w-1/3 rounded-full bg-gradient-to-r from-[#28A6BD] via-amber-300 to-[#28A6BD]"></div>
            </div>
          </div>

          <details class="mana-playlist group col-span-2 xl:col-span-1">
            <summary class="flex h-9 cursor-pointer list-none items-center justify-center rounded-lg border border-white/15 px-3 text-[11px] font-bold uppercase text-amber-100 transition-colors hover:border-white/30 hover:bg-white/10 hover:text-white">
              {t(locale, 'footer_playlist_label')}
