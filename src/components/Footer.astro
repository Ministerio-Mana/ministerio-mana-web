---
import { normalizeLocale, t } from '@i18n/locales';

const locale = normalizeLocale(Astro.props.locale ?? Astro.cookies.get('lang')?.value);
const devotionalWhatsappUrl = 'https://whatsapp.com/channel/0029VaABvlHGzzKb3f53TQ3M';
const devotionalYoutubeChannelUrl = 'https://www.youtube.com/channel/UCC85JrvTKq9dfCcgxQQU_Ag';
const devotionalYoutubeVideosUrl = `${devotionalYoutubeChannelUrl}/videos`;
const devotionalUploadsPlaylistId = 'UUC85JrvTKq9dfCcgxQQU_Ag';
const devotionalRssUrl = 'https://www.youtube.com/feeds/videos.xml?channel_id=UCC85JrvTKq9dfCcgxQQU_Ag';

type DevotionalVideo = {
  title: string;
  description: string;
  videoId: string;
  image: string;
  url: string;
};

const fallbackDevotional: DevotionalVideo = {
  title: t(locale, 'footer_player_title_fallback'),
  description: t(locale, 'footer_player_body_fallback'),
  videoId: '',
  image: '/assets/home-ministerio/front-devocional-mana.png',
  url: devotionalYoutubeChannelUrl,
};

function decodeXml(value = '') {
  return value
    .replace(/<!\[CDATA\[([\s\S]*?)\]\]>/g, '$1')
    .replace(/<[^>]+>/g, ' ')
    .replace(/&amp;/g, '&')
    .replace(/&quot;/g, '"')
    .replace(/&#39;/g, "'")
    .replace(/&apos;/g, "'")
    .replace(/&lt;/g, '<')
    .replace(/&gt;/g, '>')
    .replace(/\s+/g, ' ')
    .trim();
}

function pickXml(source: string, pattern: RegExp) {
  return source.match(pattern)?.[1] ?? '';
}

function shortText(value: string, max = 132) {
  if (value.length <= max) return value;
  const clipped = value.slice(0, max).replace(/\s+\S*$/, '').trim();
  return `${clipped}...`;
}

function descriptionFromTitle(title: string) {
  const topic = title
    .replace(/^Devocional\s*[│|-]\s*/i, '')
    .replace(/^Reto\s*#?\d+:\s*/i, '')
    .trim();
  if (!topic || topic === title) return fallbackDevotional.description;
  return shortText(`Una palabra para meditar sobre ${topic} y volver a Dios durante el día.`, 118);
}

async function fetchWithTimeout(url: string, timeoutMs: number) {
  const controller = new AbortController();
  const timeout = setTimeout(() => controller.abort(), timeoutMs);
  try {
    return await fetch(url, { signal: controller.signal });
  } finally {
    clearTimeout(timeout);
  }
}

async function getVideoFromOembed(videoId: string): Promise<DevotionalVideo | null> {
  try {
    const url = `https://www.youtube.com/oembed?url=https://www.youtube.com/watch?v=${videoId}&format=json`;
    const response = await fetchWithTimeout(url, 1500);
    if (!response.ok) return null;
    const data = await response.json();
    const title = typeof data?.title === 'string' ? data.title : fallbackDevotional.title;
    return {
      title,
      description: descriptionFromTitle(title),
      videoId,
      image: typeof data?.thumbnail_url === 'string' ? data.thumbnail_url : `https://i.ytimg.com/vi/${videoId}/hqdefault.jpg`,
      url: `https://www.youtube.com/watch?v=${videoId}`,
    };
  } catch {
    return null;
  }
}

async function getLatestFromRss(): Promise<DevotionalVideo | null> {
  try {
    const response = await fetchWithTimeout(devotionalRssUrl, 1300);
    if (!response.ok) return null;

    const xml = await response.text();
    const entry = xml.match(/<entry\b[\s\S]*?<\/entry>/)?.[0] ?? '';
    const videoId = decodeXml(pickXml(entry, /<yt:videoId>([\s\S]*?)<\/yt:videoId>/));
    if (!videoId) return null;

    const title = decodeXml(pickXml(entry, /<title>([\s\S]*?)<\/title>/)) || fallbackDevotional.title;
    const description =
      shortText(decodeXml(pickXml(entry, /<media:description>([\s\S]*?)<\/media:description>/))) ||
      fallbackDevotional.description;

    return {
      title,
      description,
      videoId,
      image: `https://i.ytimg.com/vi/${videoId}/hqdefault.jpg`,
      url: `https://www.youtube.com/watch?v=${videoId}`,
    };
  } catch {
    return null;
  }
}

async function getLatestFromVideosPage(): Promise<DevotionalVideo[]> {
  try {
    const response = await fetchWithTimeout(devotionalYoutubeVideosUrl, 4200);
    if (!response.ok) return [];
    const html = await response.text();
    const videoIds = Array.from(html.matchAll(/"videoId":"([^"]+)"/g))
      .map((match) => match[1])
      .filter((videoId, index, list) => videoId && list.indexOf(videoId) === index)
      .slice(0, 4);

    const videos = await Promise.all(videoIds.map((videoId) => getVideoFromOembed(videoId)));
    return videos.filter(Boolean) as DevotionalVideo[];
  } catch {
    return [];
  }
}

async function getDevotionalPlaylist(): Promise<DevotionalVideo[]> {
  const cacheKey = '__manaDevotionalPlaylist';
  const globalCache = globalThis as typeof globalThis & {
    [cacheKey]?: { ts: number; data: DevotionalVideo[] };
  };
  const cached = globalCache[cacheKey];
  if (cached && Date.now() - cached.ts < 1000 * 60 * 15) return cached.data;

  const videosPageData = await getLatestFromVideosPage();
  if (videosPageData.length) {
    globalCache[cacheKey] = { ts: Date.now(), data: videosPageData };
    return videosPageData;
  }

  const rssData = await getLatestFromRss();
  const data = rssData ? [rssData] : [fallbackDevotional];
  if (rssData) globalCache[cacheKey] = { ts: Date.now(), data };
  return data;
}

const devotionalPlaylist = await getDevotionalPlaylist();
const latestDevotional = devotionalPlaylist[0] ?? fallbackDevotional;
const visiblePlaylist = devotionalPlaylist.filter((video) => video.videoId);
const devotionalEmbedParams = new URLSearchParams({
  list: devotionalUploadsPlaylistId,
  rel: '0',
  modestbranding: '1',
  playsinline: '1',
  controls: '0',
  enablejsapi: '1',
  origin: Astro.url.origin,
  iv_load_policy: '3',
});
const devotionalEmbedPath = latestDevotional.videoId ? latestDevotional.videoId : 'videoseries';
const devotionalEmbedUrl = `https://www.youtube-nocookie.com/embed/${devotionalEmbedPath}?${devotionalEmbedParams.toString()}`;
---

<footer id="site-footer" data-astro-transition-persist="site-footer" class="relative z-20 bg-[#11182f] text-white">
