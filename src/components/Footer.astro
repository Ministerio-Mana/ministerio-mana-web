---
import { normalizeLocale, t } from '@i18n/locales';

const locale = normalizeLocale(Astro.props.locale ?? Astro.cookies.get('lang')?.value);
const devotionalWhatsappUrl = 'https://whatsapp.com/channel/0029VaABvlHGzzKb3f53TQ3M';
const devotionalYoutubeChannelUrl = 'https://www.youtube.com/channel/UCC85JrvTKq9dfCcgxQQU_Ag';
const devotionalYoutubeVideosUrl = `${devotionalYoutubeChannelUrl}/videos`;
const devotionalRssUrl = 'https://www.youtube.com/feeds/videos.xml?channel_id=UCC85JrvTKq9dfCcgxQQU_Ag';
const devotionalCoverFallback = '/assets/home-ministerio/front-devocional-mana.png';

type DevotionalVideo = {
  title: string;
  description: string;
  videoId: string;
  image: string;
  url: string;
};

const fallbackDevotional: DevotionalVideo = {
  title: t(locale, 'footer_player_title_fallback'),
  description: t(locale, 'footer_player_body_fallback'),
  videoId: '2Xw3LVxU1dM',
  image: devotionalCoverFallback,
  url: 'https://www.youtube.com/watch?v=2Xw3LVxU1dM',
};
const fallbackDevotionalList: DevotionalVideo[] = [
  fallbackDevotional,
  'N0o8nwTZ-Hs',
  'fDHrj3X5xT4',
  'N5emKqJLsUs',
].map((item) => {
  if (typeof item !== 'string') return item;
  return {
    ...fallbackDevotional,
    videoId: item,
    image: `https://i.ytimg.com/vi/${item}/hqdefault.jpg`,
    url: `https://www.youtube.com/watch?v=${item}`,
  };
});

function decodeXml(value = '') {
  return value
    .replace(/<!\[CDATA\[([\s\S]*?)\]\]>/g, '$1')
    .replace(/<[^>]+>/g, ' ')
    .replace(/&amp;/g, '&')
    .replace(/&quot;/g, '"')
    .replace(/&#39;/g, "'")
    .replace(/&apos;/g, "'")
    .replace(/&lt;/g, '<')
    .replace(/&gt;/g, '>')
    .replace(/\s+/g, ' ')
    .trim();
}

function pickXml(source: string, pattern: RegExp) {
  return source.match(pattern)?.[1] ?? '';
}

function shortText(value: string, max = 132) {
  if (value.length <= max) return value;
  const clipped = value.slice(0, max).replace(/\s+\S*$/, '').trim();
  return `${clipped}...`;
}

function descriptionFromTitle(title: string) {
  const topic = title
    .replace(/^Devocional\s*[│|-]\s*/i, '')
    .replace(/^Reto\s*#?\d+:\s*/i, '')
    .trim();
  if (!topic || topic === title) return fallbackDevotional.description;
  return shortText(`Una palabra para meditar sobre ${topic} y volver a Dios durante el día.`, 118);
}

function cleanDevotionalTitle(title = '') {
  const cleaned = title
    .replace(/^Devocional\s*[|│-]\s*/i, '')
    .replace(/^Reto\s*#?\d+:\s*/i, '')
    .trim();
  return cleaned || title;
}

async function fetchWithTimeout(url: string, timeoutMs: number) {
  const controller = new AbortController();
  const timeout = setTimeout(() => controller.abort(), timeoutMs);
  try {
    return await fetch(url, { signal: controller.signal });
  } finally {
    clearTimeout(timeout);
  }
}

async function getVideoFromOembed(videoId: string): Promise<DevotionalVideo | null> {
  try {
    const oembedUrl = `https://www.youtube.com/oembed?url=${encodeURIComponent(`https://www.youtube.com/watch?v=${videoId}`)}&format=json`;
    const response = await fetchWithTimeout(oembedUrl, 1500);
    if (!response.ok) return null;
    const data = await response.json();
    const title = typeof data?.title === 'string' ? data.title : fallbackDevotional.title;
    return {
      title,
      description: descriptionFromTitle(title),
      videoId,
      image: typeof data?.thumbnail_url === 'string' ? data.thumbnail_url : `https://i.ytimg.com/vi/${videoId}/hqdefault.jpg`,
      url: `https://www.youtube.com/watch?v=${videoId}`,
    };
  } catch {
    return null;
  }
}

async function getLatestListFromRss(limit = 6): Promise<DevotionalVideo[]> {
  try {
    const response = await fetchWithTimeout(devotionalRssUrl, 1800);
    if (!response.ok) return [];

    const xml = await response.text();
    return Array.from(xml.matchAll(/<entry\b[\s\S]*?<\/entry>/g))
      .slice(0, limit)
      .map((match) => {
        const entry = match[0];
        const videoId = decodeXml(pickXml(entry, /<yt:videoId>([\s\S]*?)<\/yt:videoId>/));
        const title = decodeXml(pickXml(entry, /<title>([\s\S]*?)<\/title>/)) || fallbackDevotional.title;
        const description =
          shortText(decodeXml(pickXml(entry, /<media:description>([\s\S]*?)<\/media:description>/)), 118) ||
          descriptionFromTitle(title);

        return {
          title,
          description,
          videoId,
          image: `https://i.ytimg.com/vi/${videoId}/hqdefault.jpg`,
          url: `https://www.youtube.com/watch?v=${videoId}`,
        };
      })
      .filter((video) => video.videoId);
  } catch {
    return [];
  }
}

async function getLatestFromVideosPage(): Promise<DevotionalVideo | null> {
  try {
    const response = await fetchWithTimeout(devotionalYoutubeVideosUrl, 4200);
    if (!response.ok) return null;
    const html = await response.text();
    const videoId =
      html.match(/"videoId":"([^"]+)"/)?.[1] ||
      html.match(/\/watch\?v=([A-Za-z0-9_-]{11})/)?.[1] ||
      '';
    if (!videoId) return null;
    return await getVideoFromOembed(videoId) ?? {
      ...fallbackDevotional,
      videoId,
      image: `https://i.ytimg.com/vi/${videoId}/hqdefault.jpg`,
      url: `https://www.youtube.com/watch?v=${videoId}`,
    };
  } catch {
    return null;
  }
}

async function getLatestListFromVideosPage(limit = 6): Promise<DevotionalVideo[]> {
  try {
    const response = await fetchWithTimeout(devotionalYoutubeVideosUrl, 4200);
    if (!response.ok) return [];
    const html = await response.text();
    const ids = Array.from(
      new Set(
        Array.from(html.matchAll(/"videoId":"([A-Za-z0-9_-]{11})"/g))
          .map((match) => match[1])
          .filter(Boolean)
      )
    ).slice(0, limit);
    if (ids.length === 0) return [];

    const videos = await Promise.all(ids.map((videoId) => getVideoFromOembed(videoId)));
    return ids.map((videoId, index) => videos[index] ?? {
      ...fallbackDevotional,
      videoId,
      image: `https://i.ytimg.com/vi/${videoId}/hqdefault.jpg`,
      url: `https://www.youtube.com/watch?v=${videoId}`,
    });
  } catch {
    return [];
  }
}

async function fetchLatestDevotionalsFromRemote(): Promise<DevotionalVideo[]> {
  const rssVideos = await getLatestListFromRss();
  if (rssVideos.length > 0) return rssVideos;

  const pageVideos = await getLatestListFromVideosPage();
  return pageVideos.length > 0 ? pageVideos : fallbackDevotionalList;
}

function getLatestDevotionals(): DevotionalVideo[] {
  const cacheKey = locale;
  const globalCache = globalThis as typeof globalThis & {
    __manaYoutubeFooterVideoListsV3?: Record<string, { ts: number; data: DevotionalVideo[]; inflight?: Promise<DevotionalVideo[]> }>;
  };
  const cache = (globalCache.__manaYoutubeFooterVideoListsV3 ??= {});
  const cached = cache[cacheKey];
  const now = Date.now();
  const cacheTtlMs = 1000 * 60 * 15;
  const fallbackTtlMs = 1000 * 60 * 2;

  if (cached && Array.isArray(cached.data) && now - cached.ts < cacheTtlMs) return cached.data;

  const current = cached ?? { ts: now, data: fallbackDevotionalList };
  cache[cacheKey] = current;

  if (!current.inflight && now - current.ts >= fallbackTtlMs) {
    current.inflight = fetchLatestDevotionalsFromRemote()
      .then((data) => {
        current.ts = Date.now();
        current.data = data.length > 0 ? data : fallbackDevotionalList;
        return current.data;
      })
      .catch(() => {
        current.ts = Date.now();
        current.data = fallbackDevotionalList;
        return current.data;
      })
      .finally(() => {
        current.inflight = undefined;
      });
  }

  return current.data;
}

const latestDevotionals = getLatestDevotionals();
const latestDevotional = latestDevotionals[0] ?? {
  ...fallbackDevotional,
  image: `https://i.ytimg.com/vi/${fallbackDevotional.videoId}/hqdefault.jpg`,
};
---

