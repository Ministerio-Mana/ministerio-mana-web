          <div class="mana-player-copy min-w-0">
            <h3 data-youtube-title class="mana-player-title">{cleanDevotionalTitle(latestDevotional.title)}</h3>
            <p data-youtube-description class="mana-player-description">{latestDevotional.description}</p>

          </div>

          <div class="mana-player-controls">
            <button type="button" class="mana-player-play" aria-label={t(locale, 'footer_player_play')} aria-expanded="false" data-youtube-toggle>
              <svg viewBox="0 0 24 24" class="h-5 w-5 mana-player-play-icon" aria-hidden="true"><path fill="currentColor" d="M8 5v14l11-7L8 5Z" /></svg>
              <svg viewBox="0 0 24 24" class="hidden h-5 w-5 mana-player-pause-icon" aria-hidden="true"><path fill="currentColor" d="M7 5h4v14H7V5Zm6 0h4v14h-4V5Z" /></svg>
            </button>
            <button type="button" class="mana-player-link" aria-expanded="false" data-youtube-playlist-toggle>
              {t(locale, 'footer_playlist_label')}
            </button>
            <a href={devotionalYoutubeChannelUrl} target="_blank" rel="noopener noreferrer" class="mana-player-link">
              YouTube
            </a>

            <div class="mana-wave" aria-hidden="true">
              <span></span>
              <span></span>
              <span></span>
              <span></span>
              <span></span>
            </div>
          </div>

          <div class="mana-player-progress-row">
            <div
              class="mana-player-progress-track"
              role="slider"
              tabindex="0"
              aria-label={t(locale, 'footer_player_progress')}
              aria-valuemin="0"
              aria-valuemax="100"
              aria-valuenow="0"
              data-youtube-progress
            >
              <div class="mana-progress h-full rounded-full bg-gradient-to-r from-[#28A6BD] via-amber-300 to-[#28A6BD]" data-youtube-progress-fill></div>
            </div>
            <span class="mana-player-time" data-youtube-time>0:00 / 0:00</span>
          </div>
        </div>

        <div class="mana-youtube-frame-shell" data-youtube-frame-shell hidden>
          <iframe
            data-youtube-frame
            title={t(locale, 'footer_player_iframe_title')}
            referrerpolicy="strict-origin-when-cross-origin"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
          ></iframe>
        </div>

        <div class="mana-playlist-panel" data-youtube-playlist-panel hidden>
          <div class="mana-playlist-list" role="list">
            {latestDevotionals.map((video, index) => (
              <button
                type="button"
                class="mana-playlist-item"
                data-youtube-option
                data-video-id={video.videoId}
                data-video-title={cleanDevotionalTitle(video.title)}
                data-video-description={video.description}
                data-video-image={video.image}
                data-current={index === 0 ? 'true' : undefined}
                aria-label={cleanDevotionalTitle(video.title)}
              >
                <img src={video.image} alt="" loading="lazy" decoding="async" />
                <span>
                  <small>{String(index + 1).padStart(2, '0')}</small>
                  <strong>{cleanDevotionalTitle(video.title)}</strong>
                </span>
              </button>
            ))}
