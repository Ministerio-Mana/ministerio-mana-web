
---
import { LOCALES } from '@i18n/locales';
const current = Astro.cookies.get('lang')?.value ?? 'es';
const next = current === 'es' ? 'en' : 'es';
const { variant = 'light' } = Astro.props;
const buttonClass = variant === 'dark'
  ? 'inline-flex items-center justify-center gap-2 rounded-full border border-white/25 bg-white/10 px-6 py-2.5 font-display text-xs font-semibold uppercase tracking-[0.12em] text-white transition-all duration-200 hover:bg-white/15 hover:text-white focus-visible:bg-white/15 focus-visible:text-white'
  : 'btn-outline btn-sm';
function setLang(l) {
  document.cookie = `lang=${l};path=/;max-age=${60*60*24*365}`;
  location.reload();
}
---
<button class={buttonClass} onclick={`(${setLang.toString()})('${next}')`}>{next.toUpperCase()}</button>
