    line-height: 1.55;
  }

  @media (min-width: 1180px) {
    .donation-title {
      font-size: 6.1rem;
    }
  }

  @media (max-width: 1080px) {
    .donation-stage__inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .donation-story {
      max-width: 820px;
