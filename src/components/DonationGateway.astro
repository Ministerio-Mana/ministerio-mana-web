---
import TurnstileWidget from '@components/TurnstileWidget.astro';
import SowingIcon from '@components/icons/SowingIcon.astro';

type Gateway = 'wompi' | 'stripe';

interface Props {
  preferred?: Gateway;
  country?: string;
  initialDonationType?: string;
}

const { preferred = 'wompi', country = 'CO', initialDonationType = '' } = Astro.props as Props;
const isWompi = preferred === 'wompi';
const cspNonce = Astro.locals?.cspNonce;
const countryCode = (country || 'CO').toUpperCase();
const donationOptions = [
  { value: 'diezmos', label: 'Diezmos', project: 'Diezmos' },
  { value: 'ofrendas', label: 'Ofrenda', project: 'Ofrenda' },
  { value: 'misiones', label: 'Misiones', project: 'Misiones' },
];
const selectedDonationType = donationOptions.some((option) => option.value === initialDonationType)
  ? initialDonationType
  : '';
const selectedDonationProject = donationOptions.find((option) => option.value === selectedDonationType)?.project ?? 'Ministerio Maná';

const gateway = isWompi
  ? {
      name: 'Wompi',
      action: '/api/wompi/checkout',
      currency: 'COP',
      source: 'donaciones-wompi',
      amountLabel: 'Valor en pesos colombianos',
      min: 5000,
      step: 1000,
      placeholder: 'Ej. 100000',
      button: 'Donar',
      secure: 'Pago seguro. No almacenamos datos de tarjeta.',
      presets: [50000, 100000, 200000, 500000],
    }
  : {
      name: 'Stripe',
      action: '/api/stripe/checkout',
      currency: 'USD',
      source: 'donaciones-stripe',
      amountLabel: 'Valor en dólares',
      min: 5,
      step: 1,
      placeholder: 'Ex. 50',
      button: 'Donar',
      secure: 'Pago seguro internacional. No almacenamos datos de tarjeta.',
      presets: [25, 50, 100, 250],
    };

function gatewayHref(nextGateway: Gateway): string {
  const url = new URL(Astro.url);
  url.searchParams.set('gateway', nextGateway);
  if (selectedDonationType) {
    url.searchParams.set('type', selectedDonationType);
  }
  return `${url.pathname}${url.search}${url.hash}`;
}

const wompiHref = gatewayHref('wompi');
const stripeHref = gatewayHref('stripe');

function formatPreset(value: number): string {
  if (isWompi) {
    return new Intl.NumberFormat('es-CO', {
      style: 'currency',
      currency: 'COP',
      maximumFractionDigits: 0,
    }).format(value);
  }
  return new Intl.NumberFormat('en-US', {
    style: 'currency',
    currency: 'USD',
    maximumFractionDigits: 0,
  }).format(value);
}
---

<section class="donation-shell">
  <div class="donation-stage">
    <img src="/images/cumbre/fishermen-bg-highres.jpg" alt="" class="donation-stage__image" loading="eager" />
    <div class="donation-stage__shade"></div>
    <div class="donation-stage__texture" aria-hidden="true"></div>
    <div class="donation-frame" aria-hidden="true">
      <span></span>
      <span></span>
      <span></span>
    </div>

    <div class="container-tight donation-stage__inner">
      <div class="donation-story">
        <img class="donation-logo" src="/images/cumbre/logo-ministerio-mana-blanco.svg" alt="Ministerio Maná" />
        <p class="donation-script">Sembrar</p>
        <h1 class="donation-title">
          <span>una red</span>
          <span>sostener la misión</span>
        </h1>
        <p class="donation-lead">
          Tu generosidad ayuda a formar discípulos, cuidar iglesias, enviar obreros y abrir camino
          para que más personas conozcan a Cristo.
        </p>

        <p class="donation-note">
          {isWompi
            ? 'En Colombia procesamos la donación por Wompi y pedimos identificación para conciliación contable y soportes tributarios.'
            : 'Fuera de Colombia procesamos la donación por Stripe en dólares y registramos la confirmación para soporte administrativo.'}
        </p>
      </div>

      <form
        method="POST"
        action={gateway.action}
        class="donation-form"
        data-donation-form
        data-gateway={preferred}
        data-login-url="/portal/ingresar?next=/donaciones/%3Frecurring%3D1&reason=recurring-donation"
        novalidate
      >
        <div class="donation-form__header">
          <div class="donation-form__route">
            <span>{isWompi ? 'Donación en Colombia' : 'Donación internacional'}</span>
          </div>
          <div class="donation-gateway-switch" aria-label="Selecciona moneda y pasarela">
            <a href={wompiHref} class={isWompi ? 'is-active' : ''} aria-current={isWompi ? 'true' : undefined}>
              COP / Wompi
            </a>
            <a href={stripeHref} class={!isWompi ? 'is-active' : ''} aria-current={!isWompi ? 'true' : undefined}>
              USD / Stripe
            </a>
          </div>
          <h2>Haz tu donación</h2>
          <p>
            {isWompi
              ? 'Recibimos tu donación en pesos colombianos y cuidamos la información necesaria para el soporte contable.'
              : 'Recibimos tu donación internacional en dólares y registramos el soporte administrativo correspondiente.'}
          </p>
        </div>

        <div class="donation-progress" aria-live="polite">
          <span data-progress-count>Paso 1 de 2</span>
          <strong data-progress-title>Tu donación</strong>
          <small data-progress-next>Luego: tus datos</small>
        </div>

        <div class="donation-step is-active" data-donation-step="1">
          <div class="donation-section-label">
            <span>01</span>
            <strong>Tu donación</strong>
          </div>

          <div class="donation-field donation-field--full">
            <label for="donation-type">Tipo de donación</label>
            <select id="donation-type" name="donationType" required>
              <option value="" disabled selected={!selectedDonationType}>Selecciona</option>
              {donationOptions.map((option) => (
                <option value={option.value} selected={selectedDonationType === option.value}>{option.label}</option>
              ))}
            </select>
          </div>

          <div class="donation-field donation-field--full">
            <label for="amount">{gateway.amountLabel}</label>
            <input
              id="amount"
              type="number"
              name="amount"
              min={gateway.min}
              step={gateway.step}
              required
              placeholder={gateway.placeholder}
              inputmode="numeric"
            />
            <p class="donation-quick-label">Escoge un valor rápido si quieres</p>
            <div class="donation-presets">
              {gateway.presets.map((value) => (
                <button type="button" data-amount-preset={value}>{formatPreset(value)}</button>
              ))}
            </div>
          </div>

          <fieldset class="donation-recurrence">
            <legend>Frecuencia</legend>
            <label>
              <input type="radio" name="isRecurring" value="false" checked data-recurrence-radio />
              <span>Una sola vez</span>
            </label>
            <label>
              <input type="radio" name="isRecurring" value="true" data-recurrence-radio />
              <span>Recurrente</span>
            </label>
          </fieldset>

          <div class="donation-field donation-field--full donation-frequency" data-frequency-wrap hidden>
            <label for="frequency">Cada cuánto quieres donar</label>
            <select id="frequency" name="frequency" disabled>
              <option value="monthly" selected>Cada mes</option>
              <option value="biweekly">Quincenal</option>
              <option value="every_two_months">Cada dos meses</option>
              <option value="semiannual">Cada semestre</option>
              <option value="annual">Cada año</option>
            </select>
            <p data-recurring-note>
              Para donar recurrentemente necesitas una cuenta en Maná. Desde el portal podrás pausar,
              reactivar, cancelar o actualizar tu método de pago.
            </p>
          </div>

          <details class="donation-optional">
            <summary>Destino y nota</summary>
            <div class="donation-grid">
              <div class="donation-field">
                <label for="church">Iglesia o comunidad</label>
                <input id="church" type="text" name="church" placeholder="Ministerio Maná Virtual" />
              </div>
              <div class="donation-field">
                <label for="project-name">Destino / proyecto</label>
                <input
                  id="project-name"
                  type="text"
                  name="projectName"
                  required
                  value={selectedDonationProject}
                  placeholder="Ministerio Maná"
                  data-project-name
                />
              </div>
            </div>

            <div class="donation-field donation-field--full">
              <label for="description">Nota o propósito</label>
              <input id="description" type="text" name="description" placeholder="Ej. Misiones, Campus, ofrenda familiar..." />
            </div>
          </details>

          <div class="donation-actions donation-actions--single">
            <button type="button" class="donation-next" data-step-next>Continuar</button>
          </div>
        </div>

        <div class="donation-step" data-donation-step="2" hidden>
          <div class="donation-section-label">
            <span>02</span>
            <strong>Tus datos</strong>
          </div>

          <div class="donation-grid">
            <div class="donation-field">
              <label for="full-name">Nombre completo</label>
              <input id="full-name" type="text" name="fullName" required placeholder="Nombre y apellido" autocomplete="name" />
            </div>
            <div class="donation-field">
              <label for="email">Correo</label>
              <input id="email" type="email" name="email" required placeholder="tucorreo@email.com" autocomplete="email" />
            </div>
          </div>

          <div class="donation-grid">
            <div class="donation-field">
              <label for="phone">Teléfono / WhatsApp</label>
              <input id="phone" type="tel" name="phone" required placeholder={isWompi ? '3000000000' : '+1 555 000 0000'} autocomplete="tel" />
            </div>
            <div class="donation-field">
              <label for="city">Ciudad</label>
              <input id="city" type="text" name="city" required placeholder="Ciudad" autocomplete="address-level2" />
            </div>
          </div>

          {isWompi ? (
            <div class="donation-panel">
              <div class="donation-panel__heading">
                <strong>Información requerida en Colombia</strong>
                <span>DIAN y conciliación</span>
              </div>
              <div class="donation-grid">
                <div class="donation-field">
                  <label for="person-type">Tipo de persona</label>
                  <select id="person-type" name="personType" required>
                    <option value="natural" selected>Persona natural</option>
                    <option value="juridica">Persona jurídica</option>
                  </select>
                </div>
                <div class="donation-field">
                  <label for="document-type">Tipo de identificación</label>
                  <select id="document-type" name="documentType" required>
                    <option value="" disabled selected>Selecciona</option>
                    <option value="CC">Cédula de ciudadanía</option>
                    <option value="CE">Cédula de extranjería</option>
                    <option value="NIT">NIT</option>
                    <option value="TI">Tarjeta de identidad</option>
                    <option value="PAS">Pasaporte</option>
                  </select>
                </div>
              </div>
              <div class="donation-field donation-field--full">
                <label for="document-number">Número de identificación</label>
                <input id="document-number" type="text" name="documentNumber" required placeholder="Documento o NIT" autocomplete="off" />
              </div>
              <p>
                Estos datos nos permiten registrar la donación, conciliar Wompi y preparar soportes
                contables o tributarios solicitados en Colombia. Los tratamos según nuestra política de privacidad.
              </p>
            </div>
          ) : (
            <div class="donation-grid">
              <div class="donation-field">
                <label for="document-type">Identificación (opcional)</label>
                <select id="document-type" name="documentType">
                  <option value="" selected>Selecciona</option>
                  <option value="PAS">Pasaporte</option>
                  <option value="NID">ID nacional</option>
                  <option value="DL">Licencia de conducir</option>
                  <option value="OTRO">Otro</option>
                </select>
              </div>
              <div class="donation-field">
                <label for="document-number">Número (opcional)</label>
                <input id="document-number" type="text" name="documentNumber" placeholder="Documento" autocomplete="off" />
              </div>
            </div>
          )}

          <div class="donation-terms">
            <label>
              <input type="checkbox" name="needCertificate" value="true" />
              <span>Necesito que esta donación quede marcada para certificado o soporte tributario.</span>
            </label>
            <p>
              Al donar aceptas los <a href="/donaciones/terminos-suscripciones">términos de donaciones y suscripciones</a>
              y la <a href="/privacidad">política de privacidad</a>.
            </p>
          </div>

          <input type="hidden" name="currency" value={gateway.currency} />
          <input type="hidden" name="source" value={gateway.source} />
          <input type="hidden" name="country" value={isWompi ? 'CO' : countryCode} />
          <input type="hidden" name="campus" value="" />
          <input type="hidden" name="eventName" value="Donaciones Maná" />

          <TurnstileWidget appearance="always" theme="auto" />

          <div class="donation-actions">
            <button type="button" class="donation-back" data-step-back>Volver</button>
            <button type="submit" class="donation-submit">
              <span>{gateway.button}</span>
              <SowingIcon class="h-5 w-5" />
            </button>
          </div>
          <p class="donation-secure">{gateway.secure}</p>
          <p class="donation-status" data-donation-status aria-live="polite"></p>
        </div>
      </form>
    </div>
  </div>

  <div class="donation-context">
    <div class="container-tight donation-context__grid">
      <article>
        <span>Una sola vez</span>
        <p>Elige un valor, completa tus datos y confirma la donación.</p>
      </article>
      <article>
        <span>Recurrentes</span>
        <p>Las donaciones periódicas se administran desde una cuenta Maná.</p>
      </article>
      <article>
        <span>Soporte</span>
        <p>{isWompi ? 'En Colombia pedimos identificación para soportes contables y tributarios.' : 'Registramos la confirmación de pago para soporte administrativo.'}</p>
      </article>
    </div>
  </div>
</section>

<style is:inline>
  @font-face {
    font-family: "Summer Loving";
    src: url("/fonts/SUMMER%20FONT/Summer%20Loving%20Regular.otf") format("opentype");
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  .donation-shell {
    background: #07111c;
    color: white;
  }

  .donation-stage {
    position: relative;
    min-height: 100svh;
    overflow: hidden;
    background: #07111c;
  }

  .donation-stage__image {
    position: absolute;
    inset: 0;
    height: 100%;
    width: 100%;
    object-fit: cover;
    object-position: center right;
  }

  .donation-stage__shade {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(100deg, rgba(7, 17, 28, 0.98) 0%, rgba(7, 17, 28, 0.9) 45%, rgba(7, 17, 28, 0.46) 100%),
      linear-gradient(180deg, rgba(7, 17, 28, 0.08) 0%, rgba(7, 17, 28, 0.92) 100%);
  }

  .donation-stage__texture {
    position: absolute;
    inset: 0;
    opacity: 0.22;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.08) 1px, transparent 1px);
    background-size: 96px 96px;
    mask-image: linear-gradient(90deg, black 0%, transparent 82%);
  }

  .donation-frame {
    position: absolute;
    inset: 2rem;
    z-index: 1;
    pointer-events: none;
  }

  .donation-frame span:nth-child(1) {
    position: absolute;
    left: 0;
    top: 0;
    height: 84px;
    width: 84px;
    border-left: 2px solid rgba(242, 201, 76, 0.85);
    border-top: 2px solid rgba(242, 201, 76, 0.85);
  }

  .donation-frame span:nth-child(2) {
    position: absolute;
    right: 0;
    top: 0;
    width: 28%;
    border-top: 1px solid rgba(255, 255, 255, 0.32);
  }

  .donation-frame span:nth-child(3) {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 42%;
    border-bottom: 1px solid rgba(40, 166, 189, 0.74);
  }

  .donation-stage__inner {
    position: relative;
    z-index: 2;
    display: grid;
    min-height: 100svh;
    grid-template-columns: minmax(0, 0.9fr) minmax(420px, 0.82fr);
    gap: 3rem;
    align-items: start;
    padding-top: 6.5rem;
    padding-bottom: 5rem;
  }

  .donation-story {
    position: sticky;
    top: 6.5rem;
    max-width: 760px;
    padding-top: 2rem;
  }

  .donation-logo {
    height: 4rem;
    width: auto;
    margin-bottom: 2.25rem;
  }

  .donation-script {
    margin: 0 0 -0.35rem;
    color: rgb(var(--mana-gold));
    font-family: "Summer Loving", cursive;
    font-size: 4.8rem;
    font-weight: 400;
    line-height: 0.74;
    transform: rotate(-2deg);
  }

  .donation-title {
    display: grid;
    gap: 0.15rem;
    margin: 0;
    max-width: 760px;
    color: white;
    font-size: 5.25rem;
    font-weight: 950;
    line-height: 0.88;
    text-transform: uppercase;
  }

  .donation-title span:first-child {
    color: transparent;
    -webkit-text-stroke: 1px rgba(255, 255, 255, 0.82);
    text-stroke: 1px rgba(255, 255, 255, 0.82);
  }

  .donation-lead {
    max-width: 620px;
    margin: 1.5rem 0 0;
    color: rgba(255, 255, 255, 0.84);
    font-size: 1.1rem;
    line-height: 1.65;
  }

  .donation-form__route span,
  .donation-context span,
  .donation-section-label span,
  .donation-panel__heading span {
    display: block;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .donation-note {
    max-width: 620px;
    margin: 1.6rem 0 0;
    border-left: 2px solid rgb(var(--mana-teal));
    padding-left: 1rem;
    color: rgba(255, 255, 255, 0.74);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .donation-form {
    align-self: center;
    scroll-margin-top: 5.75rem;
    border: 1px solid rgba(242, 201, 76, 0.34);
    border-radius: 8px;
    background: rgba(248, 245, 235, 0.96);
    color: rgb(var(--mana-navy));
    padding: 1.35rem;
    box-shadow: 0 28px 80px rgba(0, 0, 0, 0.34);
    backdrop-filter: blur(18px);
  }

  .donation-form__header {
    margin-bottom: 1.2rem;
    border-bottom: 1px solid rgba(var(--mana-navy), 0.12);
    padding-bottom: 1rem;
  }

  .donation-form__route {
    display: flex;
    align-items: center;
    margin-bottom: 0.75rem;
    color: rgb(var(--mana-teal));
  }

  .donation-gateway-switch {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.55rem;
    margin-bottom: 1rem;
  }

  .donation-gateway-switch a {
    display: inline-flex;
    min-height: 2.75rem;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(var(--mana-navy), 0.16);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.68);
    color: rgba(var(--mana-navy), 0.72);
    font-size: 0.76rem;
    font-weight: 900;
    letter-spacing: 0.04em;
    text-decoration: none;
    text-transform: uppercase;
    transition: background 0.18s ease, color 0.18s ease, border-color 0.18s ease;
  }

  .donation-gateway-switch a:hover,
  .donation-gateway-switch a:focus-visible,
  .donation-gateway-switch a.is-active {
    border-color: rgb(var(--mana-teal));
    background: rgb(var(--mana-navy));
    color: white;
  }

  .donation-progress {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin: 0 0 1rem;
    border-bottom: 1px solid rgba(var(--mana-navy), 0.1);
    padding: 0 0 0.9rem;
    color: rgb(var(--mana-navy));
  }

  .donation-progress span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: rgba(var(--mana-teal), 0.12);
    color: rgb(var(--mana-navy));
    font-size: 0.74rem;
    font-weight: 900;
    padding: 0.35rem 0.65rem;
  }

  .donation-progress strong {
    font-size: 0.9rem;
  }

  .donation-progress small {
    margin-left: auto;
    color: rgba(var(--mana-navy), 0.56);
    font-size: 0.78rem;
  }

  .donation-form__header h2 {
    margin: 0;
    color: rgb(var(--mana-navy));
    font-size: 2.1rem;
    line-height: 1.02;
  }

  .donation-form__header p {
    margin: 0.55rem 0 0;
    color: rgba(var(--mana-navy), 0.68);
    font-size: 0.92rem;
    line-height: 1.5;
  }

  .donation-rate {
    color: rgba(var(--mana-navy), 0.58);
    font-size: 0.78rem;
  }

  .donation-step[hidden] {
    display: none;
  }

  .donation-section-label {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin: 1.1rem 0 0.85rem;
    color: rgb(var(--mana-navy));
  }

  .donation-section-label span {
    display: inline-flex;
    height: 1.65rem;
    min-width: 1.65rem;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: rgb(var(--mana-gold));
    color: #07111c;
    font-size: 0.72rem;
  }

  .donation-section-label strong {
    font-size: 0.92rem;
  }

  .donation-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.85rem;
  }

  .donation-field {
    margin-bottom: 0.85rem;
  }

  .donation-field--full {
    grid-column: 1 / -1;
  }

  .donation-field label,
  .donation-recurrence legend {
    display: block;
    margin-bottom: 0.4rem;
    color: rgb(var(--mana-navy));
    font-size: 0.8rem;
    font-weight: 850;
  }

  .donation-field input,
  .donation-field select {
    width: 100%;
    border: 1px solid rgba(var(--mana-navy), 0.15);
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.9);
    color: rgb(var(--mana-navy));
    font-size: 0.95rem;
    padding: 0.82rem 0.88rem;
    outline: none;
    transition: border-color 160ms ease, box-shadow 160ms ease, background 160ms ease;
  }

  .donation-field input:focus,
  .donation-field select:focus {
    border-color: rgb(var(--mana-teal));
    background: white;
    box-shadow: 0 0 0 3px rgba(var(--mana-teal), 0.16);
  }

  .donation-presets {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.45rem;
    margin-top: 0.45rem;
  }

  .donation-quick-label {
    margin: 0.65rem 0 0;
