    }
  }

  @media (max-width: 760px) {
    .donation-stage__image {
      object-position: center;
    }

    .donation-stage__shade {
      background:
        linear-gradient(180deg, rgba(7, 17, 28, 0.96) 0%, rgba(7, 17, 28, 0.82) 54%, rgba(7, 17, 28, 0.96) 100%),
        linear-gradient(90deg, rgba(7, 17, 28, 0.5), rgba(7, 17, 28, 0.36));
    }

    .donation-frame {
      inset: 1rem;
    }

    .donation-stage__inner {
      padding-top: 5rem;
      padding-bottom: 3rem;
    }

    .donation-logo {
      height: 3.1rem;
      margin-bottom: 1.5rem;
    }

    .donation-script {
      font-size: 3.8rem;
    }

    .donation-title {
      font-size: 3.05rem;
      line-height: 0.92;
    }

    .donation-lead {
      font-size: 1rem;
    }

    .donation-context__grid {
      grid-template-columns: 1fr;
    }

    .donation-story {
      position: static;
      padding-right: 0;
    }

    .donation-form {
      padding: 1rem;
    }

    .donation-form__header h2 {
      font-size: 1.7rem;
    }

    .donation-progress {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.35rem;
    }

    .donation-progress small {
      margin-left: 0;
    }

    .donation-presets {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .donation-grid,
    .donation-recurrence {
      grid-template-columns: 1fr;
    }

    .donation-panel__heading {
      display: grid;
      gap: 0.25rem;
    }

    .donation-actions {
      flex-direction: column;
    }

    .donation-back,
    .donation-actions .donation-submit {
      width: 100%;
    }
  }
</style>

<script nonce={cspNonce}>
  const donationForms = document.querySelectorAll('[data-donation-form]');
  const DEFAULT_CHURCH = 'Ministerio Maná Virtual';

  function getSupabaseAccessToken() {
    try {
      const key = Object.keys(localStorage).find((k) => k.startsWith('sb-') && k.endsWith('-auth-token'));
      if (!key) return null;
      const raw = localStorage.getItem(key);
      if (!raw) return null;
      const session = JSON.parse(raw);
      return session?.access_token || null;
    } catch (err) {
      return null;
    }
  }

  function setValueIfEmpty(el, value) {
    if (!el || !value) return;
    if (el.value) return;
    el.value = value;
  }

  function ensureVirtualChurch(form) {
    const churchInput = form?.querySelector('input[name="church"]');
    const campusInput = form?.querySelector('input[name="campus"]');
    const hasCampus = campusInput?.value?.trim();
    if (churchInput && !churchInput.value.trim() && !hasCampus) {
      churchInput.value = DEFAULT_CHURCH;
    }
  }

  function syncFrequency(form) {
    const recurring = form.querySelector('input[name="isRecurring"][value="true"]')?.checked;
    const wrap = form.querySelector('[data-frequency-wrap]');
    const frequency = form.querySelector('select[name="frequency"]');
    if (!wrap || !frequency) return;
    wrap.hidden = !recurring;
    frequency.disabled = !recurring;
  }

  function buildRecurringLoginUrl(form) {
    const nextUrl = new URL(window.location.href);
    const donationType = form.querySelector('select[name="donationType"]')?.value || '';
    const amount = form.querySelector('input[name="amount"]')?.value || '';
    const frequency = form.querySelector('select[name="frequency"]')?.value || '';
    nextUrl.searchParams.set('recurring', '1');
    if (donationType) nextUrl.searchParams.set('type', donationType);
    if (amount) nextUrl.searchParams.set('amount', amount);
    if (frequency) nextUrl.searchParams.set('frequency', frequency);

    const loginUrl = new URL(form.dataset.loginUrl || '/portal/ingresar', window.location.origin);
    loginUrl.searchParams.set('next', `${nextUrl.pathname}${nextUrl.search}${nextUrl.hash}`);
    loginUrl.searchParams.set('reason', 'recurring-donation');
    return `${loginUrl.pathname}${loginUrl.search}`;
  }

  function applyDonationIntentFromUrl(form) {
    const params = new URLSearchParams(window.location.search);
    const recurring = params.get('recurring');
    if (recurring === '1' || recurring === 'true') {
      const recurringRadio = form.querySelector('input[name="isRecurring"][value="true"]');
      if (recurringRadio) recurringRadio.checked = true;
    }

    const requestedType = params.get('type');
    if (requestedType && ['diezmos', 'ofrendas', 'misiones'].includes(requestedType)) {
      const typeSelect = form.querySelector('select[name="donationType"]');
      if (typeSelect) typeSelect.value = requestedType;
    }

    const requestedAmount = params.get('amount');
    if (requestedAmount && Number(requestedAmount) > 0) {
      const amountInput = form.querySelector('input[name="amount"]');
      if (amountInput) amountInput.value = requestedAmount;
    }

    const requestedFrequency = params.get('frequency');
    if (requestedFrequency && ['biweekly', 'monthly', 'every_two_months', 'semiannual', 'annual'].includes(requestedFrequency)) {
      const frequencySelect = form.querySelector('select[name="frequency"]');
      if (frequencySelect) frequencySelect.value = requestedFrequency;
    }
  }

  function resolveValue(form, selector, fallback) {
    const el = form?.querySelector(selector);
    const value = el?.value?.trim();
    return value || fallback || '';
  }

  function saveProfileFromDonation(form, profile) {
    if (!form || !profile) return;
    ensureVirtualChurch(form);
    const token = getSupabaseAccessToken();
    if (!token) return;

    const payload = {
      fullName: resolveValue(form, 'input[name="fullName"]', profile.full_name),
      phone: resolveValue(form, 'input[name="phone"]', profile.phone),
      city: resolveValue(form, 'input[name="city"]', profile.city),
      country: resolveValue(form, 'input[name="country"]', profile.country),
      documentType: resolveValue(form, 'select[name="documentType"]', profile.document_type),
      documentNumber: resolveValue(form, 'input[name="documentNumber"]', profile.document_number),
      churchName: resolveValue(form, 'input[name="church"]', profile.church_name),
      affiliationType: profile.affiliation_type || '',
      churchId: profile.church_id || null,
    };

    try {
      fetch('/api/portal/profile', {
        method: 'POST',
        headers: {
          'content-type': 'application/json',
          Authorization: `Bearer ${token}`,
        },
        body: JSON.stringify(payload),
        keepalive: true,
        credentials: 'include',
      }).catch(() => {});
    } catch (err) {
      // Non-blocking profile update.
    }
  }

  function fillDonationForm(form, profile) {
    if (!form || !profile) return;
    setValueIfEmpty(form.querySelector('input[name="fullName"]'), profile.full_name);
    setValueIfEmpty(form.querySelector('input[name="email"]'), profile.email);
    setValueIfEmpty(form.querySelector('input[name="phone"]'), profile.phone);
    setValueIfEmpty(form.querySelector('input[name="city"]'), profile.city);
    setValueIfEmpty(form.querySelector('input[name="church"]'), profile.church_name);

    const docType = form.querySelector('select[name="documentType"]');
    if (docType && !docType.value && profile.document_type) {
      docType.value = profile.document_type;
    }
    setValueIfEmpty(form.querySelector('input[name="documentNumber"]'), profile.document_number);

    const countryInput = form.querySelector('input[name="country"]');
    if (countryInput && !countryInput.value && profile.country) {
      countryInput.value = profile.country;
    }
  }

  async function prefillFromPortalProfile() {
    const token = getSupabaseAccessToken();
    if (!token) return null;
    try {
      const res = await fetch('/api/portal/session', {
        headers: { Authorization: `Bearer ${token}` },
        credentials: 'include',
      });
      const payload = await res.json().catch(() => null);
      if (!res.ok || !payload?.ok) return null;
      const profile = payload.profile || {};
      donationForms.forEach((form) => fillDonationForm(form, profile));
      return profile;
    } catch (err) {
      console.warn('[donaciones] No se pudo precargar perfil');
      return null;
    }
  }

  function getStepControls(panel) {
    return Array.from(panel?.querySelectorAll('input, select, textarea') || []).filter((control) => {
      if (control.disabled) return false;
      if (control.type === 'hidden') return false;
      return true;
    });
  }

  function validateDonationPanel(panel) {
    const controls = getStepControls(panel);
    for (const control of controls) {
      if (typeof control.checkValidity !== 'function') continue;
      if (control.checkValidity()) continue;
      const details = control.closest('details');
      if (details) details.open = true;
      control.reportValidity?.();
      return false;
    }
    return true;
  }

  function setDonationStep(form, step, shouldFocus = true) {
    const targetStep = String(step);
    form.querySelectorAll('[data-donation-step]').forEach((panel) => {
      const isActive = panel.getAttribute('data-donation-step') === targetStep;
      panel.hidden = !isActive;
      panel.classList.toggle('is-active', isActive);
    });

    const progressCount = form.querySelector('[data-progress-count]');
    const progressTitle = form.querySelector('[data-progress-title]');
    const progressNext = form.querySelector('[data-progress-next]');
    if (progressCount) progressCount.textContent = `Paso ${targetStep} de 2`;
    if (progressTitle) progressTitle.textContent = targetStep === '1' ? 'Tu donación' : 'Tus datos';
    if (progressNext) progressNext.textContent = targetStep === '1' ? 'Luego: tus datos' : 'Último paso';
    form.dataset.currentStep = targetStep;

    if (!shouldFocus) return;
    form.scrollIntoView?.({ behavior: 'smooth', block: 'start' });
    requestAnimationFrame(() => {
      const activePanel = form.querySelector(`[data-donation-step="${targetStep}"]`);
      const focusTarget = activePanel?.querySelector('input:not([type="hidden"]), select, button, textarea');
      focusTarget?.focus?.({ preventScroll: true });
    });
  }

  function syncDonationProject(form) {
    const donationType = form.querySelector('select[name="donationType"]')?.value || '';
    const projectInput = form.querySelector('[data-project-name]');
    if (!projectInput) return;
    const current = projectInput.value?.trim() || '';
    const automaticValues = ['Ministerio Maná', 'Diezmos', 'Ofrenda', 'Misiones'];
    if (current && !automaticValues.includes(current)) return;

    const projectByType = {
      diezmos: 'Diezmos',
      ofrendas: 'Ofrenda',
      misiones: 'Misiones',
    };
    projectInput.value = projectByType[donationType] || 'Ministerio Maná';
  }

  let portalProfileCache = null;
  prefillFromPortalProfile().then((profile) => {
    portalProfileCache = profile;
  });

  donationForms.forEach((form) => {
    applyDonationIntentFromUrl(form);
    ensureVirtualChurch(form);
    syncFrequency(form);
    syncDonationProject(form);
    setDonationStep(form, 1, false);

    form.querySelector('[data-step-next]')?.addEventListener('click', () => {
      const firstStep = form.querySelector('[data-donation-step="1"]');
      if (!validateDonationPanel(firstStep)) return;
      setDonationStep(form, 2);
    });

    form.querySelector('[data-step-back]')?.addEventListener('click', () => {
      setDonationStep(form, 1);
    });

    form.querySelectorAll('[data-recurrence-radio]').forEach((radio) => {
      radio.addEventListener('change', () => syncFrequency(form));
    });

    form.querySelector('select[name="donationType"]')?.addEventListener('change', () => {
      syncDonationProject(form);
    });

    form.querySelectorAll('[data-amount-preset]').forEach((button) => {
      button.addEventListener('click', () => {
        const amountInput = form.querySelector('input[name="amount"]');
        if (amountInput) {
          amountInput.value = button.getAttribute('data-amount-preset') || '';
          amountInput.focus();
        }
      });
    });

    form.querySelectorAll('.donation-gateway-switch a').forEach((link) => {
      link.addEventListener('click', () => {
        const url = new URL(link.href);
        const donationType = form.querySelector('select[name="donationType"]')?.value || '';
        const amount = form.querySelector('input[name="amount"]')?.value || '';
        const recurring = form.querySelector('input[name="isRecurring"][value="true"]')?.checked;
        const frequency = form.querySelector('select[name="frequency"]')?.value || '';
        if (donationType) url.searchParams.set('type', donationType);
        else url.searchParams.delete('type');
        if (amount) url.searchParams.set('amount', amount);
        else url.searchParams.delete('amount');
        if (recurring) url.searchParams.set('recurring', '1');
        else url.searchParams.delete('recurring');
        if (frequency) url.searchParams.set('frequency', frequency);
        else url.searchParams.delete('frequency');
        link.href = `${url.pathname}${url.search}${url.hash}`;
      });
    });

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      ensureVirtualChurch(form);

      const firstStep = form.querySelector('[data-donation-step="1"]');
      const secondStep = form.querySelector('[data-donation-step="2"]');
      if (firstStep && !validateDonationPanel(firstStep)) {
        setDonationStep(form, 1);
        return;
      }
      if (secondStep && !validateDonationPanel(secondStep)) {
        setDonationStep(form, 2);
        return;
      }

      const status = form.querySelector('[data-donation-status]');
      const submit = form.querySelector('button[type="submit"]');
      const formData = new FormData(form);
      const isRecurring = String(formData.get('isRecurring') || '').toLowerCase() === 'true';
      const token = getSupabaseAccessToken();

      if (isRecurring && !token) {
        window.location.href = buildRecurringLoginUrl(form);
        return;
      }

      if (status) {
        status.textContent = 'Preparando checkout seguro...';
        status.removeAttribute('data-tone');
      }
      if (submit) submit.disabled = true;

      try {
        const headers = new Headers({ Accept: 'application/json' });
        if (token) headers.set('Authorization', `Bearer ${token}`);
        const res = await fetch(form.action, {
          method: 'POST',
          headers,
          body: formData,
          credentials: 'include',
        });
        const payload = await res.json().catch(() => null);
        if (!res.ok || !payload?.ok) {
          if (payload?.requiresAccount && payload?.redirect) {
            window.location.href = payload.redirect;
            return;
          }
          throw new Error(payload?.error || 'No se pudo iniciar el pago');
        }
        saveProfileFromDonation(form, portalProfileCache);
        if (payload.url) {
          window.location.href = payload.url;
          return;
        }
        throw new Error('La pasarela no devolvió una URL de checkout.');
      } catch (err) {
        if (status) {
          status.textContent = err?.message || 'No se pudo iniciar el pago.';
          status.setAttribute('data-tone', 'error');
        }
      } finally {
        if (submit) submit.disabled = false;
      }
    });
  });
</script>
