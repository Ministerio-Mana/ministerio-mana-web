    border-radius: 8px;
    background: linear-gradient(135deg, rgb(var(--mana-teal)), rgb(var(--mana-navy)));
    color: white;
    cursor: pointer;
    font-weight: 800;
    padding: 0.95rem 1.2rem;
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.24);
