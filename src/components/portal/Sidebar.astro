---
import PortalIcon from './PortalIcon.astro';
---
<aside class="portal-sidebar z-20 w-full border-r border-[#20315f] bg-[#293C74] text-white lg:w-64">
<div class="flex h-full flex-col p-4 sm:p-6 lg:sticky lg:top-0 lg:h-screen">
    
    <!-- Mobile Header -->
    <div class="mb-4 flex items-center justify-between px-2 lg:mb-8">
        <div class="flex items-center gap-4">
            <img src="/images/cumbre/logo-ministerio-mana-blanco.svg" alt="Ministerio Maná" class="h-10 lg:h-12 w-auto">
            <div class="border-l border-white/20 pl-4">
                <p class="mb-2 text-[10px] font-bold uppercase text-white/70">Portal Maná</p>
                <h2 class="text-xs font-display font-bold text-white">Panel General</h2>
            </div>
        </div>
        <!-- Mobile Toggle Button -->
        <button id="sidebar-toggle" type="button" aria-label="Abrir navegación" aria-controls="sidebar-content" aria-expanded="false" class="flex h-11 w-11 items-center justify-center rounded-md text-white/80 hover:bg-white/10 hover:text-white lg:hidden">
            <PortalIcon name="menu" size={24} />
        </button>
    </div>

    <!-- Collapsible Content -->
    <div id="sidebar-content" class="hidden h-full flex-col space-y-2 lg:flex">
        <nav aria-label="Navegación del portal" class="max-h-[calc(100vh-11rem)] space-y-2 overflow-y-auto pr-2">
        <a href="/portal" class="nav-link group flex min-h-11 w-full items-center gap-4 rounded-md px-4 py-2 transition-colors hover:bg-white/10" data-tab="resumen">
            <PortalIcon name="layout-dashboard" class="text-white/70 transition-colors group-hover:text-white" />
            <span class="text-sm font-medium text-white/90 group-hover:text-white transition-colors">Resumen</span>
        </a>
        <a href="/portal?tab=reservas" class="nav-link group flex min-h-11 w-full items-center gap-4 rounded-md px-4 py-2 transition-colors hover:bg-white/10" data-tab="reservas">
            <PortalIcon name="calendar-check" class="text-white/70 transition-colors group-hover:text-white" />
            <span class="text-sm font-medium text-white/90 group-hover:text-white transition-colors">Mis Eventos</span>
        </a>
        <a href="/portal?tab=pagos" class="nav-link group flex min-h-11 w-full items-center gap-4 rounded-md px-4 py-2 transition-colors hover:bg-white/10" data-tab="pagos">
            <PortalIcon name="receipt-text" class="text-white/70 transition-colors group-hover:text-white" />
            <span class="text-sm font-medium text-white/90 group-hover:text-white transition-colors">Mis Aportes</span>
        </a>
        <a href="/portal?tab=perfil" class="nav-link group flex min-h-11 w-full items-center gap-4 rounded-md px-4 py-2 transition-colors hover:bg-white/10" data-tab="perfil">
            <PortalIcon name="circle-user-round" class="text-white/70 transition-colors group-hover:text-white" />
            <span class="text-sm font-medium text-white/90 group-hover:text-white transition-colors">Mi Perfil</span>
        </a>
        <!-- Eventos (Visible for ALL users - Cumbre registration) -->
        <a href="/portal?tab=iglesia" class="nav-link group flex min-h-11 w-full items-center gap-4 rounded-md px-4 py-2 transition-colors hover:bg-white/10" data-tab="iglesia">
            <PortalIcon name="calendar-days" class="text-white/70 transition-colors group-hover:text-white" />
            <span id="nav-iglesia-label" class="text-sm font-medium text-white/90 group-hover:text-white transition-colors">Eventos</span>
        </a>
        <!-- Gestión de Eventos (Restricted - Pastors/Admins) -->
        <a href="/portal/events" id="nav-link-events" class="nav-link group hidden min-h-11 w-full items-center gap-4 rounded-md px-4 py-2 transition-colors hover:bg-white/10">
            <PortalIcon name="calendar-cog" class="text-white/70 transition-colors group-hover:text-white" />
            <span class="text-sm font-medium text-white/90 group-hover:text-white transition-colors">Gestión de Eventos</span>
        </a>
        <a href="/portal/church-page" id="nav-link-church-page" class="nav-link group hidden min-h-11 w-full items-center gap-4 rounded-md px-4 py-2 transition-colors hover:bg-white/10">
            <PortalIcon name="file-pen-line" class="text-white/70 transition-colors group-hover:text-white" />
            <span class="text-sm font-medium text-white/90 group-hover:text-white transition-colors">Página de mi iglesia</span>
        </a>
        <!-- Usuarios (Restricted - Pastors/Admins) -->
        <a href="/portal/users" id="nav-link-users" class="nav-link group hidden min-h-11 w-full items-center gap-4 rounded-md px-4 py-2 transition-colors hover:bg-white/10">
            <PortalIcon name="users" class="text-white/70 transition-colors group-hover:text-white" />
            <span class="text-sm font-medium text-white/90 group-hover:text-white transition-colors">Usuarios</span>
        </a>
        <a href="/portal/regions" id="nav-link-regions" class="nav-link group hidden min-h-11 w-full items-center gap-4 rounded-md px-4 py-2 transition-colors hover:bg-white/10">
            <PortalIcon name="map-pinned" class="text-white/70 transition-colors group-hover:text-white" />
            <span class="text-sm font-medium text-white/90 group-hover:text-white transition-colors">Regiones</span>
        </a>
        <!-- Campus Link (Campus Missionaries + Admins) -->
        <a href="/portal/campus" id="nav-link-campus" class="nav-link group hidden min-h-11 w-full items-center gap-4 rounded-md px-4 py-2 transition-colors hover:bg-white/10">
            <PortalIcon name="heart-handshake" class="text-white/70 transition-colors group-hover:text-white" />
            <span class="text-sm font-medium text-white/90 group-hover:text-white transition-colors">Campus</span>
        </a>
        <!-- Donaciones Link (Admins) -->
        <a href="/portal/donations" id="nav-link-donations" class="nav-link group hidden min-h-11 w-full items-center gap-4 rounded-md px-4 py-2 transition-colors hover:bg-white/10">
            <PortalIcon name="hand-coins" class="text-white/70 transition-colors group-hover:text-white" />
            <span class="text-sm font-medium text-white/90 group-hover:text-white transition-colors">Donaciones</span>
        </a>
        <a href="/portal/peticiones" id="nav-link-prayers" class="nav-link group hidden min-h-11 w-full items-center gap-4 rounded-md px-4 py-2 transition-colors hover:bg-white/10">
            <PortalIcon name="messages-square" class="text-white/70 transition-colors group-hover:text-white" />
            <span class="text-sm font-medium text-white/90 group-hover:text-white transition-colors">Peticiones</span>
        </a>
        <!-- Finances Link (Admins/Pastors) -->
        <a href="/portal/finances" id="nav-link-finances" class="nav-link group hidden min-h-11 w-full items-center gap-4 rounded-md px-4 py-2 transition-colors hover:bg-white/10">
            <PortalIcon name="wallet-cards" class="text-white/70 transition-colors group-hover:text-white" />
            <span class="text-sm font-medium text-white/90 group-hover:text-white transition-colors">Finanzas</span>
        </a>
        <a href="/portal/content" id="nav-link-content" class="nav-link group hidden min-h-11 w-full items-center gap-4 rounded-md px-4 py-2 transition-colors hover:bg-white/10">
            <PortalIcon name="file-pen-line" class="text-white/70 transition-colors group-hover:text-white" />
            <span class="text-sm font-medium text-white/90 group-hover:text-white transition-colors">Contenido</span>
        </a>
        <a href="/portal/integrations" id="nav-link-integrations" class="nav-link group hidden min-h-11 w-full items-center gap-4 rounded-md px-4 py-2 transition-colors hover:bg-white/10">
            <PortalIcon name="settings-2" class="text-white/70 transition-colors group-hover:text-white" />
            <span class="text-sm font-medium text-white/90 group-hover:text-white transition-colors">Integraciones</span>
        </a>
        </nav>

        <div class="mt-auto pt-6">
        <button id="btn-logout" type="button" class="flex min-h-11 w-full items-center justify-center gap-2 rounded-md border border-white/20 px-4 py-2 text-sm font-bold text-white/80 transition-colors hover:bg-white/10 hover:text-white">
            <PortalIcon name="log-out" size={18} />
            Cerrar sesión
        </button>
        </div>
    </div>
</div>
</aside>

<script>
    import { getPortalSession, signOutPortalSession } from '@lib/portalAuthClient';

    const toggleBtn = document.getElementById('sidebar-toggle');
    const content = document.getElementById('sidebar-content');
    const logoutBtn = document.getElementById('btn-logout');

    function setMobileMenuOpen(open) {
        content?.classList.toggle('hidden', !open);
        content?.classList.toggle('flex', open);
        toggleBtn?.setAttribute('aria-expanded', String(open));
        toggleBtn?.setAttribute('aria-label', open ? 'Cerrar navegación' : 'Abrir navegación');
    }

    toggleBtn?.addEventListener('click', () => {
        setMobileMenuOpen(content?.classList.contains('hidden'));
    });

    document.addEventListener('keydown', (event) => {
        if (event.key !== 'Escape' || toggleBtn?.getAttribute('aria-expanded') !== 'true') return;
        setMobileMenuOpen(false);
        toggleBtn?.focus();
    });

    content?.querySelectorAll('a.nav-link').forEach((link) => {
        link.addEventListener('click', () => setMobileMenuOpen(false));
    });

    function applyActiveLink() {
        const currentUrl = new URL(window.location.href);
        const currentTab = currentUrl.searchParams.get('tab') || 'resumen';

        content?.querySelectorAll('a.nav-link').forEach((link) => {
            const linkUrl = new URL(link.href, window.location.origin);
            const isPortalHomeLink = linkUrl.pathname === '/portal';
            const isActive = isPortalHomeLink
                ? currentUrl.pathname === '/portal' && link.dataset.tab === currentTab
                : linkUrl.pathname === '/portal/events'
                  ? currentUrl.pathname === '/portal/events' || currentUrl.pathname.startsWith('/portal/events/')
                  : linkUrl.pathname === currentUrl.pathname;
            link.classList.toggle('bg-white/15', isActive);
            link.classList.toggle('text-white', isActive);
            if (isActive) {
                link.setAttribute('aria-current', 'page');
            } else {
                link.removeAttribute('aria-current');
            }
        });
    }

    applyActiveLink();

    logoutBtn?.addEventListener('click', async () => {
        if (logoutBtn instanceof HTMLButtonElement) {
            logoutBtn.disabled = true;
            logoutBtn.textContent = 'Saliendo...';
        }
        await signOutPortalSession();
        window.location.replace('/portal/ingresar');
    });

    const restrictedLinks = [
        'nav-link-events',
        'nav-link-church-page',
        'nav-link-users',
        'nav-link-campus',
        'nav-link-donations',
        'nav-link-finances',
        'nav-link-regions',
        'nav-link-prayers',
        'nav-link-content',
        'nav-link-integrations',
    ];

    function setRestrictedLinkVisibility(id, visible) {
        const link = document.getElementById(id);
        if (!link) return;
        link.classList.toggle('hidden', !visible);
        link.classList.toggle('flex', visible);
        if (!visible) {
            link.style.display = 'none';
        } else {
            link.style.display = '';
        }
    }

    function resolveSidebarRole(profile, memberships = []) {
        const effectiveRole = String(profile?.effective_role || profile?.role || 'user');
        if (effectiveRole !== 'user') return effectiveRole;

        const membershipRoles = memberships.map((membership) => membership?.role).filter(Boolean);
        if (membershipRoles.includes('church_admin')) return 'pastor';
        if (membershipRoles.includes('church_member')) return 'local_collaborator';
        return effectiveRole;
    }

    function canShowRestrictedLink(id, role, permissions = {}) {
        if (id === 'nav-link-events') {
            return Boolean(
                permissions.can_manage_local_events
                || permissions.can_manage_regional_events
                || permissions.can_manage_national_events
                || permissions.can_manage_global_events
            );
        }
        if (id === 'nav-link-church-page') {
            return [
                'superadmin', 'admin',
                'national_pastor', 'national_collaborator',
                'regional_pastor', 'regional_collaborator',
                'pastor', 'local_collaborator',
            ].includes(role);
        }
        if (id === 'nav-link-users') return Boolean(permissions.can_manage_users);
        if (id === 'nav-link-campus') return Boolean(permissions.can_access_campus);
        if (id === 'nav-link-donations' || id === 'nav-link-finances') return Boolean(permissions.can_access_finances);
        if (id === 'nav-link-prayers') return Boolean(permissions.can_access_prayers);
        if (id === 'nav-link-regions' || id === 'nav-link-content') return ['superadmin', 'admin'].includes(role);
        if (id === 'nav-link-integrations') return role === 'superadmin';
        return false;
    }

    async function applySidebarPermissions() {
        restrictedLinks.forEach((id) => setRestrictedLinkVisibility(id, false));

        try {
            const { auth, data: payload } = await getPortalSession();
            if (!auth.isAuthenticated || !payload?.ok) return;
            const role = resolveSidebarRole(payload.profile || {}, payload.memberships || []);
            const permissions = payload.permissions || {};

            restrictedLinks.forEach((id) => {
                setRestrictedLinkVisibility(id, canShowRestrictedLink(id, role, permissions));
            });
        } catch {
            restrictedLinks.forEach((id) => setRestrictedLinkVisibility(id, false));
        }
    }

    applySidebarPermissions();
</script>
