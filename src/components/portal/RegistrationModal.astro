---
// Advanced Registration Modal Component
const installmentDeadline = (import.meta.env?.CUMBRE_INSTALLMENT_DEADLINE ?? '2026-05-15') as string;
---

<!-- Manual Registration Modal -->
<div id="manual-registration-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40 backdrop-blur-sm p-4">
  <div class="w-full max-w-6xl bg-white rounded-[2rem] shadow-2xl border border-slate-100 my-8 relative flex flex-col max-h-[90vh]">
    
    <!-- Modal Header -->
    <div class="p-6 md:p-8 border-b border-slate-100 flex items-start justify-between bg-white z-10 rounded-t-[2rem]">
      <div>
        <p id="manual-modal-subtitle" class="text-[10px] font-bold text-[#293C74] uppercase tracking-[0.3em]">Nueva Inscripción</p>
        <h2 id="manual-modal-title" class="text-2xl font-display font-bold text-[#293C74]">Registrar Participante</h2>
      </div>
      <button id="btn-close-manual-modal" class="p-2 hover:bg-slate-100 rounded-full transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
      </button>
    </div>

    <!-- Modal Body (Scrollable) -->
    <div id="modal-scroll-container" class="p-6 md:p-10 overflow-y-auto flex-1 bg-[#F8FAFC]">
      <form id="manual-registration-form" class="grid lg:grid-cols-[2fr_1fr] gap-8" data-installment-deadline={installmentDeadline}>
        
        <!-- Left Column: Form Fields -->
        <div class="space-y-8">
          
          <!-- Step 1: Responsable del Grupo -->
          <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
            <div class="mb-6">
              <h3 class="text-lg font-bold text-[#293C74] flex items-center gap-3">
                <span class="w-8 h-8 rounded-full bg-[#293C74] text-white flex items-center justify-center text-sm font-bold shadow-lg shadow-[#293C74]/20">1</span>
                Responsable
              </h3>
            </div>
            
            <div class="space-y-5">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                  <div class="space-y-2">
                    <label class="text-[11px] font-bold text-[#293C74] uppercase tracking-widest ml-1">Tipo Identificación</label>
                    <div class="relative">
                        <select id="reg-leader-doc-type" class="w-full bg-slate-50 border border-slate-200 rounded-2xl px-4 py-3.5 text-sm font-bold text-[#293C74] outline-none focus:border-[#293C74] focus:ring-1 focus:ring-[#293C74] appearance-none transition-all">
                          <option value="CC">Cédula (CC)</option>
                          <option value="TI">Tarjeta Identidad (TI)</option>
                          <option value="PAS">Pasaporte (PAS)</option>
                          <option value="CE">Cédula Extranjería (CE)</option>
                        </select>
                        <div class="absolute top-1/2 -translate-y-1/2 right-0 pr-4 flex items-center pointer-events-none text-[#293C74]">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                        </div>
                    </div>
                  </div>
                  <div class="space-y-2">
                    <label class="text-[11px] font-bold text-[#293C74] uppercase tracking-widest ml-1">Número Documento</label>
                    <input type="text" id="reg-leader-doc-number" class="w-full bg-slate-50 border border-slate-200 rounded-2xl px-5 py-3.5 text-sm font-bold text-[#293C74] outline-none focus:border-[#293C74] focus:ring-1 focus:ring-[#293C74] transition-all placeholder-slate-400" placeholder="Ej: 1000123456">
                  </div>
                </div>

                <div class="space-y-2">
                  <label class="text-[11px] font-bold text-[#293C74] uppercase tracking-widest ml-1">Nombre Completo</label>
                  <input type="text" id="reg-leader-name" class="w-full bg-slate-50 border border-slate-200 rounded-2xl px-5 py-3.5 text-sm font-bold text-[#293C74] outline-none focus:border-[#293C74] focus:ring-1 focus:ring-[#293C74] transition-all placeholder-slate-400" placeholder="Nombres y Apellidos">
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                  <div class="space-y-2">
                    <label class="text-[11px] font-bold text-[#293C74] uppercase tracking-widest ml-1">Email <span class="text-slate-400 font-normal normal-case tracking-normal">(Opcional)</span></label>
                    <input type="email" id="reg-leader-email" class="w-full bg-slate-50 border border-slate-200 rounded-2xl px-5 py-3.5 text-sm font-bold text-[#293C74] outline-none focus:border-[#293C74] focus:ring-1 focus:ring-[#293C74] transition-all placeholder-slate-400" placeholder="correo@ejemplo.com">
                  </div>
                  <div class="space-y-2">
                    <label class="text-[11px] font-bold text-[#293C74] uppercase tracking-widest ml-1">Celular / WhatsApp</label>
                    <input type="tel" id="reg-leader-phone" class="w-full bg-slate-50 border border-slate-200 rounded-2xl px-5 py-3.5 text-sm font-bold text-[#293C74] outline-none focus:border-[#293C74] focus:ring-1 focus:ring-[#293C74] transition-all placeholder-slate-400" placeholder="+57 300...">
                  </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
                  <div class="space-y-2">
                    <label class="text-[11px] font-bold text-[#293C74] uppercase tracking-widest ml-1">Edad</label>
                    <input type="number" id="reg-leader-age" min="0" max="120" class="w-full bg-slate-50 border border-slate-200 rounded-2xl px-5 py-3.5 text-sm font-bold text-[#293C74] outline-none focus:border-[#293C74] focus:ring-1 focus:ring-[#293C74] transition-all placeholder-slate-400" placeholder="00">
                  </div>
                  <div class="space-y-2">
                    <label class="text-[11px] font-bold text-[#293C74] uppercase tracking-widest ml-1">Alimentación</label>
                    <div class="relative">
                        <select id="reg-leader-menu" class="w-full bg-slate-50 border border-slate-200 rounded-2xl px-4 py-3.5 text-sm font-bold text-[#293C74] outline-none focus:border-[#293C74] focus:ring-1 focus:ring-[#293C74] appearance-none transition-all">
                          <option value="TRADICIONAL">Menú tradicional</option>
                          <option value="VEGETARIANO">Menú vegetariano</option>
                        </select>
                        <div class="absolute top-1/2 -translate-y-1/2 right-0 pr-4 flex items-center pointer-events-none text-[#293C74]">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                        </div>
                    </div>
                  </div>
                  <div class="space-y-2 md:col-span-1">
                    <label class="text-[11px] font-bold text-[#293C74] uppercase tracking-widest ml-1">Paquete</label>
                    <div class="relative">
                        <select id="reg-leader-package" class="w-full bg-slate-50 border border-slate-200 rounded-2xl px-4 py-3.5 text-sm font-bold text-[#293C74] outline-none focus:border-[#293C74] focus:ring-1 focus:ring-[#293C74] appearance-none transition-all">
                          <option value="lodging">Con Alojamiento</option>
                          <option value="no_lodging">Sin Alojamiento</option>
                        </select>
                        <div class="absolute top-1/2 -translate-y-1/2 right-0 pr-4 flex items-center pointer-events-none text-[#293C74]">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                        </div>
                    </div>
                  </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                  <div class="space-y-2">
                    <label class="text-[11px] font-bold text-[#293C74] uppercase tracking-widest ml-1">Fecha de nacimiento</label>
                    <input type="date" id="reg-leader-birthdate" class="w-full bg-slate-50 border border-slate-200 rounded-2xl px-5 py-3.5 text-sm font-bold text-[#293C74] outline-none focus:border-[#293C74] focus:ring-1 focus:ring-[#293C74] transition-all placeholder-slate-400">
                  </div>
                  <div class="space-y-2">
                    <label class="text-[11px] font-bold text-[#293C74] uppercase tracking-widest ml-1">Género</label>
                    <select id="reg-leader-gender" class="w-full bg-slate-50 border border-slate-200 rounded-2xl px-4 py-3.5 text-sm font-bold text-[#293C74] outline-none focus:border-[#293C74] focus:ring-1 focus:ring-[#293C74] transition-all">
                      <option value="">Selecciona</option>
                      <option value="F">Femenino</option>
                      <option value="M">Masculino</option>
                      <option value="O">Otro</option>
                    </select>
                  </div>
                </div>
            </div>
          </div>

          <!-- Step 2: Acompañantes -->
          <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
            <div class="flex items-center justify-between mb-6">
              <h3 class="text-lg font-bold text-[#293C74] flex items-center gap-3">
                <span class="w-8 h-8 rounded-full bg-[#293C74]/10 text-[#293C74] flex items-center justify-center text-sm font-bold">2</span>
                Acompañantes
              </h3>
              <button type="button" id="btn-add-companion" class="px-5 py-2.5 bg-brand-teal text-white rounded-xl text-xs font-bold hover:shadow-lg hover:shadow-brand-teal/20 transition-all flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" /></svg>
                Agregar
              </button>
            </div>

            <!-- Add Companion Form (Hidden by default) -->
            <div id="add-companion-form" class="hidden bg-slate-50 p-6 rounded-2xl border border-slate-200 space-y-5 mb-6 relative">
               <button type="button" id="btn-cancel-companion" class="absolute top-4 right-4 text-slate-400 hover:text-red-500 transition-colors">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
               </button>
               <h4 id="companion-form-title" class="text-xs font-bold text-[#293C74] uppercase tracking-widest mb-2">Nuevo Acompañante</h4>
              
              <!-- Document Info -->
              <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                <div class="space-y-2">
                  <label class="text-[11px] font-bold text-slate-500 uppercase ml-1">Documento</label>
                  <div class="flex gap-2">
                      <select id="companion-doc-type" class="w-24 bg-white border border-slate-200 rounded-xl px-2 py-3 text-sm font-bold text-[#293C74] outline-none focus:border-[#293C74]">
                        <option value="TI">TI</option>
                        <option value="RC">RC</option>
                        <option value="CC">CC</option>
                        <option value="CE">CE</option>
                        <option value="PAS">PAS</option>
                      </select>
                      <input type="text" id="companion-doc-number" class="flex-1 bg-white border border-slate-200 rounded-xl px-4 py-3 text-sm font-bold text-[#293C74] outline-none focus:border-[#293C74]" placeholder="Número">
                  </div>
                </div>
                <div class="space-y-2">
                  <label class="text-[11px] font-bold text-slate-500 uppercase ml-1">Edad</label>
                  <input type="number" id="companion-age" min="0" max="120" class="w-full bg-white border border-slate-200 rounded-xl px-4 py-3 text-sm font-bold text-[#293C74] outline-none focus:border-[#293C74]" placeholder="Años">
                </div>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                <div class="space-y-2">
                  <label class="text-[11px] font-bold text-slate-500 uppercase ml-1">Fecha de nacimiento</label>
                  <input type="date" id="companion-birthdate" class="w-full bg-white border border-slate-200 rounded-xl px-4 py-3 text-sm font-bold text-[#293C74] outline-none focus:border-[#293C74]" placeholder="AAAA-MM-DD">
                </div>
                <div class="space-y-2">
                  <label class="text-[11px] font-bold text-slate-500 uppercase ml-1">Género</label>
                  <select id="companion-gender" class="w-full bg-white border border-slate-200 rounded-xl px-3 py-3 text-sm font-bold text-[#293C74] outline-none focus:border-[#293C74]">
                    <option value="">Selecciona</option>
                    <option value="F">Femenino</option>
                    <option value="M">Masculino</option>
                    <option value="O">Otro</option>
                  </select>
                </div>
              </div>

              <div class="space-y-2">
                  <label class="text-[11px] font-bold text-slate-500 uppercase ml-1">Nombre Completo</label>
                  <input type="text" id="companion-name" class="w-full bg-white border border-slate-200 rounded-xl px-4 py-3 text-sm font-bold text-[#293C74] outline-none focus:border-[#293C74]" placeholder="Nombre del acompañante">
              </div>

              <div class="space-y-2">
                  <label class="text-[11px] font-bold text-slate-500 uppercase ml-1">Email <span class="text-slate-400 font-normal normal-case">(Opcional)</span></label>
                  <input type="email" id="companion-email" class="w-full bg-white border border-slate-200 rounded-xl px-4 py-3 text-sm font-bold text-[#293C74] outline-none focus:border-[#293C74]" placeholder="correo@ejemplo.com">
              </div>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                  <div class="space-y-2">
                    <label class="text-[11px] font-bold text-slate-500 uppercase ml-1">Paquete</label>
                    <select id="companion-package" class="w-full bg-white border border-slate-200 rounded-xl px-3 py-3 text-sm font-bold text-[#293C74] outline-none focus:border-[#293C74]">
                      <option value="lodging">Con Alojamiento</option>
                      <option value="no_lodging">Sin Alojamiento</option>
                    </select>
                  </div>
                  <div class="space-y-2">
                    <label class="text-[11px] font-bold text-slate-500 uppercase ml-1">Alimentación</label>
                    <select id="companion-menu" class="w-full bg-white border border-slate-200 rounded-xl px-3 py-3 text-sm font-bold text-[#293C74] outline-none focus:border-[#293C74]">
                      <option value="TRADICIONAL">Menú tradicional</option>
                      <option value="VEGETARIANO">Menú vegetariano</option>
                    </select>
                  </div>
              </div>
              
              <button type="button" id="btn-save-companion" class="w-full py-3 bg-[#293C74] text-white rounded-xl text-sm font-bold shadow-lg hover:bg-[#293C74]/90 transition-all transform active:scale-95">
                  Confirmar Acompañante
              </button>
            </div>

            <!-- Companions List -->
            <div id="companions-list" class="space-y-3">
              <!-- Populated dynamically -->
            </div>
            <div id="companions-empty" class="text-center py-8 text-slate-400 text-sm bg-slate-50 rounded-2xl border border-dashed border-slate-200">
              <span class="block mb-1">Sin acompañantes</span>
              <span class="text-xs opacity-60">Agrega personas adicionales a esta reserva</span>
            </div>
          </div>

          <!-- Step 3: Detalles de Inscripción -->
          <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
            <h3 class="text-lg font-bold text-[#293C74] flex items-center gap-3 mb-6">
              <span class="w-8 h-8 rounded-full bg-[#293C74]/10 text-[#293C74] flex items-center justify-center text-sm font-bold">3</span>
              Ubicación y Sede
            </h3>
            
            <div class="space-y-5">
              <div class="space-y-2">
                <label class="text-[11px] font-bold text-[#293C74] uppercase tracking-widest ml-1">Iglesia / Sede Asignada</label>
                <div class="relative">
                    <button type="button" id="btn-open-church-selector" class="w-full bg-slate-50 border border-slate-200 rounded-2xl px-5 py-3.5 text-sm font-bold text-left text-[#293C74] hover:border-brand-teal transition-colors flex items-center justify-between group">
                      <span id="selected-church-display" class="text-slate-400 group-hover:text-[#293C74]">Seleccionar iglesia...</span>
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-slate-300 group-hover:text-brand-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                    </button>
                    <input type="hidden" id="selected-church-id">
                </div>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                <div class="space-y-2">
                    <label class="text-[11px] font-bold text-[#293C74] uppercase tracking-widest ml-1">País / Región</label>
                  <input type="text" id="reg-country" value="Colombia" class="w-full bg-slate-50 border border-slate-200 rounded-2xl px-5 py-3.5 text-sm font-bold text-[#293C74] outline-none focus:border-[#293C74]">
                </div>
                <div class="space-y-2">
                  <label class="text-[11px] font-bold text-[#293C74] uppercase tracking-widest ml-1">Ciudad</label>
                  <input type="text" id="reg-city" class="w-full bg-slate-50 border border-slate-200 rounded-2xl px-5 py-3.5 text-sm font-bold text-[#293C74] outline-none focus:border-[#293C74]" placeholder="Ciudad de residencia">
                </div>
              </div>
            </div>
          </div>

          <!-- Step 4: Método de Pago -->
          <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
            <h3 class="text-lg font-bold text-[#293C74] flex items-center gap-3 mb-6">
              <span class="w-8 h-8 rounded-full bg-[#293C74]/10 text-[#293C74] flex items-center justify-center text-sm font-bold">4</span>
              Método de Pago
            </h3>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-6">
              <div class="space-y-2">
                <label class="text-[11px] font-bold text-[#293C74] uppercase tracking-widest ml-1">Moneda de pago</label>
                <div class="relative">
                  <select id="reg-currency" class="w-full bg-slate-50 border border-slate-200 rounded-2xl px-4 py-3.5 text-sm font-bold text-[#293C74] outline-none focus:border-[#293C74] focus:ring-1 focus:ring-[#293C74] appearance-none transition-all">
                    <option value="COP">Pesos colombianos (COP)</option>
                    <option value="USD">Dólares (USD)</option>
                  </select>
                  <div class="absolute top-1/2 -translate-y-1/2 right-0 pr-4 flex items-center pointer-events-none text-[#293C74]">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                  </div>
                </div>
              </div>
              <div id="manual-payment-amount-field" class="space-y-2">
                <label id="manual-payment-amount-label" class="text-[11px] font-bold text-[#293C74] uppercase tracking-widest ml-1">Valor pagado hoy</label>
                <input type="text" id="manual-payment-amount" inputmode="decimal" autocomplete="off" class="w-full bg-slate-50 border border-slate-200 rounded-2xl px-5 py-3.5 text-sm font-bold text-[#293C74] outline-none focus:border-[#293C74] focus:ring-1 focus:ring-[#293C74] transition-all placeholder-slate-400" placeholder="0">
                <div class="flex items-center justify-between text-[11px] text-slate-500 ml-1">
                  <span id="manual-payment-hint">Automático: $0</span>
                  <label class="inline-flex items-center gap-2 font-semibold text-slate-500 cursor-pointer">
                    <input id="manual-payment-custom-toggle" type="checkbox" class="h-3.5 w-3.5 rounded border-slate-300 text-brand-teal focus:ring-brand-teal">
                    Aporte libre
                  </label>
                </div>
                <p id="manual-payment-locked-hint" class="hidden text-[11px] text-amber-700 bg-amber-50 border border-amber-100 rounded-xl px-3 py-2">
                  Este registro viene de pago online. Aquí solo editas datos del participante; el pago se gestiona por pasarela.
                </p>
              </div>
            </div>

            <div id="manual-payment-summary" class="hidden mb-6 bg-slate-50 border border-slate-200 rounded-2xl p-4 space-y-3">
              <p class="text-[11px] uppercase tracking-widest font-bold text-[#293C74]">Estado de pago</p>
              <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
                <div class="bg-white border border-slate-200 rounded-xl p-3">
                  <p class="text-[10px] uppercase tracking-wider text-slate-500 font-semibold">Total</p>
                  <p id="manual-summary-total-amount" class="text-sm font-bold text-[#293C74]">$0</p>
                </div>
                <div class="bg-white border border-slate-200 rounded-xl p-3">
                  <p class="text-[10px] uppercase tracking-wider text-slate-500 font-semibold">Pagado</p>
                  <p id="manual-summary-total-paid" class="text-sm font-bold text-emerald-600">$0</p>
                </div>
                <div class="bg-white border border-slate-200 rounded-xl p-3">
                  <p class="text-[10px] uppercase tracking-wider text-slate-500 font-semibold">Pendiente</p>
                  <p id="manual-summary-remaining" class="text-sm font-bold text-amber-600">$0</p>
                </div>
              </div>
            </div>

            <div id="portal-payment-actions-section" class="hidden mb-6 space-y-3">
              <p class="text-[11px] uppercase tracking-widest font-bold text-[#293C74]">Acciones de pago</p>

              <div id="physical-payment-action" class="hidden bg-white border border-slate-200 rounded-2xl p-4 space-y-3">
                <div class="grid grid-cols-1 md:grid-cols-[minmax(0,1fr)_160px] gap-3">
                  <div class="space-y-2">
                    <label class="text-[10px] font-bold text-slate-500 uppercase tracking-widest ml-1">Abono físico</label>
                    <input type="text" id="physical-payment-amount" inputmode="decimal" autocomplete="off" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm font-bold text-[#293C74] outline-none focus:border-brand-teal focus:ring-1 focus:ring-brand-teal transition-all" placeholder="0">
                  </div>
                  <div class="space-y-2">
                    <label class="text-[10px] font-bold text-slate-500 uppercase tracking-widest ml-1">Método</label>
                    <select id="physical-payment-method" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm font-bold text-[#293C74] outline-none focus:border-brand-teal focus:ring-1 focus:ring-brand-teal transition-all">
                      <option value="cash">Efectivo</option>
                      <option value="bank_transfer">Transferencia</option>
                      <option value="card_reader">Datáfono</option>
                      <option value="other">Otro</option>
                    </select>
                  </div>
                </div>
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                  <p id="physical-payment-action-hint" class="text-[11px] text-slate-500"></p>
                  <button type="button" id="btn-record-physical-payment" class="shrink-0 px-4 py-2.5 rounded-xl bg-[#293C74] text-white text-sm font-bold hover:bg-[#1f2f5f] disabled:opacity-50 disabled:cursor-not-allowed transition-colors">
                    Registrar abono
                  </button>
                </div>
              </div>

              <div id="payment-plan-action" class="hidden bg-slate-50 border border-slate-200 rounded-2xl p-4">
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                  <div class="min-w-0">
                    <p id="payment-plan-status" class="text-sm font-bold text-[#293C74] truncate">Plan activo</p>
                    <p id="payment-plan-next" class="text-[11px] text-slate-500 mt-1"></p>
                  </div>
                  <button type="button" id="btn-stop-payment-plan" class="shrink-0 px-4 py-2.5 rounded-xl border border-amber-300 text-amber-700 bg-amber-50 text-sm font-bold hover:bg-amber-100 disabled:opacity-50 disabled:cursor-not-allowed transition-colors">
                    Detener cobros futuros
                  </button>
                </div>
                <div id="payment-plan-date-action" class="hidden mt-4 grid grid-cols-1 sm:grid-cols-[minmax(0,1fr)_auto] gap-3 items-end">
                  <div class="space-y-2">
                    <label class="text-[10px] font-bold text-slate-500 uppercase tracking-widest ml-1">Nueva fecha de próximo cobro</label>
                    <input type="date" id="payment-plan-next-date" class="w-full bg-white border border-slate-200 rounded-xl px-4 py-3 text-sm font-bold text-[#293C74] outline-none focus:border-brand-teal focus:ring-1 focus:ring-brand-teal transition-all">
                  </div>
                  <button type="button" id="btn-update-plan-date" class="px-4 py-3 rounded-xl border border-[#293C74]/20 text-[#293C74] bg-white text-sm font-bold hover:bg-[#293C74]/5 disabled:opacity-50 disabled:cursor-not-allowed transition-colors">
                    Actualizar plazo
                  </button>
                </div>
                <p id="payment-plan-action-hint" class="mt-2 text-[11px] text-slate-500"></p>
              </div>
            </div>

            <div id="manual-payments-history-section" class="hidden mb-6 space-y-3">
              <div class="flex items-center justify-between">
                <p class="text-[11px] uppercase tracking-widest font-bold text-[#293C74]">Últimos abonos manuales</p>
                <p class="text-[11px] text-slate-500">Más reciente primero</p>
              </div>
              <div id="manual-payments-history-list" class="space-y-2"></div>
              <p id="manual-payments-history-empty" class="hidden text-xs text-slate-500 bg-slate-50 border border-slate-200 rounded-xl px-3 py-2">
                Aún no hay abonos manuales registrados.
              </p>
            </div>

            <div id="payment-options-container" class="grid gap-4">
              <!-- Full Payment -->
              <label class="cursor-pointer group">
                <input type="radio" name="payment_option" value="FULL" class="peer sr-only" checked>
                <div class="flex items-center gap-5 p-5 rounded-2xl border border-slate-200 bg-white hover:border-[#293C74]/30 peer-checked:border-brand-teal peer-checked:bg-brand-teal/5 peer-checked:shadow-md peer-checked:[&_.payment-option-dot]:border-brand-teal peer-checked:[&_.payment-option-dot]:bg-brand-teal transition-all">
                  <div class="w-12 h-12 rounded-full bg-slate-50 flex items-center justify-center text-xl group-hover:scale-110 transition-transform">💳</div>
                  <div class="flex-1">
                    <span class="block font-bold text-[#293C74] text-base group-hover:text-brand-teal transition-colors">Pago Total (Efectivo)</span>
                    <span class="block text-xs text-slate-500 mt-1">El participante paga el 100% ahora</span>
                  </div>
                  <div class="payment-option-dot w-6 h-6 rounded-full border-2 border-slate-200 transition-all"></div>
                </div>
              </label>
              
              <!-- Deposit -->
              <label class="cursor-pointer group">
                <input type="radio" name="payment_option" value="DEPOSIT" class="peer sr-only">
                <div class="flex items-center gap-5 p-5 rounded-2xl border border-slate-200 bg-white hover:border-[#293C74]/30 peer-checked:border-brand-teal peer-checked:bg-brand-teal/5 peer-checked:shadow-md peer-checked:[&_.payment-option-dot]:border-brand-teal peer-checked:[&_.payment-option-dot]:bg-brand-teal transition-all">
                  <div class="w-12 h-12 rounded-full bg-slate-50 flex items-center justify-center text-xl group-hover:scale-110 transition-transform">🏦</div>
                  <div class="flex-1">
                    <span class="block font-bold text-[#293C74] text-base group-hover:text-brand-teal transition-colors">Abono Inicial (50%)</span>
                    <span class="block text-xs text-slate-500 mt-1">Paga <span id="deposit-amount-label" class="font-bold text-brand-teal">$0</span> para reservar cupo</span>
                  </div>
                  <div class="payment-option-dot w-6 h-6 rounded-full border-2 border-slate-200 transition-all"></div>
                </div>
              </label>

              <!-- Installments -->
              <label class="cursor-pointer group">
                <input type="radio" name="payment_option" value="INSTALLMENTS" class="peer sr-only">
                <div class="flex items-center gap-5 p-5 rounded-2xl border border-slate-200 bg-white hover:border-[#293C74]/30 peer-checked:border-brand-teal peer-checked:bg-brand-teal/5 peer-checked:shadow-md peer-checked:[&_.payment-option-dot]:border-brand-teal peer-checked:[&_.payment-option-dot]:bg-brand-teal transition-all">
                  <div class="w-12 h-12 rounded-full bg-slate-50 flex items-center justify-center text-xl group-hover:scale-110 transition-transform">📅</div>
                  <div class="flex-1">
                    <span class="block font-bold text-[#293C74] text-base group-hover:text-brand-teal transition-colors">Plan de Cuotas</span>
                    <span class="block text-xs text-slate-500 mt-1">Paga mes a mes hasta el 15 de mayo de 2026</span>
                  </div>
                  <div class="payment-option-dot w-6 h-6 rounded-full border-2 border-slate-200 transition-all"></div>
                </div>
              </label>
            </div>

            <!-- Installment Details (Hidden by default) -->
            <div id="installment-details" class="hidden mt-4 bg-slate-50 p-6 rounded-2xl border border-slate-200 space-y-4 animate-fadeIn">
              <h4 class="font-bold text-[#293C74] text-xs uppercase tracking-widest">Configuración del Plan</h4>
              <div class="flex gap-4">
                <label class="flex items-center gap-3 cursor-pointer bg-white px-4 py-3 rounded-xl border border-slate-200 flex-1 hover:border-brand-teal transition-colors">
                  <input type="radio" name="installment_frequency" value="MONTHLY" class="text-brand-teal focus:ring-brand-teal" checked>
                  <span class="text-sm font-bold text-[#293C74]">Mensual</span>
                </label>
                <label class="flex items-center gap-3 cursor-pointer bg-white px-4 py-3 rounded-xl border border-slate-200 flex-1 hover:border-brand-teal transition-colors">
                  <input type="radio" name="installment_frequency" value="BIWEEKLY" class="text-brand-teal focus:ring-brand-teal">
                  <span class="text-sm font-bold text-[#293C74]">Quincenal</span>
                </label>
              </div>
              <div class="grid grid-cols-3 gap-3 text-center text-sm">
                <div class="bg-white p-4 rounded-xl border border-slate-200 shadow-sm">
                  <span class="block text-[10px] text-slate-400 uppercase font-bold mb-1">Cuotas</span>
                  <span class="block font-bold text-[#293C74] text-xl" id="installment-count">1</span>
                </div>
                <div class="bg-white p-4 rounded-xl border border-slate-200 shadow-sm">
                  <span class="block text-[10px] text-slate-400 uppercase font-bold mb-1">Valor Aprox</span>
                  <span class="block font-bold text-[#293C74] text-xl" id="installment-amount">$0</span>
                </div>
                <div class="bg-white p-4 rounded-xl border border-slate-200 shadow-sm">
                  <span class="block text-[10px] text-slate-400 uppercase font-bold mb-1">Finaliza</span>
                  <span class="block font-bold text-[#293C74] text-xl">Mayo</span>
                </div>
              </div>
            </div>

            <!-- Deposit Schedule -->
            <div id="deposit-schedule" class="hidden mt-4 bg-slate-50 p-6 rounded-2xl border border-slate-200 space-y-4 animate-fadeIn">
              <h4 class="font-bold text-[#293C74] text-xs uppercase tracking-widest">Agenda tu segundo pago</h4>
              <p class="text-xs text-slate-500">
                Elige una fecha hasta
                <span id="deposit-deadline-label" class="font-semibold text-[#293C74]">15 de mayo de 2026</span>
                (incluido).
              </p>
              <div class="grid md:grid-cols-[1fr_auto] gap-4 items-end">
                <div>
                  <label class="block text-[11px] font-bold text-[#293C74] uppercase tracking-widest mb-2">Fecha de segundo pago</label>
                  <input type="date" id="deposit-due-date" name="deposit_due_date" max={installmentDeadline} class="w-full bg-white border border-slate-200 rounded-xl px-4 py-3 text-sm font-bold text-[#293C74] outline-none focus:border-brand-teal focus:ring-1 focus:ring-brand-teal transition-all">
                </div>
                <div class="text-[11px] text-slate-500">
                  Se verá como próxima cuota en el panel.
                </div>
              </div>
            </div>
          </div>

        </div>

        <!-- Right Column: Summary Sticky -->
        <div class="lg:sticky lg:top-8 h-fit">
          <div class="bg-gradient-to-br from-[#293C74] to-[#1e2b58] rounded-2xl p-6 shadow-xl border border-white/10">
            <h3 class="text-xs font-bold text-brand-teal uppercase tracking-widest mb-4">Resumen de Inscripción</h3>
            
            <div id="summary-list" class="space-y-2 mb-6 min-h-[60px]">
              <p class="italic text-white/30 text-xs">Agrega participantes...</p>
            </div>

            <div class="border-t border-white/10 pt-4 space-y-2">
              <div class="flex justify-between text-white/60 text-sm">
                <span>Subtotal</span>
                <span id="summary-subtotal">$0</span>
              </div>
              <div class="flex justify-between text-white text-xl font-bold">
                <span>Total</span>
                <span id="summary-total">$0</span>
              </div>
            </div>
            
            <div class="mt-6 p-3 bg-brand-teal/10 rounded-lg border border-brand-teal/20">
              <p class="text-[10px] text-white/70 text-center leading-tight">
                * Los precios se calculan automáticamente según edad y tipo de alojamiento
              </p>
            </div>

            <div class="mt-6 space-y-3">
              <button type="button" id="btn-cancel-manual-reg" class="w-full py-3 rounded-xl text-white/60 hover:text-white hover:bg-white/10 transition-colors font-bold">Cancelar</button>
              <button type="button" id="btn-delete-manual-booking" class="hidden w-full py-3 rounded-xl border border-red-300 text-red-100 hover:text-white hover:bg-red-500/20 hover:border-red-300 transition-colors font-bold">
                Eliminar registro manual
              </button>
              <button id="btn-submit-manual-reg" type="submit" class="w-full bg-gradient-to-r from-brand-teal to-[#4CC9E0] text-white px-8 py-4 rounded-xl font-bold shadow-lg hover:brightness-110 transition-transform hover:-translate-y-0.5">
                Registrar Grupo
              </button>
            </div>
            <p id="manual-delete-hint" class="hidden mt-2 text-[11px] text-red-100/80 leading-tight">
              Solo se habilita para perfiles manuales sin pagos online asociados.
            </p>
            
            <div id="manual-reg-status" class="mt-4 text-sm text-center text-white/60"></div>
          </div>
        </div>

      </form>
    </div>

  </div>

  <!-- Custom Alert Modal (Inside main modal container to handle z-index) -->
  <div id="custom-alert-modal" class="fixed inset-0 z-[60] hidden items-center justify-center bg-black/40 backdrop-blur-sm p-4">
    <div class="bg-white rounded-2xl shadow-2xl max-w-sm w-full p-6 text-center transform transition-all scale-100">
      <div id="alert-icon-container" class="mx-auto w-12 h-12 rounded-full bg-red-100 flex items-center justify-center mb-4">
        <svg id="alert-icon-error" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <svg id="alert-icon-success" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-green-500 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
      <h3 id="alert-title" class="text-lg font-bold text-slate-900 mb-2">Atención</h3>
      <p id="alert-message" class="text-sm text-slate-500 mb-6">Mensaje de alerta</p>
      <button id="btn-close-alert" class="w-full py-3 bg-slate-100 hover:bg-slate-200 text-slate-700 rounded-xl font-bold text-sm transition-colors">
        Entendido
      </button>
    </div>
  </div>
</div>
