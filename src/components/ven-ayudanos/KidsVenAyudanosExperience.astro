  @keyframes kidsSpin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  @keyframes kidsBars {
    0%, 100% { transform: scaleY(0.58); }
    50% { transform: scaleY(1); }
  }

  @keyframes kidsGridDrift {
    0% { background-position: 0 0, 0 0; }
    100% { background-position: 42px 42px, 42px 42px; }
  }

  @keyframes kidsBlobBreath {
    0%, 100% { transform: translate3d(0, 0, 0) scale(1) rotate(-8deg); }
    50% { transform: translate3d(12px, -14px, 0) scale(1.045) rotate(-4deg); }
