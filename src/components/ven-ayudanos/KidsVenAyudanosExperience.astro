---
import CumbreLayout from '@components/cumbre2026/CumbreLayout.astro';
import TurnstileWidget from '@components/TurnstileWidget.astro';
import venAyudanosScript from '@scripts/ven-ayudanos.js?url';

const assetsBase = '/images/ven-ayudanos/ninos';
const logoOnLight = `${assetsBase}/mana-kids-lineas-azul.svg`;
const logoOnDark = `${assetsBase}/mana-kids-completo-azul.svg`;
const decorativeLogoOnDark = `${assetsBase}/mana-kids-lineas-blancas.svg`;

const talentTracks = [
  {
    value: 'ilustracion',
    title: 'Ilustración',
    text: 'Personajes, láminas, historias visuales y recursos para explicar la Biblia con claridad.',
  },
  {
    value: 'animacion',
    title: 'Animación',
    text: 'Animaciones cortas, reels, piezas para pantallas y contenido digital para niños.',
  },
  {
    value: 'guiones',
    title: 'Guiones',
    text: 'Historias, devocionales, clases, dinámicas y narrativas centradas en la Palabra.',
  },
  {
    value: 'manualidades',
    title: 'Manualidades',
    text: 'Actividades, imprimibles, juegos y materiales que ayuden a recordar lo aprendido.',
  },
  {
    value: 'ensenanza-kids',
    title: 'Enseñanza',
    text: 'Maestros y auxiliares con amor por los niños, orden, paciencia y fundamento bíblico.',
  },
  {
    value: 'musica-kids',
    title: 'Música',
    text: 'Canciones, acompañamientos, voces, ritmos y recursos para adorar con los niños.',
  },
];

const buildIdeas = [
  'Devocionales para familias',
  'Historias bíblicas ilustradas',
  'Guías para maestros',
  'Actividades imprimibles',
  'Canciones con verdad bíblica',
  'Videos cortos para redes',
  'Material para la cumbre',
  'Juegos y retos de memoria',
];

const ideaPrompts = [
  'Tengo una canción',
  'Puedo ilustrar una historia',
  'Sé hacer juegos bíblicos',
  'Quiero animar contenido',
  'Puedo escribir clases',
  'Tengo una idea nueva',
];

const formHelpOptions = [
  { value: 'ilustracion', label: 'Ilustración' },
  { value: 'animacion', label: 'Animación' },
  { value: 'guiones', label: 'Guiones' },
  { value: 'manualidades', label: 'Manualidades' },
  { value: 'ensenanza-kids', label: 'Enseñanza' },
  { value: 'musica-kids', label: 'Música' },
  { value: 'produccion-kids', label: 'Video / foto' },
  { value: 'materiales-kids', label: 'Materiales' },
  { value: 'servicio', label: 'Servicio' },
  { value: 'oracion', label: 'Oración' },
  { value: 'generosidad', label: 'Generosidad' },
  { value: 'difusion', label: 'Difusión' },
  { value: 'propuesta-kids', label: 'Tengo una idea' },
];
---

<CumbreLayout
  title="Ayuda a que los niños conozcan la Palabra | Ven y Ayúdanos"
  description="Una invitación para servir a Maná Kids con talentos, ideas, materiales, contenido, enseñanza, oración y generosidad."
  image={logoOnLight}
  imageAlt="Maná Kids"
  imageWidth={1200}
  imageHeight={630}
  imageType="image/svg+xml"
  variant="light"
  flush
  showEventBadge={false}
  backHref="/ven-ayudanos"
  useHistoryBack={false}
  includeTurnstile
>
  <main class="kids-help" data-ven-ayudanos data-initial-ministry="ninos">
    <section class="kids-story" data-cumbre-story data-cumbre-static-mobile="true" data-cumbre-static-breakpoint="900" data-cumbre-scroll-factor-breakpoint="900" data-cumbre-snap-directional="false" data-cumbre-snap-inertia="false" style="--panel-count: 5;">
      <section class="cumbre-panel kids-panel kids-panel--hero" data-cumbre-panel data-panel-theme="light">
        <div class="kids-panel-bg" data-panel-bg aria-hidden="true">
          <div class="kids-grid-bg"></div>
          <div class="kids-blob kids-blob--blue"></div>
          <div class="kids-blob kids-blob--yellow"></div>
          <div class="kids-shapes"></div>
          <div class="kids-floating-kit">
            <span class="kids-float kids-float--music">♪</span>
            <span class="kids-float kids-float--spark">+</span>
            <span class="kids-float kids-float--play"></span>
            <span class="kids-float kids-float--dot"></span>
          </div>
        </div>

        <div class="kids-panel-inner kids-shell">
          <div class="kids-hero-grid">
            <div class="kids-copy">
              <img src={logoOnLight} alt="Maná Kids" class="kids-logo" data-reveal />
              <p class="kids-kicker" data-reveal>Ven y ayúdanos</p>
              <h1 data-split-title>Ayuda a que los niños conozcan la Palabra</h1>
              <p class="kids-lead" data-reveal>
                Talentos, ideas, materiales y manos dispuestas para crear recursos que acerquen a los niños a Jesús.
              </p>
              <div class="kids-actions" data-reveal>
                <a href="#primer-paso" class="kids-btn kids-btn--primary" data-scroll-form>Quiero ayudar</a>
                <a href="#talentos-kids" class="kids-btn kids-btn--outline">Ver talentos</a>
                <a href="/donaciones/" class="kids-btn kids-btn--soft">Sembrar</a>
              </div>
            </div>

            <div class="kids-hero-card" data-reveal aria-hidden="true">
              <div class="kids-card-stage">
                <img src={decorativeLogoOnDark} alt="" class="kids-stage-logo" />
                <div class="kids-pencil"></div>
                <div class="kids-star kids-star--one"></div>
                <div class="kids-star kids-star--two"></div>
                <div class="kids-sound-card">
                  <span>Música</span>
                  <div class="kids-eq" aria-hidden="true">
                    <i></i>
                    <i></i>
                    <i></i>
                    <i></i>
                    <i></i>
                  </div>
                  <p>Canciones, voces y ritmos con verdad bíblica.</p>
                </div>
                <div class="kids-note">
                  <span>Marcos 10:14</span>
                  <p>Dejen que los niños vengan a mí.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="talentos-kids" class="cumbre-panel kids-panel kids-panel--talents" data-cumbre-panel data-panel-theme="light">
        <div class="kids-panel-bg" data-panel-bg aria-hidden="true">
          <div class="kids-grid-bg kids-grid-bg--soft"></div>
          <div class="kids-blob kids-blob--pink"></div>
          <div class="kids-blob kids-blob--green"></div>
        </div>

        <div class="kids-panel-inner kids-shell">
          <div class="kids-two-col">
            <article class="kids-scripture" data-reveal>
              <span>Proverbios 22:6</span>
              <blockquote>Instruye al niño en su camino.</blockquote>
              <p>La creatividad también puede servir al discipulado cuando nace de la Palabra y del amor por los niños.</p>
              <img src={logoOnLight} alt="" aria-hidden="true" />
            </article>

            <div class="kids-panel-copy">
              <p class="kids-kicker" data-reveal>Talentos al servicio</p>
              <h2 data-split-title>Hay muchas formas de construir para los niños</h2>
              <p class="kids-body" data-reveal>
                Buscamos personas que puedan crear, enseñar, escribir, ilustrar, animar, hacer música, preparar actividades o apoyar materiales con excelencia y corazón pastoral.
              </p>
              <div class="kids-talent-grid" data-reveal>
                {talentTracks.map((track, index) => (
                  <article class={`kids-talent kids-talent--${(index % 6) + 1}`}>
                    <strong>{track.title}</strong>
                    <p>{track.text}</p>
                  </article>
                ))}
              </div>
              <div class="kids-idea-strip" data-reveal>
                <div>
                  <strong>¿Tienes una idea que no aparece aquí?</strong>
                  <p>También queremos escuchar propuestas nuevas para juegos, canciones, historias, recursos, retos y contenido para niños.</p>
                </div>
                <a href="#primer-paso" data-scroll-form>Proponer idea</a>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="cumbre-panel kids-panel kids-panel--build" data-cumbre-panel data-panel-theme="light">
        <div class="kids-panel-bg" data-panel-bg aria-hidden="true">
          <div class="kids-grid-bg"></div>
          <div class="kids-blob kids-blob--yellow kids-blob--wide"></div>
        </div>

        <div class="kids-panel-inner kids-shell">
          <div class="kids-build-grid">
            <div class="kids-panel-copy">
              <p class="kids-kicker" data-reveal>Recursos e ideas</p>
              <h2 data-split-title>Lo que podemos crear juntos</h2>
              <p class="kids-body" data-reveal>
                La meta no es hacer contenido por hacer contenido. Queremos materiales claros, bíblicos, memorables y fáciles de usar por maestros, familias y equipos de niños.
              </p>
              <div class="kids-build-board" data-reveal>
                {buildIdeas.map((idea, index) => (
                  <article class={`kids-build-card kids-build-card--${(index % 4) + 1}`}>
                    <span>{String(index + 1).padStart(2, '0')}</span>
                    <strong>{idea}</strong>
                  </article>
                ))}
              </div>
            </div>

            <aside class="kids-resource-card" data-reveal>
              <img src={logoOnLight} alt="" aria-hidden="true" />
              <div class="kids-mini-studio" aria-hidden="true">
                <span></span>
                <span></span>
                <span></span>
                <span></span>
              </div>
              <p>Una idea puede convertirse en una clase, una historia, una canción o una actividad que marque a un niño.</p>
            </aside>
          </div>
        </div>
      </section>

      <section class="cumbre-panel kids-panel kids-panel--give" data-cumbre-panel data-panel-theme="dark" data-give-panel>
        <div class="kids-panel-bg" data-panel-bg aria-hidden="true">
          <div class="kids-grid-bg kids-grid-bg--dark"></div>
          <div class="kids-blob kids-blob--sky"></div>
          <div class="kids-blob kids-blob--yellow"></div>
        </div>

        <div class="kids-panel-inner kids-shell">
          <div class="kids-give-grid">
            <div class="kids-panel-copy kids-panel-copy--white">
              <img src={logoOnDark} alt="Maná Kids" class="kids-logo kids-logo--white" data-reveal />
              <p class="kids-kicker kids-kicker--white" data-reveal>Materiales y recursos</p>
              <h2 data-split-title>Sembrar también prepara el camino</h2>
              <p class="kids-body" data-reveal>
                Las donaciones económicas pueden hacerse por los canales de Ministerio Maná. Si quieres apoyar a niños, puedes indicarlo en la nota de tu donación.
              </p>
              <div class="kids-actions" data-reveal>
                <a href="/donaciones/" class="kids-btn kids-btn--white">Ir a donaciones</a>
                <a href="#primer-paso" class="kids-btn kids-btn--ghost-white" data-scroll-form>Ofrecer talentos</a>
              </div>
            </div>

            <div class="kids-give-board" data-reveal>
              <article>
                <span>Talentos</span>
                <strong>Crear recursos para enseñar la Biblia</strong>
              </article>
              <article>
                <span>Materiales</span>
                <strong>Apoyar imprimibles, kits y herramientas</strong>
              </article>
              <article>
                <span>Generosidad</span>
                <strong>Sembrar para que el equipo tenga lo necesario</strong>
              </article>
            </div>
          </div>
        </div>
      </section>

      <section class="cumbre-panel kids-panel kids-panel--step" data-cumbre-panel data-panel-theme="light">
        <div class="kids-panel-bg" data-panel-bg aria-hidden="true">
          <div class="kids-grid-bg kids-grid-bg--soft"></div>
          <div class="kids-blob kids-blob--blue"></div>
        </div>

        <div class="kids-panel-inner kids-shell">
          <div class="kids-final">
            <img src={logoOnLight} alt="Maná Kids" class="kids-final-logo" data-reveal />
            <p class="kids-kicker" data-reveal>Primer paso</p>
            <h2 data-split-title>Cuéntanos cómo puedes ayudar</h2>
            <p class="kids-body" data-reveal>
              No necesitas tener todo listo. Si tienes una idea, un talento o disponibilidad para servir, empecemos con una conversación.
            </p>
            <div class="kids-actions kids-actions--center" data-reveal>
              <a href="#primer-paso" class="kids-btn kids-btn--primary" data-scroll-form>Ir al formulario</a>
              <button type="button" class="kids-btn kids-btn--outline" data-share-page>Compartir</button>
            </div>
          </div>
        </div>
      </section>
    </section>

    <section id="primer-paso" class="kids-form-section">
      <div class="kids-shell kids-form-grid">
        <div class="kids-form-copy">
          <img src={logoOnDark} alt="Maná Kids" />
          <p class="kids-kicker kids-kicker--white">Formulario</p>
          <h2>Apoya a Maná Kids</h2>
          <p>
            Queremos conocer tus talentos, ideas y disponibilidad para crear recursos que ayuden a los niños a conocer a Jesús y amar la Palabra.
          </p>
          <blockquote>Una generación puede recordar la Palabra cuando alguien decide prepararla con amor.</blockquote>
        </div>

        <div class="kids-form-panel">
          <form id="ven-ayudanos-form" class="kids-form" action="/api/ven-ayudanos/responder" method="post" data-help-form>
            <input type="hidden" name="origin" value="ninos" data-hidden-origin data-default-value="ninos" />
            <input type="hidden" name="place" value="ven-ayudanos-ninos" data-hidden-place data-default-value="ven-ayudanos-ninos" />
            <input type="hidden" name="utmSource" data-hidden-utm-source />
            <input type="hidden" name="utmMedium" data-hidden-utm-medium />
            <input type="hidden" name="utmCampaign" data-hidden-utm-campaign />
            <input type="hidden" name="qr" data-hidden-qr />
            <input type="hidden" name="path" data-hidden-path />

            <div class="kids-field-grid">
              <label>
                <span>Nombre</span>
                <input name="fullName" required autocomplete="name" class="kids-input" placeholder="Nombre completo" />
              </label>
              <label>
                <span>WhatsApp</span>
                <input name="whatsapp" required inputmode="tel" autocomplete="tel" class="kids-input" placeholder="+57 300 000 0000" />
              </label>
              <label>
                <span>Correo</span>
                <input name="email" type="email" autocomplete="email" class="kids-input" placeholder="correo@ejemplo.com" />
              </label>
              <label>
                <span>Ciudad</span>
                <input name="city" autocomplete="address-level2" class="kids-input" placeholder="Ciudad" />
              </label>
              <label>
                <span>Iglesia / sede</span>
                <input name="church" class="kids-input" placeholder="Iglesia o sede" />
              </label>
              <label>
                <span>Ministerio</span>
                <select name="ministry" required class="kids-input" data-ministry-select>
                  <option value="ninos" selected>Maná Kids</option>
                  <option value="mana">Ministerio Maná</option>
                  <option value="no-estoy-seguro">No estoy seguro</option>
                </select>
              </label>
            </div>

            <fieldset>
              <legend>Puedo aportar con</legend>
              <div class="kids-check-grid">
                {formHelpOptions.map((option) => (
                  <label class="kids-check">
                    <input type="checkbox" name="helpTypes" value={option.value} />
                    <span>{option.label}</span>
                  </label>
                ))}
              </div>
            </fieldset>

            <div class="kids-prompt-box">
              <span>También puedes proponer desde cero</span>
              <div>
                {ideaPrompts.map((prompt) => (
                  <small>{prompt}</small>
                ))}
              </div>
            </div>

            <label>
              <span>Cómo te gustaría ayudar</span>
              <textarea name="message" rows="4" class="kids-input kids-textarea" placeholder="Cuéntanos tu idea, talento, experiencia con niños, recurso que quieres crear, canción, historia, juego, animación o disponibilidad para servir."></textarea>
            </label>

            <label>
              <span>Disponibilidad</span>
              <select name="availability" class="kids-input">
                <option value="no-estoy-seguro">No estoy seguro</option>
                <option value="semanal">Semanal</option>
                <option value="mensual">Mensual</option>
                <option value="eventos-especiales">Eventos especiales</option>
              </select>
            </label>

            <TurnstileWidget appearance="always" theme="light" />

            <div class="kids-form-actions">
              <button type="submit" class="kids-btn kids-btn--primary" data-submit-button>Responder al llamado</button>
              <p class="kids-status hidden" data-form-status></p>
            </div>
          </form>

          <div class="kids-success hidden" data-success-panel>
            <img src={logoOnLight} alt="Maná Kids" />
            <h3>Gracias por responder.</h3>
            <p>Un líder del ministerio se comunicará contigo pronto.</p>
            <div class="kids-actions kids-actions--center">
              <button type="button" class="kids-btn kids-btn--outline" data-share-page>Compartir</button>
              <a href="/donaciones/" class="kids-btn kids-btn--primary">Donaciones</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <a href="#primer-paso" class="kids-mobile-cta" data-scroll-form>Quiero ayudar</a>
  </main>

  <script>
    import '@scripts/cumbre-welcome-story.js';
  </script>
  <script type="module" src={venAyudanosScript}></script>
</CumbreLayout>

<style is:global>
  .kids-help {
    --kids-navy: #1a2740;
    --kids-blue: #00a7bd;
    --kids-sky: #2ab9d4;
    --kids-green: #009e57;
    --kids-yellow: #fdc500;
    --kids-cream: #f7fbf6;
    --kids-ink: #142238;
    --active-accent: var(--kids-blue);
    background: var(--kids-cream);
    color: var(--kids-ink);
    font-family: "Intro", ui-sans-serif, system-ui, sans-serif;
  }

  .kids-shell {
    width: min(100% - 42px, 1420px);
    margin-inline: auto;
  }

  .kids-story {
    position: relative;
    height: var(--cumbre-vh, 100svh);
    min-height: var(--cumbre-vh, 100svh);
    overflow: hidden;
    background: var(--kids-cream);
  }

  .kids-panel {
    position: absolute;
    inset: 0;
    min-height: var(--cumbre-vh, 100svh);
    height: var(--cumbre-vh, 100svh);
    overflow: hidden;
    background: var(--kids-cream);
    color: var(--kids-ink);
    pointer-events: none;
    clip-path: inset(100% 0% 0% 0%);
    will-change: clip-path, transform;
  }

  .kids-panel:first-child,
  .kids-panel.is-visible {
    clip-path: inset(0% 0% 0% 0%);
  }

  .kids-panel.is-active {
    pointer-events: auto;
  }

  .kids-panel a,
  .kids-panel button {
    pointer-events: auto;
  }

  .kids-panel-bg,
  .kids-panel-bg > * {
    position: absolute;
    inset: 0;
  }

  .kids-panel-inner {
    position: relative;
    z-index: 1;
    min-height: var(--cumbre-vh, 100svh);
    height: var(--cumbre-vh, 100svh);
    display: flex;
    align-items: center;
    padding-block: clamp(62px, 8vh, 88px);
  }

  .kids-grid-bg {
    background-image:
      linear-gradient(rgba(0, 167, 189, 0.1) 2px, transparent 2px),
      linear-gradient(90deg, rgba(0, 167, 189, 0.1) 2px, transparent 2px);
    background-size: 42px 42px;
    opacity: 0.75;
    mask-image: radial-gradient(circle at 50% 50%, black, transparent 78%);
    animation: kidsGridDrift 30s linear infinite;
  }

  .kids-grid-bg--soft {
    opacity: 0.45;
  }

  .kids-grid-bg--dark {
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.11) 2px, transparent 2px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.11) 2px, transparent 2px);
    opacity: 0.34;
  }

  .kids-blob {
    inset: auto;
    border-radius: 999px;
    filter: blur(0);
    opacity: 0.18;
    transform: rotate(-8deg);
    animation: kidsBlobBreath 10s ease-in-out infinite;
  }

  .kids-blob--blue {
    left: auto;
    right: -9%;
    top: -18%;
    width: 54vw;
    height: 54vw;
    background: var(--kids-blue);
  }

  .kids-blob--yellow {
    right: auto;
    left: -11%;
    top: auto;
    bottom: -28%;
    width: 42vw;
    height: 42vw;
    background: var(--kids-yellow);
    animation-delay: -2.5s;
  }

  .kids-blob--pink {
    left: -14%;
    top: -20%;
    width: 42vw;
    height: 42vw;
    background: var(--kids-yellow);
  }

  .kids-blob--green {
    inset: auto -10% -22% auto;
    width: 42vw;
    height: 42vw;
    background: var(--kids-green);
    animation-delay: -4.5s;
  }

  .kids-blob--sky {
    inset: -18% -12% auto auto;
    width: 48vw;
    height: 48vw;
    background: var(--kids-sky);
    opacity: 0.22;
    animation-delay: -1.4s;
  }

  .kids-blob--wide {
    width: 62vw;
    height: 34vw;
    border-radius: 44% 56% 54% 46%;
  }

  .kids-shapes::before,
  .kids-shapes::after {
    content: "";
    position: absolute;
    border: 12px solid;
    opacity: 0.9;
  }

  .kids-shapes::before {
    width: 92px;
    height: 92px;
    right: 9%;
    bottom: 12%;
    border-color: rgba(253, 197, 0, 0.72);
    border-radius: 28px;
    transform: rotate(16deg);
  }

  .kids-shapes::after {
    width: 72px;
    height: 72px;
    left: 44%;
    top: 16%;
    border-color: var(--kids-green);
    border-radius: 999px;
  }

  .kids-floating-kit {
    position: absolute;
    inset: 0;
    display: block;
    pointer-events: none;
    overflow: hidden;
  }

  .kids-float {
    position: absolute;
    display: grid;
    place-items: center;
    color: var(--kids-navy);
    font-weight: 950;
    animation: kidsFloat 5.5s ease-in-out infinite;
    opacity: 0.86;
  }

  .kids-float--music {
    left: auto;
    right: 34%;
    top: 72%;
    width: 68px;
    height: 68px;
    border-radius: 20px;
    background: var(--kids-yellow);
    color: var(--kids-navy);
    font-size: 2.4rem;
    transform: rotate(-12deg);
  }

  .kids-float--spark {
    right: 7%;
    top: 30%;
    color: rgba(0, 167, 189, 0.54);
    font-size: 4.2rem;
    animation-delay: -1.8s;
  }

  .kids-float--play {
    left: auto;
    right: 13%;
    bottom: 11%;
    width: 84px;
    height: 84px;
    border-radius: 999px;
    background: var(--kids-green);
    animation-delay: -0.9s;
  }

  .kids-float--play::before {
    content: "";
    margin-left: 7px;
    border-left: 24px solid #fff;
    border-top: 16px solid transparent;
    border-bottom: 16px solid transparent;
  }

  .kids-float--dot {
    right: 27%;
    bottom: 18%;
    width: 38px;
    height: 38px;
    border-radius: 999px;
    background: var(--kids-green);
    animation-delay: -2.7s;
