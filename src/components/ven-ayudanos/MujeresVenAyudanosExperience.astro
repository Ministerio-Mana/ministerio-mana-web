---
import CumbreLayout from '@components/cumbre2026/CumbreLayout.astro';
import TurnstileWidget from '@components/TurnstileWidget.astro';
import venAyudanosScript from '@scripts/ven-ayudanos.js?url';

const assetsBase = '/images/ven-ayudanos/mujeres';
const whatsappHref = 'https://api.whatsapp.com/send/?phone=573128472997&text=%C2%A1Hola+Mujeres+que+creen+y+dejan+legado%21%0AQuiero+conocer+informaci%C3%B3n+sobre%3A&type=phone_number&app_absent=0';
const websiteHref = 'https://mujeresquecreen.org/';
const spotifyHref = 'https://open.spotify.com/show/6bZVKObfABTipTXV0PigVa?si=4576bd25a1c64fb2';
const youtubeHref = 'https://www.youtube.com/@MujeresQueCreen';
const instagramHref = 'https://www.instagram.com/mujeresquecreenydejanlegado?igsh=M3h6bDkzOWZiYTd6';
const zelleEmails = ['ministeriomana.inc2@gmail.com', 'ministeriomana.inc@gmail.com'];

const actionLinks = [
  {
    label: 'WhatsApp',
    title: 'Queremos escucharte',
    text: 'Cuéntanos tu historia y recibe orientación para conectarte.',
    href: whatsappHref,
  },
  {
    label: 'Spotify',
    title: 'Devocional diario',
    text: 'Escucha contenido de calidad para tu crecimiento en la Palabra.',
    href: spotifyHref,
  },
  {
    label: 'YouTube',
    title: 'Todo el contenido',
    text: 'Comparte enseñanzas, estudios y recursos que edifican.',
    href: youtubeHref,
  },
  {
    label: 'Instagram',
    title: 'Redes sociales',
    text: 'Acompaña invitaciones, eventos y testimonios del ministerio.',
    href: instagramHref,
  },
  {
    label: 'Sitio web',
    title: 'Historia y eventos',
    text: 'Conoce nuestra historia, eventos, devocional y contactos.',
    href: websiteHref,
  },
];

const helpTracks = [
  { value: 'feminidad', label: 'Feminidad piadosa', text: 'Reflejar el carácter de Cristo y la belleza del diseño de Dios.' },
  { value: 'servicio', label: 'Misericordia', text: 'Servir al necesitado y practicar el bien con intención.' },
  { value: 'discipulado', label: 'Discipulado', text: 'Caminar con otras y edificar a la siguiente generación.' },
  { value: 'doctrina', label: 'Sana doctrina', text: 'Enseñar la verdad con fidelidad, gracia y amor.' },
  { value: 'comunion', label: 'Unidad y generosidad', text: 'Vivir en comunión, perseverar juntas y compartir con gozo.', donation: true },
  { value: 'familia-fe', label: 'Familia de la fe', text: 'Animar y fortalecer a quienes caminan en Cristo.' },
];

const virtues = [
  'Discernimiento',
  'Honor',
  'Afecto',
  'Disciplina',
  'Responsabilidad',
  'Virtud',
  'Benevolencia',
  'Disposición',
  'Legado',
  'Belleza',
];

const contacts = [
  { city: 'Londres', detail: 'Contacto internacional', phone: '+33 666 548305', wa: '33666548305' },
  { city: 'Carolina del Norte', detail: 'Gloria Martínez', phone: '+1 347 8135589', wa: '13478135589' },
  { city: 'New Jersey', detail: 'Contacto local', phone: '+1 908 4144802', wa: '19084144802' },
  { city: 'Ixcatepec', detail: 'Contacto México', phone: '+52 789 1126016', wa: '527891126016' },
  { city: 'Cali', detail: 'Contacto Colombia', phone: '+57 301 6539295', wa: '573016539295' },
  { city: 'Armenia', detail: 'Contacto Colombia', phone: '+57 310 4001217', wa: '573104001217' },
  { city: 'Buenaventura', detail: 'Contacto Colombia', phone: '+57 315 4833033', wa: '573154833033' },
  { city: 'París', detail: 'Contacto internacional', phone: '+33 664 175342', wa: '33664175342' },
  { city: 'Providence, Rhode Island', detail: 'Contacto local', phone: '+1 401 5161478', wa: '14015161478' },
  { city: 'Tantoyuca, México', detail: 'Contacto México', phone: '+52 789 1003457', wa: '527891003457' },
  { city: 'Tantoyuca, Veracruz', detail: 'Contacto México', phone: '+52 789 1241807', wa: '527891241807' },
  { city: 'Bogotá', detail: 'Contacto Colombia', phone: '+57 318 4373583', wa: '573184373583' },
  { city: 'Marinilla', detail: 'Contacto Colombia', phone: '+57 312 8472997', wa: '573128472997' },
  { city: 'Bucaramanga', detail: 'Contacto Colombia', phone: '+57 312 8803962', wa: '573128803962' },
  { city: 'Orlando, Florida', detail: 'Beatriz Henao', phone: '+1 407 5809897', wa: '14075809897' },
  { city: 'Atlanta, Georgia', detail: 'Claudia Salazar', phone: '+1 770 5393573', wa: '17705393573' },
  { city: 'Tantoyuca', detail: 'Contacto México', phone: '+52 789 1056547', wa: '527891056547' },
  { city: 'Tempoal, México', detail: 'Contacto México', phone: '+52 789 1241807', wa: '527891241807' },
  { city: 'Cuenca, Ecuador', detail: 'Contacto Ecuador', phone: '+593 98 1696000', wa: '593981696000' },
  { city: 'Itagüí', detail: 'Contacto Colombia', phone: '+57 305 3548906', wa: '573053548906' },
  { city: 'Cartago', detail: 'Contacto Colombia', phone: '+57 313 6416313', wa: '573136416313' },
];

const formHelpOptions = [
  { value: 'servicio', label: 'Servir' },
  { value: 'difusion', label: 'Compartir' },
  { value: 'oracion', label: 'Orar' },
];
---

<CumbreLayout
  title="Mujeres que sostienen el llamado | Ven y Ayúdanos"
  description="Una invitación para unirte, servir, compartir el devocional, orar, sembrar y sostener la misión de Mujeres que Creen y Dejan Legado."
  image={`${assetsBase}/mujeres-virtudes-lineup.png`}
  imageAlt="Mujeres que creen y dejan legado"
  imageWidth={1890}
  imageHeight={1241}
  imageType="image/png"
  variant="light"
  flush
  showEventBadge={false}
  backHref="/ven-ayudanos"
  useHistoryBack={false}
  includeTurnstile
>
  <main class="mqc-page" data-ven-ayudanos data-initial-ministry="mujeres">
    <section class="mqc-story" data-cumbre-story data-cumbre-static-mobile="true" data-cumbre-static-breakpoint="1100" data-cumbre-scroll-factor-breakpoint="1100" data-cumbre-snap-directional="false" data-cumbre-snap-inertia="false" style="--panel-count: 5;">
      <section class="cumbre-panel mqc-panel mqc-panel--hero" data-cumbre-panel data-panel-theme="light">
        <div class="mqc-panel-bg" data-panel-bg aria-hidden="true">
          <div class="mqc-pattern"></div>
          <div class="mqc-arc mqc-arc--top"></div>
          <div class="mqc-arc mqc-arc--bottom"></div>
        </div>

        <div class="mqc-panel-inner mqc-shell">
          <div class="mqc-hero-grid">
            <div class="mqc-copy">
              <img src={`${assetsBase}/logo-mujeres-fucsia.svg`} alt="Mujeres que creen y dejan legado" class="mqc-logo" data-reveal />
              <p class="mqc-kicker" data-reveal>Ven y ayúdanos</p>
              <h1 data-split-title>Mujeres que sostienen el llamado</h1>
              <p class="mqc-lead" data-reveal>
                Mujeres firmes en la Palabra, activas en la enseñanza, constantes en el servicio, generosas en la comunión y comprometidas con la Gran Comisión.
              </p>
              <div class="mqc-actions" data-reveal>
                <a href="#primer-paso" class="mqc-btn mqc-btn--primary" data-scroll-form>Responder al llamado</a>
                <a href={whatsappHref} class="mqc-btn mqc-btn--outline" target="_blank" rel="noopener noreferrer">WhatsApp</a>
                <a href="#sembrar-mujeres" class="mqc-btn mqc-btn--soft mqc-btn--mobile-give" data-scroll-give>Sembrar</a>
                <button type="button" class="mqc-btn mqc-btn--soft mqc-btn--share" data-share-page>Compartir</button>
              </div>
            </div>

            <div class="mqc-hero-art" data-reveal aria-hidden="true">
              <img src={`${assetsBase}/cariatide-blanca.svg`} alt="" class="mqc-cariatide" />
              <img src={`${assetsBase}/barca-blanca.svg`} alt="" class="mqc-boat mqc-boat--hero" />
              <div class="mqc-verse-card">
                <p>“Que nuestras hijas sean como columnas elegantes, talladas para embellecer un palacio.”</p>
                <strong>Salmos 144:12 NTV</strong>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="cumbre-panel mqc-panel mqc-panel--call" data-cumbre-panel data-panel-theme="light">
        <div class="mqc-panel-bg" data-panel-bg aria-hidden="true">
          <div class="mqc-pattern"></div>
        </div>

        <div class="mqc-panel-inner mqc-shell">
          <div class="mqc-call-grid">
            <article class="mqc-scripture" data-reveal>
              <span>Hechos 16:9</span>
              <blockquote>“Ven y ayúdanos.”</blockquote>
              <p>
                El llamado se responde con presencia, misericordia, enseñanza, discipulado, unidad, generosidad y práctica del bien.
              </p>
              <img src={`${assetsBase}/barca-fucsia.svg`} alt="" aria-hidden="true" />
            </article>

            <div class="mqc-panel-copy">
              <p class="mqc-kicker" data-reveal>La red</p>
              <h2 data-split-title>La ayuda toma forma cuando alguien responde</h2>
              <p class="mqc-body" data-reveal>
                El propósito de Mujeres que Creen se vive cuando una mujer modela una feminidad piadosa, sirve con misericordia, discipula, enseña sana doctrina y camina en comunión.
              </p>
              <div class="mqc-help-grid" data-reveal>
                {helpTracks.map((track) => (
                  track.donation ? (
                    <a href="#sembrar-mujeres" class="mqc-help mqc-help--link" data-scroll-give>
                      <strong>{track.label}</strong>
                      <p>{track.text}</p>
                    </a>
                  ) : (
                    <article class="mqc-help">
                      <strong>{track.label}</strong>
                      <p>{track.text}</p>
                    </article>
                  )
                ))}
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="cumbre-panel mqc-panel mqc-panel--virtues" data-cumbre-panel data-panel-theme="light">
        <div class="mqc-panel-bg" data-panel-bg aria-hidden="true">
          <div class="mqc-pattern mqc-pattern--soft"></div>
        </div>

        <div class="mqc-panel-inner mqc-shell">
          <div class="mqc-virtues-grid">
            <div class="mqc-panel-copy">
              <p class="mqc-kicker" data-reveal>Tito 2:3-5</p>
              <h2 data-split-title>10 virtudes de feminidad bíblica</h2>
              <p class="mqc-body" data-reveal>
                Con base en Tito 2:3-5, estas virtudes llaman a vivir con reverencia, sensatez y pureza, formando carácter y discipulado.
              </p>
              <p class="mqc-tito-note" data-reveal>
                <span>Base bíblica</span>
                Mujeres reverentes, maestras del bien y formadoras de generaciones. Tito 2:3-5.
              </p>
              <div class="mqc-virtue-grid" data-reveal>
                {virtues.map((virtue, index) => (
                  <article class="mqc-virtue">
                    <span>{String(index + 1).padStart(2, '0')}</span>
                    <strong>{virtue}</strong>
                  </article>
                ))}
              </div>
            </div>

            <aside class="mqc-column-card" data-reveal>
              <img src={`${assetsBase}/cariatide-fucsia.svg`} alt="" aria-hidden="true" />
              <p>Columnas elegantes, talladas para embellecer un palacio.</p>
            </aside>
          </div>
        </div>
      </section>

      <section id="sembrar-mujeres" class="cumbre-panel mqc-panel mqc-panel--give" data-cumbre-panel data-panel-theme="light" data-give-panel>
        <div class="mqc-panel-bg" data-panel-bg aria-hidden="true">
          <div class="mqc-pattern mqc-pattern--white"></div>
        </div>

        <div class="mqc-panel-inner mqc-shell">
          <div class="mqc-give-grid">
            <div class="mqc-panel-copy mqc-panel-copy--white">
              <img src={`${assetsBase}/logo-mujeres-blanco.svg`} alt="Mujeres que creen y dejan legado" class="mqc-logo mqc-logo--white" data-reveal />
              <p class="mqc-kicker mqc-kicker--white" data-reveal>Generosidad y comunidad</p>
              <h2 data-split-title>Sembrar también sostiene la red</h2>
              <p class="mqc-body" data-reveal>
                Tu apoyo ayuda a crear materiales discipulares, sostener encuentros, preparar cartillas y llevar la visión a nuevos territorios.
              </p>
              <div class="mqc-give-note" data-reveal>
                <span>Sostén la red</span>
                <p>Escanea el QR o usa el método que corresponda a tu país. En Estados Unidos, envía por Zelle con la nota “Mujeres que Creen”.</p>
              </div>
            </div>

            <div class="mqc-giving-board" data-reveal>
              <figure class="mqc-qr mqc-qr--featured">
                <img src={`${assetsBase}/qr-bancolombia-mujeres.jpg`} alt="QR Bancolombia Mujeres que Creen" />
                <figcaption>Mujeres Que Creen · Iglesia Ministerio Maná</figcaption>
              </figure>

              <div class="mqc-method-stack">
                <article class="mqc-method">
                  <span>Colombia</span>
                  <h3>Bancolombia</h3>
                  <dl>
                    <div>
                      <dt>Cuenta de ahorros</dt>
                      <dd>255 0000 8527</dd>
                    </div>
                    <div>
                      <dt>Llave</dt>
                      <dd>0092110399</dd>
                    </div>
                  </dl>
                  <div class="mqc-method-actions">
                    <button type="button" data-copy-value="25500008527">Copiar cuenta</button>
                    <button type="button" data-copy-value="0092110399">Copiar llave</button>
                  </div>
                </article>

                <article class="mqc-method mqc-method--zelle">
                  <span>Estados Unidos</span>
                  <h3>Zelle</h3>
                  <p>En la nota o asunto escribe “Mujeres que Creen”.</p>
                  <div class="mqc-zelle-emails">
                    {zelleEmails.map((email) => (
                      <button type="button" data-copy-value={email}>{email}</button>
                    ))}
                  </div>
                </article>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="cumbre-panel mqc-panel mqc-panel--connect" data-cumbre-panel data-panel-theme="light">
        <div class="mqc-panel-bg" data-panel-bg aria-hidden="true">
          <div class="mqc-pattern mqc-pattern--soft"></div>
          <div class="mqc-connect-arc"></div>
        </div>

        <div class="mqc-panel-inner mqc-shell">
          <div class="mqc-connect-grid">
            <div class="mqc-panel-copy">
              <p class="mqc-kicker" data-reveal>Otra manera de ayudarnos</p>
              <h2 data-split-title>Extiende la red</h2>
              <p class="mqc-body" data-reveal>
                Ayúdanos a que más mujeres escuchen el devocional, encuentren enseñanzas, se unan a la comunidad y conozcan los eventos del ministerio.
              </p>
              <figure class="mqc-connect-boat" data-reveal>
                <img src={`${assetsBase}/barca-fucsia.svg`} alt="" aria-hidden="true" />
                <figcaption>Una mujer que comparte también sostiene la red.</figcaption>
              </figure>
            </div>

            <div class="mqc-connect-links" data-reveal>
              {actionLinks.map((item) => (
                <a href={item.href} target="_blank" rel="noopener noreferrer">
                  <small>{item.label}</small>
                  <strong>{item.title}</strong>
                  <span>{item.text}</span>
                </a>
              ))}
            </div>
          </div>
        </div>
      </section>
    </section>

    <section id="primer-paso" class="mqc-form-section">
      <div class="mqc-shell mqc-form-grid">
        <div class="mqc-form-copy">
          <img src={`${assetsBase}/ven-ayudanos-fondito.svg`} alt="Ven y ayúdanos" />
          <p class="mqc-kicker">Primer paso</p>
          <h2>Da tu primer paso</h2>
          <p>
            Queremos escucharte y conocer tu historia. Este formulario abre una conversación para descubrir cómo puedes servir, orar, compartir o apoyar lo que Dios está haciendo entre mujeres.
          </p>
          <blockquote>Padre amado, forma en mí una mujer que cree profundamente y deja legado.</blockquote>
        </div>

        <div class="mqc-form-panel">
          <form id="ven-ayudanos-form" class="mqc-form" action="/api/ven-ayudanos/responder" method="post" data-help-form>
            <input type="hidden" name="origin" value="mujeres" data-hidden-origin data-default-value="mujeres" />
            <input type="hidden" name="place" value="ven-ayudanos-mujeres" data-hidden-place data-default-value="ven-ayudanos-mujeres" />
            <input type="hidden" name="utmSource" data-hidden-utm-source />
            <input type="hidden" name="utmMedium" data-hidden-utm-medium />
            <input type="hidden" name="utmCampaign" data-hidden-utm-campaign />
            <input type="hidden" name="qr" data-hidden-qr />
            <input type="hidden" name="path" data-hidden-path />

            <div class="mqc-field-grid">
              <label>
                <span>Nombre</span>
                <input name="fullName" required autocomplete="name" class="mqc-input" placeholder="Nombre completo" />
              </label>
              <label>
                <span>WhatsApp</span>
                <input name="whatsapp" required inputmode="tel" autocomplete="tel" class="mqc-input" placeholder="+57 300 000 0000" />
              </label>
              <label>
                <span>Correo</span>
                <input name="email" type="email" autocomplete="email" class="mqc-input" placeholder="correo@ejemplo.com" />
              </label>
              <label>
                <span>Ciudad</span>
                <input name="city" autocomplete="address-level2" class="mqc-input" placeholder="Ciudad" />
              </label>
              <label>
                <span>Iglesia / sede</span>
                <input name="church" class="mqc-input" placeholder="Iglesia o sede" />
              </label>
              <label>
                <span>Ministerio de interés</span>
                <select name="ministry" required class="mqc-input" data-ministry-select>
                  <option value="mujeres" selected>Mujeres que Creen</option>
                  <option value="no-estoy-seguro">No estoy segura</option>
                  <option value="mana">Ministerio Maná</option>
                  <option value="ninos">Niños</option>
                  <option value="varones">Varones</option>
                  <option value="campus">Campus Maná</option>
                </select>
              </label>
            </div>

            <fieldset>
              <legend>Puedo aportar con</legend>
              <div class="mqc-check-grid">
                {formHelpOptions.map((option) => (
                  <label class="mqc-check">
                    <input type="checkbox" name="helpTypes" value={option.value} />
                    <span>{option.label}</span>
                  </label>
                ))}
              </div>
              <div class="mqc-giving-shortcuts">
                <p>Para sembrar o apadrinar, ve directo al QR y a los datos de donación.</p>
                <div>
                  <button type="button" data-scroll-give>Sembrar</button>
                  <button type="button" data-scroll-give>Apadrinar</button>
                </div>
              </div>
            </fieldset>

            <label>
              <span>Cómo te gustaría ayudar</span>
              <textarea name="message" rows="4" class="mqc-input mqc-textarea" placeholder="Cuéntanos si quieres servir, compartir el devocional, orar o unirte a la comunidad."></textarea>
            </label>

            <label>
              <span>Disponibilidad</span>
              <select name="availability" class="mqc-input">
                <option value="no-estoy-seguro">No estoy segura</option>
                <option value="semanal">Semanal</option>
                <option value="mensual">Mensual</option>
                <option value="eventos-especiales">Eventos especiales</option>
              </select>
            </label>

            <TurnstileWidget appearance="always" theme="light" />

            <div class="mqc-form-actions">
              <button type="submit" class="mqc-btn mqc-btn--primary" data-submit-button>Responder al llamado</button>
              <p class="mqc-status hidden" data-form-status></p>
            </div>
          </form>

          <div class="mqc-success hidden" data-success-panel>
            <img src={`${assetsBase}/logo-mujeres-fucsia.svg`} alt="Mujeres que creen y dejan legado" />
            <h3>Gracias por responder.</h3>
            <p>Un líder del ministerio se comunicará contigo pronto.</p>
            <div class="mqc-actions">
              <button type="button" class="mqc-btn mqc-btn--outline" data-share-page>Compartir</button>
              <a href={whatsappHref} class="mqc-btn mqc-btn--primary" target="_blank" rel="noopener noreferrer">WhatsApp</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="mqc-contact-section">
      <div class="mqc-shell">
        <div class="mqc-contact-heading">
          <p class="mqc-kicker">Red de contactos</p>
          <h2>Encuentra una mujer cerca de tu ciudad</h2>
        </div>
        <div class="mqc-contact-grid">
          {contacts.map((contact) => (
            <article class="mqc-contact">
              <div>
                <strong>{contact.city}</strong>
                <span>{contact.detail}</span>
              </div>
              <a href={`https://wa.me/${contact.wa}`} target="_blank" rel="noopener noreferrer">{contact.phone}</a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <a href="#primer-paso" class="mqc-mobile-cta" data-scroll-form>Responder al llamado</a>
  </main>

  <script>
    import '@scripts/cumbre-welcome-story.js';
  </script>
  <script type="module" src={venAyudanosScript}></script>
</CumbreLayout>

<style is:global>
  @font-face {
    font-family: "Aire Pro";
    src: url("/fonts/aire/aire-bold-pro.ttf") format("truetype");
    font-weight: 700;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: "Aire Pro";
    src: url("/fonts/aire/aire-bold-italic-pro.otf") format("opentype");
    font-weight: 700;
    font-style: italic;
    font-display: swap;
  }

  .mqc-page {
    --mqc-plum: #ac569b;
    --mqc-rose: #ce86b9;
    --mqc-soft: #fbedf6;
    --mqc-blush: #f7d9ec;
    --mqc-ink: #42233f;
    --mqc-muted: #705169;
    background: #fff;
    color: var(--mqc-ink);
    font-family: "Intro", ui-sans-serif, system-ui, sans-serif;
    overflow: hidden;
  }

  .mqc-page *,
  .mqc-page *::before,
  .mqc-page *::after {
    box-sizing: border-box;
    letter-spacing: 0;
  }

  .mqc-page :is(h1, h2, h3, p, a, strong, span) {
    color: inherit;
  }

  html:has(.mqc-page) .cumbre-action--whatsapp {
    display: none !important;
  }

  .mqc-shell {
    width: min(1180px, calc(100% - 40px));
    margin: 0 auto;
  }

  .mqc-story {
    position: relative;
    height: var(--cumbre-vh, 100svh);
    min-height: var(--cumbre-vh, 100svh);
    overflow: hidden;
    background: var(--mqc-soft);
  }

