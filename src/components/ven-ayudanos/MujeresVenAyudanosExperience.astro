    justify-content: center;
    border-radius: 999px;
    background: var(--mqc-plum);
    color: #fff !important;
    font-size: 0.82rem;
    font-weight: 900;
    text-decoration: none;
    text-transform: uppercase;
    box-shadow: 0 18px 42px rgba(172, 86, 155, 0.32);
