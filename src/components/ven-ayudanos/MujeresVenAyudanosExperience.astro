---
import CumbreLayout from '@components/cumbre2026/CumbreLayout.astro';
import TurnstileWidget from '@components/TurnstileWidget.astro';
import venAyudanosScript from '@scripts/ven-ayudanos.js?url';

const assetsBase = '/images/ven-ayudanos/mujeres';
const whatsappHref = 'https://api.whatsapp.com/send/?phone=573128472997&text=%C2%A1Hola+Mujeres+que+creen+y+dejan+legado%21%0AQuiero+conocer+informaci%C3%B3n+sobre%3A&type=phone_number&app_absent=0';
const websiteHref = 'https://mujeresquecreen.org/';
const spotifyHref = 'https://open.spotify.com/show/6bZVKObfABTipTXV0PigVa?si=4576bd25a1c64fb2';
const youtubeHref = 'https://www.youtube.com/@MujeresQueCreen';
const instagramHref = 'https://www.instagram.com/mujeresquecreenydejanlegado?igsh=M3h6bDkzOWZiYTd6';

const actionLinks = [
  {
    label: 'WhatsApp',
    title: 'Hablar con Mujeres',
    text: 'Únete, pregunta por encuentros o recibe orientación.',
    href: whatsappHref,
  },
  {
    label: 'Spotify',
    title: 'Devocional',
    text: 'Escucha y comparte el devocional diario.',
    href: spotifyHref,
  },
  {
    label: 'YouTube',
    title: 'Contenido',
    text: 'Apoya viendo, compartiendo y creando conversación.',
    href: youtubeHref,
  },
  {
    label: 'Instagram',
    title: 'Comunidad',
    text: 'Sigue la cuenta y ayuda a amplificar el llamado.',
    href: instagramHref,
  },
];

const helpTracks = [
  { value: 'servicio', label: 'Servir', text: 'Acompañar encuentros, recibir mujeres y sostener espacios.' },
  { value: 'talentos', label: 'Crear', text: 'Diseño, fotografía, video, enseñanza, música o producción.' },
  { value: 'difusion', label: 'Compartir', text: 'Enviar devocionales, contenidos, invitaciones y testimonios.' },
  { value: 'oracion', label: 'Orar', text: 'Interceder por mujeres, familias, sedes y nuevas discípulas.' },
  { value: 'generosidad', label: 'Sembrar', text: 'Apoyar recursos, encuentros, cartillas y la expansión del ministerio.' },
  { value: 'apadrinamiento', label: 'Apadrinar', text: 'Sostener procesos y mujeres que necesitan acompañamiento.' },
];

const virtues = [
  'Discernimiento',
  'Honor',
  'Afecto',
  'Disciplina',
  'Responsabilidad',
  'Virtud',
  'Benevolencia',
  'Disposición',
  'Legado',
  'Belleza',
];

const contacts = [
  { city: 'Londres', detail: 'Contacto internacional', phone: '+33 666 548305', wa: '33666548305' },
  { city: 'París', detail: 'Contacto internacional', phone: '+33 664 175342', wa: '33664175342' },
  { city: 'Orlando, Florida', detail: 'Beatriz Henao', phone: '+1 407 5809897', wa: '14075809897' },
  { city: 'Carolina del Norte', detail: 'Gloria Martínez', phone: '+1 347 8135589', wa: '13478135589' },
  { city: 'Providence, Rhode Island', detail: 'Contacto local', phone: '+1 401 5161478', wa: '14015161478' },
  { city: 'Atlanta, Georgia', detail: 'Claudia Salazar', phone: '+1 770 5393573', wa: '17705393573' },
  { city: 'New Jersey', detail: 'Contacto local', phone: '+1 908 4144802', wa: '19084144802' },
  { city: 'Ixcatepec', detail: 'Contacto México', phone: '+52 789 1126016', wa: '527891126016' },
  { city: 'Bogotá', detail: 'Contacto Colombia', phone: '+57 318 4373583', wa: '573184373583' },
  { city: 'Cali', detail: 'Contacto Colombia', phone: '+57 301 6539295', wa: '573016539295' },
  { city: 'Itagüí', detail: 'Contacto Colombia', phone: '+57 305 3548906', wa: '573053548906' },
  { city: 'Cuenca, Ecuador', detail: 'Contacto Ecuador', phone: '+593 98 1696000', wa: '593981696000' },
];

const formHelpOptions = [
  { value: 'servicio', label: 'Servir' },
  { value: 'talentos', label: 'Crear contenido' },
  { value: 'difusion', label: 'Compartir' },
  { value: 'oracion', label: 'Orar' },
  { value: 'generosidad', label: 'Sembrar' },
  { value: 'apadrinamiento', label: 'Apadrinar' },
];
---

<CumbreLayout
  title="Mujeres que sostienen el llamado | Ven y Ayúdanos"
  description="Una invitación para unirte, servir, crear contenido, compartir el devocional, sembrar y sostener la red de Mujeres que Creen y Dejan Legado."
  image={`${assetsBase}/mujeres-virtudes-lineup.png`}
  imageAlt="Mujeres que creen y dejan legado"
  imageWidth={1890}
  imageHeight={1241}
  imageType="image/png"
  variant="light"
  flush
  showEventBadge={false}
>
  <main class="mqc-page" data-ven-ayudanos data-initial-ministry="mujeres">
    <section class="mqc-story" data-cumbre-story data-cumbre-static-mobile="true" data-cumbre-static-breakpoint="540" style="--panel-count: 4;">
      <section class="cumbre-panel mqc-panel mqc-panel--hero" data-cumbre-panel data-panel-theme="light">
        <div class="mqc-panel-bg" data-panel-bg aria-hidden="true">
          <div class="mqc-pattern"></div>
          <div class="mqc-arc mqc-arc--top"></div>
          <div class="mqc-arc mqc-arc--bottom"></div>
        </div>

        <div class="mqc-panel-inner mqc-shell">
          <div class="mqc-hero-grid">
            <div class="mqc-copy">
              <img src={`${assetsBase}/logo-mujeres-fucsia.svg`} alt="Mujeres que creen y dejan legado" class="mqc-logo" data-reveal />
              <p class="mqc-kicker" data-reveal>Ven y ayúdanos</p>
              <h1 data-split-title>Mujeres que sostienen el llamado</h1>
              <p class="mqc-lead" data-reveal>
                Una red de mujeres que creen profundamente, sirven con amor, forman a otras en la Palabra y dejan legado.
              </p>
              <div class="mqc-actions" data-reveal>
                <a href="#primer-paso" class="mqc-btn mqc-btn--primary" data-scroll-form>Responder al llamado</a>
                <a href={whatsappHref} class="mqc-btn mqc-btn--outline" target="_blank" rel="noopener noreferrer">WhatsApp</a>
                <button type="button" class="mqc-btn mqc-btn--soft" data-share-page>Compartir</button>
              </div>
            </div>

            <div class="mqc-hero-art" data-reveal aria-hidden="true">
              <img src={`${assetsBase}/cariatide-blanca.svg`} alt="" class="mqc-cariatide" />
              <img src={`${assetsBase}/barca-blanca.svg`} alt="" class="mqc-boat mqc-boat--hero" />
              <div class="mqc-verse-card">
                <p>“Que nuestras hijas sean como columnas elegantes, talladas para embellecer un palacio.”</p>
                <strong>Salmos 144:12 NTV</strong>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="cumbre-panel mqc-panel mqc-panel--call" data-cumbre-panel data-panel-theme="light">
        <div class="mqc-panel-bg" data-panel-bg aria-hidden="true">
          <div class="mqc-pattern"></div>
        </div>

        <div class="mqc-panel-inner mqc-shell">
          <div class="mqc-call-grid">
            <article class="mqc-scripture" data-reveal>
              <span>Hechos 16:9</span>
              <blockquote>“Ven y ayúdanos.”</blockquote>
              <p>
                El llamado se responde con presencia, servicio, creatividad, oración, generosidad y manos dispuestas.
              </p>
              <img src={`${assetsBase}/barca-fucsia.svg`} alt="" aria-hidden="true" />
            </article>

            <div class="mqc-panel-copy">
              <p class="mqc-kicker" data-reveal>La red</p>
              <h2 data-split-title>La ayuda toma forma cuando alguien responde</h2>
              <p class="mqc-body" data-reveal>
                Esta interna convierte el llamado de la Cumbre en pasos concretos para unirse a la comunidad, compartir recursos, servir en encuentros, crear contenido, orar y sembrar.
              </p>
              <div class="mqc-help-grid" data-reveal>
                {helpTracks.map((track) => (
                  <article class="mqc-help">
                    <strong>{track.label}</strong>
                    <p>{track.text}</p>
                  </article>
                ))}
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="cumbre-panel mqc-panel mqc-panel--virtues" data-cumbre-panel data-panel-theme="light">
        <div class="mqc-panel-bg" data-panel-bg aria-hidden="true">
          <div class="mqc-pattern mqc-pattern--soft"></div>
        </div>

        <div class="mqc-panel-inner mqc-shell">
          <div class="mqc-virtues-grid">
            <div class="mqc-panel-copy">
              <p class="mqc-kicker" data-reveal>Tito 2:3-5</p>
              <h2 data-split-title>10 virtudes de feminidad bíblica</h2>
              <p class="mqc-body" data-reveal>
                La visión de Mujeres que Creen forma carácter, discipulado y servicio. Estas virtudes orientan conversaciones, encuentros, grupos y contenido.
              </p>
              <p class="mqc-tito-note" data-reveal>
                <span>Base bíblica</span>
                Mujeres reverentes, maestras del bien y formadoras de generaciones. Tito 2:3-5.
              </p>
              <div class="mqc-virtue-grid" data-reveal>
                {virtues.map((virtue, index) => (
                  <article class="mqc-virtue">
                    <span>{String(index + 1).padStart(2, '0')}</span>
                    <strong>{virtue}</strong>
                  </article>
                ))}
              </div>
            </div>

            <aside class="mqc-column-card" data-reveal>
              <img src={`${assetsBase}/cariatide-fucsia.svg`} alt="" aria-hidden="true" />
              <p>Columnas elegantes, talladas para embellecer un palacio.</p>
            </aside>
          </div>
        </div>
      </section>

      <section class="cumbre-panel mqc-panel mqc-panel--give" data-cumbre-panel data-panel-theme="light">
        <div class="mqc-panel-bg" data-panel-bg aria-hidden="true">
          <div class="mqc-pattern mqc-pattern--white"></div>
        </div>

        <div class="mqc-panel-inner mqc-shell">
          <div class="mqc-give-grid">
            <div class="mqc-panel-copy mqc-panel-copy--white">
              <img src={`${assetsBase}/logo-mujeres-blanco.svg`} alt="Mujeres que creen y dejan legado" class="mqc-logo mqc-logo--white" data-reveal />
              <p class="mqc-kicker mqc-kicker--white" data-reveal>Generosidad y comunidad</p>
              <h2 data-split-title>Sembrar también sostiene la red</h2>
              <p class="mqc-body" data-reveal>
                Tu apoyo ayuda a sostener recursos, encuentros, contenidos, cartillas y procesos de discipulado para mujeres en distintas ciudades.
              </p>
              <div class="mqc-bank" data-reveal>
                <div>
                  <span>Cuenta de ahorros Bancolombia</span>
                  <strong>255 0000 8527</strong>
                </div>
                <div>
                  <span>Llave</span>
                  <strong>0092110399</strong>
                </div>
              </div>
              <div class="mqc-actions" data-reveal>
                <button type="button" class="mqc-btn mqc-btn--white" data-copy-value="25500008527">Copiar cuenta</button>
                <button type="button" class="mqc-btn mqc-btn--white-outline" data-copy-value="0092110399">Copiar llave</button>
              </div>
            </div>

            <div class="mqc-qr-stack" data-reveal>
              <figure class="mqc-qr">
                <img src={`${assetsBase}/qr-bancolombia-mujeres.jpg`} alt="QR Bancolombia Mujeres que Creen" />
                <figcaption>Mujeres Que Creen · Iglesia Ministerio Maná</figcaption>
              </figure>
              <div class="mqc-social-links">
                {actionLinks.map((item) => (
                  <a href={item.href} target="_blank" rel="noopener noreferrer">
                    <small>{item.label}</small>
                    <strong>{item.title}</strong>
                    <span>{item.text}</span>
                  </a>
                ))}
                <a href={websiteHref} target="_blank" rel="noopener noreferrer">
                  <small>Sitio web</small>
                  <strong>Conoce Mujeres que Creen</strong>
                  <span>Historia, eventos, recursos e información oficial.</span>
                </a>
              </div>
            </div>
          </div>
        </div>
      </section>
    </section>

    <section id="primer-paso" class="mqc-form-section">
      <div class="mqc-shell mqc-form-grid">
        <div class="mqc-form-copy">
          <img src={`${assetsBase}/ven-ayudanos-fondito.svg`} alt="Ven y ayúdanos" />
          <p class="mqc-kicker">Primer paso</p>
          <h2>Da tu primer paso</h2>
          <p>
            Esto no es un compromiso definitivo. Es una conversación para descubrir cómo tus manos, recursos, ideas y dones pueden ayudar.
          </p>
          <blockquote>Padre amado, forma en mí una mujer que cree profundamente y deja legado.</blockquote>
        </div>

        <div class="mqc-form-panel">
          <form id="ven-ayudanos-form" class="mqc-form" action="/api/ven-ayudanos/responder" method="post" data-help-form>
            <input type="hidden" name="origin" value="mujeres" data-hidden-origin data-default-value="mujeres" />
            <input type="hidden" name="place" value="ven-ayudanos-mujeres" data-hidden-place data-default-value="ven-ayudanos-mujeres" />
            <input type="hidden" name="utmSource" data-hidden-utm-source />
            <input type="hidden" name="utmMedium" data-hidden-utm-medium />
            <input type="hidden" name="utmCampaign" data-hidden-utm-campaign />
            <input type="hidden" name="qr" data-hidden-qr />
            <input type="hidden" name="path" data-hidden-path />

            <div class="mqc-field-grid">
              <label>
                <span>Nombre</span>
                <input name="fullName" required autocomplete="name" class="mqc-input" placeholder="Nombre completo" />
              </label>
              <label>
                <span>WhatsApp</span>
                <input name="whatsapp" required inputmode="tel" autocomplete="tel" class="mqc-input" placeholder="+57 300 000 0000" />
              </label>
              <label>
                <span>Correo</span>
                <input name="email" type="email" autocomplete="email" class="mqc-input" placeholder="correo@ejemplo.com" />
              </label>
              <label>
                <span>Ciudad</span>
                <input name="city" autocomplete="address-level2" class="mqc-input" placeholder="Ciudad" />
              </label>
              <label>
                <span>Iglesia / sede</span>
                <input name="church" class="mqc-input" placeholder="Iglesia o sede" />
              </label>
              <label>
                <span>Ministerio de interés</span>
                <select name="ministry" required class="mqc-input" data-ministry-select>
                  <option value="mujeres" selected>Mujeres que Creen</option>
                  <option value="no-estoy-seguro">No estoy segura</option>
                  <option value="mana">Ministerio Maná</option>
                  <option value="ninos">Niños</option>
                  <option value="varones">Varones</option>
                  <option value="campus">Campus Maná</option>
                </select>
              </label>
            </div>

            <fieldset>
              <legend>Puedo aportar con</legend>
              <div class="mqc-check-grid">
                {formHelpOptions.map((option) => (
                  <label class="mqc-check">
                    <input type="checkbox" name="helpTypes" value={option.value} />
                    <span>{option.label}</span>
                  </label>
                ))}
              </div>
            </fieldset>

            <label>
              <span>Cómo te gustaría ayudar</span>
              <textarea name="message" rows="4" class="mqc-input mqc-textarea" placeholder="Cuéntanos si quieres servir, crear contenido, compartir el devocional, orar, sembrar o unirte a la comunidad."></textarea>
            </label>

            <label>
              <span>Disponibilidad</span>
              <select name="availability" class="mqc-input">
                <option value="no-estoy-seguro">No estoy segura</option>
                <option value="semanal">Semanal</option>
                <option value="mensual">Mensual</option>
                <option value="eventos-especiales">Eventos especiales</option>
              </select>
            </label>

            <TurnstileWidget appearance="always" theme="light" />

            <div class="mqc-form-actions">
              <button type="submit" class="mqc-btn mqc-btn--primary" data-submit-button>Responder al llamado</button>
              <p class="mqc-status hidden" data-form-status></p>
            </div>
          </form>

          <div class="mqc-success hidden" data-success-panel>
            <img src={`${assetsBase}/logo-mujeres-fucsia.svg`} alt="Mujeres que creen y dejan legado" />
            <h3>Gracias por responder.</h3>
            <p>Un líder del ministerio se comunicará contigo pronto.</p>
            <div class="mqc-actions">
              <button type="button" class="mqc-btn mqc-btn--outline" data-share-page>Compartir</button>
              <a href={whatsappHref} class="mqc-btn mqc-btn--primary" target="_blank" rel="noopener noreferrer">WhatsApp</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="mqc-contact-section">
      <div class="mqc-shell">
        <div class="mqc-contact-heading">
          <p class="mqc-kicker">Red de contactos</p>
          <h2>Encuentra una mujer cerca de tu ciudad</h2>
        </div>
        <div class="mqc-contact-grid">
          {contacts.map((contact) => (
            <article class="mqc-contact">
              <div>
                <strong>{contact.city}</strong>
                <span>{contact.detail}</span>
              </div>
              <a href={`https://wa.me/${contact.wa}`} target="_blank" rel="noopener noreferrer">{contact.phone}</a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <a href="#primer-paso" class="mqc-mobile-cta" data-scroll-form>Responder al llamado</a>
  </main>

  <script>
    import '@scripts/cumbre-welcome-story.js';
  </script>
  <script type="module" src={venAyudanosScript}></script>
</CumbreLayout>

<style is:global>
  @font-face {
    font-family: "Aire Pro";
    src: url("/fonts/aire/aire-bold-pro.ttf") format("truetype");
    font-weight: 700;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: "Aire Pro";
    src: url("/fonts/aire/aire-bold-italic-pro.otf") format("opentype");
    font-weight: 700;
    font-style: italic;
    font-display: swap;
  }

  .mqc-page {
    --mqc-plum: #ac569b;
    --mqc-rose: #ce86b9;
    --mqc-soft: #fbedf6;
    --mqc-blush: #f7d9ec;
    --mqc-ink: #42233f;
    --mqc-muted: #705169;
    background: #fff;
    color: var(--mqc-ink);
    font-family: "Intro", ui-sans-serif, system-ui, sans-serif;
    overflow: hidden;
  }

  .mqc-page *,
  .mqc-page *::before,
  .mqc-page *::after {
    box-sizing: border-box;
    letter-spacing: 0;
  }

  .mqc-page :is(h1, h2, h3, p, a, strong, span) {
    color: inherit;
  }

  .mqc-shell {
    width: min(1180px, calc(100% - 40px));
    margin: 0 auto;
  }

  .mqc-story {
    position: relative;
    height: var(--cumbre-vh, 100svh);
    min-height: var(--cumbre-vh, 100svh);
    overflow: hidden;
    background: var(--mqc-soft);
  }

  .mqc-page .cumbre-panel {
    position: absolute;
    inset: 0;
    height: var(--cumbre-vh, 100svh);
    min-height: var(--cumbre-vh, 100svh);
    width: 100%;
    overflow: hidden;
    pointer-events: none;
    clip-path: inset(100% 0% 0% 0%);
    will-change: clip-path, transform;
  }

  .mqc-page .cumbre-panel:first-child,
  .mqc-page .cumbre-panel.is-visible {
    clip-path: inset(0% 0% 0% 0%);
  }

  .mqc-page .cumbre-panel.is-active {
    pointer-events: auto;
  }

  .mqc-page .cumbre-panel a,
  .mqc-page .cumbre-panel button {
    pointer-events: auto;
  }

  .mqc-page [data-panel-bg] {
    transform-origin: center;
    will-change: transform;
  }

  .mqc-page [data-reveal] {
    will-change: transform, opacity;
  }

  .mqc-page [data-split-title] .split-word {
    display: inline-block;
    overflow: hidden;
    vertical-align: top;
  }

  .mqc-page [data-split-title] .split-word > span {
    display: inline-block;
    will-change: transform, opacity;
  }

  .mqc-panel {
    background: linear-gradient(135deg, #fff 0%, #fff 58%, var(--mqc-soft) 100%);
  }

  .mqc-panel--give {
    background: var(--mqc-plum);
    color: #fff;
  }

  .mqc-panel-bg,
  .mqc-pattern,
  .mqc-arc {
    position: absolute;
    pointer-events: none;
  }

  .mqc-panel-bg {
    inset: 0;
  }

  .mqc-pattern {
    right: -8vw;
    bottom: -10vh;
    width: min(540px, 74vw);
    height: min(540px, 74vw);
    background-image: url("/images/ven-ayudanos/mujeres/corazon-fucsia.svg");
    background-repeat: repeat;
    background-size: 72px auto;
    opacity: 0.08;
    mask-image: radial-gradient(circle at 50% 50%, black 0 52%, transparent 76%);
  }

  .mqc-panel--hero .mqc-pattern,
  .mqc-panel--call .mqc-pattern {
    display: none;
  }

  .mqc-pattern--soft {
    opacity: 0.07;
  }

  .mqc-pattern--white {
    background-image: url("/images/ven-ayudanos/mujeres/corazon-blanco.svg");
    opacity: 0.07;
  }

  .mqc-arc {
    left: 50%;
    width: min(1180px, 136vw);
    height: 330px;
    border-radius: 0 0 620px 620px;
    background: var(--mqc-rose);
    transform: translateX(-50%);
  }

  .mqc-arc--top {
    top: -238px;
  }

  .mqc-arc--bottom {
    bottom: -250px;
    border-radius: 620px 620px 0 0;
    background: var(--mqc-blush);
  }

  .mqc-panel-inner {
    position: relative;
    z-index: 2;
    min-height: var(--cumbre-vh, 100svh);
    height: var(--cumbre-vh, 100svh);
    display: flex;
    align-items: center;
    padding: 92px 0 72px;
  }

  .mqc-panel--call .mqc-panel-inner,
  .mqc-panel--virtues .mqc-panel-inner,
  .mqc-panel--give .mqc-panel-inner {
    align-items: flex-start;
    padding-top: clamp(80px, 10vh, 108px);
    padding-bottom: clamp(44px, 6vh, 68px);
  }

  .mqc-hero-grid,
  .mqc-call-grid,
  .mqc-virtues-grid,
  .mqc-give-grid,
  .mqc-form-grid {
    width: 100%;
    display: grid;
    gap: clamp(28px, 5vw, 64px);
    align-items: center;
  }

  .mqc-hero-grid {
    grid-template-columns: minmax(0, 0.98fr) minmax(280px, 0.82fr);
  }

  .mqc-call-grid,
  .mqc-give-grid {
    grid-template-columns: minmax(290px, 0.82fr) minmax(0, 1.18fr);
  }

  .mqc-virtues-grid,
  .mqc-form-grid {
    grid-template-columns: minmax(0, 1.12fr) minmax(300px, 0.88fr);
  }

  .mqc-logo {
    width: clamp(140px, 18vw, 210px);
    height: auto;
    margin-bottom: clamp(22px, 4vh, 44px);
  }

  .mqc-logo--white {
    margin-bottom: 22px;
  }

  .mqc-kicker {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    margin: 0 0 14px;
    border: 1px solid rgba(172, 86, 155, 0.2);
    border-radius: 999px;
    background: #fff;
    color: var(--mqc-plum) !important;
    padding: 8px 15px;
    font-size: 0.76rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .mqc-kicker--white {
    border-color: rgba(255, 255, 255, 0.28);
    background: rgba(255, 255, 255, 0.18);
    color: #fff !important;
  }

  .mqc-copy h1,
  .mqc-panel-copy h2,
  .mqc-form-copy h2,
  .mqc-contact-heading h2 {
    margin: 0;
    color: var(--mqc-ink);
    font-family: "Intro", ui-sans-serif, system-ui, sans-serif;
    font-size: clamp(3rem, 6.7vw, 6.6rem);
    font-weight: 900;
    line-height: 0.9;
    text-transform: uppercase;
    text-wrap: balance;
  }

  .mqc-panel-copy h2,
  .mqc-form-copy h2,
  .mqc-contact-heading h2 {
    font-size: clamp(2.55rem, 5.2vw, 5.2rem);
    line-height: 0.98;
  }

  .mqc-panel-copy--white h2 {
    color: #fff;
  }

  .mqc-copy h1 .split-word:first-child > span,
  .mqc-panel-copy h2 .split-word:first-child > span,
  .mqc-form-copy h2,
  .mqc-contact-heading h2 {
    color: var(--mqc-plum);
  }

  .mqc-panel-copy--white h2 .split-word:first-child > span {
    color: #fff;
  }

  .mqc-lead,
  .mqc-body,
  .mqc-form-copy p {
    max-width: 680px;
    margin: 24px 0 0;
    color: var(--mqc-muted) !important;
    font-size: clamp(1.05rem, 1.55vw, 1.32rem);
    line-height: 1.62;
    font-weight: 500;
  }

  .mqc-panel-copy--white .mqc-body {
    color: rgba(255, 255, 255, 0.84) !important;
  }

  .mqc-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 28px;
  }

  .mqc-btn,
  .mqc-btn:visited {
    min-height: 48px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid transparent;
    border-radius: 999px;
    padding: 13px 22px;
    font-size: 0.78rem;
    font-weight: 900;
    text-transform: uppercase;
    text-decoration: none;
    transition: transform 180ms ease, background-color 180ms ease, color 180ms ease, border-color 180ms ease;
    cursor: pointer;
  }

  .mqc-btn:hover,
  .mqc-btn:focus-visible {
    transform: translateY(-2px);
  }

  .mqc-btn--primary {
    background: var(--mqc-plum);
    color: #fff !important;
    box-shadow: 0 18px 42px rgba(172, 86, 155, 0.22);
  }

  .mqc-btn--outline {
    background: #fff;
    border-color: rgba(172, 86, 155, 0.34);
    color: var(--mqc-plum) !important;
  }

  .mqc-btn--soft {
    background: var(--mqc-soft);
    color: var(--mqc-plum) !important;
  }

  .mqc-btn--white {
    background: #fff;
    color: var(--mqc-plum) !important;
  }

  .mqc-btn--white-outline {
    background: transparent;
    border-color: rgba(255, 255, 255, 0.42);
    color: #fff !important;
  }

  .mqc-hero-art {
    position: relative;
    min-height: min(620px, calc(var(--cumbre-vh, 100svh) - 150px));
    display: grid;
    place-items: center;
    overflow: hidden;
    background:
      linear-gradient(180deg, rgba(206, 134, 185, 0.95), rgba(172, 86, 155, 0.98)),
      var(--mqc-plum);
    border-radius: 999px 999px 0 0;
  }

  .mqc-hero-art::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: url("/images/ven-ayudanos/mujeres/corazon-blanco.svg");
    background-repeat: repeat;
    background-size: 82px auto;
    opacity: 0.07;
  }

  .mqc-cariatide {
    position: relative;
    z-index: 2;
    height: clamp(330px, 56vh, 560px);
    width: auto;
    max-width: 100%;
  }

  .mqc-boat--hero {
    position: absolute;
    z-index: 1;
    left: 0;
    bottom: 74px;
    width: min(410px, 82%);
    height: auto;
    opacity: 0.5;
  }

  .mqc-verse-card {
    position: absolute;
    z-index: 3;
    right: 20px;
    bottom: 20px;
    left: 20px;
    background: rgba(255, 255, 255, 0.94);
    border: 1px solid rgba(255, 255, 255, 0.58);
    border-radius: 34px 34px 34px 12px;
    box-shadow: 0 26px 64px rgba(82, 34, 76, 0.18);
    padding: 18px 20px;
  }

  .mqc-verse-card p,
  .mqc-scripture p,
  .mqc-help p,
  .mqc-virtue strong,
  .mqc-social-links span,
  .mqc-contact span {
    margin: 0;
    color: var(--mqc-muted) !important;
    line-height: 1.48;
  }

  .mqc-verse-card strong {
    display: block;
    margin-top: 10px;
    color: var(--mqc-plum);
    font-family: "Aire Pro", Georgia, "Times New Roman", serif;
    font-size: 1rem;
  }

  .mqc-scripture,
  .mqc-column-card,
  .mqc-qr,
  .mqc-form-panel {
    border: 1px solid rgba(172, 86, 155, 0.18);
    background: rgba(255, 255, 255, 0.82);
    box-shadow: 0 24px 80px rgba(172, 86, 155, 0.16);
  }

  .mqc-scripture {
    padding: clamp(24px, 4vw, 44px);
    border-radius: 72px 72px 26px 26px;
  }

  .mqc-scripture span {
    color: var(--mqc-plum);
    font-size: 0.8rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .mqc-scripture blockquote {
    margin: 18px 0 18px;
    color: var(--mqc-plum);
    font-family: "Aire Pro", Georgia, "Times New Roman", serif;
    font-size: clamp(2.5rem, 5.2vw, 5rem);
    font-style: italic;
    line-height: 0.98;
  }

  .mqc-scripture img {
    width: min(360px, 100%);
    height: auto;
    margin-top: 34px;
  }

  .mqc-help-grid {
    margin-top: 28px;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }

  .mqc-help {
    min-height: 116px;
    padding: 16px;
    border-radius: 22px 22px 34px 22px;
    border: 1px solid rgba(172, 86, 155, 0.16);
    background: #fff;
  }

  .mqc-help strong {
    display: block;
    margin-bottom: 9px;
    color: var(--mqc-plum);
    font-family: "Intro", ui-sans-serif, system-ui, sans-serif;
    font-size: 1rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .mqc-virtue-grid {
    margin-top: 28px;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
  }

  .mqc-virtue {
    min-height: 60px;
    display: grid;
    grid-template-columns: 42px 1fr;
    align-items: center;
    gap: 12px;
    border-radius: 18px 18px 28px 18px;
    border: 1px solid rgba(172, 86, 155, 0.16);
    background: #fff;
    padding: 10px 12px;
  }

  .mqc-tito-note {
    margin: 18px 0 0;
    border: 1px solid rgba(172, 86, 155, 0.16);
    border-radius: 26px 26px 26px 8px;
    background: rgba(255, 255, 255, 0.82);
    color: var(--mqc-muted) !important;
    padding: 14px 16px;
    font-size: 0.94rem;
    font-weight: 600;
    line-height: 1.42;
  }

  .mqc-tito-note span {
    display: block;
    margin-bottom: 4px;
    color: var(--mqc-plum) !important;
    font-size: 0.7rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .mqc-virtue span {
    display: grid;
    place-items: center;
    width: 38px;
    height: 38px;
    border-radius: 999px;
    background: var(--mqc-rose);
    color: #fff;
    font-weight: 900;
  }

  .mqc-virtue strong {
    color: var(--mqc-ink) !important;
    font-family: "Intro", ui-sans-serif, system-ui, sans-serif;
    font-size: 0.98rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .mqc-column-card {
    min-height: 530px;
    position: relative;
    display: grid;
    place-items: center;
    overflow: hidden;
    border-radius: 120px 120px 28px 28px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(251, 237, 246, 0.94)),
      #fff;
  }

  .mqc-column-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: url("/images/ven-ayudanos/mujeres/corazon-fucsia.svg");
    background-size: 74px auto;
    opacity: 0.08;
  }

  .mqc-column-card img {
    position: relative;
    z-index: 1;
    height: clamp(320px, 50vh, 500px);
    width: auto;
  }

  .mqc-column-card p {
    position: absolute;
    z-index: 2;
    left: 24px;
    right: 24px;
    bottom: 24px;
    margin: 0;
    background: var(--mqc-plum);
    border-radius: 28px 28px 28px 10px;
    color: #fff !important;
    padding: 16px 18px;
    font-family: "Aire Pro", Georgia, "Times New Roman", serif;
    font-size: 1.22rem;
    line-height: 1.12;
  }

  .mqc-bank {
    margin-top: 28px;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

  .mqc-bank div {
    border: 1px solid rgba(255, 255, 255, 0.24);
    border-radius: 24px 24px 32px 24px;
    background: rgba(255, 255, 255, 0.14);
    padding: 15px;
  }

  .mqc-bank span {
    display: block;
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.78rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .mqc-bank strong {
    display: inline-flex;
    align-items: center;
    width: 100%;
    margin-top: 8px;
    border-radius: 999px;
    background: #fff;
    color: var(--mqc-plum);
    font-family: "Intro", ui-sans-serif, system-ui, sans-serif;
    font-size: clamp(1rem, 1.7vw, 1.24rem);
    font-weight: 900;
    line-height: 1;
    padding: 12px 14px;
    white-space: nowrap;
  }

  .mqc-qr-stack {
    display: grid;
    grid-template-columns: minmax(240px, 360px) 1fr;
    gap: 16px;
    align-items: stretch;
  }

  .mqc-qr {
    margin: 0;
    padding: 12px;
    border-radius: 38px 38px 18px 18px;
    background: #fff;
    color: var(--mqc-ink);
  }

  .mqc-qr img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 28px 28px 10px 10px;
  }

  .mqc-qr figcaption {
    margin-top: 10px;
    color: var(--mqc-plum);
    font-family: "Intro", ui-sans-serif, system-ui, sans-serif;
    font-size: 0.74rem;
    font-weight: 900;
    line-height: 1.3;
    text-align: center;
    text-transform: uppercase;
  }

  .mqc-social-links {
    display: grid;
    gap: 10px;
  }

  .mqc-social-links a,
  .mqc-social-links a:visited {
    display: grid;
    gap: 4px;
    align-content: center;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 24px 24px 30px 24px;
    background: rgba(255, 255, 255, 0.12);
    padding: 13px 14px;
    color: #fff !important;
    text-decoration: none;
  }

  .mqc-social-links small {
    color: rgba(255, 255, 255, 0.68);
    font-size: 0.72rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .mqc-social-links strong {
    color: #fff;
    font-family: "Intro", ui-sans-serif, system-ui, sans-serif;
    font-size: 0.96rem;
    font-weight: 900;
    line-height: 1.08;
    text-transform: uppercase;
  }

  .mqc-social-links span {
    color: rgba(255, 255, 255, 0.74) !important;
    font-size: 0.9rem;
  }

  .mqc-form-section,
  .mqc-contact-section {
    position: relative;
    background: var(--mqc-soft);
    color: var(--mqc-ink);
    padding: 96px 0;
  }

  .mqc-form-section::before,
  .mqc-contact-section::before {
    content: "";
    position: absolute;
    right: -90px;
    bottom: -120px;
    width: min(520px, 76vw);
    height: min(520px, 76vw);
    background-image: url("/images/ven-ayudanos/mujeres/corazon-fucsia.svg");
    background-repeat: repeat;
    background-size: 82px auto;
    opacity: 0.055;
    mask-image: radial-gradient(circle at 50% 50%, black 0 52%, transparent 76%);
    pointer-events: none;
  }

  .mqc-form-grid,
  .mqc-contact-section .mqc-shell {
    position: relative;
    z-index: 1;
  }

  .mqc-form-copy img {
    width: 86px;
    height: auto;
    margin-bottom: 24px;
  }

  .mqc-form-copy {
    position: relative;
    border: 1px solid rgba(172, 86, 155, 0.16);
    border-radius: 76px 76px 28px 28px;
    background: rgba(255, 255, 255, 0.82);
    box-shadow: 0 24px 80px rgba(172, 86, 155, 0.12);
    padding: clamp(28px, 4vw, 44px);
  }

  .mqc-form-copy blockquote {
    margin: 28px 0 0;
    background: var(--mqc-plum);
    border: 0;
    border-radius: 34px 34px 34px 12px;
    color: #fff !important;
    padding: 22px 24px;
    font-family: "Aire Pro", Georgia, "Times New Roman", serif;
    font-size: clamp(1.55rem, 2.4vw, 2.15rem);
    font-style: italic;
    line-height: 1.16;
  }

  .mqc-form-panel {
    padding: clamp(20px, 3vw, 30px);
    border-radius: 34px;
    background: rgba(255, 255, 255, 0.9);
  }

  .mqc-form {
    display: grid;
    gap: 22px;
  }

  .mqc-field-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
  }

  .mqc-form label,
  .mqc-form fieldset {
    display: grid;
    gap: 8px;
    margin: 0;
    border: 0;
    padding: 0;
  }

  .mqc-form span,
  .mqc-form legend {
    color: var(--mqc-plum);
    font-size: 0.76rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .mqc-input {
    width: 100%;
    min-height: 48px;
    border: 1px solid rgba(172, 86, 155, 0.2);
    border-radius: 16px;
    background: #fff;
    color: var(--mqc-ink);
    padding: 12px 14px;
    outline: none;
  }

  .mqc-input::placeholder {
    color: rgba(66, 35, 63, 0.42);
  }

  .mqc-input:focus {
    border-color: var(--mqc-plum);
    box-shadow: 0 0 0 3px rgba(172, 86, 155, 0.12);
  }

  .mqc-input option {
    background: #fff;
    color: var(--mqc-ink);
  }

  .mqc-textarea {
    min-height: 130px;
    resize: vertical;
  }

  .mqc-check-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
  }

  .mqc-check {
    display: flex !important;
    align-items: center;
    min-height: 46px;
    border: 1px solid rgba(172, 86, 155, 0.18);
    border-radius: 18px;
    background: #fff;
    padding: 11px 12px;
  }

  .mqc-check input {
    width: 16px;
    height: 16px;
    margin: 0;
    color: var(--mqc-plum);
  }

  .mqc-check span {
    color: var(--mqc-ink);
    font-size: 0.82rem;
  }

  .mqc-form-actions {
    display: grid;
    gap: 14px;
  }

  .mqc-form-actions .mqc-btn {
    width: 100%;
  }

  .mqc-status {
    margin: 0;
    border: 1px solid rgba(172, 86, 155, 0.18);
    border-radius: 18px;
    background: #fff;
    color: var(--mqc-plum) !important;
    padding: 12px 14px;
  }

  .mqc-success {
    text-align: center;
  }

  .mqc-success img {
    width: 170px;
    margin: 0 auto 28px;
  }

  .mqc-success h3 {
    margin: 0;
    color: var(--mqc-plum);
    font-family: "Aire Pro", Georgia, "Times New Roman", serif;
    font-size: 2.4rem;
  }

  .mqc-success p {
    color: var(--mqc-muted) !important;
  }

  .mqc-contact-section {
    background: #fff;
    padding-top: 88px;
  }

  .mqc-contact-heading {
    max-width: 720px;
  }

  .mqc-contact-grid {
    margin-top: 34px;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }

  .mqc-contact {
    min-height: 116px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 16px;
    border: 1px solid rgba(172, 86, 155, 0.16);
    border-radius: 24px;
    background: var(--mqc-soft);
    padding: 18px;
  }

  .mqc-contact strong {
    display: block;
    color: var(--mqc-ink);
    font-size: 1.05rem;
  }

  .mqc-contact span {
    display: block;
    margin-top: 4px;
    font-size: 0.9rem;
  }

  .mqc-contact a,
  .mqc-contact a:visited {
    color: var(--mqc-plum) !important;
    font-weight: 900;
    text-decoration: none;
  }

  .mqc-mobile-cta,
  .mqc-mobile-cta:visited {
    position: fixed;
    z-index: 60;
    left: 16px;
    right: 16px;
    bottom: 16px;
    min-height: 52px;
    display: none;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: var(--mqc-plum);
    color: #fff !important;
    font-size: 0.82rem;
    font-weight: 900;
    text-decoration: none;
    text-transform: uppercase;
    box-shadow: 0 18px 42px rgba(172, 86, 155, 0.32);
  }

  .hidden {
    display: none !important;
  }

  @media (max-width: 1120px) {
    .mqc-help-grid,
    .mqc-contact-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .mqc-qr-stack {
      grid-template-columns: minmax(160px, 0.72fr) minmax(0, 1fr);
    }
  }

  @media (max-width: 900px) {
    .mqc-panel-inner {
      padding: 74px 0 54px;
    }

    .mqc-panel--call .mqc-panel-inner,
    .mqc-panel--virtues .mqc-panel-inner,
    .mqc-panel--give .mqc-panel-inner {
      padding-top: 70px;
      padding-bottom: 44px;
    }

    .mqc-hero-grid {
      grid-template-columns: minmax(0, 1fr) minmax(275px, 0.72fr);
      gap: 28px;
    }

    .mqc-call-grid {
      grid-template-columns: minmax(220px, 0.72fr) minmax(0, 1.28fr);
      gap: 24px;
    }

    .mqc-give-grid {
      grid-template-columns: minmax(250px, 0.78fr) minmax(0, 1.22fr);
      gap: 24px;
    }

    .mqc-virtues-grid {
      grid-template-columns: minmax(0, 1.08fr) minmax(230px, 0.72fr);
      gap: 24px;
    }

    .mqc-form-grid {
      grid-template-columns: 1fr;
    }

    .mqc-logo {
      width: 136px;
      margin-bottom: 22px;
    }

    .mqc-copy h1 {
      font-size: clamp(3rem, 6.1vw, 4.2rem);
    }

    .mqc-panel-copy h2 {
      font-size: clamp(2.05rem, 4.9vw, 3.25rem);
      line-height: 0.96;
    }

    .mqc-lead,
    .mqc-body,
    .mqc-form-copy p {
      margin-top: 16px;
      font-size: 0.98rem;
      line-height: 1.48;
    }

    .mqc-scripture {
      padding: 22px;
      border-radius: 54px 54px 22px 22px;
    }

    .mqc-scripture blockquote {
      margin: 14px 0;
      font-size: clamp(2.15rem, 5vw, 3.15rem);
    }

    .mqc-scripture img {
      width: min(260px, 100%);
      margin-top: 18px;
    }

    .mqc-help-grid,
    .mqc-virtue-grid {
      margin-top: 18px;
      gap: 9px;
    }

    .mqc-help {
      min-height: 94px;
      padding: 12px 13px;
    }

    .mqc-help strong {
      margin-bottom: 5px;
      font-size: 0.88rem;
    }

    .mqc-help p {
      font-size: 0.78rem;
      line-height: 1.34;
    }

    .mqc-tito-note {
      margin-top: 14px;
      padding: 12px 14px;
      font-size: 0.84rem;
    }

    .mqc-virtue {
      min-height: 50px;
      grid-template-columns: 34px 1fr;
      gap: 9px;
      padding: 8px 10px;
    }

    .mqc-virtue span {
      width: 32px;
      height: 32px;
      font-size: 0.78rem;
    }

    .mqc-virtue strong {
      font-size: 0.82rem;
      line-height: 1.08;
    }

