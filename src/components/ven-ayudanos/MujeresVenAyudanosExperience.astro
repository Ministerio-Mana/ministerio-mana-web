---
import CumbreLayout from '@components/cumbre2026/CumbreLayout.astro';
import TurnstileWidget from '@components/TurnstileWidget.astro';
import venAyudanosScript from '@scripts/ven-ayudanos.js?url';

const assetsBase = '/images/ven-ayudanos/mujeres';
const whatsappHref = 'https://api.whatsapp.com/send/?phone=573128472997&text=%C2%A1Hola+Mujeres+que+creen+y+dejan+legado%21%0AQuiero+conocer+informaci%C3%B3n+sobre%3A&type=phone_number&app_absent=0';
const websiteHref = 'https://mujeresquecreen.org/';
const spotifyHref = 'https://open.spotify.com/show/6bZVKObfABTipTXV0PigVa?si=4576bd25a1c64fb2';
const youtubeHref = 'https://www.youtube.com/@MujeresQueCreen';
const instagramHref = 'https://www.instagram.com/mujeresquecreenydejanlegado?igsh=M3h6bDkzOWZiYTd6';

const actionLinks = [
  {
    label: 'WhatsApp',
    title: 'Hablar con Mujeres',
    text: 'Escribe para unirte, preguntar por encuentros o recibir orientación.',
    href: whatsappHref,
  },
  {
    label: 'Spotify',
    title: 'Devocional',
    text: 'Escucha y comparte el devocional diario con otras mujeres.',
    href: spotifyHref,
  },
  {
    label: 'YouTube',
    title: 'Contenido',
    text: 'Apoya viendo, compartiendo y creando conversación alrededor de la Palabra.',
    href: youtubeHref,
  },
  {
    label: 'Instagram',
    title: 'Comunidad',
    text: 'Sigue la cuenta, comparte publicaciones y ayuda a amplificar el llamado.',
    href: instagramHref,
  },
];

const helpTracks = [
  { value: 'servicio', label: 'Servir', text: 'Acompañar encuentros, recibir mujeres y sostener espacios.' },
  { value: 'talentos', label: 'Crear', text: 'Diseño, fotografía, video, enseñanza, música o producción.' },
  { value: 'difusion', label: 'Compartir', text: 'Enviar devocionales, contenidos, invitaciones y testimonios.' },
  { value: 'oracion', label: 'Orar', text: 'Interceder por mujeres, familias, sedes y nuevas discípulas.' },
  { value: 'generosidad', label: 'Sembrar', text: 'Apoyar recursos, encuentros, cartillas y la expansión del ministerio.' },
  { value: 'apadrinamiento', label: 'Apadrinar', text: 'Sostener procesos y mujeres que necesitan acompañamiento.' },
];

const virtues = [
  'Discernimiento',
  'Honor',
  'Afecto',
  'Disciplina',
  'Responsabilidad',
  'Virtud',
  'Benevolencia',
  'Disposición',
  'Legado',
  'Belleza',
];

const contacts = [
  { city: 'Londres', detail: 'Contacto internacional', phone: '+33 666 548305', wa: '33666548305' },
  { city: 'París', detail: 'Contacto internacional', phone: '+33 664 175342', wa: '33664175342' },
  { city: 'Orlando, Florida', detail: 'Beatriz Henao', phone: '+1 407 5809897', wa: '14075809897' },
  { city: 'Carolina del Norte', detail: 'Gloria Martínez', phone: '+1 347 8135589', wa: '13478135589' },
  { city: 'Providence, Rhode Island', detail: 'Contacto local', phone: '+1 401 5161478', wa: '14015161478' },
  { city: 'Atlanta, Georgia', detail: 'Claudia Salazar', phone: '+1 770 5393573', wa: '17705393573' },
  { city: 'New Jersey', detail: 'Contacto local', phone: '+1 908 4144802', wa: '19084144802' },
  { city: 'Ixcatepec', detail: 'Contacto México', phone: '+52 789 1126016', wa: '527891126016' },
  { city: 'Bogotá', detail: 'Contacto Colombia', phone: '+57 318 4373583', wa: '573184373583' },
  { city: 'Cali', detail: 'Contacto Colombia', phone: '+57 301 6539295', wa: '573016539295' },
  { city: 'Itagüí', detail: 'Contacto Colombia', phone: '+57 305 3548906', wa: '573053548906' },
  { city: 'Cuenca, Ecuador', detail: 'Contacto Ecuador', phone: '+593 98 1696000', wa: '593981696000' },
];

const formHelpOptions = [
  { value: 'servicio', label: 'Servir' },
  { value: 'talentos', label: 'Crear contenido' },
  { value: 'difusion', label: 'Compartir' },
  { value: 'oracion', label: 'Orar' },
  { value: 'generosidad', label: 'Sembrar' },
  { value: 'apadrinamiento', label: 'Apadrinar' },
];
---

<CumbreLayout
  title="Mujeres que sostienen el llamado | Ven y Ayúdanos"
  description="Una invitación para unirte, servir, crear contenido, compartir el devocional, sembrar y sostener la red de Mujeres que Creen y Dejan Legado."
  image={`${assetsBase}/mujeres-virtudes-lineup.png`}
  imageAlt="Mujeres que creen y dejan legado"
  imageWidth={1890}
  imageHeight={1241}
  imageType="image/png"
  flush
  showEventBadge={false}
>
  <main class="mqc-page" data-ven-ayudanos data-initial-ministry="mujeres">
    <section class="mqc-hero" id="inicio">
      <div class="mqc-hero__background" aria-hidden="true">
        <div class="mqc-hero__arc mqc-hero__arc--top"></div>
        <div class="mqc-hero__arc mqc-hero__arc--bottom"></div>
        <div class="mqc-dot-field"></div>
      </div>

      <div class="mqc-hero__inner">
        <div class="mqc-hero__copy">
          <img src={`${assetsBase}/logo-mujeres-blanco.svg`} alt="Mujeres que creen y dejan legado" class="mqc-logo" />
          <p class="mqc-kicker">Ven y ayúdanos</p>
          <h1>Mujeres que sostienen el llamado</h1>
          <p class="mqc-lead">
            Una red de mujeres que creen profundamente, sirven con amor, forman a otras en la Palabra y dejan legado.
          </p>
          <div class="mqc-actions">
            <a href="#primer-paso" class="mqc-btn mqc-btn--light" data-scroll-form>Responder al llamado</a>
            <a href={whatsappHref} class="mqc-btn mqc-btn--outline" target="_blank" rel="noopener noreferrer">WhatsApp</a>
            <button type="button" class="mqc-btn mqc-btn--ghost" data-share-page>Compartir</button>
          </div>
        </div>

        <div class="mqc-hero__art" aria-hidden="true">
          <img src={`${assetsBase}/cariatide-blanca.svg`} alt="" class="mqc-cariatide" />
          <img src={`${assetsBase}/barca-blanca.svg`} alt="" class="mqc-boat mqc-boat--hero" />
          <div class="mqc-verse">
            <p>
              “Que nuestras hijas sean como columnas elegantes, talladas para embellecer un palacio.”
            </p>
            <strong>Salmos 144:12 NTV</strong>
          </div>
        </div>
      </div>
    </section>

    <section class="mqc-section mqc-section--light" id="llamado">
      <div class="mqc-shell mqc-intro">
        <div class="mqc-intro__aside">
          <div class="mqc-section-heading">
            <p>Hechos 16:9</p>
            <h2>La ayuda toma forma cuando alguien responde</h2>
          </div>
          <img src={`${assetsBase}/barca-fucsia.svg`} alt="" class="mqc-intro-boat" aria-hidden="true" />
        </div>
        <div class="mqc-intro__text">
          <p>
            Esta interna existe para convertir el llamado de la Cumbre en pasos concretos: unirse a la comunidad, compartir recursos, servir en encuentros, crear contenido, orar y sembrar.
          </p>
          <p>
            La barca y la red hablan de una obra que no se sostiene sola. Mujeres sostiene estructura, cuidado, formación y comunidad para que otras puedan florecer en Cristo.
          </p>
        </div>
      </div>
    </section>

    <section class="mqc-section mqc-section--dark" id="virtudes">
      <div class="mqc-shell mqc-virtues">
        <div class="mqc-virtues__art" aria-hidden="true">
          <img src={`${assetsBase}/mujeres-virtudes-lineup.png`} alt="" />
        </div>
        <div class="mqc-virtues__content">
          <div class="mqc-section-heading">
            <p>Tito 2:3-5</p>
            <h2>10 virtudes de feminidad bíblica</h2>
          </div>
          <p class="mqc-section-copy">
            La visión de Mujeres que Creen no se queda en inspiración: forma carácter, discipulado y servicio. Estas virtudes ayudan a orientar conversaciones, encuentros, grupos y contenido.
          </p>
          <div class="mqc-virtue-grid">
            {virtues.map((virtue, index) => (
              <article class="mqc-virtue">
                <span>{String(index + 1).padStart(2, '0')}</span>
                <strong>{virtue}</strong>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="mqc-section mqc-section--paper" id="acciones">
      <div class="mqc-shell">
        <div class="mqc-section-heading mqc-section-heading--center">
          <p>Cómo puedes ayudar</p>
          <h2>Un sí puede sostener muchas vidas</h2>
        </div>

        <div class="mqc-help-grid">
          {helpTracks.map((track) => (
            <article class="mqc-help">
              <span>{track.label}</span>
              <p>{track.text}</p>
            </article>
          ))}
        </div>

        <div class="mqc-link-band">
          {actionLinks.map((item) => (
            <a href={item.href} target="_blank" rel="noopener noreferrer" class="mqc-link-item">
              <small>{item.label}</small>
              <strong>{item.title}</strong>
              <span>{item.text}</span>
            </a>
          ))}
          <a href={websiteHref} target="_blank" rel="noopener noreferrer" class="mqc-link-item mqc-link-item--wide">
            <small>Sitio web</small>
            <strong>Conoce Mujeres que Creen</strong>
            <span>Consulta historia, eventos, recursos y más información oficial del ministerio.</span>
          </a>
        </div>
      </div>
    </section>

    <section class="mqc-section mqc-section--donation" id="sembrar">
      <div class="mqc-shell mqc-donation">
        <div class="mqc-donation__copy">
          <img src={`${assetsBase}/corazon-blanco.svg`} alt="" class="mqc-heart" />
          <p class="mqc-kicker">Generosidad</p>
          <h2>Siembra en la obra de Mujeres</h2>
          <p>
            Tu apoyo ayuda a sostener recursos, encuentros, contenidos, cartillas y procesos de discipulado para mujeres en distintas ciudades.
          </p>
          <div class="mqc-bank">
            <div>
              <span>Cuenta de ahorros Bancolombia</span>
              <strong>255 0000 8527</strong>
            </div>
            <div>
              <span>Llave</span>
              <strong>0092110399</strong>
            </div>
          </div>
          <div class="mqc-actions">
            <button type="button" class="mqc-btn mqc-btn--light" data-copy-value="25500008527">Copiar cuenta</button>
            <button type="button" class="mqc-btn mqc-btn--outline" data-copy-value="0092110399">Copiar llave</button>
          </div>
        </div>
        <figure class="mqc-qr">
          <img src={`${assetsBase}/qr-bancolombia-mujeres.jpg`} alt="QR Bancolombia Mujeres que Creen" />
          <figcaption>Mujeres Que Creen · Iglesia Ministerio Maná</figcaption>
        </figure>
      </div>
    </section>

    <section class="mqc-section mqc-section--light" id="contactos">
      <div class="mqc-shell">
        <div class="mqc-section-heading">
          <p>Red de contactos</p>
          <h2>Encuentra una mujer cerca de tu ciudad</h2>
        </div>
        <div class="mqc-contact-grid">
          {contacts.map((contact) => (
            <article class="mqc-contact">
              <div>
                <strong>{contact.city}</strong>
                <span>{contact.detail}</span>
              </div>
              <a href={`https://wa.me/${contact.wa}`} target="_blank" rel="noopener noreferrer">{contact.phone}</a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="primer-paso" class="mqc-section mqc-section--form">
      <div class="mqc-shell mqc-form-layout">
        <div class="mqc-form-copy">
          <img src={`${assetsBase}/ven-y-ayudanos.svg`} alt="Ven y ayúdanos" class="mqc-help-logo" />
          <h2>Da tu primer paso</h2>
          <p>
            Esto no es un compromiso definitivo. Es una conversación para descubrir cómo tus manos, recursos, ideas y dones pueden ayudar.
          </p>
          <blockquote>
            Padre amado, forma en mí una mujer que cree profundamente y deja legado.
          </blockquote>
        </div>

        <div class="mqc-form-panel">
          <form
            id="ven-ayudanos-form"
            class="mqc-form"
            action="/api/ven-ayudanos/responder"
            method="post"
            data-help-form
          >
            <input type="hidden" name="origin" value="mujeres" data-hidden-origin data-default-value="mujeres" />
            <input type="hidden" name="place" value="ven-ayudanos-mujeres" data-hidden-place data-default-value="ven-ayudanos-mujeres" />
            <input type="hidden" name="utmSource" data-hidden-utm-source />
            <input type="hidden" name="utmMedium" data-hidden-utm-medium />
            <input type="hidden" name="utmCampaign" data-hidden-utm-campaign />
            <input type="hidden" name="qr" data-hidden-qr />
            <input type="hidden" name="path" data-hidden-path />

            <div class="mqc-field-grid">
              <label>
                <span>Nombre</span>
                <input name="fullName" required autocomplete="name" class="mqc-input" placeholder="Nombre completo" />
              </label>
              <label>
                <span>WhatsApp</span>
                <input name="whatsapp" required inputmode="tel" autocomplete="tel" class="mqc-input" placeholder="+57 300 000 0000" />
              </label>
              <label>
                <span>Correo</span>
                <input name="email" type="email" autocomplete="email" class="mqc-input" placeholder="correo@ejemplo.com" />
              </label>
              <label>
                <span>Ciudad</span>
                <input name="city" autocomplete="address-level2" class="mqc-input" placeholder="Ciudad" />
              </label>
              <label>
                <span>Iglesia / sede</span>
                <input name="church" class="mqc-input" placeholder="Iglesia o sede" />
              </label>
              <label>
                <span>Ministerio de interés</span>
                <select name="ministry" required class="mqc-input" data-ministry-select>
                  <option value="mujeres" selected>Mujeres que Creen</option>
                  <option value="no-estoy-seguro">No estoy segura</option>
                  <option value="mana">Ministerio Maná</option>
                  <option value="ninos">Niños</option>
                  <option value="varones">Varones</option>
                  <option value="campus">Campus Maná</option>
                </select>
              </label>
            </div>

            <fieldset>
              <legend>Puedo aportar con</legend>
              <div class="mqc-check-grid">
                {formHelpOptions.map((option) => (
                  <label class="mqc-check">
                    <input type="checkbox" name="helpTypes" value={option.value} />
                    <span>{option.label}</span>
                  </label>
                ))}
              </div>
            </fieldset>

            <label>
              <span>Cómo te gustaría ayudar</span>
              <textarea name="message" rows="4" class="mqc-input mqc-textarea" placeholder="Cuéntanos si quieres servir, crear contenido, compartir el devocional, orar, sembrar o unirte a la comunidad."></textarea>
            </label>

            <label>
              <span>Disponibilidad</span>
              <select name="availability" class="mqc-input">
                <option value="no-estoy-seguro">No estoy segura</option>
                <option value="semanal">Semanal</option>
                <option value="mensual">Mensual</option>
                <option value="eventos-especiales">Eventos especiales</option>
              </select>
            </label>

            <TurnstileWidget appearance="always" theme="dark" />

            <div class="mqc-form-actions">
              <button type="submit" class="mqc-btn mqc-btn--light" data-submit-button>Responder al llamado</button>
              <p class="mqc-status hidden" data-form-status></p>
            </div>
          </form>

          <div class="mqc-success hidden" data-success-panel>
            <img src={`${assetsBase}/logo-mujeres-blanco.svg`} alt="Mujeres que creen y dejan legado" />
            <h3>Gracias por responder.</h3>
            <p>Un líder del ministerio se comunicará contigo pronto.</p>
            <div class="mqc-actions">
              <button type="button" class="mqc-btn mqc-btn--outline" data-share-page>Compartir</button>
              <a href={whatsappHref} class="mqc-btn mqc-btn--light" target="_blank" rel="noopener noreferrer">WhatsApp</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <a href="#primer-paso" class="mqc-mobile-cta" data-scroll-form>Responder al llamado</a>
  </main>

  <script type="module" src={venAyudanosScript}></script>
</CumbreLayout>

<style is:global>
  @font-face {
    font-family: "Aire Pro";
    src: url("/fonts/aire/aire-bold-pro.ttf") format("truetype");
    font-weight: 700;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: "Aire Pro";
    src: url("/fonts/aire/aire-bold-italic-pro.otf") format("opentype");
    font-weight: 700;
    font-style: italic;
    font-display: swap;
  }

  .mqc-page {
    --mqc-plum: #ac569b;
    --mqc-rose: #ce86b9;
    --mqc-soft: #f8eef5;
    --mqc-ink: #171019;
    --mqc-muted: #6d5b68;
    background: var(--mqc-ink);
    color: #fff;
    font-family: "Intro", ui-sans-serif, system-ui, sans-serif;
    overflow: hidden;
  }

  .mqc-page * {
    box-sizing: border-box;
    letter-spacing: 0;
  }

  .mqc-page p,
  .mqc-page strong,
  .mqc-page a {
    color: inherit;
  }

  .mqc-shell {
    width: min(1180px, calc(100% - 40px));
    margin: 0 auto;
  }

  .mqc-hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    overflow: hidden;
    isolation: isolate;
    background:
      linear-gradient(115deg, rgba(20, 11, 22, 0.98), rgba(44, 24, 44, 0.88)),
      #171019;
  }

  .mqc-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 0;
    background-image: url("/images/ven-ayudanos/mujeres/corazon-fucsia.svg");
    background-repeat: repeat;
    background-size: 86px auto;
    opacity: 0.08;
    pointer-events: none;
  }

  .mqc-hero__background {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .mqc-hero__arc {
    position: absolute;
    left: 50%;
    width: 1180px;
    height: 430px;
    border-radius: 0 0 620px 620px;
    background: var(--mqc-plum);
    transform: translateX(-50%);
  }

  .mqc-hero__arc--top {
    top: -270px;
  }

  .mqc-hero__arc--bottom {
    bottom: -285px;
    border-radius: 620px 620px 0 0;
    background: var(--mqc-rose);
    opacity: 0.86;
  }

  .mqc-dot-field {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle, rgba(255, 255, 255, 0.92) 0 2px, transparent 2.6px),
      radial-gradient(circle, rgba(206, 134, 185, 0.52) 0 2px, transparent 2.8px);
    background-position: 74% 18%, 24% 78%;
    background-size: 120px 120px, 160px 160px;
    opacity: 0.42;
  }

  .mqc-hero__inner {
    position: relative;
    z-index: 2;
    width: min(1240px, calc(100% - 40px));
    margin: 0 auto;
    padding: 120px 0 96px;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 0.78fr);
    gap: 56px;
    align-items: center;
  }

  .mqc-logo {
    width: 180px;
    height: auto;
    margin-bottom: 42px;
  }

  .mqc-kicker {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    margin: 0 0 18px;
    padding: 9px 18px;
    border-radius: 999px;
    background: #fff;
    color: var(--mqc-plum) !important;
    font-size: 0.76rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .mqc-hero h1 {
    max-width: 740px;
    margin: 0;
    color: #fff;
    font-size: 4.7rem;
    line-height: 0.95;
    font-weight: 800;
    text-transform: uppercase;
  }

  .mqc-lead {
    max-width: 650px;
    margin: 28px 0 0;
    color: rgba(255, 255, 255, 0.82) !important;
    font-size: 1.25rem;
    line-height: 1.55;
    font-weight: 500;
  }

  .mqc-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 30px;
  }

  .mqc-btn,
  .mqc-btn:visited {
    min-height: 48px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid transparent;
    border-radius: 999px;
    padding: 13px 22px;
    font-size: 0.82rem;
    font-weight: 800;
    text-transform: uppercase;
    text-decoration: none;
    transition: transform 180ms ease, background-color 180ms ease, color 180ms ease, border-color 180ms ease;
    cursor: pointer;
  }

  .mqc-btn:hover,
  .mqc-btn:focus-visible {
    transform: translateY(-2px);
  }

  .mqc-btn--light {
    background: #fff;
    color: var(--mqc-plum) !important;
  }

  .mqc-btn--outline {
    background: transparent;
    border-color: rgba(255, 255, 255, 0.45);
    color: #fff !important;
  }

  .mqc-btn--ghost {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.18);
    color: #fff !important;
  }

  .mqc-hero__art {
    position: relative;
    min-height: 650px;
    display: grid;
    place-items: center;
  }

  .mqc-cariatide {
    position: relative;
    z-index: 2;
    height: 560px;
    width: auto;
    max-width: 100%;
    filter: drop-shadow(0 20px 32px rgba(0, 0, 0, 0.25));
  }

  .mqc-boat {
    display: block;
    height: auto;
  }

  .mqc-boat--hero {
    position: absolute;
    z-index: 1;
    left: -18px;
    bottom: 118px;
    width: min(430px, 76%);
    opacity: 0.72;
    transform: rotate(-2deg);
    filter: drop-shadow(0 22px 24px rgba(0, 0, 0, 0.2));
  }

  .mqc-verse {
    position: absolute;
    z-index: 3;
    right: 0;
    bottom: 44px;
    width: min(340px, 88%);
    padding: 24px;
    background: rgba(172, 86, 155, 0.88);
    color: #fff;
  }

  .mqc-verse p {
    margin: 0;
    color: #fff !important;
    font-size: 1rem;
    line-height: 1.5;
  }

  .mqc-verse strong {
    display: block;
    margin-top: 16px;
    color: #fff;
