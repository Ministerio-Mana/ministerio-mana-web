---
interface Props {
  missionaryName: string;
  wompiLink?: string;
  stripePriceId?: string;
  slug?: string;
}

const { wompiLink, stripePriceId, slug, missionaryName } = Astro.props;
---

<div class="donation-widget relative p-6 transition-all group overflow-visible" data-wompi={wompiLink} data-stripe={stripePriceId} data-slug={slug}>
  
  <!-- Title -->
  <div class="mb-6 text-center">
      <h3 class="font-intro text-[#001B3A] text-xl uppercase tracking-wide">
        TU APOYO
      </h3>
      <p class="text-xs font-intro-reg text-brand-teal uppercase tracking-widest mt-2">Siembra en el Reino</p>
      <div class="w-12 h-[2px] bg-brand-teal mx-auto mt-3 rounded-full"></div>
  </div>

  <div class="relative z-10">
      <!-- Frequency Selector -->
      <div class="flex mb-6 gap-3 frequency-selector">
        <button type="button" class="freq-btn flex-1 py-2 text-xs font-intro uppercase transition-all text-[#001B3A] bg-transparent border-2 border-[#001B3A] hover:bg-brand-teal hover:border-brand-teal hover:text-white" style="border-radius: 255px 15px 225px 15px / 15px 225px 15px 255px;" data-freq="monthly">Mensual</button>
        <button type="button" class="freq-btn flex-1 py-2 text-xs font-intro uppercase transition-all text-gray-400 border-2 border-transparent hover:text-[#001B3A] hover:underline decoration-wavy decoration-brand-teal" data-freq="once">Única vez</button>
      </div>

      <!-- Currency Selector -->
      <div class="mb-6 relative">
          <label class="block text-[10px] font-intro uppercase text-gray-400 mb-2 tracking-widest">Moneda</label>
        <div class="relative">
            <select class="currency-select w-full appearance-none bg-transparent border-b-2 border-[#001B3A]/20 text-[#001B3A] font-intro text-sm py-2 px-0 pr-8 focus:outline-none focus:border-brand-teal transition-all cursor-pointer">
                <option value="COP">🇨🇴 Peso Colombiano (COP)</option>
                <option value="USD">🇺🇸 Dólar (USD)</option>
            </select>
            <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center text-[#001B3A]">
                <svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg>
            </div>
        </div>
      </div>

      <!-- Predefined Amounts -->
      <div class="amounts-grid grid grid-cols-3 gap-3 mb-6">
        <!-- JS populates this -->
      </div>

      <!-- Custom Amount -->
      <div class="relative mb-8 group-input border-2 border-[#001B3A] p-2" style="border-radius: 255px 15px 225px 15px / 15px 225px 15px 255px;">
        <span class="currency-symbol absolute left-4 top-1/2 -translate-y-1/2 text-brand-teal font-intro text-lg">$</span>
        <input type="number" 
               class="custom-amount-input w-full bg-transparent border-none text-[#001B3A] font-intro text-xl py-1 pl-6 pr-4 focus:outline-none text-center placeholder-gray-300"
               placeholder="Otro..." min="0">
      </div>

      <!-- CTA Button -->
      <a href={wompiLink || '#'} target="_blank" class="donate-cta block w-full py-4 bg-[#001B3A] text-white font-intro text-center text-sm uppercase tracking-widest hover:bg-brand-teal hover:text-[#001B3A] transition-all flex items-center justify-center gap-2 shadow-lg" style="border-radius: 255px 15px 225px 15px / 15px 225px 15px 255px;">
        <span class="cta-text">Donar Ahora</span>
        <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
      </a>
      
      <p class="text-[10px] text-center text-gray-400 mt-4 font-intro-reg tracking-wide flex items-center justify-center gap-2">
         <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
         Pago seguro vía <span class="provider-name text-gray-500 font-bold">Wompi</span>
      </p>
  </div>
</div>

<style>
    .font-intro { font-family: 'Intro', sans-serif; font-weight: 900; }
    .font-intro-reg { font-family: 'Intro', sans-serif; font-weight: 400; }
    
    /* Organic Input Focus */
    .group-input:focus-within {
        border-color: #2DD4BF;
        box-shadow: 0 4px 12px rgba(45, 212, 191, 0.2);
    }
</style>
