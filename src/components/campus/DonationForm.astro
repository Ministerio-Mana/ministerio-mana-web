---
interface Props {
  missionaryName: string;
  wompiLink?: string;
  stripePriceId?: string;
  slug?: string;
}

const { wompiLink, stripePriceId, slug, missionaryName } = Astro.props;
---

<div class="donation-widget relative bg-[#001B3A] border border-white/10 p-8 rounded-3xl shadow-xl transition-all hover:bg-[#002552] group overflow-hidden" data-wompi={wompiLink} data-stripe={stripePriceId} data-slug={slug}>
  
  <!-- Geometric Decoration -->
  <div class="absolute -top-12 -right-12 w-32 h-32 bg-brand-teal/5 rounded-full blur-2xl group-hover:bg-brand-teal/10 transition-all"></div>
  <div class="absolute bottom-0 left-0 w-full h-1 bg-gradient-to-r from-brand-teal to-transparent"></div>

  <div class="relative z-10">
      <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-full bg-brand-teal flex items-center justify-center text-[#001B3A]">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <div>
            <h3 class="font-intro text-xl text-white uppercase tracking-wide">Tu Apoyo</h3>
            <p class="text-xs font-bold text-brand-teal uppercase tracking-widest">Siembra en el Reino</p>
          </div>
      </div>

      <!-- Frequency Selector -->
      <div class="flex mb-6 p-1 bg-black/20 rounded-full border border-white/5 frequency-selector">
        <button type="button" class="freq-btn flex-1 py-2 text-xs font-bold uppercase rounded-full transition-all text-[#001B3A] bg-white shadow-lg" data-freq="monthly">Mensual</button>
        <button type="button" class="freq-btn flex-1 py-2 text-xs font-bold uppercase rounded-full transition-all text-white/40 hover:text-white" data-freq="once">Única vez</button>
      </div>

      <!-- Currency Selector -->
      <div class="mb-6">
        <label class="block text-[10px] font-bold uppercase text-white/40 mb-2 tracking-widest">Moneda</label>
        <div class="relative">
            <select class="currency-select w-full appearance-none bg-white/5 border border-white/10 text-white font-bold text-sm py-3 px-4 pr-8 rounded-xl focus:outline-none focus:border-brand-teal focus:ring-1 focus:ring-brand-teal transition-all cursor-pointer hover:bg-white/10">
                <option value="COP" class="text-[#001B3A]">🇨🇴 Peso Colombiano (COP)</option>
                <option value="USD" class="text-[#001B3A]">🇺🇸 Dólar (USD)</option>
            </select>
            <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-white/40">
                <svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg>
            </div>
        </div>
      </div>

      <!-- Predefined Amounts -->
      <div class="amounts-grid grid grid-cols-3 gap-2 mb-4">
        <!-- JS populates this -->
      </div>

      <!-- Custom Amount -->
      <div class="relative mb-8 group-input">
        <span class="currency-symbol absolute left-4 top-1/2 -translate-y-1/2 text-brand-teal font-intro text-lg">$</span>
        <input type="number" 
               class="custom-amount-input w-full bg-transparent border-b border-white/20 text-white font-intro text-2xl py-3 pl-8 pr-4 focus:outline-none focus:border-brand-teal transition-colors placeholder-white/10"
               placeholder="Otro valor..." min="0">
      </div>

      <!-- CTA Button -->
      <a href={wompiLink || '#'} target="_blank" class="donate-cta block w-full py-4 bg-gradient-to-r from-brand-teal to-blue-500 text-white font-intro text-center text-sm uppercase tracking-widest rounded-full shadow-lg hover:shadow-brand-teal/20 hover:scale-[1.02] transition-all flex items-center justify-center gap-2 group-hover:brightness-110">
        <span class="cta-text">Donar Ahora</span>
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
      </a>
      
      <p class="text-[10px] text-center text-white/30 mt-4 font-medium tracking-wide flex items-center justify-center gap-2">
         <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
         Pago seguro vía <span class="provider-name text-white/60 font-bold">Wompi</span>
      </p>
  </div>
</div>

<style>
    .font-intro { font-family: 'Montserrat', sans-serif; font-weight: 900; }
    .amounts-grid button.selected {
        background-color: #2DD4BF; /* brand-teal */
        color: #001B3A;
        border-color: #2DD4BF;
        font-weight: 900;
        box-shadow: 0 4px 12px rgba(45, 212, 191, 0.3);
    }
</style>
