---
import SowingIcon from '@components/icons/SowingIcon.astro';

interface Props {
  missionaryName: string;
  slug: string;
  country?: string;
}

const { slug, missionaryName, country = 'CO' } = Astro.props;
const initialCurrency = String(country).toUpperCase() === 'CO'
  ? {
      code: 'COP',
      context: 'Monto en pesos colombianos (COP)',
      placeholder: '50.000',
      minLabel: 'Mínimo $5.000 COP',
      provider: 'Wompi',
    }
  : {
      code: 'USD',
      context: 'Monto en dólares (USD)',
      placeholder: '25',
      minLabel: 'Mínimo $5 USD',
      provider: 'Stripe',
    };
---

<div class="donation-widget relative p-4 sm:p-6 transition-all group overflow-visible"
     data-slug={slug}
     data-missionary-name={missionaryName}
     data-country={country}>
  
  <!-- Title -->
  <div class="mb-6 text-center">
      <h3 class="font-intro text-[#001B3A] text-lg uppercase tracking-wide">
        Tu apoyo ayuda a la extensión
      </h3>
      <p class="text-xs font-intro-reg text-brand-teal uppercase tracking-widest mt-1">del Reino</p>
      <div class="w-12 h-[2px] bg-brand-teal mx-auto mt-3 rounded-full"></div>
  </div>

  <div class="relative z-10">
      <!-- Frequency Selector — scribble buttons -->
      <div class="flex mb-6 gap-3 frequency-selector">
        <button type="button" class="freq-btn btn-scribble flex-1 py-2 text-xs font-intro uppercase text-[#001B3A]" data-freq="monthly">Mensual</button>
        <button type="button" class="freq-btn btn-scribble flex-1 py-2 text-xs font-intro uppercase text-gray-400" data-freq="once">Única vez</button>
      </div>

      <!-- Custom Amount — organic border -->
      <div class="custom-amount-control">
        <div class="mb-4 text-center">
          <p class="amount-title text-[10px] font-intro uppercase text-[#001B3A] tracking-widest">Escribe tu donación</p>
          <p class="currency-context mt-1 text-[10px] font-intro-reg text-gray-500">{initialCurrency.context}</p>
        </div>
        <div class="relative mb-2 group-input select-organic p-2">
          <span class="currency-symbol absolute left-4 top-1/2 -translate-y-1/2 text-brand-teal font-intro text-lg">$</span>
          <input type="text"
                 inputmode="decimal"
                 class="custom-amount-input w-full bg-transparent border-none text-[#001B3A] font-intro text-xl py-1 pl-8 pr-4 focus:outline-none text-center placeholder-gray-300"
                 placeholder={initialCurrency.placeholder}>
          <span class="currency-code sr-only">{initialCurrency.code}</span>
        </div>
        <p class="amount-min-label mb-5 text-center text-[10px] font-intro-reg text-gray-400">{initialCurrency.minLabel}</p>
      </div>

      <div class="amount-method-state hidden mb-5 rounded-xl border border-[#001B3A]/15 bg-[#F3F0E6] px-4 py-3 text-center">
        <p class="amount-method-text font-intro-reg text-xs leading-relaxed text-[#001B3A]/75"></p>
        <button type="button" class="amount-method-reset mt-2 font-intro text-[10px] uppercase tracking-widest text-[#001B3A] underline decoration-brand-teal/60 underline-offset-4">
          Cambiar monto
        </button>
      </div>

      <!-- Predefined Amounts -->
      <div class="quick-amount-control mb-6">
        <p class="quick-amount-label block text-[10px] font-intro uppercase text-gray-400 mb-2 tracking-widest text-center">Escoge un monto rápido</p>
        <div class="amounts-grid grid grid-cols-3 gap-3">
          <!-- JS populates this -->
        </div>
      </div>

      <!-- Donor Info (inline, shown in same form) -->
      <div class="donor-info-section hidden mb-6 space-y-3">
        <p class="text-center text-[10px] font-intro uppercase text-gray-400 tracking-widest mb-2">Tus datos para el pago</p>
        <input type="text" class="donor-name-input donor-input-single w-full" placeholder="Nombre completo *">
        <input type="email" class="donor-email-input donor-input-single w-full" placeholder="tucorreo@email.com *">
        <input type="tel" class="donor-phone-input donor-input-single w-full" placeholder="Teléfono / WhatsApp">
        <input type="text" class="donor-city-input donor-input-single w-full" placeholder="Ciudad">
        <div class="campus-document-fields space-y-3">
          <select class="donor-document-type-input donor-input-single w-full" aria-label="Tipo de documento">
            <option value="">Tipo de identificación *</option>
            <option value="CC">Cédula de ciudadanía</option>
            <option value="CE">Cédula de extranjería</option>
            <option value="TI">Tarjeta de identidad</option>
            <option value="PAS">Pasaporte</option>
            <option value="NIT">NIT</option>
          </select>
          <input type="text" class="donor-document-number-input donor-input-single w-full" placeholder="Número de identificación *">
          <p class="document-help text-[10px] font-intro-reg text-gray-400 text-center">
            Requerido para pagos procesados en Colombia por Wompi.
          </p>
        </div>
      </div>

      <div class="monthly-account-gate hidden mb-6 rounded-xl border border-[#001B3A]/15 bg-[#F3F0E6] p-4 text-center">
        <p class="font-intro text-xs uppercase tracking-widest text-[#001B3A]">Cuenta requerida</p>
        <p class="mt-2 text-xs font-intro-reg leading-relaxed text-[#001B3A]/70">
          Para una siembra mensual necesitas iniciar sesión o crear una cuenta. Así podrás pausar, reactivar o cancelar desde el portal.
        </p>
        <div class="mt-4 grid gap-2">
          <a class="account-login-link inline-flex items-center justify-center rounded-lg bg-[#001B3A] px-3 py-2 text-[10px] font-intro uppercase tracking-widest text-white" href="/portal/ingresar">
            Iniciar sesión
          </a>
          <a class="account-register-link inline-flex items-center justify-center rounded-lg border border-[#001B3A]/20 bg-white px-3 py-2 text-[10px] font-intro uppercase tracking-widest text-[#001B3A]" href="/portal/registro">
            Crear cuenta
          </a>
        </div>
      </div>

      <!-- Error message -->
      <div class="donation-error hidden text-center mb-3">
        <p class="text-red-600 text-xs font-intro-reg bg-red-50 py-2 px-3 rounded-lg inline-block"></p>
      </div>

      <!-- CTA Button — scribble style -->
      <button type="button" class="donate-cta btn-scribble block w-full py-4 bg-[#001B3A] text-white font-intro text-center text-sm uppercase tracking-widest flex items-center justify-center gap-2 opacity-50 pointer-events-none">
        <span class="cta-text">Donar Ahora</span>
        <SowingIcon class="cta-icon" />
      </button>
      
      <p class="text-[10px] text-center text-gray-400 mt-4 font-intro-reg tracking-wide flex items-center justify-center gap-2">
         <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
         Pago seguro vía <span class="provider-name text-gray-500 font-bold">{initialCurrency.provider}</span>
      </p>
      <p class="mt-2 text-center text-[10px] font-intro-reg text-gray-400">
        Al donar aceptas los <a href="/donaciones/terminos-suscripciones" class="font-bold text-[#001B3A] underline decoration-brand-teal/60 underline-offset-2">terminos de donaciones y suscripciones</a>.
      </p>
  </div>
</div>

<style>
    .font-intro { font-family: 'Intro', sans-serif; font-weight: 900; }
    .font-intro-reg { font-family: 'Intro', sans-serif; font-weight: 400; }

    /* Scribble Button in DonationForm context */
    .btn-scribble {
        position: relative;
        z-index: 10;
        transition: transform 0.2s, background-color 0.3s, color 0.3s;
    }
    .btn-scribble::before {
        content: '';
        position: absolute;
        inset: -4px;
        border: 2px solid currentColor;
        border-radius: 255px 15px 225px 15px / 15px 225px 15px 255px;
        z-index: -1;
        opacity: 0.5;
        transition: all 0.4s ease;
    }
    .btn-scribble:hover::before {
        border-radius: 15px 255px 15px 255px / 255px 15px 255px 15px;
        transform: scale(1.06);
        opacity: 1;
    }

    /* Organic selector */
    .select-organic {
        border-radius: 255px 15px 225px 15px / 15px 225px 15px 255px;
        border: 2px solid #001B3A;
        background: transparent;
        transition: border-color 0.3s;
    }
    .select-organic:focus, .select-organic:hover {
        border-color: #2DD4BF;
    }
    
    /* Focus glow on custom input */
    .group-input:focus-within {
        border-color: #2DD4BF;
        box-shadow: 0 4px 12px rgba(45, 212, 191, 0.2);
    }

    .amounts-grid {
        grid-template-columns: repeat(auto-fit, minmax(5.8rem, 1fr));
    }

    .amount-btn {
        min-height: 2.75rem;
        white-space: nowrap;
    }

    /* Single donation form inputs */
    .donor-input-single {
        background: #ffffff;
        color: #001B3A;
        font-family: 'Intro', sans-serif;
        font-weight: 400;
        font-size: 0.8rem;
        padding: 0.5rem 0.75rem;
        border: 2px solid #001B3A;
        border-radius: 255px 15px 225px 15px / 15px 225px 15px 255px;
        transition: border-color 0.3s, box-shadow 0.3s;
        outline: none;
    }
    .donor-input-single::placeholder {
        color: rgba(0, 27, 58, 0.35);
    }
    .donor-input-single:focus {
        border-color: #2DD4BF;
        box-shadow: 0 0 0 3px rgba(45, 212, 191, 0.15);
    }

    .cta-icon {
        display: inline-flex;
        width: 1.85rem;
        height: 1.85rem;
        padding: 0.18rem;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.14);
        transform: translateY(-1px);
        transition: background 0.2s ease, transform 0.2s ease;
    }

    .donate-cta:hover .cta-icon {
        background: rgba(255, 255, 255, 0.22);
        transform: translate(2px, -1px);
    }

    .donate-cta.is-hidden {
        display: none !important;
    }
</style>
