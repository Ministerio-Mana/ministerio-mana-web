---
import { MISIONEROS } from '@data/misioneros';
import SowingIcon from '@components/icons/SowingIcon.astro';
interface Props {
    country?: string;
    initialMissionarySlug?: string;
    initialMissionaryName?: string;
}
const { country = 'CO', initialMissionarySlug = '', initialMissionaryName = '' } = Astro.props;
const totalMissionaries = MISIONEROS.length;
const hasInitialMissionary = Boolean(initialMissionarySlug);
const initialCurrency = String(country).toUpperCase() === 'CO'
    ? {
        code: 'COP',
        context: 'Monto en pesos colombianos (COP)',
        placeholder: 'Ej: 200.000',
        minLabel: 'Mínimo $5.000 COP',
        provider: 'Wompi',
    }
    : {
        code: 'USD',
        context: 'Monto en dólares (USD)',
        placeholder: 'Ej: 100',
        minLabel: 'Mínimo $5 USD',
        provider: 'Stripe',
    };
---

<section id="multi-donation" class="scroll-mt-28 py-24 bg-brand-teal relative overflow-hidden">
    <div class="absolute inset-0 opacity-5 bg-[url('https://www.transparenttextures.com/patterns/notebook.png')]"></div>

    <div class="container-tight px-4 relative z-10"
         id="multi-donation-flow"
         data-country={country}
         data-initial-missionary={initialMissionarySlug}
         data-initial-missionary-name={initialMissionaryName}
         data-missionaries={JSON.stringify(MISIONEROS.map(m => ({
            slug: m.slug,
            nombre: m.nombre,
            rol: m.rol,
            foto: m.foto,
         })))}>

        <!-- ===== STEP 1: ¿Quieres sembrar en varios? ===== -->
        <div class="flow-step active" data-step="1">
            <div class="text-center mb-12">
                <span class="font-summer text-white block mb-[-8px] transform -rotate-2" style="font-size: clamp(3.7rem, 12vw, 8rem);">¿Quieres sembrar</span>
                <h2 class="font-intro text-[#001B3A] uppercase" style="font-size: clamp(2.35rem, 10vw, 6rem);">
                    {hasInitialMissionary ? 'EN MÁS MISIONEROS?' : 'EN VARIOS MISIONEROS?'}
                </h2>
            </div>

            <p class="text-center text-white/90 font-intro-reg text-lg md:text-xl max-w-2xl mx-auto mb-12 leading-relaxed">
                {hasInitialMissionary
                    ? `Ya incluimos a ${initialMissionaryName || 'este misionero'} por este QR. Puedes sumar más misioneros y luego escribir cuánto quieres sembrar a cada uno.`
                    : 'Selecciona cuántos misioneros Campus quieres apoyar y luego escribe cuánto quieres sembrar a cada uno.'}
            </p>

            <div class="flex flex-wrap justify-center gap-4 md:gap-6">
                <button type="button" class="count-btn btn-scribble px-8 py-4 bg-[#001B3A] text-white font-intro text-xl md:text-2xl uppercase tracking-wider" data-count="2">
                    2 misioneros
                </button>
                <button type="button" class="count-btn btn-scribble px-8 py-4 bg-[#001B3A] text-white font-intro text-xl md:text-2xl uppercase tracking-wider" data-count="3">
                    3 misioneros
                </button>
                <button type="button" class="count-btn btn-scribble px-8 py-4 bg-[#001B3A] text-white font-intro text-xl md:text-2xl uppercase tracking-wider" data-count="4">
                    4 misioneros
                </button>
                {totalMissionaries >= 5 && (
                    <button type="button" class="count-btn btn-scribble px-8 py-4 bg-[#001B3A] text-white font-intro text-xl md:text-2xl uppercase tracking-wider" data-count="5">
                        5 misioneros
                    </button>
                )}
                <button type="button" class="count-btn btn-scribble px-8 py-4 bg-[#001B3A] text-white font-intro text-xl md:text-2xl uppercase tracking-wider" data-count={totalMissionaries}>
                    Todos ({totalMissionaries})
                </button>
            </div>
        </div>

        <!-- ===== STEP 2: Selecciona misioneros ===== -->
        <div class="flow-step hidden" data-step="2">
            <div class="text-center mb-8">
                <span class="font-summer text-white block mb-[-8px] transform -rotate-2" style="font-size: clamp(3.5rem, 7vw, 5.5rem);">Selecciona</span>
                <h2 class="font-intro text-[#001B3A] uppercase" style="font-size: clamp(2.5rem, 6vw, 4.5rem);">
                    TUS MISIONEROS
                </h2>
                <p class="text-white/90 font-intro-reg text-lg mt-4">
                    Seleccionados: <span class="selected-count font-intro text-[#001B3A]">0/2</span>
                </p>
                <p class={`initial-missionary-note ${hasInitialMissionary ? '' : 'hidden'} text-white/75 font-intro-reg text-sm mt-2`}>
                    <span class="font-intro text-[#001B3A]">{initialMissionaryName}</span> ya está incluido por el QR.
                </p>
            </div>

            <!-- Random button -->
            <div class="text-center mb-8">
                <button type="button" id="random-btn" class="btn-scribble px-6 py-3 bg-[#001B3A]/80 text-white font-intro text-sm uppercase tracking-wider inline-flex items-center gap-2">
                    🎲 AL AZAR
                </button>
            </div>

            <!-- Missionary cards -->
            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 mb-12" id="missionary-chips">
                {MISIONEROS.map((m) => (
                    <button type="button"
                        class={`missionary-chip ${m.slug === initialMissionarySlug ? 'locked' : ''} p-3 text-left transition-all duration-300 cursor-pointer select-none`}
                        data-slug={m.slug}
                        data-name={m.nombre}>
                        <span class="flex items-center gap-3">
                            <span class="relative h-16 w-16 shrink-0 overflow-hidden rounded-2xl border-2 border-[#001B3A] bg-[#001B3A]">
                                {m.foto ? (
                                    <img src={m.foto} alt={m.nombre} class="h-full w-full object-cover" loading="lazy" />
                                ) : (
                                    <span class="flex h-full w-full items-center justify-center text-xs text-white/40">CM</span>
                                )}
                            </span>
                            <span class="min-w-0">
                                <span class="name block font-intro text-sm uppercase tracking-wide text-white">{m.nombre}</span>
                                <span class="block font-intro-reg text-[11px] text-white/65">{m.rol || 'Misionero Campus'}</span>
                                <span class="locked-label mt-1 hidden font-intro text-[9px] uppercase tracking-widest text-[#FACC15]">Incluido por QR</span>
                            </span>
                            <span class="check-mark ml-auto hidden h-7 w-7 shrink-0 items-center justify-center rounded-full bg-[#2DD4BF] font-intro text-[#001B3A]">✓</span>
                        </span>
                    </button>
                ))}
            </div>

            <div class="flex justify-center gap-4">
                <button type="button" class="back-btn btn-scribble px-6 py-3 bg-transparent text-white font-intro text-base uppercase border-none">
                    ← Volver
                </button>
                <button type="button" id="confirm-selection-btn" class="btn-scribble px-8 py-4 bg-[#001B3A] text-white font-intro text-lg uppercase tracking-wider opacity-50 pointer-events-none">
                    Continuar →
                </button>
            </div>
        </div>

        <!-- ===== STEP 3: Monto y Frecuencia ===== -->
        <div class="flow-step hidden" data-step="3">
            <div class="text-center mb-8">
                <span class="font-summer text-white block mb-[-8px] transform -rotate-2" style="font-size: clamp(3.5rem, 7vw, 5.5rem);">¿Cuánto quieres</span>
                <h2 class="font-intro text-[#001B3A] uppercase" style="font-size: clamp(2.5rem, 6vw, 4.5rem);">
                    SEMBRAR?
                </h2>
            </div>

            <div class="max-w-xl mx-auto">
                <!-- Frequency -->
                <div class="flex gap-3 mb-6 max-w-xs mx-auto">
                    <button type="button" class="multi-freq-btn btn-scribble flex-1 py-2 text-xs font-intro uppercase text-white" data-freq="monthly" style="background-color: #001B3A;">Mensual</button>
                    <button type="button" class="multi-freq-btn btn-scribble flex-1 py-2 text-xs font-intro uppercase text-white/50" data-freq="once">Única vez</button>
                </div>

                <!-- Total budget input -->
                <div id="multi-total-control" class="mb-5">
                    <div class="mb-4 text-center">
                        <p class="text-[10px] font-intro uppercase text-[#001B3A] tracking-widest">Tengo este presupuesto total para Campus</p>
                        <p id="multi-currency-context" class="mt-1 text-[10px] font-intro-reg text-white/75">{initialCurrency.context}</p>
                    </div>
                    <div class="relative mb-2 select-organic p-2 bg-white max-w-xs mx-auto">
                        <span class="multi-currency-symbol absolute left-4 top-1/2 -translate-y-1/2 text-brand-teal font-intro text-lg">$</span>
                        <input type="text"
                               inputmode="decimal"
                               id="multi-total-amount"
                               class="w-full bg-transparent border-none text-[#001B3A] font-intro text-xl py-1 pl-8 pr-4 focus:outline-none text-center placeholder-gray-300"
                               placeholder={initialCurrency.placeholder}>
                        <span id="multi-currency-code" class="sr-only">{initialCurrency.code}</span>
                    </div>
                    <p id="multi-amount-min-label" class="mb-2 text-center text-[10px] font-intro-reg text-white/65">{initialCurrency.minLabel}</p>
                    <p class="text-center text-[10px] font-intro-reg text-white/75">
                        Lo dividimos en partes iguales. Luego puedes ajustar cada misionero.
                    </p>
                </div>

                <div id="multi-method-state" class="hidden mb-5 rounded-2xl border border-white/25 bg-white/15 px-4 py-3 text-center">
                    <p id="multi-method-state-text" class="font-intro-reg text-xs leading-relaxed text-white"></p>
                    <button type="button" id="multi-method-reset" class="mt-2 font-intro text-[10px] uppercase tracking-widest text-[#001B3A] underline decoration-white/60 underline-offset-4">
                        Cambiar forma de calcular
                    </button>
                </div>

                <p id="multi-manual-help" class="mb-5 text-center text-[10px] font-intro-reg text-white/75">
                    También puedes escribir directamente cuánto quieres sembrar en cada misionero.
                </p>

                <!-- Amount buttons -->
                <div id="multi-quick-control" class="mb-6">
                    <p class="block text-[10px] font-intro uppercase text-white/70 mb-2 tracking-widest text-center">Mismo monto rápido para cada misionero</p>
                    <div class="grid grid-cols-3 gap-3" id="multi-amounts-grid">
                        <!-- JS populates -->
                    </div>
                </div>

                <div class="mb-6 rounded-2xl bg-[#001B3A]/15 p-4">
                    <p class="mb-3 text-center text-[10px] font-intro uppercase tracking-widest text-[#001B3A]">
                        Ajusta la siembra por misionero
                    </p>
                    <div id="multi-allocation-list" class="space-y-3">
                        <!-- JS populates selected missionaries -->
                    </div>
                </div>

                <!-- Summary -->
                <div id="multi-summary" class="text-center mb-8 py-4 px-6 bg-[#001B3A]/20 rounded-2xl hidden">
                    <p class="text-white font-intro-reg text-base">
                        Total de tu siembra:
                        <span id="summary-total" class="font-intro text-white text-xl">$0</span>
                        <span class="block text-xs text-white/70 mt-1">
                            Distribuida entre <span id="summary-count" class="font-intro text-[#001B3A]">0</span> misioneros.
                        </span>
                    </p>
                </div>
            </div>

            <div class="flex justify-center gap-4">
                <button type="button" class="back-btn btn-scribble px-6 py-3 bg-transparent text-white font-intro text-base uppercase border-none">
                    ← Volver
                </button>
                <button type="button" id="confirm-amount-btn" class="btn-scribble px-8 py-4 bg-[#001B3A] text-white font-intro text-lg uppercase tracking-wider opacity-50 pointer-events-none">
                    Ver Resumen →
                </button>
            </div>
        </div>

        <!-- ===== STEP 4: Donor Info & Pay ===== -->
        <div class="flow-step hidden" data-step="4">
            <div class="text-center mb-8">
                <span class="font-summer text-white block mb-[-8px] transform -rotate-2" style="font-size: clamp(3.5rem, 7vw, 5.5rem);">Tu siembra</span>
                <h2 class="font-intro text-[#001B3A] uppercase" style="font-size: clamp(2.5rem, 6vw, 4.5rem);">
                    ESTÁ LISTA
                </h2>
            </div>

            <!-- Summary cards -->
            <div class="max-w-2xl mx-auto mb-8" id="payment-summary">
                <!-- JS populates with per-missionary cards -->
            </div>

            <div class="text-center mb-8">
                <p class="text-[#001B3A] font-intro text-2xl" id="grand-total">Total: $0</p>
                <p class="text-white/70 font-intro-reg text-xs mt-1" id="freq-label"></p>
            </div>

            <!-- Donor Info Form -->
            <div class="max-w-md mx-auto mb-8 space-y-4">
                <p class="text-center text-white/80 font-intro text-xs uppercase tracking-widest mb-4">Tus datos para el pago</p>

                <div id="multi-account-gate" class="hidden rounded-2xl border border-white/25 bg-white/90 p-4 text-center shadow-lg">
                    <p class="font-intro text-xs uppercase tracking-widest text-[#001B3A]">Cuenta requerida</p>
                    <p class="mt-2 text-xs font-intro-reg leading-relaxed text-[#001B3A]/70">
                        Para una siembra mensual necesitas iniciar sesión o crear una cuenta. Así podrás pausar, reactivar o cancelar desde el portal.
                    </p>
                    <div class="mt-4 grid gap-2 sm:grid-cols-2">
                        <a id="multi-login-link" class="inline-flex items-center justify-center rounded-lg bg-[#001B3A] px-3 py-2 text-[10px] font-intro uppercase tracking-widest text-white" href="/portal/ingresar">
                            Iniciar sesión
                        </a>
                        <a id="multi-register-link" class="inline-flex items-center justify-center rounded-lg border border-[#001B3A]/20 bg-white px-3 py-2 text-[10px] font-intro uppercase tracking-widest text-[#001B3A]" href="/portal/registro">
                            Crear cuenta
                        </a>
                    </div>
                </div>
                
                <div class="multi-donor-field">
                    <input type="text" id="donor-name" required
                           placeholder="Nombre completo *"
                           class="donor-input">
                </div>
                <div class="multi-donor-field">
                    <input type="email" id="donor-email" required
                           placeholder="tucorreo@email.com *"
                           class="donor-input">
                </div>
                <div class="multi-donor-field">
                    <input type="tel" id="donor-phone"
                           placeholder="Teléfono / WhatsApp"
                           class="donor-input">
                </div>
                <div class="multi-donor-field">
                    <input type="text" id="donor-city"
                           placeholder="Ciudad"
                           class="donor-input">
                </div>
                <div id="multi-document-fields" class="multi-donor-field space-y-3">
                    <select id="donor-document-type" class="donor-input" aria-label="Tipo de documento">
                        <option value="">Tipo de identificación *</option>
                        <option value="CC">Cédula de ciudadanía</option>
                        <option value="CE">Cédula de extranjería</option>
                        <option value="TI">Tarjeta de identidad</option>
                        <option value="PAS">Pasaporte</option>
                        <option value="NIT">NIT</option>
                    </select>
                    <input type="text" id="donor-document-number"
                           placeholder="Número de identificación *"
                           class="donor-input">
                    <p class="text-center text-white/65 font-intro-reg text-[10px]">
                        Requerido para pagos procesados en Colombia por Wompi.
                    </p>
                </div>
            </div>

            <!-- Error message -->
            <div id="checkout-error" class="hidden text-center mb-4">
                <p class="text-red-200 font-intro-reg text-sm bg-red-900/30 py-2 px-4 rounded-xl inline-block"></p>
            </div>

            <div class="flex justify-center gap-4">
                <button type="button" class="back-btn btn-scribble px-6 py-3 bg-transparent text-white font-intro text-base uppercase border-none">
                    ← Volver
                </button>
                <button type="button" id="pay-btn" class="btn-scribble inline-flex items-center justify-center gap-3 px-10 py-5 bg-[#001B3A] text-white font-intro text-2xl uppercase tracking-wider shadow-2xl">
                    <span>SEMBRAR AHORA</span>
                    <SowingIcon class="pay-seed-icon" />
                </button>
            </div>

            <p class="text-center text-white/50 font-intro-reg text-[10px] mt-4 flex items-center justify-center gap-1">
                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
                Pago seguro procesado por <span id="provider-label" class="font-intro">{initialCurrency.provider}</span>
            </p>
            <p class="mt-2 text-center text-white/55 font-intro-reg text-[10px]">
                Al donar aceptas los <a href="/donaciones/terminos-suscripciones" class="font-intro text-[#001B3A] underline decoration-white/60 underline-offset-2">terminos de donaciones y suscripciones</a>.
            </p>
        </div>
    </div>
</section>

<style>
    .font-intro { font-family: 'Intro', sans-serif; font-weight: 900; }
    .font-intro-reg { font-family: 'Intro', sans-serif; font-weight: 400; }
    .font-summer { font-family: 'Summer Loving', cursive; }

    .flow-step {
        transition: opacity 0.4s ease, transform 0.4s ease;
    }
    .flow-step.hidden {
        display: none;
    }
    .flow-step.active {
        animation: fadeSlideIn 0.5s ease forwards;
    }

    @keyframes fadeSlideIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* Missionary card — organic unselected */
    .missionary-chip {
        background: rgba(255, 255, 255, 0.08);
        color: white;
        border: 2px solid rgba(255,255,255,0.4);
        border-radius: 24px 10px 22px 12px / 12px 22px 10px 24px;
        min-height: 92px;
    }
    .missionary-chip:hover {
        border-color: white;
        background: rgba(255,255,255,0.1);
    }
    .missionary-chip.selected {
        background: #001B3A;
        color: #2DD4BF;
        border-color: #001B3A;
        transform: translateY(-2px);
        box-shadow: 0 4px 15px rgba(0,27,58,0.4);
    }
    .missionary-chip.locked {
        cursor: default;
    }
    .missionary-chip.locked .locked-label {
        display: block;
    }
    .missionary-chip.selected .check-mark {
        display: inline-flex;
    }

    /* Scribble Button in multi-flow context */
    .btn-scribble {
        position: relative;
        z-index: 10;
        transition: transform 0.2s, background-color 0.3s, color 0.3s;
    }
    .btn-scribble::before {
        content: '';
        position: absolute;
        inset: -4px;
        border: 2px solid currentColor;
        border-radius: 255px 15px 225px 15px / 15px 225px 15px 255px;
        z-index: -1;
        opacity: 0.5;
        transition: all 0.4s ease;
    }
    .btn-scribble:hover::before {
        border-radius: 15px 255px 15px 255px / 255px 15px 255px 15px;
        transform: scale(1.06);
        opacity: 1;
    }

    .select-organic {
        border-radius: 255px 15px 225px 15px / 15px 225px 15px 255px;
        border: 2px solid #001B3A;
        background: transparent;
        transition: border-color 0.3s;
    }
    .select-organic:focus, .select-organic:hover {
        border-color: #001B3A;
    }

    /* Donor info inputs — solid white with visible placeholders */
    .donor-input {
        width: 100%;
        background: #ffffff;
        color: #001B3A;
        font-family: 'Intro', sans-serif;
        font-weight: 400;
        font-size: 0.875rem;
        padding: 0.625rem 1rem;
        border: 2px solid #001B3A;
        border-radius: 255px 15px 225px 15px / 15px 225px 15px 255px;
        transition: border-color 0.3s, box-shadow 0.3s;
        outline: none;
    }
    .donor-input::placeholder {
        color: rgba(0, 27, 58, 0.40);
    }
    .donor-input:focus {
        border-color: #001B3A;
        box-shadow: 0 0 0 3px rgba(0, 27, 58, 0.15);
    }

    #pay-btn.is-hidden {
        display: none !important;
    }
</style>
