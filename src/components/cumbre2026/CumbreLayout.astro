---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NetOverlay from './NetOverlay.astro';
import AccountButton from '@components/AccountButton.astro';
import cumbreNavScript from '../../scripts/cumbre-nav.js?url';

const {
  title,
  description,
  image,
  imageAlt,
  imageWidth,
  imageHeight,
  imageType,
  variant = 'dark',
  enableSmoothScroll = false,
  flush = false,
  showEventBadge = true,
  showBackButton = true,
  backHref = '/eventos/cumbre-mundial-2026',
  backLabel = 'Volver',
  useHistoryBack = true,
  noindex = false,
} = Astro.props;

const isLight = variant === 'light';
const mainBg = isLight ? 'bg-slate-50 text-brand-dark' : 'bg-brand-void text-white';
const overflowMode = flush ? 'overflow-visible' : 'overflow-hidden';
const cspNonce = Astro.locals?.cspNonce;
---

<BaseLayout
  title={title}
  description={description}
  image={image}
  imageAlt={imageAlt}
  imageWidth={imageWidth}
  imageHeight={imageHeight}
  imageType={imageType}
  noindex={noindex}
  hideHeader
  hideFooter
  disableSmoothScroll={!enableSmoothScroll}
>
  <div class={`relative min-h-screen ${mainBg} ${overflowMode}`}>
    <!-- Top Controls -->
    <div class="fixed top-5 left-5 right-5 z-50 flex items-center justify-between pointer-events-none">
      {showBackButton ? (
        <a
          id="cumbre-back-link"
          href={backHref}
          data-use-history-back={useHistoryBack ? 'true' : 'false'}
          class={`cumbre-action ${
            isLight
              ? 'cumbre-action--light-ghost'
              : 'cumbre-action--dark-ghost'
          } pointer-events-auto inline-flex gap-2 rounded-full px-4 py-2 text-xs font-bold uppercase tracking-widest backdrop-blur-md transition`}
        >
          <span aria-hidden="true">←</span>
          <span>{backLabel}</span>
        </a>
      ) : (
        <div aria-hidden="true"></div>
      )}
      <div class="pointer-events-auto">
        <div
          id="cumbre-account-shell"
          class={`rounded-full border backdrop-blur-md px-2 py-1 ${isLight ? 'bg-white/70 border-brand-navy/10' : 'bg-white/10 border-white/10'}`}
        >
          <AccountButton variant={isLight ? 'light' : 'dark'} />
        </div>
      </div>
    </div>
    <!-- Shared Background Effects (Dark Mode Only) -->
    {!isLight && (
      <div class="fixed inset-0 pointer-events-none z-0">
         <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-brand-void via-[#0F1623] to-black opacity-90"></div>
         <NetOverlay />
      </div>
    )}

    {isLight && (
       <div class="fixed inset-0 pointer-events-none z-0 opacity-40">
          <div class="absolute inset-0 bg-[url('/grid.svg')] opacity-[0.05]"></div>
          <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-brand-gold/5 rounded-full blur-[120px]"></div>
          <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-brand-navy/5 rounded-full blur-[100px]"></div>
       </div>
    )}

    <!-- Content -->
    <div class={`relative z-10 ${flush ? '' : 'pt-16'}`}>
      {showEventBadge && (
        <div class="px-4 md:px-8">
          <div class="max-w-7xl mx-auto">
            <div class={`inline-flex items-center gap-2 px-4 py-2 rounded-full border backdrop-blur-md text-xs font-semibold tracking-[0.4em] uppercase ${isLight ? 'bg-white/60 border-brand-navy/10 text-brand-navy' : 'bg-white/5 border-white/10 text-brand-teal'}`}>
              Ven y Ayúdanos · Cumbre Mundial
            </div>
          </div>
        </div>
      )}
      <slot />
    </div>

    <!-- Floating WhatsApp -->
    <a 
      href="https://wa.me/573148297534" 
      target="_blank"
      rel="noopener noreferrer"
      class="cumbre-action cumbre-action--whatsapp fixed bottom-6 right-6 z-50 flex items-center justify-center w-14 h-14 rounded-full shadow-lg hover:scale-110 transition-transform duration-300 group"
      aria-label="Contactar por WhatsApp"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
      </svg>
      <!-- Tooltip -->
      <span class="absolute right-full mr-3 px-3 py-1 bg-white text-gray-800 text-xs font-bold rounded-lg opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap">
        ¿Necesitas ayuda?
      </span>
    </a>

    <script type="module" src={cumbreNavScript} nonce={cspNonce}></script>
  </div>
</BaseLayout>

<style is:global>
  .cumbre-action {
    --cumbre-action-bg: transparent;
    --cumbre-action-fg: #ffffff;
    --cumbre-action-border: transparent;
    --cumbre-action-hover-bg: var(--cumbre-action-bg);
    --cumbre-action-hover-fg: var(--cumbre-action-fg);
    --cumbre-action-hover-border: var(--cumbre-action-border);
    align-items: center;
    justify-content: center;
    border: 1px solid var(--cumbre-action-border);
    background: var(--cumbre-action-bg);
    color: var(--cumbre-action-fg) !important;
  }

  .cumbre-action:hover,
  .cumbre-action:focus-visible,
  .cumbre-action:active {
    border-color: var(--cumbre-action-hover-border);
    background: var(--cumbre-action-hover-bg);
    color: var(--cumbre-action-hover-fg) !important;
  }

  .cumbre-action--teal {
    --cumbre-action-bg: #28a6bd;
    --cumbre-action-fg: #0b1120;
    --cumbre-action-border: #28a6bd;
    --cumbre-action-hover-bg: #4cc9e0;
    --cumbre-action-hover-fg: #0b1120;
    --cumbre-action-hover-border: #4cc9e0;
  }

  .cumbre-action--white {
    --cumbre-action-bg: #ffffff;
    --cumbre-action-fg: #293c74;
    --cumbre-action-border: #ffffff;
    --cumbre-action-hover-bg: #f1f3f8;
    --cumbre-action-hover-fg: #1a255c;
    --cumbre-action-hover-border: #f1f3f8;
  }

  .cumbre-action--dark-ghost {
    --cumbre-action-bg: rgba(255, 255, 255, 0.1);
    --cumbre-action-fg: rgba(255, 255, 255, 0.82);
    --cumbre-action-border: rgba(255, 255, 255, 0.16);
    --cumbre-action-hover-bg: rgba(255, 255, 255, 0.18);
    --cumbre-action-hover-fg: #ffffff;
    --cumbre-action-hover-border: rgba(255, 255, 255, 0.3);
  }

  .cumbre-action--light-ghost {
    --cumbre-action-bg: rgba(255, 255, 255, 0.8);
    --cumbre-action-fg: #293c74;
    --cumbre-action-border: rgba(41, 60, 116, 0.12);
    --cumbre-action-hover-bg: #ffffff;
    --cumbre-action-hover-fg: #1a255c;
    --cumbre-action-hover-border: rgba(41, 60, 116, 0.22);
  }

  .cumbre-action--gold-ghost {
    --cumbre-action-bg: transparent;
    --cumbre-action-fg: #f2c94c;
    --cumbre-action-border: rgba(242, 201, 76, 0.4);
    --cumbre-action-hover-bg: rgba(242, 201, 76, 0.14);
    --cumbre-action-hover-fg: #ffe38a;
    --cumbre-action-hover-border: rgba(255, 227, 138, 0.58);
  }

  .cumbre-action--whatsapp {
    --cumbre-action-bg: #25d366;
    --cumbre-action-fg: #062914;
    --cumbre-action-border: #25d366;
    --cumbre-action-hover-bg: #20bd5c;
    --cumbre-action-hover-fg: #031b0d;
    --cumbre-action-hover-border: #20bd5c;
  }

  .cumbre-inline-link {
    color: rgba(255, 255, 255, 0.72) !important;
  }

  .cumbre-inline-link:hover,
  .cumbre-inline-link:focus-visible,
  .cumbre-inline-link:active {
    color: #ffffff !important;
  }

  html[data-cumbre-panel-theme='light'] #cumbre-back-link {
    background: rgba(255, 255, 255, 0.84);
    border-color: rgba(26, 37, 92, 0.16);
    color: #1A255C;
    box-shadow: 0 14px 40px rgba(26, 37, 92, 0.12);
  }

  html[data-cumbre-panel-theme='light'] #cumbre-account-shell {
    background: rgba(255, 255, 255, 0.84);
    border-color: rgba(26, 37, 92, 0.16);
    box-shadow: 0 14px 40px rgba(26, 37, 92, 0.12);
  }

  html[data-cumbre-panel-theme='light'] #account-guest {
    color: #1A255C;
    border-color: rgba(26, 37, 92, 0.18);
  }
</style>
