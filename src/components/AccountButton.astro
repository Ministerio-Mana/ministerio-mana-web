---
// This component detects if user has an active session
// Shows "Iniciar sesión" for guests or account dropdown for logged users
const { variant = 'light' } = Astro.props;
const cspNonce = Astro.locals?.cspNonce;

const isDark = variant === 'dark';
const guestClass = isDark
  ? 'hidden items-center gap-2 px-4 py-2 rounded-full border border-white/20 bg-white/10 hover:border-white/40 hover:bg-white/15 transition-all text-sm font-medium text-white/90 hover:text-white'
  : 'hidden items-center gap-2 px-4 py-2 rounded-full border border-[var(--mana-border)] bg-white/70 hover:border-brand-medium hover:bg-brand-teal/5 transition-all text-sm font-medium text-brand-dark hover:text-brand-medium';
const loggedSummaryClass = isDark
  ? 'flex items-center gap-2 px-4 py-2 rounded-full border border-white/20 bg-white/10 hover:border-white/40 hover:bg-white/15 transition-all cursor-pointer select-none text-white/90 hover:text-white'
  : 'flex items-center gap-2 px-4 py-2 rounded-full border border-[var(--mana-border)] bg-white/70 hover:border-brand-medium hover:bg-brand-teal/5 transition-all cursor-pointer select-none text-brand-dark hover:text-brand-medium';
const avatarClass = isDark
  ? 'w-8 h-8 rounded-full bg-brand-teal/20 flex items-center justify-center text-white font-bold text-sm'
  : 'w-8 h-8 rounded-full bg-brand-teal/10 flex items-center justify-center text-brand-dark font-bold text-sm';
const nameClass = isDark
  ? 'hidden sm:inline text-sm font-medium text-white/90'
  : 'hidden sm:inline text-sm font-medium text-brand-dark';
const chevronClass = isDark ? 'h-4 w-4 text-white/70' : 'h-4 w-4 text-neutral-400';
const dropdownClass = isDark
  ? 'absolute right-0 mt-3 w-56 rounded-2xl border border-white/20 bg-brand-void/95 p-2 shadow-2xl shadow-black/30 backdrop-blur-xl z-50'
  : 'absolute right-0 mt-3 w-56 rounded-2xl border border-[var(--mana-border-strong)] bg-[var(--mana-surface)] p-2 shadow-lg z-50';
const portalLinkClass = isDark
  ? 'flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-white/10 text-white/80 hover:text-white transition-colors text-sm'
  : 'flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-neutral-50 text-neutral-700 hover:text-brand-dark transition-colors text-sm';
const dividerClass = isDark ? 'my-2 border-white/15' : 'my-2 border-[var(--mana-border)]';
const logoutClass = isDark
  ? 'w-full flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-red-500/10 text-red-300 hover:text-red-200 transition-colors text-sm'
  : 'w-full flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-red-50 text-red-600 hover:text-red-700 transition-colors text-sm';
---

<div id="account-button-container" class="relative">
  <!-- Guest state: Show login button -->
  <a 
    id="account-guest" 
    href="/portal/ingresar" 
    class={guestClass.replace('hidden ', 'flex ')}
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
    </svg>
    <span class="inline max-[420px]:sr-only">Iniciar sesión</span>
  </a>
  
  <!-- Logged state: Show account button -->
  <details id="account-logged" class="hidden relative">
    <summary class={loggedSummaryClass}>
      <div class={avatarClass}>
        <span id="account-initials">U</span>
      </div>
      <span id="account-name" class={nameClass}></span>
      <svg xmlns="http://www.w3.org/2000/svg" class={chevronClass} fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
      </svg>
    </summary>
    
    <div class={dropdownClass}>
      <a href="/portal/" class={portalLinkClass}>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
        </svg>
        Portal Maná
      </a>
      <hr class={dividerClass} />
      <button id="btn-logout-header" class={logoutClass}>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1" />
        </svg>
        Cerrar sesión
      </button>
    </div>
  </details>
</div>

<script>
  import { getSupabaseBrowserClient } from '@lib/supabaseBrowser';
  import type { SupabaseClient } from '@supabase/supabase-js';

  const container = document.getElementById('account-button-container');
  const guestBtn = document.getElementById('account-guest');
  const loggedBtn = document.getElementById('account-logged');
  const loggedSummary = loggedBtn?.querySelector('summary');
  const accountName = document.getElementById('account-name');
  const accountInitials = document.getElementById('account-initials');
  const logoutBtn = document.getElementById('btn-logout-header');

  function showGuest() {
    if (loggedBtn) loggedBtn.classList.add('hidden');
    if (guestBtn) {
      guestBtn.classList.remove('hidden');
      guestBtn.classList.add('flex');
    }
  }

  let supabase: SupabaseClient | null = null;
  try {
    supabase = getSupabaseBrowserClient();
  } catch {
    showGuest();
  }

  async function checkSession() {
    if (!supabase) {
      showGuest();
      return;
    }
    try {
      const { data: { session } } = await supabase.auth.getSession();

      if (session?.user) {
        const userName = String(
          session.user.user_metadata?.full_name || session.user.email?.split('@')[0] || 'Usuario',
        );
        const nameParts = userName.split(' ');
        const initials = nameParts
          .map((part) => (part ? part[0] : ''))
          .join('')
          .substring(0, 2)
          .toUpperCase();

        if (accountName) accountName.textContent = userName.split(' ')[0];
        if (accountInitials) accountInitials.textContent = initials;

        if (guestBtn) {
          guestBtn.classList.remove('flex');
          guestBtn.classList.add('hidden');
        }
        if (loggedBtn) loggedBtn.classList.remove('hidden');
      } else {
        if (loggedBtn) loggedBtn.classList.add('hidden');
        if (guestBtn) {
          guestBtn.classList.remove('hidden');
          guestBtn.classList.add('flex');
        }
      }
    } catch (err) {
      console.error('Error checking session:', err);
      if (loggedBtn) loggedBtn.classList.add('hidden');
      if (guestBtn) {
        guestBtn.classList.remove('hidden');
        guestBtn.classList.add('flex');
      }
    }
  }

  if (logoutBtn instanceof HTMLButtonElement) {
    logoutBtn.addEventListener('click', async () => {
      logoutBtn.disabled = true;
      logoutBtn.textContent = 'Saliendo...';
      if (supabase) {
        await supabase.auth.signOut();
      }
      window.location.href = '/';
    });
  }

  loggedSummary?.addEventListener('click', (event) => {
    if (!window.matchMedia('(max-width: 680px)').matches) return;
    event.preventDefault();
    window.location.href = '/portal/';
  });

  checkSession();
</script>
