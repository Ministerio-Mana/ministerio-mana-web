---
import churchesData from '@data/churches.json';
import { buildChurchGeoTree } from '@lib/churchGeo';
import { geoNaturalEarth1, geoPath } from 'd3-geo';
import bookOpenCheckIcon from 'lucide-static/icons/book-open-check.svg?raw';
import churchIcon from 'lucide-static/icons/church.svg?raw';
import globeIcon from 'lucide-static/icons/globe-2.svg?raw';
import graduationCapIcon from 'lucide-static/icons/graduation-cap.svg?raw';
import handHeartIcon from 'lucide-static/icons/hand-heart.svg?raw';
import handHelpingIcon from 'lucide-static/icons/hand-helping.svg?raw';
import heartHandshakeIcon from 'lucide-static/icons/heart-handshake.svg?raw';
import heartIcon from 'lucide-static/icons/heart.svg?raw';
import sendIcon from 'lucide-static/icons/send-horizontal.svg?raw';
import targetIcon from 'lucide-static/icons/target.svg?raw';
import usersIcon from 'lucide-static/icons/users-round.svg?raw';
import { feature } from 'topojson-client';
import worldLand from 'world-atlas/land-110m.json';
import manaPinnedStoryScript from '../../scripts/mana-pinned-story.js?url';

const assetBase = '/assets/home-ministerio';
const bibleLinesTeal = `${assetBase}/bible-lines-teal.svg`;
const bibleLinesWhite = `${assetBase}/bible-lines-white.svg`;
const brandMark = `${assetBase}/ministerio-mana-mark.svg`;
const brandLogoWhite = `${assetBase}/mana-logo-white.svg`;
const devotionalLogo = `${assetBase}/devocional-logo.svg`;

const churchGeoTree = buildChurchGeoTree(churchesData as any[]);
const churchCount = churchGeoTree.churches.length;
const churchCountryCount = churchGeoTree.countryStats.length;
const churchCityCount = churchGeoTree.cityStats.length;
const churchCountryLabel = 'Colombia, Ecuador, México y Europa';
const historyMapSize = { width: 1120, height: 620 };

const worldLandFeature = feature(worldLand as any, (worldLand as any).objects.land) as any;
const worldProjection = geoNaturalEarth1().fitExtent(
  [
    [16, 20],
    [historyMapSize.width - 16, historyMapSize.height - 18],
  ],
  worldLandFeature,
);
const worldPath = geoPath(worldProjection);
const worldLandPath = worldPath(worldLandFeature) || '';
const projectPoint = ([lng, lat]: [number, number]) => {
  const [x = 0, y = 0] = worldProjection([lng, lat]) || [];
  return {
    x,
    y,
  };
};
const londonPoint = projectPoint([-0.1276, 51.5072]);
const medellinPoint = projectPoint([-75.5812, 6.2442]);
const offsetMapPoint = (point: { x: number; y: number }, xOffset: number, yOffset: number) => {
  return { x: point.x + xOffset, y: point.y + yOffset };
};
const londonLabelPoint = offsetMapPoint(londonPoint, 78, -4);
const medellinLabelPoint = offsetMapPoint(medellinPoint, 72, 52);
const historyLabelSize = { width: 190, height: 58 };
const labelY = (point: { y: number }) => (point.y - historyLabelSize.height / 2).toFixed(1);
const londonLabelPath = `M${londonPoint.x.toFixed(1)} ${londonPoint.y.toFixed(1)} L${londonLabelPoint.x.toFixed(1)} ${londonLabelPoint.y.toFixed(1)}`;
const medellinLabelPath = `M${medellinPoint.x.toFixed(1)} ${medellinPoint.y.toFixed(1)} L${medellinLabelPoint.x.toFixed(1)} ${medellinLabelPoint.y.toFixed(1)}`;
const historyRoutePath = [
  `M${medellinPoint.x.toFixed(1)} ${medellinPoint.y.toFixed(1)}`,
  `C${(medellinPoint.x + 84).toFixed(1)} ${(medellinPoint.y - 86).toFixed(1)}`,
  `${(londonPoint.x - 128).toFixed(1)} ${(londonPoint.y + 88).toFixed(1)}`,
  `${londonPoint.x.toFixed(1)} ${londonPoint.y.toFixed(1)}`,
].join(' ');
const churchMarkerBuckets = new Map<string, number>();
const churchMapPoints = churchGeoTree.churches
  .filter((church: any) => typeof church.lat === 'number' && typeof church.lng === 'number')
  .map((church: any) => {
    const projected = projectPoint([church.lng, church.lat]);
    const bucketKey = `${Math.round(projected.x / 18)}:${Math.round(projected.y / 18)}`;
    const bucketIndex = churchMarkerBuckets.get(bucketKey) || 0;
    churchMarkerBuckets.set(bucketKey, bucketIndex + 1);

    const angle = bucketIndex * 2.38;
    const radius = bucketIndex ? Math.min(18, 5 + bucketIndex * 2.4) : 0;

    return {
      x: projected.x + Math.cos(angle) * radius,
      y: projected.y + Math.sin(angle) * radius,
      label: [church.city, church.country].filter(Boolean).join(' · '),
      country: String(church.country || '').toLowerCase(),
    };
  });
const churchRegionLabels = [
  { key: 'colombia', label: 'Colombia', count: churchMapPoints.filter((point) => point.country.includes('colombia')).length, point: offsetMapPoint(projectPoint([-74.2, 5.4]), 24, -22) },
  { key: 'ecuador', label: 'Ecuador', count: churchMapPoints.filter((point) => point.country.includes('ecuador')).length, point: offsetMapPoint(projectPoint([-78.9, -1.5]), 22, 28) },
  { key: 'mexico', label: 'México', count: churchMapPoints.filter((point) => point.country.includes('mexico') || point.country.includes('méxico')).length, point: offsetMapPoint(projectPoint([-98.2, 21.4]), 18, -18) },
  { key: 'europa', label: 'Europa', count: churchMapPoints.filter((point) => point.country.includes('francia') || point.country.includes('europa')).length, point: offsetMapPoint(projectPoint([2.4, 48.8]), 24, -20) },
].filter((entry) => entry.count > 0);

const lucideIcon = (svg: string) =>
  svg
    .replace(/<!--[\s\S]*?-->\s*/g, '')
    .replace(/<svg\b([^>]*)class="([^"]*)"([^>]*)>/, '<svg$1class="mana-lucide-icon $2"$3 aria-hidden="true" focusable="false">');

const fronts = [
  ['01', `${assetBase}/front-devocional-mana.png`, 'Devocional Maná', '5 audios cada semana y agenda devocional.'],
  ['02', `${assetBase}/front-escuela-biblica.png`, 'Escuela Bíblica', '5 cursos discipulares.'],
  ['03', `${assetBase}/front-mana-logo.jpg`, 'Iglesias Maná', `${churchCount} sedes y misiones en ${churchCityCount} ciudades.`],
];

const objectiveIcons = {
  reach: lucideIcon(globeIcon),
  disciple: lucideIcon(usersIcon),
  equip: lucideIcon(graduationCapIcon),
};

const objectives = [
  {
    lead: 'Llevar el evangelio',
    detail: 'hasta lo último de la tierra.',
    icon: objectiveIcons.reach,
  },
  {
    lead: 'Discipular',
    detail: 'a quienes han nacido de nuevo hasta la madurez.',
    icon: objectiveIcons.disciple,
  },
  {
    lead: 'Capacitar',
    detail: 'a los hijos de Dios en el uso de sus dones.',
    icon: objectiveIcons.equip,
  },
];

const values = [
  {
    icon: lucideIcon(bookOpenCheckIcon),
    text: 'Enseñamos la Palabra de Dios como fundamento de fe y práctica.',
  },
  {
    icon: lucideIcon(handHeartIcon),
    text: 'Procuramos depender de Dios a través de hábitos de vida piadosos y la interdependencia de los otros para madurar.',
  },
  {
    icon: lucideIcon(handHelpingIcon),
    text: 'Desafiamos a servir a Dios en el liderazgo para el uso de los dones en los ministerios.',
  },
  {
    icon: lucideIcon(sendIcon),
    text: 'Proclamamos nuestra fe para dar a conocer a Dios a través de grupos y plantación de iglesias.',
  },
  {
    icon: lucideIcon(heartIcon),
    text: 'Propiciamos ambientes de adoración y de consagración a Dios.',
  },
];

const waveBars = [48, 62, 76, 58, 88, 72, 50, 66, 34, 54, 84, 44, 68, 82, 52, 74, 92, 64, 86, 100, 70, 56, 80, 46, 60];

const iconSvg = {
  mission: lucideIcon(heartHandshakeIcon),
  vision: lucideIcon(targetIcon),
  church: lucideIcon(churchIcon),
};

const cspNonce = Astro.locals?.cspNonce;
---

<section class="mana-story-code" aria-label="Borrador del nuevo home de Ministerio Maná">
  <section class="mana-scene mana-scene--hero" data-mana-scene>
    <div class="mana-slide mana-slide--dark">
      <div class="mana-slide__art" data-mana-visual aria-hidden="true">
        <span class="mana-outline">ORAR</span>
        <span class="mana-script-ghost">Es momento de</span>
        <span class="mana-solid-ghost">AGRADECER</span>
      </div>
      <div class="mana-slide__content mana-hero-grid">
        <div class="mana-copy-stack">
          <img class="mana-hero-mark" src={brandMark} alt="Ministerio Maná" data-mana-visual />
          <h1 class="mana-hero-title">
            <span data-mana-split>Es momento de</span>
            <strong data-mana-title data-mana-split>ORAR</strong>
            <strong data-mana-title data-mana-split>AGRADECER</strong>
          </h1>
          <p class="mana-lead" data-mana-copy data-mana-split>
            Una iglesia que enseña las Escrituras, edifica vidas y forma discípulos para impactar su entorno cercano y el mundo.
          </p>
          <nav class="mana-actions" data-mana-ui aria-label="Acciones del borrador">
            <button type="button" class="mana-btn mana-btn--fill" data-mana-next>Comenzar historia</button>
            <a href="/eventos/cumbre-mundial-2026/" class="mana-btn mana-btn--line">Volver a Cumbre</a>
          </nav>
        </div>
      </div>
      <div class="mana-slide-progress" aria-hidden="true"><span data-mana-progress></span></div>
    </div>
  </section>

  <section class="mana-scene mana-scene--mission" data-mana-scene>
    <div class="mana-slide mana-slide--light">
      <div class="mana-slide__content mana-mission-grid">
        <div class="mana-mission-title">
          <div class="mana-orbit-icon" data-mana-visual aria-hidden="true">
            <span></span>
            <i set:html={iconSvg.mission}></i>
          </div>
          <div class="mana-title-lockup">
            <p class="mana-script" data-mana-split>Nuestra</p>
            <h2 data-mana-title data-ghost="MISIÓN" data-mana-split>MISIÓN</h2>
          </div>
        </div>
        <div class="mana-mission-copy" data-mana-copy>
          <p data-mana-split>
            Somos una iglesia que enseña las Escrituras, edificando las vidas de los hijos de Dios a través de hábitos espirituales que los lleven a conocer, amar y obedecer a Dios, con un alto grado de compromiso en el servicio ministerial para dar cumplimiento al plan de Dios.
          </p>
          <p data-mana-split>
            Formamos hombres y mujeres de Dios que guiados por el Espíritu Santo lleguen a ser sus instrumentos en el establecimiento de grupos pequeños e iglesias locales que impacten su entorno cercano y el mundo.
          </p>
        </div>
      </div>
      <div class="mana-slide-progress" aria-hidden="true"><span data-mana-progress></span></div>
    </div>
  </section>

  <section class="mana-scene mana-scene--vision" data-mana-scene>
    <div class="mana-slide mana-slide--dark">
      <div class="mana-slide__content mana-vision-grid">
        <div class="mana-title-lockup">
          <div class="mana-orbit-icon" data-mana-visual aria-hidden="true">
            <span></span>
            <i set:html={iconSvg.vision}></i>
          </div>
          <p class="mana-script" data-mana-split>Nuestra</p>
          <h2 data-mana-title data-ghost="VISIÓN" data-mana-split>VISIÓN</h2>
        </div>
        <div class="mana-big-number" data-mana-visual data-mana-split>2030</div>
        <div class="mana-text-panel mana-text-panel--dark" data-mana-copy>
          <p data-mana-split>
            Ser una <strong>iglesia bíblica, cristocéntrica y relevante en su entorno</strong>, con presencia <strong>nacional e internacional</strong> en el 2030.
          </p>
          <p data-mana-split>
            Una iglesia que discipula a quienes han nacido de nuevo, que <strong>predica el evangelio como un estilo de vida a través de todos los medios posibles</strong>, enseñando a amar a Dios genuinamente y a servir a su prójimo, en obediencia al mandato de cumplir la <strong>Gran Comisión a todos los términos de la tierra</strong>.
          </p>
        </div>
      </div>
      <div class="mana-slide-progress" aria-hidden="true"><span data-mana-progress></span></div>
    </div>
  </section>

  <section class="mana-scene mana-scene--history" data-mana-scene>
    <div class="mana-slide mana-slide--light">
      <div class="mana-slide__content mana-history-presentation">
        <div class="mana-history-copy">
          <h2 class="mana-history-statement">
            <span data-mana-title data-mana-split>La Iglesia</span>
            <span data-mana-title data-mana-split>Ministerio Maná</span>
            <span data-mana-title data-mana-split>surge en</span>
            <strong data-mana-title data-mana-split>2016</strong>
          </h2>
          <div class="mana-history-summary" data-mana-copy>
            <p data-mana-split>
              Tras la llegada a Medellín de los pastores <strong>Carlos Ríos</strong> y su esposa <strong>Gloria Cano</strong> desde Londres.
            </p>
          </div>
          <svg class="mana-history-callout" viewBox="0 0 560 96" aria-hidden="true">
            <path data-mana-draw pathLength="1" d="M18 72H396L514 16" />
            <circle cx="18" cy="72" r="12" />
          </svg>
        </div>
        <div class="mana-history-map" data-mana-visual aria-label="Mapa de Londres a Medellín">
          <svg class="mana-dotted-world mana-dotted-world--history" viewBox={`0 0 ${historyMapSize.width} ${historyMapSize.height}`} aria-hidden="true">
            <defs>
              <pattern id="mana-history-dot-grid" width="10" height="10" patternUnits="userSpaceOnUse">
                <circle class="mana-map-grid-dot" cx="4" cy="4" r="2.35" />
              </pattern>
              <filter id="mana-map-glow" x="-30%" y="-30%" width="160%" height="160%">
                <feGaussianBlur stdDeviation="5" result="blur" />
                <feMerge>
                  <feMergeNode in="blur" />
                  <feMergeNode in="SourceGraphic" />
                </feMerge>
              </filter>
              <path id="mana-history-land-shape" d={worldLandPath} />
              <clipPath id="mana-history-land-clip">
                <use href="#mana-history-land-shape" />
              </clipPath>
            </defs>
            <use class="mana-world-land-soft" href="#mana-history-land-shape" />
            <rect class="mana-world-dot-field" width={historyMapSize.width} height={historyMapSize.height} clip-path="url(#mana-history-land-clip)" />
            <use class="mana-world-outline" href="#mana-history-land-shape" />
            <path class="mana-map-route" data-mana-draw pathLength="1" d={historyRoutePath} />
            <path class="mana-map-label-line mana-map-label-line--uk" data-mana-draw pathLength="1" d={londonLabelPath} />
            <path class="mana-map-label-line mana-map-label-line--co" data-mana-draw pathLength="1" d={medellinLabelPath} />
            <circle class="mana-map-city-dot mana-map-city-dot--uk" cx={londonPoint.x} cy={londonPoint.y} r="7" />
            <circle class="mana-map-city-dot mana-map-city-dot--co" cx={medellinPoint.x} cy={medellinPoint.y} r="7" />
            <foreignObject class="mana-map-flag-object mana-map-flag-object--uk" x={londonLabelPoint.x.toFixed(1)} y={labelY(londonLabelPoint)} width={historyLabelSize.width} height={historyLabelSize.height} data-mana-pin>
              <div xmlns="http://www.w3.org/1999/xhtml" class="mana-flag-pin mana-flag-pin--uk mana-flag-pin--svg">
                <span class="mana-flag mana-flag--uk" aria-hidden="true"></span>
                <strong>LONDRES</strong>
              </div>
            </foreignObject>
            <foreignObject class="mana-map-flag-object mana-map-flag-object--co" x={medellinLabelPoint.x.toFixed(1)} y={labelY(medellinLabelPoint)} width={historyLabelSize.width} height={historyLabelSize.height} data-mana-pin>
              <div xmlns="http://www.w3.org/1999/xhtml" class="mana-flag-pin mana-flag-pin--co mana-flag-pin--svg">
                <span class="mana-flag mana-flag--co" aria-hidden="true"></span>
                <strong>MEDELLÍN</strong>
              </div>
            </foreignObject>
          </svg>
          <img class="mana-history-brand" src={brandLogoWhite} alt="Maná" loading="lazy" />
        </div>
      </div>
      <div class="mana-slide-progress" aria-hidden="true"><span data-mana-progress></span></div>
    </div>
  </section>

  <section class="mana-scene mana-scene--devotional-origin" data-mana-scene>
    <div class="mana-slide mana-slide--dark">
      <div class="mana-slide__content mana-devotional-grid">
        <div class="mana-devotional-map" data-mana-visual aria-hidden="true">
          <svg class="mana-dotted-world mana-dotted-world--devotional" viewBox={`0 0 ${historyMapSize.width} ${historyMapSize.height}`}>
            <defs>
              <pattern id="mana-devotional-dot-grid" width="14" height="14" patternUnits="userSpaceOnUse">
                <circle class="mana-map-grid-dot" cx="4" cy="4" r="3" />
              </pattern>
              <path id="mana-devotional-land-shape" d={worldLandPath} />
              <clipPath id="mana-devotional-land-clip">
                <use href="#mana-devotional-land-shape" />
              </clipPath>
            </defs>
            <use class="mana-world-land-soft mana-world-land-soft--devotional" href="#mana-devotional-land-shape" />
            <rect class="mana-world-dot-field mana-world-dot-field--devotional" width={historyMapSize.width} height={historyMapSize.height} clip-path="url(#mana-devotional-land-clip)" />
          </svg>
        </div>
        <div class="mana-devotional-content">
          <div class="mana-devotional-lockup" data-mana-visual>
            <div class="mana-audio-wave mana-audio-wave--left" aria-hidden="true">
              {waveBars.map((height, index) => <span style={`--bar-h:${height}px;--bar-i:${index}`}></span>)}
            </div>
            <div class="mana-devotional-logo" aria-label="Devocional Maná">
              <img class="mana-devotional-logo-image" src={devotionalLogo} alt="Devocional Maná" loading="lazy" />
            </div>
            <div class="mana-audio-wave mana-audio-wave--right" aria-hidden="true">
              {waveBars.map((height, index) => <span style={`--bar-h:${height}px;--bar-i:${index}`}></span>)}
            </div>
          </div>
          <div class="mana-devotional-copy" data-mana-copy>
            <p data-mana-split>
              10 años antes de llegar a Medellín, el pastor Carlos inició un podcast desde Londres llamado <strong>“Devocional Maná”</strong>, que le permitió llegar a sus feligreses en lugares apartados.
            </p>
            <p data-mana-split>
              Este devocional en audio llegó a reproducirse entre los familiares, amigos y compañeros de trabajo de la feligresía.
            </p>
          </div>
        </div>
      </div>
      <div class="mana-slide-progress" aria-hidden="true"><span data-mana-progress></span></div>
    </div>
  </section>

  <section class="mana-scene mana-scene--values" data-mana-scene>
    <div class="mana-slide mana-slide--dark">
      <div class="mana-slide__content mana-values-presentation">
        <div class="mana-values-title">
          <p class="mana-script" data-mana-split>Principios y</p>
          <h2 data-mana-title data-ghost="VALORES" data-mana-split>VALORES</h2>
          <div class="mana-values-orbit" data-mana-visual aria-hidden="true">
            <i set:html={iconSvg.vision}></i>
            <span></span>
          </div>
        </div>
        <div class="mana-values-list" data-mana-stagger>
          {values.map((value) => (
            <article>
              <span class="mana-value-chat" set:html={value.icon}></span>
              <p>{value.text}</p>
            </article>
          ))}
        </div>
      </div>
      <div class="mana-slide-progress" aria-hidden="true"><span data-mana-progress></span></div>
    </div>
  </section>

  <section class="mana-scene mana-scene--fronts" data-mana-scene>
    <div class="mana-slide mana-slide--dark">
      <div class="mana-slide__content mana-fronts-grid">
        <div class="mana-fronts-intro">
          <p data-mana-copy data-mana-split>
            Oficializamos el nombre <strong>“Ministerio Maná”,</strong> contando con
          </p>
          <div class="mana-fronts-number" data-mana-visual>
            <strong data-mana-title data-mana-split>3</strong>
            <span data-mana-split>Grandes<br />frentes<br />de acción</span>
          </div>
          <img class="mana-bible-line" src={bibleLinesTeal} alt="" aria-hidden="true" />
        </div>
        <div class="mana-fronts-rail" data-mana-visual aria-hidden="true"></div>
        <div class="mana-card-list" data-mana-stagger>
          {fronts.map(([number, logo, title, detail]) => (
            <article>
              <span class="mana-card-index">{number}</span>
              <span class="mana-card-logo" aria-hidden="true">
                <img src={logo} alt="" loading="lazy" />
              </span>
              <h3 data-mana-split>{title}</h3>
              <p>{detail}</p>
            </article>
          ))}
        </div>
      </div>
      <div class="mana-slide-progress" aria-hidden="true"><span data-mana-progress></span></div>
    </div>
  </section>

  <section class="mana-scene mana-scene--objectives" data-mana-scene>
    <div class="mana-slide mana-slide--light">
      <div class="mana-slide__content mana-objectives-grid">
        <div class="mana-objectives-title">
          <div class="mana-title-lockup">
            <p class="mana-script" data-mana-split>Nuestros</p>
            <h2 data-mana-title data-ghost="OBJETIVOS" data-mana-split>OBJETIVOS</h2>
          </div>
          <div class="mana-objectives-emblem" data-mana-ui aria-hidden="true">
            <span></span>
            <i set:html={iconSvg.vision}></i>
          </div>
        </div>
        <div class="mana-objective-stack" data-mana-stagger>
          {objectives.map((objective, index) => (
            <article class="mana-objective-step" data-mana-copy>
              <span class="mana-objective-number">0{index + 1}</span>
              <span class="mana-objective-icon" set:html={objective.icon}></span>
              <p data-mana-split>
                <strong>{objective.lead}</strong>
                <span class="mana-objective-detail">{objective.detail}</span>
              </p>
            </article>
          ))}
        </div>
      </div>
      <div class="mana-slide-progress" aria-hidden="true"><span data-mana-progress></span></div>
    </div>
  </section>

  <section class="mana-scene mana-scene--food" data-mana-scene>
    <div class="mana-slide mana-slide--light">
      <div class="mana-slide__content mana-food-grid">
        <div>
          <p class="mana-script" data-mana-split>Alimento</p>
          <h2 data-mana-title data-ghost="ESPIRITUAL" data-mana-split>ESPIRITUAL</h2>
        </div>
        <div class="mana-pill-cloud" data-mana-stagger>
          <span>21 Hábitos que Sanan</span>
          <span>Mi Casa</span>
          <span>Dos para Ser Uno</span>
          <span>Nacidos para Multiplicarnos</span>
          <span>Escogidos para Servir</span>
        </div>
      </div>
      <div class="mana-slide-progress" aria-hidden="true"><span data-mana-progress></span></div>
    </div>
  </section>

  <section class="mana-scene mana-scene--churches" data-mana-scene>
    <div class="mana-slide mana-slide--light">
      <div class="mana-church-map-shell" data-mana-visual>
        <svg class="mana-church-dotted-map" viewBox={`0 0 ${historyMapSize.width} ${historyMapSize.height}`} aria-hidden="true">
          <defs>
            <pattern id="mana-church-dot-grid" width="10" height="10" patternUnits="userSpaceOnUse">
              <circle class="mana-church-map-grid-dot" cx="4" cy="4" r="2.35" />
            </pattern>
            <filter id="mana-church-map-glow" x="-40%" y="-40%" width="180%" height="180%">
              <feGaussianBlur stdDeviation="6" result="blur" />
              <feMerge>
                <feMergeNode in="blur" />
                <feMergeNode in="SourceGraphic" />
              </feMerge>
            </filter>
            <path id="mana-church-land-shape" d={worldLandPath} />
            <clipPath id="mana-church-land-clip">
              <use href="#mana-church-land-shape" />
            </clipPath>
          </defs>
          <use class="mana-church-world-land-soft" href="#mana-church-land-shape" />
          <rect class="mana-church-world-dot-field" width={historyMapSize.width} height={historyMapSize.height} clip-path="url(#mana-church-land-clip)" />
          <use class="mana-church-world-outline" href="#mana-church-land-shape" />
          {churchMapPoints.map((point) => (
            <g class="mana-church-location" data-mana-pin>
              <title>{point.label}</title>
              <circle class="mana-church-location-halo" cx={point.x.toFixed(1)} cy={point.y.toFixed(1)} r="13" />
              <circle class="mana-church-location-dot" cx={point.x.toFixed(1)} cy={point.y.toFixed(1)} r="5.2" />
            </g>
          ))}
          {churchRegionLabels.map((entry) => (
            <g class={`mana-church-region-label mana-church-region-label--${entry.key}`} transform={`translate(${entry.point.x.toFixed(1)} ${entry.point.y.toFixed(1)})`} data-mana-pin>
              <rect x="-10" y="-17" width="116" height="34" rx="17" />
              <text x="8" y="-1">{entry.label}</text>
              <text class="mana-church-region-count" x="8" y="12">{entry.count} puntos</text>
            </g>
          ))}
        </svg>
      </div>
      <div class="mana-slide__content mana-church-story-grid">
        <div class="mana-church-copy">
          <div class="mana-title-lockup">
            <p class="mana-script" data-mana-split>Nuestras</p>
            <h2 data-mana-title data-ghost="IGLESIAS" data-mana-split>IGLESIAS</h2>
          </div>
          <div class="mana-church-stats" data-mana-stagger>
            <article>
              <strong>{churchCount}</strong>
              <span>Sedes y misiones</span>
            </article>
            <article>
              <strong>{churchCountryCount}</strong>
              <span>Países / regiones</span>
            </article>
            <article>
              <strong>{churchCityCount}</strong>
              <span>Ciudades</span>
            </article>
          </div>
          <div class="mana-text-panel mana-text-panel--compact" data-mana-copy>
            <p data-mana-split>
              Tenemos presencia en {churchCountryLabel}, con sedes y misiones ubicadas en {churchCityCount} ciudades.
            </p>
            <p data-mana-split>
              Cada punto representa una sede o misión; la ubicación exacta vive en el mapa completo de iglesias.
            </p>
          </div>
        </div>
      </div>
      <div class="mana-slide-progress" aria-hidden="true"><span data-mana-progress></span></div>
    </div>
  </section>

  <section class="mana-scene mana-scene--final" data-mana-scene>
    <div class="mana-slide mana-slide--dark">
      <div class="mana-slide__content mana-final-grid">
        <div class="mana-final-logo" data-mana-visual aria-hidden="true">
          <img src={brandLogoWhite} alt="" loading="lazy" />
        </div>
        <div>
          <p class="mana-script" data-mana-split>Ministerio Maná</p>
          <h2>
            <span data-mana-title data-mana-split>Conocer, amar,</span>
            <span data-mana-title data-mana-split>obedecer y servir.</span>
          </h2>
        </div>
        <div class="mana-final-copy" data-mana-copy>
          <p data-mana-split>
            Ministerio Maná existe para enseñar las Escrituras, formar discípulos y servir a Dios con una fe que se vive en comunidad.
          </p>
          <p data-mana-split>
            Una iglesia bíblica, cristocéntrica y relevante para esta generación.
          </p>
        </div>
        <nav class="mana-actions" data-mana-ui aria-label="Acciones finales">
          <a href="/devocional/" class="mana-btn mana-btn--fill">Devocional Maná</a>
          <a href="/escuela-biblica/" class="mana-btn mana-btn--line">Escuela Bíblica</a>
          <a href="/iglesias/" class="mana-btn mana-btn--line">Encontrar iglesia</a>
        </nav>
      </div>
      <div class="mana-slide-progress" aria-hidden="true"><span data-mana-progress></span></div>
    </div>
  </section>
</section>

<style>
  @font-face {
    font-family: "Mana Script";
    src: url("/fonts/SUMMER%20FONT/Summer%20Loving%20Regular.otf") format("opentype");
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  :global(html) {
    scroll-behavior: auto;
  }

  :global(html),
  :global(body) {
    overflow-x: hidden;
  }

  :global(html),
  :global(body),
  :global(main) {
    background: #1e315f;
  }

  .mana-story-code {
    --navy: #243f78;
    --deep: #1e315f;
    --ink: #17245b;
    --teal: #28a6bd;
    --sky: #cbd9e6;
    --beige: #f5efeb;
    --white: #fff;
    --slide-h: 100svh;
    --mana-copy-gap: clamp(16px, 2.5vh, 28px);
    --mana-block-gap: clamp(24px, 4.2vh, 52px);
    --mana-layout-gap: clamp(44px, 6.5vw, 108px);
    background: var(--deep);
    color: var(--ink);
    isolation: isolate;
    overflow-x: clip;
  }

  @supports (height: 100dvh) {
    .mana-story-code {
      --slide-h: 100dvh;
    }
  }

  .mana-story-code,
  .mana-story-code * {
    box-sizing: border-box;
  }

  .mana-story-code :global(.mana-lucide-icon) {
    stroke-width: 2.15;
  }

  .mana-scene {
    min-height: var(--slide-h);
    height: var(--slide-h);
    position: relative;
    z-index: 1;
  }

  .mana-story-code.is-pinned-deck {
    height: var(--slide-h);
    min-height: var(--slide-h);
    overflow: hidden;
  }

  .mana-story-code.is-pinned-deck .mana-scene {
    position: absolute;
    inset: 0;
    width: 100%;
    min-height: var(--slide-h);
    height: var(--slide-h);
    will-change: clip-path, transform;
  }

  .mana-slide {
    position: relative;
    width: 100%;
    height: var(--slide-h);
    min-height: var(--slide-h);
    display: grid;
    align-items: center;
    overflow: hidden;
    padding: clamp(22px, 5vw, 72px);
    transform-origin: center center;
    will-change: transform, opacity;
  }

  .mana-slide--dark {
    background:
      linear-gradient(135deg, #243f78 0%, #223a70 48%, #1d305e 100%);
    color: var(--white);
  }

  .mana-slide--light {
    background:
      linear-gradient(135deg, #243f78 0%, #223a70 48%, #1d305e 100%);
    color: var(--white);
  }

  .mana-slide::before,
  .mana-slide::after {
    content: "";
    position: absolute;
    pointer-events: none;
    z-index: 0;
  }

  .mana-slide::before {
    top: -110px;
    right: -46px;
    width: clamp(190px, 24vw, 420px);
    height: clamp(150px, 18vw, 310px);
    border-radius: 0 0 0 62%;
    background: var(--teal);
  }

  .mana-slide::after {
    left: -96px;
    bottom: -104px;
    width: clamp(180px, 22vw, 360px);
    height: clamp(180px, 22vw, 360px);
    border: 3px solid rgba(20, 176, 196, 0.78);
    border-radius: 999px 999px 0 0;
  }

  .mana-slide__content {
    position: relative;
    z-index: 2;
    width: min(1260px, 100%);
    max-height: calc(var(--slide-h) - clamp(44px, 10vw, 144px));
    margin: 0 auto;
    min-width: 0;
  }

  .mana-slide__content > * {
    position: relative;
    z-index: 2;
  }

  .mana-slide__art {
    position: absolute;
    z-index: 1;
    inset: 0;
    pointer-events: none;
  }

  .mana-outline,
  .mana-script-ghost,
  .mana-solid-ghost {
    position: absolute;
    opacity: 0.28;
  }

  .mana-outline {
    left: 31%;
    top: 25%;
    color: transparent;
    font-family: "Intro", system-ui, sans-serif;
    font-size: clamp(5.5rem, 15vw, 13rem);
    font-weight: 800;
    line-height: 0.8;
    -webkit-text-stroke: 4px var(--teal);
    text-stroke: 4px var(--teal);
  }

  .mana-script-ghost {
    left: 44%;
    top: 43%;
