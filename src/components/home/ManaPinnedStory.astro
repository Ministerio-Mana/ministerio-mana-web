  .mana-card-list,
  .mana-number-list,
  .mana-value-grid,
  .mana-schedule,
  .mana-metrics {
    display: grid;
    gap: clamp(9px, 1.5vw, 14px);
  }

  .mana-card-list article,
  .mana-number-list article,
  .mana-value-grid p,
  .mana-schedule article,
  .mana-metrics article,
  .mana-country-strip span,
  .mana-pill-cloud span {
    border-radius: 8px;
    padding: clamp(13px, 2vw, 20px);
