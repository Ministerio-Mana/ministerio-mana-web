  }

  @media (max-width: 900px) {
    .mana-two-col,
    .mana-mission-grid,
    .mana-list-grid,
    .mana-objectives-grid,
    .mana-vision-grid,
    .mana-history-grid,
    .mana-history-presentation,
    .mana-devotional-grid,
    .mana-values-presentation,
    .mana-church-story-grid,
    .mana-church-grid,
    .mana-impact-grid,
    .mana-fronts-grid {
      grid-template-columns: 1fr;
      gap: clamp(16px, 3vw, 28px);
