    .mana-audio-wave {
      gap: 5px;
      width: clamp(104px, 20vw, 180px);
    }

    .mana-audio-wave--left {
      right: calc(50% + clamp(118px, 18vw, 180px));
    }

    .mana-audio-wave--right {
      left: calc(50% + clamp(118px, 18vw, 180px));
    }

    .mana-devotional-lockup::before,
    .mana-devotional-lockup::after {
      width: clamp(104px, 20vw, 180px);
    }

    .mana-devotional-lockup::before {
      right: calc(50% + clamp(118px, 18vw, 180px));
    }

    .mana-devotional-lockup::after {
      left: calc(50% + clamp(118px, 18vw, 180px));
    }

    .mana-values-presentation {
      align-content: center;
    }

    .mana-values-title .mana-script,
    .mana-values-title h2 {
      justify-self: start;
      text-align: left;
    }

    .mana-values-orbit {
      justify-self: start;
      margin-top: 18px;
    }

    .mana-values-orbit span {
      display: none;
    }

    .mana-values-list {
      gap: 16px;
    }

    .mana-fronts-rail {
      display: none;
    }

    .mana-fronts-intro {
      justify-items: start;
      text-align: left;
    }

    .mana-bible-line {
      width: min(360px, 76%);
    }

    .mana-halo-logo {
      display: none;
    }
  }

  @media (max-width: 680px) {
