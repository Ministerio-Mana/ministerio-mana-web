    .mana-history-copy {
      min-height: auto;
      gap: clamp(18px, 3vh, 34px);
    }

    .mana-history-statement {
      max-width: 560px;
      justify-self: center;
    }

    .mana-history-summary {
      max-width: 640px;
    }

    .mana-history-callout {
      display: none;
    }

    .mana-history-presentation .mana-history-map {
      min-height: 360px;
      margin-right: 0;
      transform: none;
    }

    .mana-dotted-world--history {
      min-height: 360px;
    }

    .mana-history-map {
      grid-column: auto;
      grid-row: auto;
      min-height: 280px;
    }

    .mana-history-world {
      min-height: 280px;
    }

    .mana-history-grid .mana-text-panel {
      grid-row: auto;
      max-width: 100%;
    }

    .mana-big-number {
      justify-self: start;
    }

    .mana-orbit-icon {
      margin-left: clamp(72px, 18vw, 160px);
    }

    .mana-value-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .mana-code-map {
      min-height: 28svh;
    }

    .mana-mission-title {
      gap: 18px;
    }

    .mana-mission-copy {
      justify-self: start;
      gap: 18px;
      max-width: 100%;
    }

    .mana-objectives-grid {
      align-content: center;
    }

    .mana-objectives-title {
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: end;
      gap: 18px;
    }

    .mana-objectives-emblem {
      width: 86px;
      height: 86px;
      margin-left: 0;
      border-width: 3px;
      box-shadow: 0 16px 38px rgba(5, 17, 48, 0.16);
    }

    .mana-objectives-emblem::before,
    .mana-objectives-emblem span {
      display: none;
    }

    .mana-objective-stack {
      justify-self: start;
      max-width: 100%;
    }

    .mana-objective-step {
      grid-template-columns: 54px 46px minmax(0, 1fr);
      gap: 14px;
      min-height: auto;
      padding: 16px 0;
    }

    .mana-objective-number {
      font-size: 2.55rem;
    }

    .mana-objective-icon {
      width: 44px;
      height: 44px;
    }

    .mana-objective-step p {
      max-width: 100%;
      font-size: clamp(0.94rem, 3.3vw, 1.12rem);
      line-height: 1.25;
    }

    .mana-objective-step strong {
      font-size: clamp(1.18rem, 4vw, 1.52rem);
    }

    .mana-church-story-grid {
      align-content: center;
      min-height: min(720px, calc(var(--slide-h) - 56px));
    }

    .mana-church-copy {
      gap: clamp(18px, 3vh, 34px);
      max-width: min(620px, 72vw);
    }

    .mana-church-map-shell {
      top: auto;
      right: -42%;
      bottom: -4%;
      width: 118vw;
      height: 58%;
      opacity: 0.38;
    }

    .mana-church-map-shell::before {
      inset: -12% 36% -12% -6%;
    }

    .mana-devotional-grid {
      position: relative;
      min-height: min(720px, calc(var(--slide-h) - 60px));
      align-content: center;
