  .mana-church-region-label .mana-church-region-count {
    fill: rgba(255, 255, 255, 0.58);
    font-size: 8px;
    font-weight: 700;
  }

  .mana-schedule {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .mana-impact-grid {
    display: grid;
    grid-template-columns: minmax(220px, 0.56fr) minmax(280px, 0.72fr) minmax(260px, 0.72fr);
    gap: clamp(18px, 3vw, 38px);
    align-items: center;
  }

  .mana-metrics article {
    border: 1px solid rgba(255, 255, 255, 0.14);
    background: rgba(255, 255, 255, 0.07);
  }

  .mana-metrics strong {
    display: block;
    color: var(--teal);
    font-family: "Intro", system-ui, sans-serif;
    font-size: clamp(2rem, 4.2vw, 3.8rem);
    font-weight: 800;
    line-height: 0.9;
  }

  .mana-metrics span {
    display: block;
    margin-top: 6px;
    color: rgba(255, 255, 255, 0.78);
    font-size: 0.94rem;
  }

  .mana-country-strip {
    display: grid;
    gap: 12px;
  }

  .mana-country-strip span {
    display: block;
    background: rgba(255, 255, 255, 0.08);
    color: var(--white);
    font-weight: 800;
  }

  .mana-final-grid {
    display: grid;
    justify-items: center;
    gap: clamp(18px, 3vw, 36px);
    text-align: center;
    max-width: 1040px;
  }

  .mana-final-grid h2 {
    max-width: 920px;
    color: var(--white);
    font-size: clamp(2.3rem, 5.1vw, 4.9rem);
    line-height: 0.98;
  }

  .mana-final-grid h2 > span {
    display: block;
  }

  .mana-final-logo {
    display: grid;
    place-items: center;
    width: clamp(176px, 20vw, 270px);
    min-height: clamp(98px, 10vw, 138px);
    padding: clamp(10px, 1.2vw, 16px);
    border: 0;
    border-radius: 0;
    background: transparent;
    box-shadow: none;
  }

  .mana-final-logo img {
    width: 100%;
    height: auto;
    filter: drop-shadow(0 20px 42px rgba(5, 15, 43, 0.22));
  }

  .mana-final-copy {
    display: grid;
    gap: var(--mana-copy-gap);
    max-width: 760px;
    color: rgba(255, 255, 255, 0.78);
  }

  .mana-final-copy p {
    margin: 0;
    color: inherit;
    font-size: clamp(1.04rem, 1.65vw, 1.32rem);
    line-height: 1.46;
    text-wrap: pretty;
  }

  .mana-final-grid .mana-actions {
    justify-content: center;
    margin-top: 0;
  }

  .mana-slide-progress {
    position: absolute;
    z-index: 5;
    left: clamp(20px, 5vw, 72px);
    right: clamp(20px, 5vw, 72px);
    bottom: clamp(14px, 2.2vw, 28px);
    height: 2px;
    background: rgba(40, 166, 189, 0.22);
  }

  .mana-slide-progress span {
    display: block;
    width: 100%;
    height: 100%;
    transform: scaleX(0);
    transform-origin: left center;
    background: var(--teal);
  }

  .mana-word {
    display: inline-block;
    white-space: pre;
    transform-origin: 50% 80%;
    backface-visibility: hidden;
    will-change: transform, opacity, filter;
  }

  .mana-char {
    display: inline-block;
    white-space: pre;
    transform-origin: 50% 80%;
    backface-visibility: hidden;
    will-change: transform, opacity, filter;
  }

  .mana-char--space {
    width: 0.24em;
  }

  @media (max-width: 1080px) {
    .mana-value-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
