    .mana-devotional-content {
      z-index: 4;
      gap: clamp(24px, 4vh, 46px);
    }

    .mana-devotional-lockup {
      grid-template-columns: minmax(84px, 1fr) auto minmax(84px, 1fr);
      gap: clamp(10px, 2vw, 22px);
