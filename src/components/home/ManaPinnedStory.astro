<script nonce={cspNonce}>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initManaStoryCode() {
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const scenes = gsap.utils.toArray('[data-mana-scene]');

    ScrollTrigger.getAll()
      .filter((trigger) => trigger.vars?.id?.startsWith('mana-code-story-'))
      .forEach((trigger) => trigger.kill());

    if (reduceMotion || !scenes.length) return;

    document.querySelectorAll('[data-mana-next]').forEach((button) => {
      if (button.dataset.manaBound === 'true') return;
      button.dataset.manaBound = 'true';
      button.addEventListener('click', () => {
        const nextY = window.scrollY + window.innerHeight * 1.45;
        if (window.lenis?.scrollTo) window.lenis.scrollTo(nextY);
        else window.scrollTo({ top: nextY, behavior: 'smooth' });
      }, { once: false });
    });

    scenes.forEach((scene, index) => {
      const stage = scene.querySelector('.mana-stage');
      const title = scene.querySelector('[data-mana-title]') || scene.querySelector('h2');
      const copy = scene.querySelectorAll('[data-mana-copy], [data-mana-line], [data-mana-actions]');
      const visual = scene.querySelector('[data-mana-visual]');
      const staggerItems = scene.querySelectorAll('[data-mana-stagger] > *');
      const progress = scene.querySelector('[data-mana-progress]');

      const timeline = gsap.timeline({
        defaults: { ease: 'power2.out' },
        scrollTrigger: {
          id: `mana-code-story-${index}`,
          trigger: scene,
          start: 'top top',
          end: '+=145%',
          pin: stage,
          scrub: 1.15,
          anticipatePin: 1,
          invalidateOnRefresh: true,
          onUpdate: ({ progress: t }) => {
            if (progress) progress.style.transform = `scaleX(${t})`;
          },
        },
      });

      timeline
        .fromTo(title, { autoAlpha: 0.18, y: 56 }, { autoAlpha: 1, y: 0, duration: 0.28 }, 0.03)
        .fromTo(copy, { autoAlpha: 0.18, y: 30 }, { autoAlpha: 1, y: 0, duration: 0.26, stagger: 0.035 }, 0.11);

      if (visual) {
        timeline.fromTo(visual, { autoAlpha: 0.18, y: 48, scale: 0.96 }, { autoAlpha: 1, y: 0, scale: 1, duration: 0.34 }, 0.14);
        timeline.to(visual, { y: -16, scale: 1.03, duration: 0.46, ease: 'none' }, 0.5);
      }

      if (staggerItems.length) {
        timeline.fromTo(staggerItems, { autoAlpha: 0.18, y: 30 }, { autoAlpha: 1, y: 0, duration: 0.22, stagger: 0.04 }, 0.23);
      }

      timeline.to(stage, { autoAlpha: 0.72, scale: 0.988, duration: 0.16, ease: 'power1.in' }, 0.91);
    });

    requestAnimationFrame(() => ScrollTrigger.refresh());
  }

  document.addEventListener('astro:page-load', initManaStoryCode);
  document.addEventListener('DOMContentLoaded', initManaStoryCode);
</script>
