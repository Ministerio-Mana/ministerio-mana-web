    box-shadow: 0 18px 44px rgba(5, 15, 43, 0.16);
  }

  .mana-church-stats strong {
    display: block;
    color: var(--teal);
    font-family: "Intro", system-ui, sans-serif;
    font-size: clamp(2.2rem, 4.8vw, 4.5rem);
    font-weight: 800;
    line-height: 0.86;
  }

  .mana-church-stats span {
    display: block;
    margin-top: 8px;
    color: rgba(255, 255, 255, 0.78);
    font-size: clamp(0.75rem, 1vw, 0.92rem);
    line-height: 1.22;
  }

  .mana-text-panel--compact {
    max-width: 560px;
    border-left: 0;
    padding: 0;
  }

  .mana-text-panel--compact p {
    font-size: clamp(1.04rem, 1.5vw, 1.28rem);
    line-height: 1.44;
  }

  .mana-church-map-shell {
    position: absolute;
    z-index: 1;
    top: 5%;
    right: -12%;
    bottom: 1%;
    width: min(76vw, 1180px);
    min-width: 0;
    pointer-events: none;
    opacity: 0.82;
    filter: saturate(1.12);
  }

  .mana-church-map-shell::before {
    content: "";
    position: absolute;
    inset: -8% 44% -8% -10%;
    z-index: 10;
    pointer-events: none;
    background: linear-gradient(90deg, #243f78 0%, rgba(36, 63, 120, 0.96) 42%, rgba(36, 63, 120, 0) 100%);
  }

  .mana-church-map-shell::after {
    content: "";
    position: absolute;
    inset: -8%;
    z-index: 9;
    pointer-events: none;
    background:
      radial-gradient(circle at 72% 48%, rgba(40, 166, 189, 0.18), transparent 36%),
      linear-gradient(180deg, #243f78 0%, rgba(36, 63, 120, 0) 20%, rgba(36, 63, 120, 0) 72%, #243f78 100%);
  }

  .mana-church-dotted-map {
    position: absolute;
    inset: 0;
    display: block;
    width: 100%;
    height: 100%;
    overflow: visible;
    filter: drop-shadow(0 28px 64px rgba(5, 17, 48, 0.24));
  }

  .mana-church-world-land-soft {
    fill: rgba(40, 166, 189, 0.035);
    stroke: none;
  }

  .mana-church-world-dot-field {
    fill: url("#mana-church-dot-grid");
    opacity: 0.72;
  }

  .mana-church-world-outline {
    fill: none;
    stroke: rgba(87, 145, 225, 0.14);
    stroke-width: 1.3;
    vector-effect: non-scaling-stroke;
  }

  .mana-church-map-grid-dot {
    fill: rgba(91, 154, 230, 0.68);
  }

  .mana-church-location {
    transform-box: fill-box;
    transform-origin: center;
  }

  .mana-church-location-halo {
    fill: rgba(40, 166, 189, 0.2);
    stroke: rgba(40, 166, 189, 0.26);
    stroke-width: 2;
    filter: url("#mana-church-map-glow");
    vector-effect: non-scaling-stroke;
  }

  .mana-church-location-dot {
    fill: var(--teal);
    stroke: rgba(255, 255, 255, 0.78);
    stroke-width: 2.8;
    filter: url("#mana-church-map-glow");
    vector-effect: non-scaling-stroke;
  }

  .mana-church-region-label {
    opacity: 0.94;
    filter: drop-shadow(0 12px 28px rgba(5, 15, 43, 0.18));
  }

  .mana-church-region-label rect {
    fill: rgba(16, 31, 72, 0.62);
    stroke: rgba(40, 166, 189, 0.35);
    stroke-width: 1.2;
    vector-effect: non-scaling-stroke;
  }

  .mana-church-region-label text {
    fill: var(--white);
    font-family: "Intro", system-ui, sans-serif;
    font-size: 11px;
    font-weight: 800;
