---
const id = 'churches-map';
---

<div class="relative w-full h-[600px] bg-brand-void rounded-3xl overflow-hidden border border-white/10 shadow-2xl group select-none z-0">
  
  <!-- Map Container -->
  <div id="map" class="absolute inset-0 w-full h-full z-0"></div>

  <!-- Legend -->
  <div class="absolute top-6 left-6 pointer-events-none opacity-0 animate-fade-in z-[1000]" style="animation-delay: 0.5s; animation-fill-mode: forwards;">
    <div class="bg-brand-navy/90 backdrop-blur px-5 py-3 rounded-2xl border border-white/10 shadow-lg shadow-brand-void/50">
      <p class="text-[10px] font-intro tracking-widest text-brand-teal uppercase mb-1">Ubicaciones</p>
      <p class="text-xs text-white/80 font-intro-reg">Iglesias Maná Global</p>
    </div>
  </div>

</div>

<!-- Leaflet CSS -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
     integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
     crossorigin=""/>

<!-- Leaflet JS -->
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
     integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
     crossorigin=""></script>

<script>
  import CHURCHES from '../data/churches.json';

  // Wait for Leaflet to load
  function initMap() {
    if (typeof L === 'undefined') {
      setTimeout(initMap, 100);
      return;
    }

    const map = L.map('map', {
      center: [20, 0],
      zoom: 2,
      minZoom: 2,
      maxZoom: 18, // Allow deeper zoom
      zoomControl: false,
      attributionControl: false
    });

    // Standard OSM Tiles (Reliable fallback with Dark Mode Filter via CSS)
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      maxZoom: 19,
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
      className: 'dark-mode-tiles' 
    }).addTo(map);

    L.control.zoom({
      position: 'bottomright'
    }).addTo(map);

    // Custom Icon for Pins
    const manaIcon = L.divIcon({
      className: 'custom-div-icon',
      html: `<div class="w-4 h-4 bg-brand-teal rounded-full shadow-[0_0_10px_#2DD4BF] border-2 border-white relative cursor-pointer hover:scale-125 transition-transform">
              <div class="absolute inset-0 rounded-full animate-ping bg-brand-teal opacity-75"></div>
             </div>`,
      iconSize: [20, 20],
      iconAnchor: [10, 10],
      popupAnchor: [0, -10]
    });

    // Add Markers
    CHURCHES.forEach(church => {
        if (church.lat && church.lng) {
            L.marker([church.lat, church.lng], { icon: manaIcon })
             .addTo(map)
             .bindPopup(`
                <div class="font-intro text-brand-navy min-w-[200px]">
                    <h3 class="font-bold text-sm mb-1">${church.name}</h3>
                    <p class="text-xs font-intro-reg text-gray-600 mb-2">${church.city}, ${church.country || 'Colombia'}</p>
                    <a href="https://www.google.com/maps?q=${church.lat},${church.lng}" target="_blank" class="inline-block px-3 py-1.5 bg-brand-teal text-white text-[10px] font-bold rounded-lg hover:bg-brand-medium transition-colors">
                      Cómo llegar &rarr;
                    </a>
                </div>
             `, {
                className: 'mana-popup',
                closeButton: false
             });
        }
    });

    // Initial view adjustment
    if (window.innerWidth < 768) {
       map.setZoom(1);
    }
    
    // Force a resize event to ensure Leaflet calculates dimensions correctly
    setTimeout(() => { map.invalidateSize(); }, 500);
  }

  // Start initialization
  // We use a small timeout to ensure DOM is ready even with View Transitions
  setTimeout(initMap, 300);

</script>

<style is:global>
  /* Custom Popup Styles - Glassmorphism */
  .leaflet-popup-content-wrapper {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(8px);
    border-radius: 16px;
    box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.2), 0 8px 10px -6px rgba(0, 0, 0, 0.2);
    border: 1px solid rgba(255,255,255,0.2);
    padding: 0;
    overflow: hidden;
  }
  .leaflet-popup-content {
    margin: 12px 16px;
    line-height: 1.4;
  }
  .leaflet-popup-tip {
    background: rgba(255, 255, 255, 0.95);
  }
  
  /* Map Container Background */
  .leaflet-container {
    background: #0D1626; /* Match brand-void */
    font-family: 'Intro', sans-serif;
  }

  /* Zoom Controls Customization */
  .leaflet-bar a {
    background-color: rgba(255, 255, 255, 0.1) !important;
    backdrop-filter: blur(4px);
    border: 1px solid rgba(255, 255, 255, 0.2) !important;
    color: white !important;
    border-radius: 999px !important; /* Circle */
    width: 40px !important;
    height: 40px !important;
    line-height: 40px !important;
    margin-bottom: 8px !important;
    transition: all 0.2s ease;
  }
  .leaflet-bar a:hover {
    background-color: rgba(255, 255, 255, 0.2) !important;
    transform: scale(1.1);
  }
  .leaflet-bar {
    border: none !important;
    box-shadow: none !important;
  }
  .leaflet-control-zoom-in, .leaflet-control-zoom-out {
    font-size: 18px !important;
    font-weight: 300 !important;
  }

  @keyframes fade-in { to { opacity: 1; } }
</style>
