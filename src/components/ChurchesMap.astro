      <!-- Rectangle filled with dot pattern, masked by world map -->
      <rect width="100%" height="100%" fill="url(#dot-pattern)" mask="url(#world-mask)" />

    </svg>
    
    <!-- Pins Container -->
    <div id="pins-layer" class="absolute inset-0 pointer-events-none">
      <!-- Pins will be injected here by JS -->
    </div>
  </div>

  <!-- Zoom Controls -->
  <div class="absolute bottom-6 right-6 flex flex-col gap-2 z-20">
    <button id="zoom-in" class="w-10 h-10 rounded-full bg-white/10 backdrop-blur-md border border-white/20 flex items-center justify-center text-white hover:bg-white/20 hover:scale-105 active:scale-95 transition-all outline-none focus:ring-2 focus:ring-brand-teal/50">
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
    </button>
    <button id="zoom-out" class="w-10 h-10 rounded-full bg-white/10 backdrop-blur-md border border-white/20 flex items-center justify-center text-white hover:bg-white/20 hover:scale-105 active:scale-95 transition-all outline-none focus:ring-2 focus:ring-brand-teal/50">
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4"/></svg>
    </button>
  </div>

  <!-- Legend -->
  <div class="absolute top-6 left-6 pointer-events-none opacity-0 animate-fade-in" style="animation-delay: 0.5s; animation-fill-mode: forwards;">
    <div class="bg-brand-navy/90 backdrop-blur px-5 py-3 rounded-2xl border border-white/10 shadow-lg shadow-brand-void/50">
      <p class="text-[10px] font-intro tracking-widest text-brand-teal uppercase mb-1">Ubicaciones</p>
      <p class="text-xs text-white/80 font-intro-reg">Iglesias Maná Global</p>
    </div>
  </div>

</div>

<script>
  import '@scripts/churches-map.js';
</script>

<style>
  @keyframes fade-in { to { opacity: 1; } }
</style>
